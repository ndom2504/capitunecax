  function renderTrafficGlobe(countries, totals) {
    var listHost = document.getElementById('traffic-top-countries');
    if (!listHost) return;

    var items = Array.isArray(countries) ? countries.filter(function(c){ return c && c.code; }) : [];
    var payload = { countries: items, totals: totals || {} };
    window.__trafficMapLastPayload = payload;
    try {
      window.dispatchEvent(new CustomEvent('capitune:traffic-map-data', { detail: payload }));
    } catch(_) {}

    if (!items.length) {
      listHost.innerHTML = '<div class="empty-state"><i class="fa fa-globe"></i>Aucun pays détecté</div>';
      return;
    }

    listHost.innerHTML = '<div class="country-list">' + items.map(function(item){
      var code = String(item.code || '').toUpperCase();
      var visitors = Number(item.visitors || 0);
      return '<div class="country-item">'
        + '<div class="country-code">' + esc(code) + '</div>'
        + '<div><div class="country-name">' + esc(COUNTRY_NAMES[code] || code) + '</div><div class="country-sub">' + Number(item.pageviews || 0) + ' vues · ' + Number(item.clicks || 0) + ' clics</div></div>'
        + '<div class="country-val"><strong>' + visitors.toLocaleString('fr-CA') + '</strong>visiteurs</div>'
        + '</div>';
    }).join('') + '</div>';
  }

  async function loadWebTraffic(force) {
    var daysEl = document.getElementById('traffic-days');
    var days = Number(daysEl && daysEl.value ? daysEl.value : 7) || 7;
    var topPagesEl = document.getElementById('traffic-top-pages');
    var overviewEl = document.getElementById('traffic-overview-panel');
    var topZonesEl = document.getElementById('traffic-top-zones');
    var topCountriesEl = document.getElementById('traffic-top-countries');
    var globeCardEl = document.getElementById('traffic-globe-card');
    var dailyBody = document.getElementById('traffic-daily-body');
    var linksBody = document.getElementById('traffic-links-body');
    var recentBody = document.getElementById('traffic-recent-body');
    if (!force && _trafficLoaded && recentBody && recentBody.dataset.loaded === '1') return;

    try {
      window.dispatchEvent(new CustomEvent('capitune:traffic-map-loading'));
    } catch(_) {}

    if (topPagesEl) topPagesEl.innerHTML = '<div class="spinner"></div>';
    if (overviewEl) overviewEl.innerHTML = '<div class="spinner"></div>';
    if (topZonesEl) topZonesEl.innerHTML = '<div class="spinner"></div>';
    if (topCountriesEl) topCountriesEl.innerHTML = '<div class="spinner"></div>';
    if (dailyBody) dailyBody.innerHTML = '<tr><td colspan="3"><div class="spinner"></div></td></tr>';
    if (linksBody) linksBody.innerHTML = '<tr><td colspan="2"><div class="spinner"></div></td></tr>';
    if (recentBody) recentBody.innerHTML = '<tr><td colspan="4"><div class="spinner"></div></td></tr>';

    try {
      var r = await fetch('/api/admin/web-traffic?days=' + encodeURIComponent(days));
      var d = await r.json().catch(function(){ return null; });
      if (!r.ok || !d || d.error) {
        var msg = (d && d.error) ? d.error : ('Erreur ' + r.status);
        if (topPagesEl) topPagesEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(msg) + '</div>';
        if (overviewEl) overviewEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(msg) + '</div>';
        if (topZonesEl) topZonesEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(msg) + '</div>';
        if (topCountriesEl) topCountriesEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(msg) + '</div>';
        try {
          window.dispatchEvent(new CustomEvent('capitune:traffic-map-error', { detail: { message: msg } }));
        } catch(_) {}
        if (dailyBody) dailyBody.innerHTML = '<tr><td colspan="3" style="color:var(--red);padding:20px">' + esc(msg) + '</td></tr>';
        if (linksBody) linksBody.innerHTML = '<tr><td colspan="2" style="color:var(--red);padding:20px">' + esc(msg) + '</td></tr>';
        if (recentBody) recentBody.innerHTML = '<tr><td colspan="4" style="color:var(--red);padding:20px">' + esc(msg) + '</td></tr>';
        return;
      }

      document.getElementById('traffic-pageviews').textContent = Number((d.totals||{}).pageviews || 0).toLocaleString('fr-CA');
      document.getElementById('traffic-clicks').textContent = Number((d.totals||{}).clicks || 0).toLocaleString('fr-CA');
      document.getElementById('traffic-visitors').textContent = Number((d.totals||{}).visitors || 0).toLocaleString('fr-CA');
      document.getElementById('traffic-zones').textContent = Number((d.totals||{}).tracked_zones || 0).toLocaleString('fr-CA');
      document.getElementById('traffic-pageviews-sub').textContent = 'sur ' + Number(d.days || days) + ' jours';
      document.getElementById('traffic-pages-sub').textContent = 'pages trackées : ' + Number((d.totals||{}).tracked_pages || 0).toLocaleString('fr-CA');

      renderTrafficOverview(d.daily || [], d.totals || {}, d.days || days);
      renderTopPages(d.topPages || []);
      renderTopZones(d.topZones || []);
      renderTrafficGlobe(d.topCountries || [], d.totals || {});

      if (dailyBody) {
        var daily = d.daily || [];
        dailyBody.innerHTML = daily.length ? daily.map(function(item){
          return '<tr><td>' + esc(String(item.day || '—')) + '</td><td>' + Number(item.pageviews || 0).toLocaleString('fr-CA') + '</td><td>' + Number(item.clicks || 0).toLocaleString('fr-CA') + '</td></tr>';
        }).join('') : '<tr><td colspan="3"><div class="empty-state"><i class="fa fa-calendar"></i>Aucune activité</div></td></tr>';
      }

      if (linksBody) {
        var links = d.topLinks || [];
        linksBody.innerHTML = links.length ? links.map(function(item){
          var label = String(item.label || item.href || '—');
          var href = String(item.href || '');
          return '<tr><td><div class="client-name">' + esc(label) + '</div>'
            + (href ? '<div class="muted-cell">' + esc(href) + '</div>' : '')
            + '</td><td>' + Number(item.clicks || 0).toLocaleString('fr-CA') + '</td></tr>';
        }).join('') : '<tr><td colspan="2"><div class="empty-state"><i class="fa fa-link"></i>Aucun clic enregistré</div></td></tr>';
      }

      if (recentBody) {
        var recent = d.recentClicks || [];
        recentBody.innerHTML = recent.length ? recent.map(function(item){
          var date = item.created_at ? new Date(item.created_at).toLocaleString('fr-CA') : '—';
          return '<tr>'
            + '<td class="muted-cell">' + esc(date) + '</td>'
            + '<td>' + esc(String(item.path || '/')) + '</td>'
            + '<td>' + esc(String(item.zone || '—')) + '</td>'
            + '<td><div class="client-name">' + esc(String(item.label || '—')) + '</div>'
            + (item.href ? '<div class="muted-cell">' + esc(String(item.href)) + '</div>' : '')
            + '</td></tr>';
        }).join('') : '<tr><td colspan="4"><div class="empty-state"><i class="fa fa-mouse-pointer"></i>Aucun clic récent</div></td></tr>';
        recentBody.dataset.loaded = '1';
      }

      _trafficLoaded = true;
    } catch (e) {
      var err = (e && e.message) ? e.message : 'Erreur réseau';
      if (topPagesEl) topPagesEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(err) + '</div>';
      if (overviewEl) overviewEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(err) + '</div>';
      if (topZonesEl) topZonesEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(err) + '</div>';
      if (topCountriesEl) topCountriesEl.innerHTML = '<div class="empty-state"><i class="fa fa-triangle-exclamation"></i>' + esc(err) + '</div>';
      try {
        window.dispatchEvent(new CustomEvent('capitune:traffic-map-error', { detail: { message: err } }));
      } catch(_) {}
      if (dailyBody) dailyBody.innerHTML = '<tr><td colspan="3" style="color:var(--red);padding:20px">' + esc(err) + '</td></tr>';
      if (linksBody) linksBody.innerHTML = '<tr><td colspan="2" style="color:var(--red);padding:20px">' + esc(err) + '</td></tr>';
      if (recentBody) recentBody.innerHTML = '<tr><td colspan="4" style="color:var(--red);padding:20px">' + esc(err) + '</td></tr>';
    }
  }

  function setScope(scope) {
    _scope = (scope === 'unassigned' || scope === 'all') ? scope : 'me';
    document.getElementById('scope-me').classList.toggle('active', _scope === 'me');
    document.getElementById('scope-unassigned').classList.toggle('active', _scope === 'unassigned');
    var allBtn = document.getElementById('scope-all');
    if (allBtn) allBtn.classList.toggle('active', _scope === 'all');
    syncAssignProVisibility();
    _page = 1;
    loadClients();
  }

  async function ensureProsLoaded() {
    if (!_isSuper || _prosLoaded) return;
    const sel = document.getElementById('assign-pro-select');
    if (!sel) return;
    try {
      const r = await fetch('/api/admin/pros');
      if (!r.ok) return;
      const d = await r.json();
      if (!d || !Array.isArray(d.pros)) return;

      // Conserver l'option "Moi" si elle est déjà là
      sel.innerHTML = '';
      sel.appendChild(new Option('Moi', _meId));
      d.pros.forEach(function(p) {
        if (!p || !p.id) return;
        if (String(p.id) === String(_meId)) return;
        var roleLabel = p.role === 'admin' ? 'Admin' : (p.account_type === 'pro' ? 'Pro' : 'Compte');
        var label = (p.name ? String(p.name) : 'Pro')
          + (p.email ? ' — ' + String(p.email) : '')
          + ' (' + roleLabel + ')';
        sel.appendChild(new Option(label, String(p.id)));
      });
      sel.value = _meId;
      _prosLoaded = true;
    } catch (e) {
      console.warn('[Admin] pros load failed', e);
    }
  }

  function syncAssignProVisibility() {
    if (!_isSuper) return;
    var sel = document.getElementById('assign-pro-select');
    if (!sel) return;
    sel.style.display = (_scope === 'unassigned') ? '' : 'none';
    if (_scope === 'unassigned') ensureProsLoaded();
  }

  // ── Clients list ─────────────────────────────────────────────────────────
  async function loadClients() {
    var tbody = document.getElementById('clients-body');
    tbody.innerHTML = '<tr><td colspan="6"><div class="spinner"></div></td></tr>';
    var url = '/api/admin/clients?page=' + _page + '&scope=' + encodeURIComponent(_scope) + (_search ? '&q=' + encodeURIComponent(_search) : '');
    const r = await fetch(url);
    if (!r.ok) {
      let details = '';
      try { details = await r.text(); } catch {}
      console.warn('[Admin] clients failed', r.status, details);
      tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">Erreur de chargement (' + r.status + ')</td></tr>';
      return;
    }
    const d = await r.json();
    if (d && d.error) {
      toast((d.error || 'Erreur') + (d.hint ? ' — ' + d.hint : ''), true);
      tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">' + esc(d.error) + (d.hint ? '<br><span style="color:var(--muted)">' + esc(d.hint) + '</span>' : '') + '</td></tr>';
      return;
    }
    tbody.dataset.loaded = '1';
    if (!d.clients.length) {
      var emptyMsg = _scope === 'unassigned' ? 'Aucune demande non assignée' : (_scope === 'all' ? 'Aucun client' : 'Aucun client assigné');
      tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><i class="fa fa-users"></i>' + emptyMsg + '</div></td></tr>';
      return;
    }
    tbody.innerHTML = d.clients.map(function(c) {
      var initials = (c.name || c.email).charAt(0).toUpperCase();
      var av = avatarSmHtml(c.avatar_key, c.name || c.email);
      var type = c.project_type ? c.project_type.replace(/_/g,' ') : '—';
      var status = c.project_status || 'aucun';
      var pillClass = 'pill-' + status;
      var pillLabel = { soumis:'Soumis', en_cours:'En cours', termine:'Terminé', annule:'Annulé', aucun:'Aucun' }[status] || status;
      var lastMsg = c.last_msg ? esc(String(c.last_msg).slice(0, 60)) + (String(c.last_msg).length > 60 ? '…' : '') : '<em>—</em>';
      var paid = c.total_paid ? '$' + Number(c.total_paid).toFixed(0) : '—';
      if (_scope === 'unassigned') {
        var assignLabel = _isSuper ? 'Assigner' : "M'assigner";
        return '<tr>'
          + '<td><div style="display:flex;align-items:center;gap:10px">'
          + av
          + '<div><div class="client-name">'+esc(c.name||'—')+'</div><div class="client-email">'+esc(c.email)+'</div></div></div></td>'
          + '<td style="font-size:12px">'+esc(type)+'</td>'
          + '<td><span class="status-pill '+pillClass+'">'+pillLabel+'</span></td>'
          + '<td class="msg-preview">'+lastMsg+'</td>'
          + '<td style="color:var(--muted);font-weight:600">—</td>'
          + '<td><button class="btn-sm" onclick="assignClient(\''+c.id+'\')"><i class="fa fa-hand-pointer"></i> '+assignLabel+'</button></td>'
          + '</tr>';
      }

      var isSusp = c.suspended == 1 || c.suspended === true;
      var suspBtn = isSusp
        ? '<button class="btn-unsuspend" onclick="event.stopPropagation();suspendUser(\''+c.id+'\',false)"><i class="fa fa-play"></i> Réactiver</button>'
        : '<button class="btn-suspend" onclick="event.stopPropagation();suspendUser(\''+c.id+'\',true)"><i class="fa fa-ban"></i> Suspendre</button>';
      var delBtn = '<button class="btn-delete" onclick="event.stopPropagation();deleteUser(\''+c.id+'\', \''+esc(c.name||c.email)+'\')"><i class="fa fa-trash"></i></button>';
      return '<tr class="client-row" onclick="openClient(\''+c.id+'\')">'  
        + '<td><div style="display:flex;align-items:center;gap:10px">'
        + av
        + '<div><div class="client-name">'+esc(c.name||'—')+'</div><div class="client-email">'+esc(c.email)+'</div></div></div></td>'
        + '<td style="font-size:12px">'+esc(type)+'</td>'
        + '<td><span class="status-pill '+pillClass+'">'+pillLabel+'</span></td>'
        + '<td class="msg-preview">'+lastMsg+'</td>'
        + '<td style="color:var(--green);font-weight:600">'+paid+'</td>'
        + '<td><div class="actions-cell"><button class="btn-sm" onclick="event.stopPropagation();openClient(\''+c.id+'\')" style="margin:0"><i class="fa fa-eye"></i> Voir</button>' + suspBtn + delBtn + '</div></td>'
        + '</tr>';
    }).join('');
    // Pagination
    renderPagination(d.page, d.pages);
  }

  function renderPagination(page, pages) {
    var el = document.getElementById('pagination');
    if (pages <= 1) { el.innerHTML = ''; return; }
    var html = '';
    if (page > 1) html += '<button class="page-btn" onclick="goPage(' + (page-1) + ')">‹ Préc</button>';
    for (var i = Math.max(1, page-2); i <= Math.min(pages, page+2); i++) {
      html += '<button class="page-btn' + (i===page?' active':'') + '" onclick="goPage(' + i + ')">' + i + '</button>';
    }
    if (page < pages) html += '<button class="page-btn" onclick="goPage(' + (page+1) + ')">Suiv ›</button>';
    el.innerHTML = html;
  }

  function goPage(p) { _page = p; loadClients(); }

  // ── Comptes Pro ──────────────────────────────────────────────────────────
  async function loadPros() {
    var tbody = document.getElementById('pros-body');
    if (!tbody) return;
    tbody.innerHTML = '<tr><td colspan="6"><div class="spinner"></div></td></tr>';
    try {
      const r = await fetch('/api/admin/pros-list');
      if (!r.ok) {
        tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">Erreur ' + r.status + '</td></tr>';
        return;
      }
      const d = await r.json();
      if (!d.pros || !d.pros.length) {
        tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><i class="fa fa-user-tie"></i>Aucun compte pro / admin</div></td></tr>';
        tbody.dataset.loaded = '1';
        return;
      }
      tbody.innerHTML = d.pros.map(function(p) {
        var initials = (p.name || p.email || '?').charAt(0).toUpperCase();
        var av = avatarSmHtml(p.avatar_key, p.name || p.email || '?');
        var roleBadge = p.role === 'admin'
          ? '<span class="pro-badge badge-admin"><i class="fa fa-shield-alt"></i> Admin</span>'
          : '';
        var typeBadge = p.account_type === 'pro'
          ? '<span class="pro-badge badge-pro"><i class="fa fa-briefcase"></i> Pro</span>'
          : '<span class="pro-badge badge-client">Client</span>';
        var clients = Number(p.clients_count || 0);
        var revenue = Number(p.total_revenue || 0);
        var date = p.created_at ? new Date(p.created_at).toLocaleDateString('fr-CA') : '—';
        var isSelf = String(p.id) === String(_meId);
        var isSuspPro = p.suspended == 1 || p.suspended === true;
        var actionBtn = '';
        if (!isSelf) {
          var promoPart = '';
          if (p.account_type === 'pro') {
            promoPart = '<button class="btn-demote" onclick="changePro(\'' + p.id + '\', \'demote\')"><i class="fa fa-user-minus"></i> Rétrograder</button>';
          } else if (p.role !== 'admin') {
            promoPart = '<button class="btn-promote" onclick="changePro(\'' + p.id + '\', \'promote\')"><i class="fa fa-user-plus"></i> Promouvoir Pro</button>';
          }
          var suspPartPro = isSuspPro
            ? '<button class="btn-unsuspend" onclick="suspendUser(\'' + p.id + '\',false)"><i class="fa fa-play"></i> Réactiver</button>'
            : '<button class="btn-suspend" onclick="suspendUser(\'' + p.id + '\',true)"><i class="fa fa-ban"></i> Suspendre</button>';
          var delPartPro = '<button class="btn-delete" onclick="deleteUser(\'' + p.id + '\', \'' + esc(p.name||p.email) + '\')" title="Supprimer le compte"><i class="fa fa-trash"></i></button>';
          actionBtn = '<div class="actions-cell">' + promoPart + suspPartPro + delPartPro + '</div>';
        }
        var suspBadgePro = isSuspPro ? ' <span class="badge-suspended"><i class="fa fa-ban"></i> Suspendu</span>' : '';
        return '<tr>'
          + '<td><div style="display:flex;align-items:center;gap:10px">'
          + av
          + '<div><div class="client-name">' + esc(p.name || '—') + suspBadgePro + '</div><div class="client-email">' + esc(p.email) + '</div></div>'
          + '</div></td>'
          + '<td><div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">' + roleBadge + ' ' + typeBadge + '</div></td>'
          + '<td style="font-weight:600">' + clients + '</td>'
          + '<td style="color:var(--green);font-weight:600">' + (revenue > 0 ? '$' + revenue.toFixed(0) : '—') + '</td>'
          + '<td style="color:var(--muted);font-size:12px">' + date + '</td>'
          + '<td>' + (actionBtn || (isSelf ? '<span style="color:var(--muted);font-size:12px">Vous</span>' : '—')) + '</td>'
          + '</tr>';
      }).join('');
      tbody.dataset.loaded = '1';
    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">Erreur de connexion</td></tr>';
    }
  }

  async function changePro(userId, action) {
    var label = action === 'promote' ? 'Promouvoir en Pro' : 'Rétrograder en Client';
    if (!confirm(label + ' ?')) return;
    try {
      const r = await fetch('/api/admin/pros-list', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: userId, action }),
      });
      const d = await r.json();
      if (r.ok && d.ok) {
        toast(label + ' effectué ✓');
        // Recharger la liste
        document.getElementById('pros-body').dataset.loaded = '';
        loadPros();
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch {
      toast('Erreur de connexion', true);
    }
  }

  function debounceSearch() {
    clearTimeout(_debounceTimer);
    _debounceTimer = setTimeout(function() {
      _search = document.getElementById('client-search').value;
      _page = 1;
      loadClients();
    }, 350);
  }

  // ── Drawer ────────────────────────────────────────────────────────────────
  async function openClient(id) {
    _currentClient = id;
    _currentTab = 'messages';
    document.getElementById('drawer-overlay').classList.add('open');
    document.getElementById('client-drawer').classList.add('open');
    document.getElementById('drawer-body').innerHTML = '<div class="spinner"></div>';
    document.getElementById('dr-name').textContent  = 'Chargement…';
    document.getElementById('dr-email').textContent = '';

    const r = await fetch('/api/admin/client/' + id);
    if (!r.ok) {
      let msg = 'Erreur';
      try {
        const j = await r.json();
        msg = j && j.error ? j.error : msg;
      } catch {}
      document.getElementById('drawer-body').innerHTML = '<p style="color:var(--red);padding:20px">' + esc(msg) + '</p>';
      toast(msg, true);
      return;
    }
    _clientData = await r.json();

    var u = _clientData.user;
    document.getElementById('dr-name').textContent  = u.name || '—';
    document.getElementById('dr-email').textContent = u.email;
    setAvatarEl(document.getElementById('dr-avatar'), u.avatar_key, (u.name || u.email));

    renderDrawerTab('messages');
    // Activer le 1er onglet
    document.querySelectorAll('.dtab').forEach(function(el, i){ el.classList.toggle('active', i===0); });
  }

  function closeDrawer() {
    document.getElementById('drawer-overlay').classList.remove('open');
    document.getElementById('client-drawer').classList.remove('open');
    _currentClient = null;
    _clientData = null;
  }

  function switchDTab(tab) {
    _currentTab = tab;
    document.querySelectorAll('.dtab').forEach(function(el){
      el.classList.toggle('active', el.textContent.trim().toLowerCase().includes(tab.slice(0,5)));
    });
    var replyBar = document.getElementById('reply-bar');
    replyBar.style.display = tab === 'messages' ? '' : 'none';
    renderDrawerTab(tab);
  }

  function renderDrawerTab(tab) {
    var body = document.getElementById('drawer-body');
    if (!_clientData) return;
    if (tab === 'messages')  body.innerHTML = renderMessages();
    if (tab === 'projet')    body.innerHTML = renderProjet();
    if (tab === 'profil')    body.innerHTML = renderProfil();
    if (tab === 'paiements') body.innerHTML = renderPaiements();
    // Scroll messages vers le bas
    if (tab === 'messages') body.scrollTop = body.scrollHeight;
  }

  function renderMessages() {
    var msgs = _clientData.messages || [];
    if (!msgs.length) return '<div class="empty-state"><i class="fa fa-comment-slash"></i>Aucun message</div>';
    return '<div class="msg-list">' + msgs.map(function(m) {
      var cls = m.sender === 'user' ? 'user' : m.sender === 'admin' ? 'admin' : 'bot';
      var label = m.sender === 'user' ? '' : m.sender === 'admin' ? '<small>Admin</small> ' : '<small>Bot</small> ';
      var time = new Date(m.created_at).toLocaleString('fr-CA', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
      return '<div class="msg-item ' + cls + '">' + label + esc(m.content) + '<span class="msg-time">' + time + '</span></div>';
    }).join('') + '</div>';
  }

  function renderProjet() {
    var projs = _clientData.projects || [];
    if (!projs.length) return '<div class="empty-state"><i class="fa fa-folder-open"></i>Aucun projet</div>';
    return projs.map(function(p) {
      var status = p.status || 'en_cours';
      var pillClass = 'pill-' + status;
      var statusLabels = { soumis:'Soumis', en_cours:'En cours', termine:'Terminé', annule:'Annulé' };
      return '<div class="drawer-section">'
        + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">'
        + '<span class="drawer-section-title">Projet</span>'
        + '<div style="display:flex;align-items:center;gap:10px">'
        + '<span class="status-pill '+pillClass+'">'+esc(statusLabels[status]||status)+'</span>'
        + '<select class="status-select" onchange="updateStatus(\''+p.id+'\', this.value)">'
        + ['en_cours','soumis','termine','annule'].map(function(s) {
            return '<option value="'+s+'"'+(s===status?' selected':'')+'>'+statusLabels[s]+'</option>';
          }).join('')
        + '</select></div></div>'
        + '<div class="info-grid">'
        + infoCell('Type', p.type) + infoCell('Province', p.province) + infoCell('Pays cible', p.pays)
        + infoCell('Diplôme', p.diplome) + infoCell('Délai', p.delai) + infoCell('Personnes', p.nbpersonnes)
        + (p.pack_id ? infoCell('Pack', p.pack_id + ' — $' + p.pack_price) : '')
        + '</div>'
        + (p.notes ? '<div style="margin-top:12px;background:var(--card);border-radius:8px;padding:14px;font-size:13px;color:var(--muted)"><strong style="color:var(--text)">Notes :</strong> ' + esc(p.notes) + '</div>' : '')
        + '</div>';
    }).join('');
  }

  function renderProfil() {
    var u = _clientData.user;
    return '<div class="drawer-section"><div class="drawer-section-title">Informations</div>'
      + '<div class="info-grid">'
      + infoCell('Nom', u.name) + infoCell('Email', u.email)
      + infoCell('Téléphone', u.phone || '—') + infoCell('Ville / Pays', u.location || '—')
      + infoCell('Rôle', u.role) + infoCell('Inscrit le', new Date(u.created_at).toLocaleDateString('fr-CA'))
      + '</div>'
      + '<div class="drawer-section" style="margin-top:18px">'
      +   '<div class="drawer-section-title">Accès</div>'
      +   '<div style="display:flex;align-items:center;justify-content:space-between;gap:12px;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:12px 14px">'
      +     '<div style="min-width:0">'
      +       '<div style="font-weight:700">Autonomie (étapes)</div>'
      +       '<div style="color:var(--muted);font-size:12px;margin-top:2px">'
      +         (u.autonomie_unlocked ? 'Débloqué' : 'Bloqué (paiement requis)')
      +       '</div>'
      +     '</div>'
      +     '<button class="btn-sm" onclick="toggleAutonomieUnlock()">'
      +       (u.autonomie_unlocked ? 'Rebloquer' : 'Débloquer')
      +     '</button>'
      +   '</div>'
      + '</div>'
      + (u.bio ? '<div style="margin-top:12px;background:var(--card);border-radius:8px;padding:14px;font-size:13px;color:var(--muted)"><strong style="color:var(--text)">Bio :</strong> ' + esc(u.bio) + '</div>' : '')
      + '</div>';
  }

  async function toggleAutonomieUnlock() {
    if (!_clientData || !_currentClient) return;
    var u = _clientData.user || {};
    var next = !u.autonomie_unlocked;
    var label = next ? 'Débloquer Autonomie (voir les étapes)' : 'Rebloquer Autonomie (paiement requis)';
    if (!confirm(label + ' ?')) return;

    try {
      const r = await fetch('/api/admin/autonomie-unlock', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: _currentClient, unlocked: next }),
      });
      const d = await r.json().catch(() => ({}));
      if (r.ok && d.ok) {
        _clientData.user.autonomie_unlocked = !!d.unlocked;
        toast('Accès Autonomie mis à jour ✓');
        renderDrawerTab('profil');
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch {
      toast('Erreur de connexion', true);
    }
  }

  function renderPaiements() {
    var pays = _clientData.payments || [];
    if (!pays.length) return '<div class="empty-state"><i class="fa fa-receipt"></i>Aucun paiement</div>';
    return '<div class="drawer-section"><div class="drawer-section-title">Paiements</div>'
      + pays.map(function(p) {
          var stPill = p.status === 'paid' ? 'pill-termine' : p.status === 'failed' ? 'pill-annule' : 'pill-en_cours';
          var stLabel = { paid:'Payé', failed:'Échoué', pending:'En attente', refunded:'Remboursé' }[p.status] || p.status;
          return '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:var(--card);border-radius:8px;margin-bottom:8px">'
            + '<div><div style="font-weight:600">' + esc(p.method) + '</div><div style="color:var(--muted);font-size:11px">' + new Date(p.created_at).toLocaleDateString('fr-CA') + '</div></div>'
            + '<div style="display:flex;align-items:center;gap:12px">'
            + '<span style="font-weight:700;color:var(--green)">$' + Number(p.amount).toFixed(2) + ' ' + esc(p.currency) + '</span>'
            + '<span class="status-pill '+stPill+'">'+stLabel+'</span>'
            + '</div></div>';
        }).join('')
      + '</div>';
  }

  function infoCell(label, value) {
    return '<div class="info-cell"><label>' + label + '</label><span>' + esc(String(value || '—')) + '</span></div>';
  }

  // ── Actions ───────────────────────────────────────────────────────────────
  async function sendReply() {
    var input = document.getElementById('reply-input');
    var content = input.value.trim();
    if (!content || !_currentClient) return;
    input.value = '';
    const r = await fetch('/api/admin/reply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: _currentClient, content }),
    });
    if (r.ok) {
      // Ajouter le message localement sans recharger
      if (!_clientData.messages) _clientData.messages = [];
      _clientData.messages.push({ sender: 'admin', content, created_at: new Date().toISOString() });
      renderDrawerTab('messages');
      toast('Message envoyé ✓');
    } else {
      let msg = 'Erreur envoi';
      try {
        const j = await r.json();
        msg = j && j.error ? j.error : msg;
      } catch {}
      toast(msg, true);
    }
  }

  async function suggestReply() {
    if (!_clientData || !_currentClient) return;
    var btn = document.getElementById('btn-ai-suggest');
    var input = document.getElementById('reply-input');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="ai-spin"></span>'; }

    // Récupérer les messages + les infos projet
    var messages = (_clientData.messages || []).map(function(m) {
      return { sender: m.sender, content: m.content };
    });
    var project = {};
    var projs = _clientData.projects || [];
    if (projs.length) {
      var p = projs[0];
      if (p.type)      project.type     = p.type;
      if (p.province)  project.province = p.province;
      if (p.pays)      project.pays     = p.pays;
      if (p.pack_id)   project.pack_id  = p.pack_id;
      if (p.status)    project.status   = p.status;
    }

    try {
      const r = await fetch('/api/ai-suggest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages, project }),
      });
      const data = await r.json();
      if (r.ok && data.suggestion) {
        input.value = data.suggestion;
        input.focus();
        // Ajuster la hauteur du textarea
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 140) + 'px';
        toast('Suggestion IA prête ✓');
      } else {
        toast(data.error || 'Erreur IA', true);
      }
    } catch (err) {
      toast('Erreur de connexion IA', true);
    }
    if (btn) { btn.disabled = false; btn.innerHTML = '✨'; }
  }

  async function assignClient(clientId) {
    var payload = { client_id: clientId };
    var sel = document.getElementById('assign-pro-select');
    var selectedProId = (_isSuper && _scope === 'unassigned' && sel) ? String(sel.value || '') : '';
    if (_isSuper && selectedProId && selectedProId !== _meId) {
      payload.pro_id = selectedProId;
    }
    const r = await fetch('/api/admin/assign', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      if (_isSuper && selectedProId && selectedProId !== _meId) {
        toast('Client assigné à un pro ✓');
        if (document.getElementById('scope-all')) setScope('all'); else setScope('me');
        openClient(clientId);
        return;
      }
      toast('Client assigné ✓');
      setScope('me');
      openClient(clientId);
      return;
    }
    let msg = 'Impossible d\'assigner';
    try {
      const j = await r.json();
      msg = j && j.error ? j.error : msg;
    } catch {}
    toast(msg, true);
  }

  async function updateStatus(projectId, status) {
    const r = await fetch('/api/admin/project/' + projectId + '/status', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    if (r.ok) {
      toast('Statut mis à jour ✓');
      // Mettre à jour localement
      var proj = _clientData.projects.find(function(p){ return p.id === projectId; });
      if (proj) proj.status = status;
    } else {
      toast('Erreur mise à jour', true);
    }
  }

  // ── Utils ─────────────────────────────────────────────────────────────────
  async function suspendUser(userId, doSuspend) {
    var label = doSuspend ? 'Suspendre' : 'Réactiver';
    var warning = doSuspend ? 'L\'utilisateur ne pourra plus se connecter.' : 'L\'utilisateur pourra se reconnecter.';
    if (!confirm(label + ' ce compte ?\n' + warning)) return;
    try {
      const r = await fetch('/api/admin/user/' + userId + '/suspend', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ suspend: !!doSuspend }),
      });
      const d = await r.json();
      if (r.ok && d.ok) {
        toast(label + ' effectué ✓');
        // Recharger la liste active
        var prosBody = document.getElementById('pros-body');
        if (prosBody && prosBody.dataset.loaded) { prosBody.dataset.loaded = ''; loadPros(); }
        var clientsBody = document.getElementById('clients-body');
        if (clientsBody && clientsBody.dataset.loaded) { loadClients(); }
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch { toast('Erreur de connexion', true); }
  }

  async function deleteUser(userId, userName) {
    var msg = 'Supprimer définitivement le compte de « ' + userName + ' » ?\n\nCette action est IRRÉVERSIBLE. Tous ses projets, messages et paiements seront supprimés.';
    if (!confirm(msg)) return;
    // Double confirmation
    var confirm2 = prompt('Tapez SUPPRIMER pour confirmer :');
    if ((confirm2 || '').trim().toUpperCase() !== 'SUPPRIMER') { toast('Annulé', false); return; }
    try {
      const r = await fetch('/api/admin/user/' + userId + '/suspend', {
        method: 'DELETE',
      });
      const d = await r.json();
      if (r.ok && d.ok) {
        toast('Compte supprimé ✓');
        // Fermer le drawer si c'est ce client
        if (_currentClient === userId) closeDrawer();
        // Recharger
        var prosBody = document.getElementById('pros-body');
        if (prosBody && prosBody.dataset.loaded) { prosBody.dataset.loaded = ''; loadPros(); }
        var clientsBody = document.getElementById('clients-body');
        if (clientsBody && clientsBody.dataset.loaded) { loadClients(); }
        // Dashboard stats
        loadStats();
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch { toast('Erreur de connexion', true); }
  }

  function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function isValidAvatarKey(v) {
    if (!v) return false;
    var s = String(v).trim();
    return /^https?:\/\//i.test(s) || /^data:image\//i.test(s);
  }

  function avatarSmHtml(avatarKey, fallbackText) {
    var fb = (fallbackText || '?').charAt(0).toUpperCase();
    if (isValidAvatarKey(avatarKey)) {
      return '<div class="avatar-sm"><img src="' + esc(avatarKey) + '" alt="Avatar" /></div>';
    }
    return '<div class="avatar-sm">' + esc(fb) + '</div>';
  }

  function setAvatarEl(el, avatarKey, fallbackText) {
    if (!el) return;
    var fb = (fallbackText || '?').charAt(0).toUpperCase();
    if (!isValidAvatarKey(avatarKey)) {
      el.textContent = fb;
      return;
    }
    try {
      el.innerHTML = '';
      var img = document.createElement('img');
      img.alt = 'Avatar';
      img.src = String(avatarKey);
      img.onerror = function() {
        el.textContent = fb;
      };
      el.appendChild(img);
    } catch (e) {
      el.textContent = fb;
    }
  }

  function toast(msg, error) {
    var t = document.getElementById('adm-toast');
    t.textContent = msg;
    t.style.background = error ? '#e74c3c' : '#2ecc71';
    t.style.display = 'block';
    clearTimeout(t._timer);
    t._timer = setTimeout(function(){ t.style.display = 'none'; }, 3000);
  }

  // ── Inside publish ───────────────────────────────────────────────────────
  function setInsideEditMode(on) {
    var cancelBtn = document.getElementById('inside-edit-cancel');
    var submitBtn = document.getElementById('inside-publish-submit');
    if (cancelBtn) cancelBtn.style.display = on ? '' : 'none';
    if (submitBtn) submitBtn.innerHTML = on
      ? '<i class="fa fa-floppy-disk"></i> Mettre à jour'
      : '<i class="fa fa-paper-plane"></i> Publier';
  }

  function setInsideEditId(id) {
    var el = document.getElementById('inside-edit-id');
    if (el) el.value = id || '';
    setInsideEditMode(!!id);
  }

  function getInsideEditId() {
    var el = document.getElementById('inside-edit-id');
    return el ? String(el.value || '').trim() : '';
  }

  function truncateText(s, n) {
    var t = String(s || '');
    if (t.length <= n) return t;
    return t.slice(0, Math.max(0, n - 1)) + '…';
  }

  async function loadInsidePosts(force) {
    var tbody = document.getElementById('inside-posts-body');
    if (!tbody) return;
    if (!force && tbody.dataset.loaded) return;

    tbody.innerHTML = '<tr><td colspan="6"><div class="spinner"></div></td></tr>';

    try {
      const r = await fetch('/api/inside?includeHidden=1', { method: 'GET' });
      let d = null;
      try { d = await r.json(); } catch { d = null; }

      if (!r.ok) {
        var msg = (d && d.error) ? String(d.error) : ('Erreur (' + r.status + ')');
        tbody.innerHTML = '<tr><td colspan="6" class="empty-state">' + esc(msg) + '</td></tr>';
        toast('Inside: ' + msg, true);
        return;
      }

      var posts = (d && d.posts) ? d.posts : [];
      _insidePosts = posts || [];
      if (!posts || !posts.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="empty-state">Aucune publication</td></tr>';
        tbody.dataset.loaded = '1';
        return;
      }

      var html = '';
      for (var i = 0; i < posts.length; i++) {
        var p = posts[i] || {};
        var createdAt = p.createdAt || p.created_at || '';
        var date = createdAt ? new Date(createdAt).toLocaleString('fr-CA', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) : '—';
        var title = String(p.title || '');
        var content = String(p.content || '');
        var mediaType = String(p.mediaType || p.media_type || '');
        var mediaUrl = String(p.mediaUrl || p.media_url || '');
        var isHidden = !!(p.isHidden || p.is_hidden);

        var mediaCell = '—';
        if (mediaUrl) {
          var label = mediaType ? (mediaType + ' ↗') : 'Lien ↗';
          mediaCell = '<a class="inside-link" href="' + esc(mediaUrl) + '" target="_blank" rel="noreferrer">' + esc(label) + '</a>';
        } else if (mediaType) {
          mediaCell = esc(mediaType);
        }

        var statusPill = isHidden
          ? '<span class="status-pill pill-annule">Masqué</span>'
          : '<span class="status-pill pill-termine">Visible</span>';

        var actions = ''
          + '<button class="btn-sm" data-inside-action="edit" data-id="' + esc(String(p.id || '')) + '"><i class="fa fa-pen"></i> Modifier</button> '
          + '<button class="btn-sm" data-inside-action="toggleHidden" data-hidden="' + (isHidden ? '1' : '0') + '" data-id="' + esc(String(p.id || '')) + '">' + (isHidden ? '<i class="fa fa-eye"></i> Afficher' : '<i class="fa fa-eye-slash"></i> Masquer') + '</button> '
          + '<button class="btn-sm" data-inside-action="delete" data-id="' + esc(String(p.id || '')) + '" style="background: rgba(231,76,60,.15); color: var(--red)"><i class="fa fa-trash"></i></button>';

        html += '<tr>'
          + '<td style="white-space:nowrap;color:var(--muted);font-size:12px">' + esc(date) + '</td>'
          + '<td>' + statusPill + '</td>'
          + '<td><div style="font-weight:700">' + esc(truncateText(title, 70)) + '</div></td>'
          + '<td>' + mediaCell + '</td>'
          + '<td><div class="msg-preview">' + esc(truncateText(content, 140)) + '</div></td>'
          + '<td style="white-space:nowrap">' + actions + '</td>'
          + '</tr>';
      }
      tbody.innerHTML = html;
      tbody.dataset.loaded = '1';
    } catch (err) {
      console.warn('[Admin] inside list failed', err);
      tbody.innerHTML = '<tr><td colspan="6" class="empty-state">Erreur de connexion</td></tr>';
    }
  }

  function setInsideResult(text, isError) {
    var el = document.getElementById('inside-publish-result');
    if (!el) return;
    el.textContent = text || '';
    el.style.color = isError ? 'var(--red)' : 'var(--muted)';
  }

  function clearInsideForm() {
    var t = document.getElementById('inside-title');
    var c = document.getElementById('inside-content');
    var mf = document.getElementById('inside-media-file');
    if (t) t.value = '';
    if (c) c.value = '';
    if (mf) mf.value = '';
    setInsideResult('', false);
    setInsideEditId('');
  }

  async function publishInside(e) {
    e.preventDefault();
    setInsideResult('Publication en cours…', false);

    var title = String((document.getElementById('inside-title') || {}).value || '').trim();
    var content = String((document.getElementById('inside-content') || {}).value || '').trim();
    var mediaType = '';
    var mediaUrl = '';
    var mf = document.getElementById('inside-media-file');
    var file = (mf && mf.files && mf.files[0]) ? mf.files[0] : null;

    try {
      var editId = getInsideEditId();

      if (file) {
        setInsideResult('Upload du média…', false);
        var fd = new FormData();
        fd.append('file', file);
        const ur = await fetch('/api/inside/upload', { method: 'POST', body: fd });
        let ud = null;
        try { ud = await ur.json(); } catch { ud = null; }
        if (!ur.ok) {
          var umsg = (ud && ud.error) ? String(ud.error) : ('Erreur upload (' + ur.status + ')');
          setInsideResult(umsg, true);
          return;
        }
        if (!ud || !ud.ok || !ud.media || !ud.media.url) {
          setInsideResult('Upload: réponse invalide', true);
          return;
        }
        mediaUrl = String(ud.media.url || '');
        mediaType = String(ud.media.mediaType || '');
      }

      var payload = { title: title, content: content };
      if (file) {
        payload.mediaType = mediaType;
        payload.mediaUrl = mediaUrl;
      } else if (!editId) {
        payload.mediaType = '';
        payload.mediaUrl = '';
      }

      const r = await fetch(editId ? ('/api/inside/' + encodeURIComponent(editId)) : '/api/inside', {
        method: editId ? 'PATCH' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      let d = null;
      try { d = await r.json(); } catch { d = null; }

      if (!r.ok) {
        var msg = (d && d.error) ? String(d.error) : ('Erreur (' + r.status + ')');
        setInsideResult(msg, true);
        return;
      }

      if (d && d.ok) {
        setInsideResult(editId ? 'Mis à jour ✓' : 'Publié ✓', false);
        clearInsideForm();
        toast(editId ? 'Inside: mis à jour ✓' : 'Inside: publié ✓', false);
        loadInsidePosts(true);
        return;
      }

      setInsideResult('Publié ✓', false);
      clearInsideForm();
    } catch (err) {
      console.warn('[Admin] inside publish failed', err);
      setInsideResult('Erreur de connexion', true);
    }
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  loadStats();

  // ── Event delegation (remplace tous les onclick= statiques du HTML) ────────
  document.addEventListener('click', function(e) {
    var el = e.target;

    // Remonte jusqu'à 4 niveaux pour trouver l'élément portant le data-*
    for (var i = 0; i < 4; i++) {
      if (!el || el === document) break;

      // Navigation sidebar : data-section
      if (el.hasAttribute && el.hasAttribute('data-section')) {
        e.preventDefault();
        showSection(el.getAttribute('data-section'));
        return;
      }
      // Scope clients : data-scope
      if (el.hasAttribute && el.hasAttribute('data-scope')) {
        setScope(el.getAttribute('data-scope'));
        return;
      }
      // Actions génériques : data-action
      if (el.hasAttribute && el.hasAttribute('data-action')) {
        var action = el.getAttribute('data-action');
        if (action === 'closeDrawer')  { closeDrawer();  return; }
        if (action === 'sendReply')    { sendReply();    return; }
        if (action === 'suggestReply') { suggestReply(); return; }
        return;
      }

      // Actions Inside (gestionnaire)
      if (el.hasAttribute && el.hasAttribute('data-inside-action')) {
        var ia = el.getAttribute('data-inside-action');
        var pid = el.getAttribute('data-id') || '';
        var hidden = el.getAttribute('data-hidden') === '1';
        if (ia === 'edit') {
          var p = (_insidePosts || []).find(function(x){ return String((x||{}).id||'') === String(pid); });
          if (p) {
            document.getElementById('inside-title').value = String(p.title || '');
            document.getElementById('inside-content').value = String(p.content || '');
            setInsideEditId(String(p.id || ''));
            setInsideResult('Mode édition: ' + truncateText(String(p.title || ''), 40), false);
          }
          return;
        }
        if (ia === 'toggleHidden') {
          (async function(){
            try {
              const rr = await fetch('/api/inside/' + encodeURIComponent(pid), {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ hidden: !hidden }),
              });
              const dd = await rr.json().catch(function(){ return null; });
              if (!rr.ok) {
                toast('Inside: ' + ((dd && dd.error) ? dd.error : 'Erreur'), true);
                return;
              }
              toast(!hidden ? 'Inside: masqué' : 'Inside: affiché', false);
              loadInsidePosts(true);
            } catch {
              toast('Inside: erreur réseau', true);
            }
          })();
          return;
        }
        if (ia === 'delete') {
          if (!confirm('Supprimer définitivement ce post Inside ?')) return;
          (async function(){
            try {
              const rr = await fetch('/api/inside/' + encodeURIComponent(pid), { method: 'DELETE' });
              const dd = await rr.json().catch(function(){ return null; });
              if (!rr.ok) {
                toast('Inside: ' + ((dd && dd.error) ? dd.error : 'Erreur'), true);
                return;
              }
              toast('Inside: supprimé', false);
              loadInsidePosts(true);
            } catch {
              toast('Inside: erreur réseau', true);
            }
          })();
          return;
        }
        return;
      }
      // Onglets drawer : data-tab
      if (el.hasAttribute && el.hasAttribute('data-tab')) {
        var tab = el.getAttribute('data-tab');
        switchDTab(tab);
        document.getElementById('reply-bar').style.display = tab === 'messages' ? '' : 'none';
        return;
      }

      el = el.parentElement;
    }
  });

  // Recherche client (input)
  var searchEl = document.getElementById('client-search');
  if (searchEl) searchEl.addEventListener('input', function() { debounceSearch(); });

  // Inside publish
  var insideForm = document.getElementById('inside-publish-form');
  if (insideForm) insideForm.addEventListener('submit', publishInside);
  var insideClear = document.getElementById('btn-inside-clear');
  if (insideClear) insideClear.addEventListener('click', function() { clearInsideForm(); });
  var insideEditCancel = document.getElementById('inside-edit-cancel');
  if (insideEditCancel) insideEditCancel.addEventListener('click', function() { clearInsideForm(); });
  var insideRefresh = document.getElementById('btn-inside-refresh');
  if (insideRefresh) insideRefresh.addEventListener('click', function() { loadInsidePosts(true); });
  var trafficRefresh = document.getElementById('btn-traffic-refresh');
  if (trafficRefresh) trafficRefresh.addEventListener('click', function() { _trafficLoaded = false; loadWebTraffic(true); });
  var trafficDays = document.getElementById('traffic-days');
  if (trafficDays) trafficDays.addEventListener('change', function() { _trafficLoaded = false; loadWebTraffic(true); });

  // Textarea reply : Enter pour envoyer
  var replyInput = document.getElementById('reply-input');
  if (replyInput) replyInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendReply(); }
  });
</script>
</body>
</html>
