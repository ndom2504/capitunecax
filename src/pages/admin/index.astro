---
// Protection front supplémentaire (le middleware couvre déjà /admin)
import { getUserFromSessionFullAny } from '../../lib/db';
import { isSuperAdminEmail } from '../../lib/admin-emails';
import TrafficWorldMap from '../../components/admin/TrafficWorldMap';
const db = (Astro.locals.runtime?.env as Env | undefined)?.DB ?? null;
const token = Astro.cookies.get('capitune_session')?.value ?? '';
const adminUser = await getUserFromSessionFullAny(db, token);
const adminName = adminUser?.name ?? 'Admin';
const adminId = adminUser?.id ?? '';
const isSuperAdmin = adminUser?.email ? isSuperAdminEmail(adminUser.email) : false;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — CAPITUNE</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root {
      --bg:      #0f1117;
      --surface: #1a1d27;
      --card:    #20243a;
      --border:  #2e3349;
      --text:    #e6e9f4;
      --muted:   #8891b4;
      --accent:  #ff9408;
      --green:   #2ecc71;
      --red:     #e74c3c;
      --blue:    #3498db;
      --yellow:  #f1c40f;
      --radius:  12px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; font-size: 14px; min-height: 100vh; display: flex; }

    /* ── Sidebar ─────────────────────────────── */
    .sidebar {
      width: 220px; min-height: 100vh; background: var(--surface);
      border-right: 1px solid var(--border); display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 100;
    }
    .sidebar-logo { padding: 24px 20px; border-bottom: 1px solid var(--border); }
    .sidebar-logo img { height: 36px; }
    .sidebar-logo span { font-size: 18px; font-weight: 700; color: var(--accent); letter-spacing: 1px; }
    .sidebar-nav { flex: 1; padding: 16px 0; }
    .nav-item {
      display: flex; align-items: center; gap: 12px; padding: 11px 20px;
      color: var(--muted); cursor: pointer; transition: all .18s; border-radius: 0;
      font-weight: 500; text-decoration: none;
    }
    .nav-item:hover, .nav-item.active { background: rgba(255,148,8,.1); color: var(--accent); }
    .nav-item i { width: 18px; text-align: center; font-size: 15px; }
    .sidebar-footer { padding: 16px 20px; border-top: 1px solid var(--border); color: var(--muted); font-size: 12px; }
    .sidebar-footer strong { display: block; color: var(--text); margin-bottom: 4px; font-size: 13px; }

    /* ── Main ───────────────────────────────── */
    .main { margin-left: 220px; flex: 1; min-height: 100vh; }
    .topbar {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 50;
    }
    .topbar h1 { font-size: 18px; font-weight: 600; }
    .topbar-right { display: flex; align-items: center; gap: 16px; }
    .badge-notif {
      background: var(--red); color: #fff; border-radius: 50%; width: 20px; height: 20px;
      font-size: 11px; display: flex; align-items: center; justify-content: center; font-weight: 700;
    }
    .content { padding: 28px 32px; }

    /* ── Stats cards ─────────────────────────── */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 28px; }
    .stat-card {
      background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 20px; display: flex; align-items: center; gap: 16px;
    }
    .stat-icon {
      width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px;
    }
    .stat-icon.orange { background: rgba(255,148,8,.15); color: var(--accent); }
    .stat-icon.green  { background: rgba(46,204,113,.15); color: var(--green); }
    .stat-icon.blue   { background: rgba(52,152,219,.15); color: var(--blue); }
    .stat-icon.red    { background: rgba(231,76,60,.15);  color: var(--red); }
    .stat-label { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
    .stat-value { font-size: 26px; font-weight: 700; line-height: 1; }

    /* ── Table clients ───────────────────────── */
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title { font-size: 16px; font-weight: 600; }
    .search-box {
      background: var(--card); border: 1px solid var(--border); border-radius: 8px;
      padding: 8px 14px; color: var(--text); font-size: 13px; width: 260px; outline: none;
    }
    .search-box:focus { border-color: var(--accent); }
    .search-box::placeholder { color: var(--muted); }
    .table-wrap { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .mini-stats-grid { display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:18px; margin-bottom:22px; }
    .traffic-hero { display:grid; grid-template-columns:minmax(0, 1.45fr) minmax(340px, .85fr); gap:18px; margin-bottom:18px; }
    .traffic-stack { display:grid; gap:18px; }
    .traffic-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:18px; margin-bottom:18px; }
    .traffic-card, .traffic-table {
      background:
        linear-gradient(180deg, rgba(255,255,255,.025), rgba(255,255,255,.01)),
        radial-gradient(circle at top right, rgba(255,148,8,.14), transparent 34%),
        var(--card);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 14px 40px rgba(0,0,0,.22);
    }
    .traffic-card-body { padding: 18px 18px 20px; }
    .traffic-card-head { display:flex; align-items:flex-start; justify-content:space-between; gap:14px; margin-bottom:16px; }
    .traffic-card-title { font-size:15px; font-weight:700; color:var(--text); }
    .traffic-card-caption { font-size:12px; color:var(--muted); margin-top:4px; }
    .traffic-toolbar { display:flex; align-items:center; gap:10px; }
    .traffic-note { color:var(--muted); font-size:12px; margin-bottom:16px; max-width:760px; line-height:1.55; }
    .muted-cell { color: var(--muted); font-size: 12px; }

    .traffic-kpi { position:relative; min-height:116px; }
    .traffic-kpi-icon {
      width:42px; height:42px; border-radius:14px; display:flex; align-items:center; justify-content:center;
      background:rgba(255,255,255,.05); color:var(--accent); border:1px solid rgba(255,255,255,.06); margin-bottom:16px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
    }
    .traffic-kpi-label { font-size:12px; color:var(--muted); margin-bottom:8px; }
    .traffic-kpi-value { font-size:30px; font-weight:800; line-height:1; letter-spacing:-.03em; }
    .traffic-sub { font-size:12px; color:var(--muted); margin-top:8px; }

    .traffic-map-stage {
      position:relative; min-height:330px; border-radius:20px; overflow:hidden;
      background:
        radial-gradient(circle at 18% 18%, rgba(82,136,255,.16), transparent 30%),
        radial-gradient(circle at 85% 18%, rgba(255,148,8,.12), transparent 28%),
        linear-gradient(180deg, #101827 0%, #0f1726 100%);
      border:1px solid rgba(255,255,255,.06);
    }
    .traffic-map-react { position:relative; }
    .traffic-map-shell {
      position:relative; min-height:330px; border-radius:20px; overflow:hidden;
      background:
        radial-gradient(circle at 18% 18%, rgba(82,136,255,.16), transparent 30%),
        radial-gradient(circle at 85% 18%, rgba(255,148,8,.12), transparent 28%),
        linear-gradient(180deg, #101827 0%, #0f1726 100%);
      border:1px solid rgba(255,255,255,.06);
    }
    .traffic-map-svg { width:100%; height:100%; min-height:330px; display:block; }
    .traffic-map-node { cursor:pointer; }
    .traffic-map-empty {
      min-height:330px; display:flex; align-items:center; justify-content:center; padding:24px;
      color:var(--muted); font-size:13px;
    }
    .traffic-map-badges { position:absolute; top:14px; left:14px; display:flex; gap:8px; flex-wrap:wrap; z-index:2; }
    .traffic-badge {
      display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:999px;
      background:rgba(13,19,34,.72); backdrop-filter: blur(10px); border:1px solid rgba(255,255,255,.08);
      font-size:11px; color:#d6def7; font-weight:700;
    }
    .traffic-badge i { color:var(--accent); }
    .traffic-map-legend {
      position:absolute; left:14px; right:14px; bottom:14px; display:flex; align-items:center; justify-content:space-between; gap:12px;
      padding:10px 12px; border-radius:14px; background:rgba(12,18,32,.72); backdrop-filter: blur(8px); border:1px solid rgba(255,255,255,.06);
      color:#d6def7; font-size:11px;
    }
    .traffic-map-legend strong { display:block; font-size:13px; color:#fff; margin-bottom:4px; }
    .traffic-map-legend span { color:#b9c4e5; }
    .traffic-legend-scale { display:flex; align-items:center; gap:10px; }
    .traffic-legend-bar { width:140px; height:8px; border-radius:999px; background:linear-gradient(90deg, rgba(82,136,255,.28), rgba(255,148,8,.95)); }

    .traffic-overview-grid { display:grid; gap:12px; }
    .traffic-overview-top { display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:10px; }
    .traffic-mini-stat {
      padding:12px; border-radius:14px; background:rgba(255,255,255,.035); border:1px solid rgba(255,255,255,.06);
    }
    .traffic-mini-stat label { display:block; color:var(--muted); font-size:11px; margin-bottom:6px; }
    .traffic-mini-stat strong { display:block; font-size:20px; line-height:1; letter-spacing:-.02em; }
    .traffic-trend-chart {
      padding:14px; border-radius:16px; background:rgba(255,255,255,.035); border:1px solid rgba(255,255,255,.06);
    }
    .traffic-trend-head { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:10px; }
    .traffic-trend-title { font-size:13px; font-weight:700; }
    .traffic-trend-sub { font-size:11px; color:var(--muted); }
    .sparkline-svg { width:100%; height:150px; display:block; }
    .sparkline-meta { display:flex; gap:10px; flex-wrap:wrap; margin-top:10px; }
    .sparkline-pill {
      display:inline-flex; align-items:center; gap:8px; padding:7px 10px; border-radius:999px;
      background:rgba(255,255,255,.045); border:1px solid rgba(255,255,255,.06); font-size:11px; color:var(--muted);
    }
    .sparkline-pill strong { color:var(--text); font-size:12px; }

    .rank-list { display:flex; flex-direction:column; gap:10px; }
    .rank-item {
      display:grid; grid-template-columns:40px minmax(0, 1fr) auto; gap:12px; align-items:center;
      padding:12px 14px; border-radius:14px; background:rgba(255,255,255,.035); border:1px solid rgba(255,255,255,.055);
    }
    .rank-index {
      width:40px; height:40px; border-radius:12px; display:flex; align-items:center; justify-content:center;
      background:linear-gradient(135deg, rgba(255,148,8,.22), rgba(82,136,255,.16)); color:var(--text); font-weight:800;
      border:1px solid rgba(255,255,255,.06);
    }
    .rank-main { min-width:0; }
    .rank-title { font-size:13px; font-weight:700; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .rank-sub { font-size:11px; color:var(--muted); margin-top:4px; }
    .rank-value { text-align:right; min-width:90px; }
    .rank-value strong { display:block; font-size:18px; line-height:1; }
    .rank-progress { margin-top:8px; width:100%; height:7px; border-radius:999px; background:rgba(255,255,255,.05); overflow:hidden; }
    .rank-progress > span { display:block; height:100%; border-radius:999px; background:linear-gradient(90deg, #5b8cff, #ff9408); }

    .country-list { display:flex; flex-direction:column; gap:10px; }
    .country-item { display:grid; grid-template-columns: 46px minmax(0, 1fr) 72px; gap:12px; align-items:center; padding:12px 14px; border-radius:14px; background:rgba(255,255,255,.035); border:1px solid rgba(255,255,255,.055); }
    .country-code { display:inline-flex; align-items:center; justify-content:center; width:46px; height:32px; border-radius:10px; background:linear-gradient(135deg, rgba(255,148,8,.2), rgba(82,136,255,.14)); color:var(--text); font-weight:800; font-size:12px; border:1px solid rgba(255,255,255,.06); }
    .country-name { font-size:13px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .country-sub { font-size:11px; color:var(--muted); margin-top:4px; }
    .country-val { text-align:right; font-size:12px; color:var(--muted); font-weight:700; }
    .country-val strong { display:block; color:var(--text); font-size:18px; line-height:1; margin-bottom:4px; }

    .traffic-table { border-radius:18px; }
    .traffic-table table thead { background:rgba(255,255,255,.03); }
    .traffic-table table th { color:#96a0c6; }
    .traffic-table table td { border-top:1px solid rgba(255,255,255,.06); }
    table { width: 100%; border-collapse: collapse; }
    thead { background: var(--surface); }
    th { padding: 12px 16px; text-align: left; font-size: 12px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
    td { padding: 13px 16px; border-top: 1px solid var(--border); vertical-align: middle; }
    tr.client-row { cursor: pointer; transition: background .15s; }
    tr.client-row:hover { background: rgba(255,255,255,.03); }
    .avatar-sm {
      width: 34px; height: 34px; border-radius: 50%; background: var(--accent);
      display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: #fff; flex-shrink: 0;
      overflow: hidden;
    }
    .avatar-sm img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .client-name { font-weight: 600; }
    .client-email { color: var(--muted); font-size: 12px; }
    .status-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; text-transform: uppercase;
    }
    .pill-soumis   { background: rgba(52,152,219,.15);  color: var(--blue); }
    .pill-en_cours { background: rgba(241,196,15,.15);  color: var(--yellow); }
    .pill-termine  { background: rgba(46,204,113,.15);  color: var(--green); }
    .pill-annule   { background: rgba(231,76,60,.15);   color: var(--red); }
    .pill-aucun    { background: rgba(136,145,180,.1);  color: var(--muted); }
    .msg-preview { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--muted); font-size: 12px; }
    .btn-sm {
      padding: 5px 12px; border-radius: 6px; border: none; cursor: pointer; font-size: 12px; font-weight: 600;
      background: rgba(255,148,8,.15); color: var(--accent); transition: background .15s;
    }
    .btn-sm:hover { background: var(--accent); color: #fff; }

    /* ── Scope toggle (Mes clients / Non assignés) ───────────────────── */
    .segmented {
      display: inline-flex;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .seg-btn {
      background: transparent;
      border: none;
      color: var(--muted);
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all .15s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .seg-btn:hover { color: var(--text); }
    .seg-btn.active { background: rgba(255,148,8,.12); color: var(--accent); }

    /* ── Drawer client ───────────────────────── */
    .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; opacity: 0; pointer-events: none; transition: opacity .25s; }
    .drawer-overlay.open { opacity: 1; pointer-events: auto; }
    .drawer {
      position: fixed; top: 0; right: -700px; bottom: 0; width: 680px;
      background: var(--surface); border-left: 1px solid var(--border);
      z-index: 201; transition: right .3s cubic-bezier(.4,0,.2,1); display: flex; flex-direction: column; overflow: hidden;
    }
    .drawer.open { right: 0; }
    .drawer-head {
      padding: 20px 28px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
    }
    .drawer-client-info { display: flex; align-items: center; gap: 14px; }
    .avatar-lg {
      width: 48px; height: 48px; border-radius: 50%; background: var(--accent);
      display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 18px; color: #fff; flex-shrink: 0;
      overflow: hidden;
    }
    .avatar-lg img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .drawer-name { font-size: 16px; font-weight: 700; }
    .drawer-email { color: var(--muted); font-size: 13px; }
    .btn-close { background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; padding: 4px; }
    .btn-close:hover { color: var(--text); }

    .drawer-tabs { display: flex; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .dtab {
      padding: 13px 20px; font-size: 13px; font-weight: 600; color: var(--muted);
      cursor: pointer; border-bottom: 2px solid transparent; transition: all .18s;
    }
    .dtab.active { color: var(--accent); border-bottom-color: var(--accent); }
    .dtab:hover { color: var(--text); }

    .drawer-body { flex: 1; overflow-y: auto; padding: 24px 28px; }
    .drawer-section { margin-bottom: 24px; }
    .drawer-section-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--muted); margin-bottom: 12px; }

    /* Messages inside drawer */
    .msg-list { display: flex; flex-direction: column; gap: 10px; }
    .msg-item {
      max-width: 82%; padding: 10px 14px; border-radius: 12px; font-size: 13px; line-height: 1.5;
    }
    .msg-item.user { background: var(--card); border-bottom-left-radius: 4px; align-self: flex-start; }
    .msg-item.admin { background: rgba(255,148,8,.15); border-bottom-right-radius: 4px; align-self: flex-end; color: #ffd09a; }
    .msg-item.bot  { background: rgba(52,152,219,.1); border-bottom-left-radius: 4px; align-self: flex-start; color: #a8d4f5; }
    .msg-time { font-size: 10px; color: var(--muted); margin-top: 4px; display: block; }

    /* Reply form */
    .reply-bar {
      border-top: 1px solid var(--border); padding: 16px 28px; display: flex; gap: 10px;
      flex-shrink: 0; background: var(--surface);
    }
    .reply-input {
      flex: 1; background: var(--card); border: 1px solid var(--border); border-radius: 10px;
      padding: 10px 14px; color: var(--text); font-size: 13px; resize: none; outline: none; min-height: 42px; max-height: 140px;
    }
    .reply-input:focus { border-color: var(--accent); }
    .btn-send {
      background: var(--accent); color: #fff; border: none; border-radius: 10px;
      padding: 10px 18px; font-size: 13px; font-weight: 600; cursor: pointer; flex-shrink: 0;
    }
    .btn-send:hover { background: #e08400; }
    .btn-ai {
      background: linear-gradient(135deg, #7c3aed, #a855f7); color: #fff; border: none;
      border-radius: 10px; padding: 10px 14px; font-size: 15px; cursor: pointer; flex-shrink: 0;
      transition: opacity .2s, transform .1s; title: 'Suggérer avec l\'IA';
    }
    .btn-ai:hover { opacity: .85; }
    @media (max-width: 1220px) {
      .traffic-hero { grid-template-columns:1fr; }
      .traffic-overview-top { grid-template-columns:repeat(3, minmax(0, 1fr)); }
    }
    @media (max-width: 1100px) {
      .mini-stats-grid, .traffic-grid, .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 760px) {
      .mini-stats-grid, .traffic-grid, .stats-grid, .traffic-overview-top { grid-template-columns: 1fr; }
      .traffic-map-legend { flex-direction:column; align-items:flex-start; }
    }
    .btn-ai:active { transform: scale(.95); }
    .btn-ai:disabled { opacity: .45; cursor: not-allowed; }
    .btn-ai .ai-spin {
      display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4);
      border-top-color: #fff; border-radius: 50%; animation: spin .6s linear infinite;
      vertical-align: middle;
    }
    .info-cell span { display: block; font-weight: 600; margin-top: 3px; }

    /* Status select */
    .status-select {
      background: var(--card); border: 1px solid var(--border); color: var(--text);
      border-radius: 8px; padding: 6px 12px; font-size: 13px; cursor: pointer; outline: none;
    }
    .status-select:focus { border-color: var(--accent); }

    /* Inside publish */
    .inside-card { padding: 16px; }
    .inside-form { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .inside-field { display: flex; flex-direction: column; gap: 6px; }
    .inside-field label { font-size: 12px; color: var(--muted); font-weight: 700; }
    .inside-input, .inside-textarea {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      color: var(--text);
      font-size: 13px;
      outline: none;
    }
    .inside-input:focus, .inside-textarea:focus { border-color: var(--accent); }
    .inside-textarea { min-height: 160px; resize: vertical; }
    .inside-span { font-size: 12px; color: var(--muted); }
    .inside-actions { display: flex; align-items: center; justify-content: flex-end; gap: 10px; }
    .inside-actions .btn-send { padding: 10px 18px; }
    .inside-full { grid-column: 1 / -1; }

    /* Inside list */
    .inside-subheader { margin-top: 16px; }
    .inside-link { color: var(--accent); text-decoration: none; }
    .inside-link:hover { text-decoration: underline; }

    /* Pagination */
    .pagination { display: flex; gap: 6px; align-items: center; margin-top: 16px; justify-content: flex-end; }
    .page-btn {
      background: var(--card); border: 1px solid var(--border); color: var(--text);
      border-radius: 6px; padding: 5px 12px; font-size: 13px; cursor: pointer;
    }
    .page-btn:hover { border-color: var(--accent); color: var(--accent); }
    .page-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* Empty */
    .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
    .empty-state i { font-size: 40px; margin-bottom: 12px; display: block; }

    /* Loading spinner */
    .spinner { width: 24px; height: 24px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin .7s linear infinite; margin: 40px auto; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Pro badges */
    .pro-badge { display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;text-transform:uppercase; }
    .badge-admin { background:rgba(231,76,60,.15);color:var(--red); }
    .badge-pro { background:rgba(52,152,219,.15);color:var(--blue); }
    .badge-client { background:rgba(136,145,180,.1);color:var(--muted); }
    .btn-promote { background:rgba(46,204,113,.12);color:var(--green);border:none;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-promote:hover { background:var(--green);color:#fff; }
    .btn-demote { background:rgba(231,76,60,.12);color:var(--red);border:none;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-demote:hover { background:var(--red);color:#fff; }

    /* Suspend / Delete buttons */
    .btn-suspend { background:rgba(241,196,15,.12);color:var(--yellow);border:none;border-radius:6px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-suspend:hover { background:var(--yellow);color:#000; }
    .btn-unsuspend { background:rgba(46,204,113,.12);color:var(--green);border:none;border-radius:6px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-unsuspend:hover { background:var(--green);color:#fff; }
    .btn-delete { background:rgba(231,76,60,.12);color:var(--red);border:none;border-radius:6px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-delete:hover { background:var(--red);color:#fff; }
    .badge-suspended { background:rgba(241,196,15,.18);color:var(--yellow);display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:12px;font-size:10px;font-weight:700;text-transform:uppercase; }
    .actions-cell { display:flex;gap:6px;flex-wrap:wrap;align-items:center; }

    /* Toast */
    #adm-toast {
      position: fixed; bottom: 24px; right: 24px; background: var(--green);
      color: #fff; padding: 12px 20px; border-radius: 10px; font-size: 13px; font-weight: 600;
      z-index: 999; display: none; box-shadow: 0 6px 24px rgba(0,0,0,.4);
    }
  </style>
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <span>CAPITUNE</span><br>
    <small style="color:var(--muted);font-size:11px;font-weight:400;">Panneau Admin</small>
  </div>
  <nav class="sidebar-nav">
    <a class="nav-item active" href="#dashboard" data-section="dashboard">
      <i class="fa fa-chart-pie"></i> Tableau de bord
    </a>
    <a class="nav-item" href="#inside" data-section="inside">
      <i class="fa fa-bullhorn"></i> Inside
    </a>
    <a class="nav-item" href="#clients" data-section="clients">
      <i class="fa fa-users"></i> Clients
    </a>
    <a class="nav-item" href="#pros" data-section="pros">
      <i class="fa fa-user-tie"></i> Comptes Pro
    </a>
    <a class="nav-item" href="#traffic" data-section="traffic">
      <i class="fa fa-chart-line"></i> Trafic web
    </a>
    <a class="nav-item" href="/admin/stripe-configuration">
      <i class="fa fa-credit-card"></i> Stripe
    </a>
    <a class="nav-item" href="/dashboard?pro=1">
      <i class="fa fa-rocket"></i> Espace Pro
    </a>
    <a class="nav-item" href="/api/oauth/signout" style="margin-top:auto;">
      <i class="fa fa-sign-out-alt"></i> Déconnexion
    </a>
  </nav>
  <div class="sidebar-footer">
    <strong>{adminName}</strong>
    Administrateur
  </div>
</aside>

<!-- Main -->
<main class="main">
  <div class="topbar">
    <h1 id="page-title">Tableau de bord</h1>
    <div class="topbar-right">
      <span style="color:var(--muted);font-size:12px;" id="pending-badge"></span>
      <a href="/api/oauth/signout" style="color:var(--muted);font-size:12px;text-decoration:none;">
        <i class="fa fa-sign-out-alt"></i> Déconnexion
      </a>
    </div>
  </div>

  <div class="content">

    <!-- SECTION DASHBOARD -->
    <div id="section-dashboard">
      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon orange"><i class="fa fa-users"></i></div>
          <div><div class="stat-label">Clients</div><div class="stat-value" id="stat-users">—</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue"><i class="fa fa-folder-open"></i></div>
          <div><div class="stat-label">Projets actifs</div><div class="stat-value" id="stat-projects">—</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon red"><i class="fa fa-envelope"></i></div>
          <div><div class="stat-label">Messages en attente</div><div class="stat-value" id="stat-pending">—</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green"><i class="fa fa-dollar-sign"></i></div>
          <div><div class="stat-label">Revenus (payé)</div><div class="stat-value" id="stat-revenue">—</div></div>
        </div>
      </div>

      <!-- Derniers clients -->
      <div class="section-header">
        <div class="section-title">Derniers inscrits</div>
        <button class="btn-sm" data-section="clients">Voir tous →</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Nom</th><th>Email</th><th>Inscrit le</th><th></th></tr></thead>
          <tbody id="recent-users-body">
            <tr><td colspan="4"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SECTION INSIDE -->
    <div id="section-inside" style="display:none">
      <div class="section-header">
        <div>
          <div class="section-title">Inside — Publication</div>
          <span class="inside-span">Publie un post visible dans l’onglet Inside (mobile).</span>
        </div>
        <button class="btn-sm" id="btn-inside-clear" type="button"><i class="fa fa-eraser"></i> Vider</button>
      </div>

      <div class="table-wrap">
        <div class="inside-card">
          <form id="inside-publish-form" class="inside-form">
            <div class="inside-field inside-full">
              <label for="inside-title">Titre</label>
              <input class="inside-input" id="inside-title" name="title" maxlength="120" placeholder="Ex: Nouvelle mise à jour — mars 2026" required />
            </div>

            <div class="inside-field inside-full">
              <label for="inside-content">Contenu</label>
              <textarea class="inside-textarea" id="inside-content" name="content" maxlength="5000" placeholder="Écris le message à diffuser…" required></textarea>
              <span class="inside-span">Minimum: 10 caractères. Le titre doit faire au moins 3 caractères.</span>
            </div>

            <div class="inside-field inside-full">
              <label for="inside-media-file">Média (optionnel)</label>
              <input class="inside-input" type="file" id="inside-media-file" name="mediaFile" accept="image/*,video/*" />
              <span class="inside-span">Importe une image ou une vidéo (max 8 Mo). Pas de lien externe.</span>
            </div>

            <div class="inside-actions inside-full">
              <span class="inside-span" id="inside-publish-result"></span>
              <input type="hidden" id="inside-edit-id" value="" />
              <button class="btn-sm" id="inside-edit-cancel" type="button" style="display:none"><i class="fa fa-ban"></i> Annuler édition</button>
              <button class="btn-send" id="inside-publish-submit" type="submit"><i class="fa fa-paper-plane"></i> Publier</button>
            </div>
          </form>
        </div>
      </div>

      <div class="section-header inside-subheader">
        <div>
          <div class="section-title">Dernières publications</div>
          <span class="inside-span">Aperçu des 50 derniers posts (lecture seule).</span>
        </div>
        <button class="btn-sm" id="btn-inside-refresh" type="button"><i class="fa fa-rotate"></i> Rafraîchir</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Statut</th>
              <th>Titre</th>
              <th>Média</th>
              <th>Aperçu</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="inside-posts-body" data-loaded="0">
            <tr><td colspan="6"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SECTION CLIENTS -->
    <div id="section-clients" style="display:none">
      <div class="section-header">
        <div style="display:flex;align-items:center;gap:12px">
          <div class="section-title">Clients</div>
          <div class="segmented" title="Filtrer par assignation">
            <button class="seg-btn" id="scope-me" data-scope="me"><i class="fa fa-user"></i> Mes clients</button>
            <button class="seg-btn" id="scope-unassigned" data-scope="unassigned"><i class="fa fa-inbox"></i> Non assignés</button>
            <button class="seg-btn active" id="scope-all" data-scope="all"><i class="fa fa-layer-group"></i> Tous</button>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          {isSuperAdmin && (
            <select class="status-select" id="assign-pro-select" style="display:none; width:240px" title="Assigner les non-assignés à">
              <option value={adminId}>Moi</option>
            </select>
          )}
          <input class="search-box" id="client-search" placeholder="🔍  Rechercher nom ou email..." />
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Client</th>
              <th>Projet</th>
              <th>Statut</th>
              <th>Dernier message</th>
              <th>Revenus</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="clients-body">
            <tr><td colspan="6"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>
      <div class="pagination" id="pagination"></div>
    </div>

    <!-- SECTION COMPTES PRO -->
    <div id="section-pros" style="display:none">
      <div class="section-header">
        <div style="display:flex;align-items:center;gap:12px">
          <div class="section-title">Comptes Pro / Admins</div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <span style="font-size:12px;color:var(--muted);">Comptes avec accès professionnel au dashboard</span>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Utilisateur</th>
              <th>Rôle / Type</th>
              <th>Clients assignés</th>
              <th>Revenus générés</th>
              <th>Inscrit le</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="pros-body">
            <tr><td colspan="6"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SECTION TRAFIC WEB -->
    <div id="section-traffic" style="display:none">
      <div class="section-header">
        <div>
          <div class="section-title">Indicateurs de trafic web</div>
          <div class="traffic-note">Vues, clics et zones les plus actives sur le site public. Les zones sont calculées à partir des sections cliquées.</div>
        </div>
        <div class="traffic-toolbar">
          <select class="status-select" id="traffic-days" style="width:140px">
            <option value="7">7 jours</option>
            <option value="14">14 jours</option>
            <option value="30">30 jours</option>
            <option value="90">90 jours</option>
          </select>
          <button class="btn-sm" id="btn-traffic-refresh" type="button"><i class="fa fa-rotate"></i> Rafraîchir</button>
        </div>
      </div>

      <div class="mini-stats-grid">
        <div class="traffic-card traffic-kpi"><div class="traffic-card-body"><div class="traffic-kpi-icon"><i class="fa fa-eye"></i></div><div class="traffic-kpi-label">Pages vues</div><div class="traffic-kpi-value" id="traffic-pageviews">—</div><div class="traffic-sub" id="traffic-pageviews-sub">sur la période</div></div></div>
        <div class="traffic-card traffic-kpi"><div class="traffic-card-body"><div class="traffic-kpi-icon"><i class="fa fa-arrow-pointer"></i></div><div class="traffic-kpi-label">Clics</div><div class="traffic-kpi-value" id="traffic-clicks">—</div><div class="traffic-sub">liens et boutons</div></div></div>
        <div class="traffic-card traffic-kpi"><div class="traffic-card-body"><div class="traffic-kpi-icon"><i class="fa fa-users"></i></div><div class="traffic-kpi-label">Visiteurs estimés</div><div class="traffic-kpi-value" id="traffic-visitors">—</div><div class="traffic-sub">sessions distinctes</div></div></div>
        <div class="traffic-card traffic-kpi"><div class="traffic-card-body"><div class="traffic-kpi-icon"><i class="fa fa-layer-group"></i></div><div class="traffic-kpi-label">Zones suivies</div><div class="traffic-kpi-value" id="traffic-zones">—</div><div class="traffic-sub" id="traffic-pages-sub">pages trackées : —</div></div></div>
      </div>

      <div class="traffic-hero">
        <div class="traffic-card">
          <div class="traffic-card-body">
            <div class="traffic-card-head">
              <div>
                <div class="traffic-card-title">Carte du trafic mondial</div>
                <div class="traffic-card-caption">Lecture visuelle des zones d’origine les plus actives.</div>
              </div>
            </div>
            <div id="traffic-globe-card"><TrafficWorldMap client:only="react" /></div>
          </div>
        </div>
        <div class="traffic-stack">
          <div class="traffic-card">
            <div class="traffic-card-body">
              <div class="traffic-card-head">
                <div>
                  <div class="traffic-card-title">Tendance</div>
                  <div class="traffic-card-caption">Évolution récente des vues et de l’engagement.</div>
                </div>
              </div>
              <div id="traffic-overview-panel">
                <div class="spinner"></div>
              </div>
            </div>
          </div>
          <div class="traffic-card">
            <div class="traffic-card-body">
              <div class="traffic-card-head">
                <div>
                  <div class="traffic-card-title">Pages les plus actives</div>
                  <div class="traffic-card-caption">Pages qui concentrent le plus d’attention.</div>
                </div>
              </div>
              <div id="traffic-top-pages"><div class="spinner"></div></div>
            </div>
          </div>
        </div>
      </div>

      <div class="traffic-grid">
        <div class="traffic-card">
          <div class="traffic-card-body">
            <div class="traffic-card-head">
              <div>
                <div class="traffic-card-title">Zones les plus cliquées</div>
                <div class="traffic-card-caption">Sections qui déclenchent le plus d’actions.</div>
              </div>
            </div>
            <div id="traffic-top-zones"><div class="spinner"></div></div>
          </div>
        </div>
        <div class="traffic-card">
          <div class="traffic-card-body">
            <div class="traffic-card-head">
              <div>
                <div class="traffic-card-title">Pays les plus présents</div>
                <div class="traffic-card-caption">Origine estimée des visiteurs de la période.</div>
              </div>
            </div>
            <div id="traffic-top-countries"><div class="spinner"></div></div>
          </div>
        </div>
      </div>

      <div class="traffic-grid">
        <div class="table-wrap traffic-table">
          <table>
            <thead><tr><th>Jour</th><th>Pages vues</th><th>Clics</th></tr></thead>
            <tbody id="traffic-daily-body"><tr><td colspan="3"><div class="spinner"></div></td></tr></tbody>
          </table>
        </div>
        <div class="table-wrap traffic-table">
          <table>
            <thead><tr><th>Libellé / lien</th><th>Clics</th></tr></thead>
            <tbody id="traffic-links-body"><tr><td colspan="2"><div class="spinner"></div></td></tr></tbody>
          </table>
        </div>
      </div>

      <div class="table-wrap traffic-table">
        <table>
          <thead><tr><th>Date</th><th>Page</th><th>Zone</th><th>Élément cliqué</th></tr></thead>
          <tbody id="traffic-recent-body"><tr><td colspan="4"><div class="spinner"></div></td></tr></tbody>
        </table>
      </div>
    </div>

  </div>
</main>

<!-- Drawer overlay -->
<div class="drawer-overlay" id="drawer-overlay" data-action="closeDrawer"></div>

<!-- Drawer fiche client -->
<div class="drawer" id="client-drawer">
  <div class="drawer-head">
    <div class="drawer-client-info">
      <div class="avatar-lg" id="dr-avatar">?</div>
      <div>
        <div class="drawer-name" id="dr-name">Client</div>
        <div class="drawer-email" id="dr-email">—</div>
      </div>
    </div>
    <button class="btn-close" data-action="closeDrawer"><i class="fa fa-times"></i></button>
  </div>
  <div class="drawer-tabs">
    <div class="dtab active" data-tab="messages"> <i class="fa fa-comments"></i> Messages</div>
    <div class="dtab" data-tab="projet"><i class="fa fa-folder"></i> Projet</div>
    <div class="dtab" data-tab="profil"><i class="fa fa-user"></i> Profil</div>
    <div class="dtab" data-tab="paiements"><i class="fa fa-credit-card"></i> Paiements</div>
  </div>
  <div class="drawer-body" id="drawer-body">
    <div class="spinner"></div>
  </div>
  <div class="reply-bar" id="reply-bar">
    <textarea class="reply-input" id="reply-input" placeholder="Répondre au client..." rows="1"
      ></textarea>
    <button class="btn-ai" id="btn-ai-suggest" data-action="suggestReply" title="Suggérer une réponse avec l'IA">✨</button>
    <button class="btn-send" data-action="sendReply"><i class="fa fa-paper-plane"></i></button>
  </div>
</div>

<div id="adm-toast"></div>

<script is:inline define:vars={{ isSuperAdmin, adminId }}>
  window.__admIsSuperAdmin = !!isSuperAdmin;
  window.__admAdminId      = String(adminId || '');
</script>

<script is:inline>
  var _currentClient = null;
  var _currentTab    = 'messages';
  var _clientData    = null;
  var _page          = 1;
  var _search        = '';
  var _scope         = 'all';
  var _debounceTimer = null;
  var _isSuper       = !!(window.__admIsSuperAdmin);
  var _meId          = String(window.__admAdminId || '');
  var _prosLoaded    = false;
  var _insidePosts   = [];
  var _trafficLoaded = false;

  // ── Sections ────────────────────────────────────────────────────────────
  function showSection(name) {
    document.getElementById('section-dashboard').style.display = name === 'dashboard' ? '' : 'none';
    document.getElementById('section-inside').style.display    = name === 'inside'    ? '' : 'none';
    document.getElementById('section-clients').style.display   = name === 'clients'   ? '' : 'none';
    document.getElementById('section-pros').style.display      = name === 'pros'      ? '' : 'none';
    document.getElementById('section-traffic').style.display   = name === 'traffic'   ? '' : 'none';
    document.querySelectorAll('.nav-item').forEach(function(el){ el.classList.remove('active'); });
    document.querySelectorAll('.sidebar-nav .nav-item[data-section]').forEach(function(el) {
      if (el.getAttribute('data-section') === name) el.classList.add('active');
    });
    var titles = { dashboard: 'Tableau de bord', inside: 'Inside', clients: 'Clients', pros: 'Comptes Pro', traffic: 'Trafic web' };
    document.getElementById('page-title').textContent = titles[name] || name;
    if (name === 'clients' && !document.getElementById('clients-body').dataset.loaded) {
      loadClients();
    }
    if (name === 'pros' && !document.getElementById('pros-body').dataset.loaded) {
      loadPros();
    }
    if (name === 'inside') {
      var insideBody = document.getElementById('inside-posts-body');
      if (insideBody && !insideBody.dataset.loaded) {
        loadInsidePosts(false);
      }
    }
    if (name === 'traffic' && !_trafficLoaded) {
      loadWebTraffic(false);
    }
  }

  // ── Stats ────────────────────────────────────────────────────────────────
  async function loadStats() {
    const r = await fetch('/api/admin/stats');
    if (!r.ok) {
      try {
        const t = await r.text();
        console.warn('[Admin] stats failed', r.status, t);
        toast('Stats: erreur (' + r.status + ')', true);
      } catch {
        toast('Stats: erreur', true);
      }
      return;
    }
    const d = await r.json();
    if (d && d.error) {
      toast((d.error || 'Erreur') + (d.hint ? ' — ' + d.hint : ''), true);
      return;
    }
    document.getElementById('stat-users').textContent    = d.users;
    document.getElementById('stat-projects').textContent = d.projects;
    document.getElementById('stat-pending').textContent  = d.pending;
    document.getElementById('stat-revenue').textContent  = '$' + Number(d.revenue).toFixed(0);
    if (d.pending > 0) {
      document.getElementById('pending-badge').innerHTML = '<span class="badge-notif">' + d.pending + '</span> non-répondus';
    }
    // Derniers inscrits
    var tbody = document.getElementById('recent-users-body');
    if (!d.recentUsers || !d.recentUsers.length) {
      tbody.innerHTML = '<tr><td colspan="4" class="empty-state">Aucun client</td></tr>';
      return;
    }
    tbody.innerHTML = d.recentUsers.map(function(u) {
      var initials = (u.name || u.email).charAt(0).toUpperCase();
      var av = avatarSmHtml(u.avatar_key, u.name || u.email);
      var date = new Date(u.created_at).toLocaleDateString('fr-CA');
      return '<tr class="client-row" onclick="openClient(\''+u.id+'\')">'
        + '<td><div style="display:flex;align-items:center;gap:10px">' + av
        + '<span class="client-name">'+esc(u.name || '—')+'</span></div></td>'
        + '<td class="client-email">'+esc(u.email)+'</td>'
        + '<td style="color:var(--muted);font-size:12px">'+date+'</td>'
        + '<td><button class="btn-sm" onclick="event.stopPropagation();openClient(\''+u.id+'\')">Voir</button></td>'
        + '</tr>';
    }).join('');
  }

