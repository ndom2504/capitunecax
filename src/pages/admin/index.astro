---
// Protection front supplémentaire (le middleware couvre déjà /admin)
import { getUserFromSessionFullAny } from '../../lib/db';
import { isSuperAdminEmail } from '../../lib/admin-emails';
const db = (Astro.locals.runtime?.env as Env | undefined)?.DB ?? null;
const token = Astro.cookies.get('capitune_session')?.value ?? '';
const adminUser = await getUserFromSessionFullAny(db, token);
const adminName = adminUser?.name ?? 'Admin';
const adminId = adminUser?.id ?? '';
const isSuperAdmin = adminUser?.email ? isSuperAdminEmail(adminUser.email) : false;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — CAPITUNE</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root {
      --bg:      #0f1117;
      --surface: #1a1d27;
      --card:    #20243a;
      --border:  #2e3349;
      --text:    #e6e9f4;
      --muted:   #8891b4;
      --accent:  #ff9408;
      --green:   #2ecc71;
      --red:     #e74c3c;
      --blue:    #3498db;
      --yellow:  #f1c40f;
      --radius:  12px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; font-size: 14px; min-height: 100vh; display: flex; }

    /* ── Sidebar ─────────────────────────────── */
    .sidebar {
      width: 220px; min-height: 100vh; background: var(--surface);
      border-right: 1px solid var(--border); display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 100;
    }
    .sidebar-logo { padding: 24px 20px; border-bottom: 1px solid var(--border); }
    .sidebar-logo img { height: 36px; }
    .sidebar-logo span { font-size: 18px; font-weight: 700; color: var(--accent); letter-spacing: 1px; }
    .sidebar-nav { flex: 1; padding: 16px 0; }
    .nav-item {
      display: flex; align-items: center; gap: 12px; padding: 11px 20px;
      color: var(--muted); cursor: pointer; transition: all .18s; border-radius: 0;
      font-weight: 500; text-decoration: none;
    }
    .nav-item:hover, .nav-item.active { background: rgba(255,148,8,.1); color: var(--accent); }
    .nav-item i { width: 18px; text-align: center; font-size: 15px; }
    .sidebar-footer { padding: 16px 20px; border-top: 1px solid var(--border); color: var(--muted); font-size: 12px; }
    .sidebar-footer strong { display: block; color: var(--text); margin-bottom: 4px; font-size: 13px; }

    /* ── Main ───────────────────────────────── */
    .main { margin-left: 220px; flex: 1; min-height: 100vh; }
    .topbar {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 50;
    }
    .topbar h1 { font-size: 18px; font-weight: 600; }
    .topbar-right { display: flex; align-items: center; gap: 16px; }
    .badge-notif {
      background: var(--red); color: #fff; border-radius: 50%; width: 20px; height: 20px;
      font-size: 11px; display: flex; align-items: center; justify-content: center; font-weight: 700;
    }
    .content { padding: 28px 32px; }

    /* ── Stats cards ─────────────────────────── */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-bottom: 28px; }
    .stat-card {
      background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 20px; display: flex; align-items: center; gap: 16px;
    }
    .stat-icon {
      width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px;
    }
    .stat-icon.orange { background: rgba(255,148,8,.15); color: var(--accent); }
    .stat-icon.green  { background: rgba(46,204,113,.15); color: var(--green); }
    .stat-icon.blue   { background: rgba(52,152,219,.15); color: var(--blue); }
    .stat-icon.red    { background: rgba(231,76,60,.15);  color: var(--red); }
    .stat-label { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
    .stat-value { font-size: 26px; font-weight: 700; line-height: 1; }

    /* ── Table clients ───────────────────────── */
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title { font-size: 16px; font-weight: 600; }
    .search-box {
      background: var(--card); border: 1px solid var(--border); border-radius: 8px;
      padding: 8px 14px; color: var(--text); font-size: 13px; width: 260px; outline: none;
    }
    .search-box:focus { border-color: var(--accent); }
    .search-box::placeholder { color: var(--muted); }
    .table-wrap { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead { background: var(--surface); }
    th { padding: 12px 16px; text-align: left; font-size: 12px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
    td { padding: 13px 16px; border-top: 1px solid var(--border); vertical-align: middle; }
    tr.client-row { cursor: pointer; transition: background .15s; }
    tr.client-row:hover { background: rgba(255,255,255,.03); }
    .avatar-sm {
      width: 34px; height: 34px; border-radius: 50%; background: var(--accent);
      display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; color: #fff; flex-shrink: 0;
      overflow: hidden;
    }
    .avatar-sm img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .client-name { font-weight: 600; }
    .client-email { color: var(--muted); font-size: 12px; }
    .status-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; text-transform: uppercase;
    }
    .pill-soumis   { background: rgba(52,152,219,.15);  color: var(--blue); }
    .pill-en_cours { background: rgba(241,196,15,.15);  color: var(--yellow); }
    .pill-termine  { background: rgba(46,204,113,.15);  color: var(--green); }
    .pill-annule   { background: rgba(231,76,60,.15);   color: var(--red); }
    .pill-aucun    { background: rgba(136,145,180,.1);  color: var(--muted); }
    .msg-preview { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--muted); font-size: 12px; }
    .btn-sm {
      padding: 5px 12px; border-radius: 6px; border: none; cursor: pointer; font-size: 12px; font-weight: 600;
      background: rgba(255,148,8,.15); color: var(--accent); transition: background .15s;
    }
    .btn-sm:hover { background: var(--accent); color: #fff; }

    /* ── Scope toggle (Mes clients / Non assignés) ───────────────────── */
    .segmented {
      display: inline-flex;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .seg-btn {
      background: transparent;
      border: none;
      color: var(--muted);
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all .15s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .seg-btn:hover { color: var(--text); }
    .seg-btn.active { background: rgba(255,148,8,.12); color: var(--accent); }

    /* ── Drawer client ───────────────────────── */
    .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; opacity: 0; pointer-events: none; transition: opacity .25s; }
    .drawer-overlay.open { opacity: 1; pointer-events: auto; }
    .drawer {
      position: fixed; top: 0; right: -700px; bottom: 0; width: 680px;
      background: var(--surface); border-left: 1px solid var(--border);
      z-index: 201; transition: right .3s cubic-bezier(.4,0,.2,1); display: flex; flex-direction: column; overflow: hidden;
    }
    .drawer.open { right: 0; }
    .drawer-head {
      padding: 20px 28px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
    }
    .drawer-client-info { display: flex; align-items: center; gap: 14px; }
    .avatar-lg {
      width: 48px; height: 48px; border-radius: 50%; background: var(--accent);
      display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 18px; color: #fff; flex-shrink: 0;
      overflow: hidden;
    }
    .avatar-lg img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .drawer-name { font-size: 16px; font-weight: 700; }
    .drawer-email { color: var(--muted); font-size: 13px; }
    .btn-close { background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; padding: 4px; }
    .btn-close:hover { color: var(--text); }

    .drawer-tabs { display: flex; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .dtab {
      padding: 13px 20px; font-size: 13px; font-weight: 600; color: var(--muted);
      cursor: pointer; border-bottom: 2px solid transparent; transition: all .18s;
    }
    .dtab.active { color: var(--accent); border-bottom-color: var(--accent); }
    .dtab:hover { color: var(--text); }

    .drawer-body { flex: 1; overflow-y: auto; padding: 24px 28px; }
    .drawer-section { margin-bottom: 24px; }
    .drawer-section-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--muted); margin-bottom: 12px; }

    /* Messages inside drawer */
    .msg-list { display: flex; flex-direction: column; gap: 10px; }
    .msg-item {
      max-width: 82%; padding: 10px 14px; border-radius: 12px; font-size: 13px; line-height: 1.5;
    }
    .msg-item.user { background: var(--card); border-bottom-left-radius: 4px; align-self: flex-start; }
    .msg-item.admin { background: rgba(255,148,8,.15); border-bottom-right-radius: 4px; align-self: flex-end; color: #ffd09a; }
    .msg-item.bot  { background: rgba(52,152,219,.1); border-bottom-left-radius: 4px; align-self: flex-start; color: #a8d4f5; }
    .msg-time { font-size: 10px; color: var(--muted); margin-top: 4px; display: block; }

    /* Reply form */
    .reply-bar {
      border-top: 1px solid var(--border); padding: 16px 28px; display: flex; gap: 10px;
      flex-shrink: 0; background: var(--surface);
    }
    .reply-input {
      flex: 1; background: var(--card); border: 1px solid var(--border); border-radius: 10px;
      padding: 10px 14px; color: var(--text); font-size: 13px; resize: none; outline: none; min-height: 42px; max-height: 140px;
    }
    .reply-input:focus { border-color: var(--accent); }
    .btn-send {
      background: var(--accent); color: #fff; border: none; border-radius: 10px;
      padding: 10px 18px; font-size: 13px; font-weight: 600; cursor: pointer; flex-shrink: 0;
    }
    .btn-send:hover { background: #e08400; }
    .btn-ai {
      background: linear-gradient(135deg, #7c3aed, #a855f7); color: #fff; border: none;
      border-radius: 10px; padding: 10px 14px; font-size: 15px; cursor: pointer; flex-shrink: 0;
      transition: opacity .2s, transform .1s; title: 'Suggérer avec l\'IA';
    }
    .btn-ai:hover { opacity: .85; }
    .btn-ai:active { transform: scale(.95); }
    .btn-ai:disabled { opacity: .45; cursor: not-allowed; }
    .btn-ai .ai-spin {
      display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4);
      border-top-color: #fff; border-radius: 50%; animation: spin .6s linear infinite;
      vertical-align: middle;
    }
    .info-cell span { display: block; font-weight: 600; margin-top: 3px; }

    /* Status select */
    .status-select {
      background: var(--card); border: 1px solid var(--border); color: var(--text);
      border-radius: 8px; padding: 6px 12px; font-size: 13px; cursor: pointer; outline: none;
    }
    .status-select:focus { border-color: var(--accent); }

    /* Pagination */
    .pagination { display: flex; gap: 6px; align-items: center; margin-top: 16px; justify-content: flex-end; }
    .page-btn {
      background: var(--card); border: 1px solid var(--border); color: var(--text);
      border-radius: 6px; padding: 5px 12px; font-size: 13px; cursor: pointer;
    }
    .page-btn:hover { border-color: var(--accent); color: var(--accent); }
    .page-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* Empty */
    .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
    .empty-state i { font-size: 40px; margin-bottom: 12px; display: block; }

    /* Loading spinner */
    .spinner { width: 24px; height: 24px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin .7s linear infinite; margin: 40px auto; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Pro badges */
    .pro-badge { display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;text-transform:uppercase; }
    .badge-admin { background:rgba(231,76,60,.15);color:var(--red); }
    .badge-pro { background:rgba(52,152,219,.15);color:var(--blue); }
    .badge-client { background:rgba(136,145,180,.1);color:var(--muted); }
    .btn-promote { background:rgba(46,204,113,.12);color:var(--green);border:none;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-promote:hover { background:var(--green);color:#fff; }
    .btn-demote { background:rgba(231,76,60,.12);color:var(--red);border:none;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-demote:hover { background:var(--red);color:#fff; }

    /* Suspend / Delete buttons */
    .btn-suspend { background:rgba(241,196,15,.12);color:var(--yellow);border:none;border-radius:6px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-suspend:hover { background:var(--yellow);color:#000; }
    .btn-unsuspend { background:rgba(46,204,113,.12);color:var(--green);border:none;border-radius:6px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-unsuspend:hover { background:var(--green);color:#fff; }
    .btn-delete { background:rgba(231,76,60,.12);color:var(--red);border:none;border-radius:6px;padding:5px 10px;font-size:12px;font-weight:600;cursor:pointer;transition:background .15s; }
    .btn-delete:hover { background:var(--red);color:#fff; }
    .badge-suspended { background:rgba(241,196,15,.18);color:var(--yellow);display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:12px;font-size:10px;font-weight:700;text-transform:uppercase; }
    .actions-cell { display:flex;gap:6px;flex-wrap:wrap;align-items:center; }

    /* Toast */
    #adm-toast {
      position: fixed; bottom: 24px; right: 24px; background: var(--green);
      color: #fff; padding: 12px 20px; border-radius: 10px; font-size: 13px; font-weight: 600;
      z-index: 999; display: none; box-shadow: 0 6px 24px rgba(0,0,0,.4);
    }
  </style>
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <span>CAPITUNE</span><br>
    <small style="color:var(--muted);font-size:11px;font-weight:400;">Panneau Admin</small>
  </div>
  <nav class="sidebar-nav">
    <a class="nav-item active" href="#dashboard" data-section="dashboard">
      <i class="fa fa-chart-pie"></i> Tableau de bord
    </a>
    <a class="nav-item" href="#clients" data-section="clients">
      <i class="fa fa-users"></i> Clients
    </a>
    <a class="nav-item" href="#pros" data-section="pros">
      <i class="fa fa-user-tie"></i> Comptes Pro
    </a>
    <a class="nav-item" href="/admin/stripe-configuration">
      <i class="fa fa-credit-card"></i> Stripe
    </a>
    <a class="nav-item" href="/dashboard?pro=1">
      <i class="fa fa-rocket"></i> Espace Pro
    </a>
    <a class="nav-item" href="/api/oauth/signout" style="margin-top:auto;">
      <i class="fa fa-sign-out-alt"></i> Déconnexion
    </a>
  </nav>
  <div class="sidebar-footer">
    <strong>{adminName}</strong>
    Administrateur
  </div>
</aside>

<!-- Main -->
<main class="main">
  <div class="topbar">
    <h1 id="page-title">Tableau de bord</h1>
    <div class="topbar-right">
      <span style="color:var(--muted);font-size:12px;" id="pending-badge"></span>
      <a href="/api/oauth/signout" style="color:var(--muted);font-size:12px;text-decoration:none;">
        <i class="fa fa-sign-out-alt"></i> Déconnexion
      </a>
    </div>
  </div>

  <div class="content">

    <!-- SECTION DASHBOARD -->
    <div id="section-dashboard">
      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon orange"><i class="fa fa-users"></i></div>
          <div><div class="stat-label">Clients</div><div class="stat-value" id="stat-users">—</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue"><i class="fa fa-folder-open"></i></div>
          <div><div class="stat-label">Projets actifs</div><div class="stat-value" id="stat-projects">—</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon red"><i class="fa fa-envelope"></i></div>
          <div><div class="stat-label">Messages en attente</div><div class="stat-value" id="stat-pending">—</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green"><i class="fa fa-dollar-sign"></i></div>
          <div><div class="stat-label">Revenus (payé)</div><div class="stat-value" id="stat-revenue">—</div></div>
        </div>
      </div>

      <!-- Derniers clients -->
      <div class="section-header">
        <div class="section-title">Derniers inscrits</div>
        <button class="btn-sm" data-section="clients">Voir tous →</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Nom</th><th>Email</th><th>Inscrit le</th><th></th></tr></thead>
          <tbody id="recent-users-body">
            <tr><td colspan="4"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SECTION CLIENTS -->
    <div id="section-clients" style="display:none">
      <div class="section-header">
        <div style="display:flex;align-items:center;gap:12px">
          <div class="section-title">Clients</div>
          <div class="segmented" title="Filtrer par assignation">
            <button class="seg-btn" id="scope-me" data-scope="me"><i class="fa fa-user"></i> Mes clients</button>
            <button class="seg-btn" id="scope-unassigned" data-scope="unassigned"><i class="fa fa-inbox"></i> Non assignés</button>
            <button class="seg-btn active" id="scope-all" data-scope="all"><i class="fa fa-layer-group"></i> Tous</button>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          {isSuperAdmin && (
            <select class="status-select" id="assign-pro-select" style="display:none; width:240px" title="Assigner les non-assignés à">
              <option value={adminId}>Moi</option>
            </select>
          )}
          <input class="search-box" id="client-search" placeholder="🔍  Rechercher nom ou email..." />
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Client</th>
              <th>Projet</th>
              <th>Statut</th>
              <th>Dernier message</th>
              <th>Revenus</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="clients-body">
            <tr><td colspan="6"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>
      <div class="pagination" id="pagination"></div>
    </div>

    <!-- SECTION COMPTES PRO -->
    <div id="section-pros" style="display:none">
      <div class="section-header">
        <div style="display:flex;align-items:center;gap:12px">
          <div class="section-title">Comptes Pro / Admins</div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <span style="font-size:12px;color:var(--muted);">Comptes avec accès professionnel au dashboard</span>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Utilisateur</th>
              <th>Rôle / Type</th>
              <th>Clients assignés</th>
              <th>Revenus générés</th>
              <th>Inscrit le</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="pros-body">
            <tr><td colspan="6"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</main>

<!-- Drawer overlay -->
<div class="drawer-overlay" id="drawer-overlay" data-action="closeDrawer"></div>

<!-- Drawer fiche client -->
<div class="drawer" id="client-drawer">
  <div class="drawer-head">
    <div class="drawer-client-info">
      <div class="avatar-lg" id="dr-avatar">?</div>
      <div>
        <div class="drawer-name" id="dr-name">Client</div>
        <div class="drawer-email" id="dr-email">—</div>
      </div>
    </div>
    <button class="btn-close" data-action="closeDrawer"><i class="fa fa-times"></i></button>
  </div>
  <div class="drawer-tabs">
    <div class="dtab active" data-tab="messages"> <i class="fa fa-comments"></i> Messages</div>
    <div class="dtab" data-tab="projet"><i class="fa fa-folder"></i> Projet</div>
    <div class="dtab" data-tab="profil"><i class="fa fa-user"></i> Profil</div>
    <div class="dtab" data-tab="paiements"><i class="fa fa-credit-card"></i> Paiements</div>
  </div>
  <div class="drawer-body" id="drawer-body">
    <div class="spinner"></div>
  </div>
  <div class="reply-bar" id="reply-bar">
    <textarea class="reply-input" id="reply-input" placeholder="Répondre au client..." rows="1"
      ></textarea>
    <button class="btn-ai" id="btn-ai-suggest" data-action="suggestReply" title="Suggérer une réponse avec l'IA">✨</button>
    <button class="btn-send" data-action="sendReply"><i class="fa fa-paper-plane"></i></button>
  </div>
</div>

<div id="adm-toast"></div>

<script is:inline define:vars={{ isSuperAdmin, adminId }}>
  window.__admIsSuperAdmin = !!isSuperAdmin;
  window.__admAdminId      = String(adminId || '');
</script>

<script is:inline>
  var _currentClient = null;
  var _currentTab    = 'messages';
  var _clientData    = null;
  var _page          = 1;
  var _search        = '';
  var _scope         = 'all';
  var _debounceTimer = null;
  var _isSuper       = !!(window.__admIsSuperAdmin);
  var _meId          = String(window.__admAdminId || '');
  var _prosLoaded    = false;

  // ── Sections ────────────────────────────────────────────────────────────
  function showSection(name) {
    document.getElementById('section-dashboard').style.display = name === 'dashboard' ? '' : 'none';
    document.getElementById('section-clients').style.display   = name === 'clients'   ? '' : 'none';
    document.getElementById('section-pros').style.display      = name === 'pros'      ? '' : 'none';
    document.querySelectorAll('.nav-item').forEach(function(el){ el.classList.remove('active'); });
    document.querySelectorAll('.sidebar-nav .nav-item[data-section]').forEach(function(el) {
      if (el.getAttribute('data-section') === name) el.classList.add('active');
    });
    var titles = { dashboard: 'Tableau de bord', clients: 'Clients', pros: 'Comptes Pro' };
    document.getElementById('page-title').textContent = titles[name] || name;
    if (name === 'clients' && !document.getElementById('clients-body').dataset.loaded) {
      loadClients();
    }
    if (name === 'pros' && !document.getElementById('pros-body').dataset.loaded) {
      loadPros();
    }
  }

  // ── Stats ────────────────────────────────────────────────────────────────
  async function loadStats() {
    const r = await fetch('/api/admin/stats');
    if (!r.ok) {
      try {
        const t = await r.text();
        console.warn('[Admin] stats failed', r.status, t);
        toast('Stats: erreur (' + r.status + ')', true);
      } catch {
        toast('Stats: erreur', true);
      }
      return;
    }
    const d = await r.json();
    if (d && d.error) {
      toast((d.error || 'Erreur') + (d.hint ? ' — ' + d.hint : ''), true);
      return;
    }
    document.getElementById('stat-users').textContent    = d.users;
    document.getElementById('stat-projects').textContent = d.projects;
    document.getElementById('stat-pending').textContent  = d.pending;
    document.getElementById('stat-revenue').textContent  = '$' + Number(d.revenue).toFixed(0);
    if (d.pending > 0) {
      document.getElementById('pending-badge').innerHTML = '<span class="badge-notif">' + d.pending + '</span> non-répondus';
    }
    // Derniers inscrits
    var tbody = document.getElementById('recent-users-body');
    if (!d.recentUsers || !d.recentUsers.length) {
      tbody.innerHTML = '<tr><td colspan="4" class="empty-state">Aucun client</td></tr>';
      return;
    }
    tbody.innerHTML = d.recentUsers.map(function(u) {
      var initials = (u.name || u.email).charAt(0).toUpperCase();
      var av = avatarSmHtml(u.avatar_key, u.name || u.email);
      var date = new Date(u.created_at).toLocaleDateString('fr-CA');
      return '<tr class="client-row" onclick="openClient(\''+u.id+'\')">'
        + '<td><div style="display:flex;align-items:center;gap:10px">' + av
        + '<span class="client-name">'+esc(u.name || '—')+'</span></div></td>'
        + '<td class="client-email">'+esc(u.email)+'</td>'
        + '<td style="color:var(--muted);font-size:12px">'+date+'</td>'
        + '<td><button class="btn-sm" onclick="event.stopPropagation();openClient(\''+u.id+'\')">Voir</button></td>'
        + '</tr>';
    }).join('');
  }

  function setScope(scope) {
    _scope = (scope === 'unassigned' || scope === 'all') ? scope : 'me';
    document.getElementById('scope-me').classList.toggle('active', _scope === 'me');
    document.getElementById('scope-unassigned').classList.toggle('active', _scope === 'unassigned');
    var allBtn = document.getElementById('scope-all');
    if (allBtn) allBtn.classList.toggle('active', _scope === 'all');
    syncAssignProVisibility();
    _page = 1;
    loadClients();
  }

  async function ensureProsLoaded() {
    if (!_isSuper || _prosLoaded) return;
    const sel = document.getElementById('assign-pro-select');
    if (!sel) return;
    try {
      const r = await fetch('/api/admin/pros');
      if (!r.ok) return;
      const d = await r.json();
      if (!d || !Array.isArray(d.pros)) return;

      // Conserver l'option "Moi" si elle est déjà là
      sel.innerHTML = '';
      sel.appendChild(new Option('Moi', _meId));
      d.pros.forEach(function(p) {
        if (!p || !p.id) return;
        if (String(p.id) === String(_meId)) return;
        var roleLabel = p.role === 'admin' ? 'Admin' : (p.account_type === 'pro' ? 'Pro' : 'Compte');
        var label = (p.name ? String(p.name) : 'Pro')
          + (p.email ? ' — ' + String(p.email) : '')
          + ' (' + roleLabel + ')';
        sel.appendChild(new Option(label, String(p.id)));
      });
      sel.value = _meId;
      _prosLoaded = true;
    } catch (e) {
      console.warn('[Admin] pros load failed', e);
    }
  }

  function syncAssignProVisibility() {
    if (!_isSuper) return;
    var sel = document.getElementById('assign-pro-select');
    if (!sel) return;
    sel.style.display = (_scope === 'unassigned') ? '' : 'none';
    if (_scope === 'unassigned') ensureProsLoaded();
  }

  // ── Clients list ─────────────────────────────────────────────────────────
  async function loadClients() {
    var tbody = document.getElementById('clients-body');
    tbody.innerHTML = '<tr><td colspan="6"><div class="spinner"></div></td></tr>';
    var url = '/api/admin/clients?page=' + _page + '&scope=' + encodeURIComponent(_scope) + (_search ? '&q=' + encodeURIComponent(_search) : '');
    const r = await fetch(url);
    if (!r.ok) {
      let details = '';
      try { details = await r.text(); } catch {}
      console.warn('[Admin] clients failed', r.status, details);
      tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">Erreur de chargement (' + r.status + ')</td></tr>';
      return;
    }
    const d = await r.json();
    if (d && d.error) {
      toast((d.error || 'Erreur') + (d.hint ? ' — ' + d.hint : ''), true);
      tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">' + esc(d.error) + (d.hint ? '<br><span style="color:var(--muted)">' + esc(d.hint) + '</span>' : '') + '</td></tr>';
      return;
    }
    tbody.dataset.loaded = '1';
    if (!d.clients.length) {
      var emptyMsg = _scope === 'unassigned' ? 'Aucune demande non assignée' : (_scope === 'all' ? 'Aucun client' : 'Aucun client assigné');
      tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><i class="fa fa-users"></i>' + emptyMsg + '</div></td></tr>';
      return;
    }
    tbody.innerHTML = d.clients.map(function(c) {
      var initials = (c.name || c.email).charAt(0).toUpperCase();
      var av = avatarSmHtml(c.avatar_key, c.name || c.email);
      var type = c.project_type ? c.project_type.replace(/_/g,' ') : '—';
      var status = c.project_status || 'aucun';
      var pillClass = 'pill-' + status;
      var pillLabel = { soumis:'Soumis', en_cours:'En cours', termine:'Terminé', annule:'Annulé', aucun:'Aucun' }[status] || status;
      var lastMsg = c.last_msg ? esc(String(c.last_msg).slice(0, 60)) + (String(c.last_msg).length > 60 ? '…' : '') : '<em>—</em>';
      var paid = c.total_paid ? '$' + Number(c.total_paid).toFixed(0) : '—';
      if (_scope === 'unassigned') {
        var assignLabel = _isSuper ? 'Assigner' : "M'assigner";
        return '<tr>'
          + '<td><div style="display:flex;align-items:center;gap:10px">'
          + av
          + '<div><div class="client-name">'+esc(c.name||'—')+'</div><div class="client-email">'+esc(c.email)+'</div></div></div></td>'
          + '<td style="font-size:12px">'+esc(type)+'</td>'
          + '<td><span class="status-pill '+pillClass+'">'+pillLabel+'</span></td>'
          + '<td class="msg-preview">'+lastMsg+'</td>'
          + '<td style="color:var(--muted);font-weight:600">—</td>'
          + '<td><button class="btn-sm" onclick="assignClient(\''+c.id+'\')"><i class="fa fa-hand-pointer"></i> '+assignLabel+'</button></td>'
          + '</tr>';
      }

      var isSusp = c.suspended == 1 || c.suspended === true;
      var suspBtn = isSusp
        ? '<button class="btn-unsuspend" onclick="event.stopPropagation();suspendUser(\''+c.id+'\',false)"><i class="fa fa-play"></i> Réactiver</button>'
        : '<button class="btn-suspend" onclick="event.stopPropagation();suspendUser(\''+c.id+'\',true)"><i class="fa fa-ban"></i> Suspendre</button>';
      var delBtn = '<button class="btn-delete" onclick="event.stopPropagation();deleteUser(\''+c.id+'\', \''+esc(c.name||c.email)+'\')"><i class="fa fa-trash"></i></button>';
      return '<tr class="client-row" onclick="openClient(\''+c.id+'\')">'  
        + '<td><div style="display:flex;align-items:center;gap:10px">'
        + av
        + '<div><div class="client-name">'+esc(c.name||'—')+'</div><div class="client-email">'+esc(c.email)+'</div></div></div></td>'
        + '<td style="font-size:12px">'+esc(type)+'</td>'
        + '<td><span class="status-pill '+pillClass+'">'+pillLabel+'</span></td>'
        + '<td class="msg-preview">'+lastMsg+'</td>'
        + '<td style="color:var(--green);font-weight:600">'+paid+'</td>'
        + '<td><div class="actions-cell"><button class="btn-sm" onclick="event.stopPropagation();openClient(\''+c.id+'\')" style="margin:0"><i class="fa fa-eye"></i> Voir</button>' + suspBtn + delBtn + '</div></td>'
        + '</tr>';
    }).join('');
    // Pagination
    renderPagination(d.page, d.pages);
  }

  function renderPagination(page, pages) {
    var el = document.getElementById('pagination');
    if (pages <= 1) { el.innerHTML = ''; return; }
    var html = '';
    if (page > 1) html += '<button class="page-btn" onclick="goPage(' + (page-1) + ')">‹ Préc</button>';
    for (var i = Math.max(1, page-2); i <= Math.min(pages, page+2); i++) {
      html += '<button class="page-btn' + (i===page?' active':'') + '" onclick="goPage(' + i + ')">' + i + '</button>';
    }
    if (page < pages) html += '<button class="page-btn" onclick="goPage(' + (page+1) + ')">Suiv ›</button>';
    el.innerHTML = html;
  }

  function goPage(p) { _page = p; loadClients(); }

  // ── Comptes Pro ──────────────────────────────────────────────────────────
  async function loadPros() {
    var tbody = document.getElementById('pros-body');
    if (!tbody) return;
    tbody.innerHTML = '<tr><td colspan="6"><div class="spinner"></div></td></tr>';
    try {
      const r = await fetch('/api/admin/pros-list');
      if (!r.ok) {
        tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">Erreur ' + r.status + '</td></tr>';
        return;
      }
      const d = await r.json();
      if (!d.pros || !d.pros.length) {
        tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><i class="fa fa-user-tie"></i>Aucun compte pro / admin</div></td></tr>';
        tbody.dataset.loaded = '1';
        return;
      }
      tbody.innerHTML = d.pros.map(function(p) {
        var initials = (p.name || p.email || '?').charAt(0).toUpperCase();
        var av = avatarSmHtml(p.avatar_key, p.name || p.email || '?');
        var roleBadge = p.role === 'admin'
          ? '<span class="pro-badge badge-admin"><i class="fa fa-shield-alt"></i> Admin</span>'
          : '';
        var typeBadge = p.account_type === 'pro'
          ? '<span class="pro-badge badge-pro"><i class="fa fa-briefcase"></i> Pro</span>'
          : '<span class="pro-badge badge-client">Client</span>';
        var clients = Number(p.clients_count || 0);
        var revenue = Number(p.total_revenue || 0);
        var date = p.created_at ? new Date(p.created_at).toLocaleDateString('fr-CA') : '—';
        var isSelf = String(p.id) === String(_meId);
        var isSuspPro = p.suspended == 1 || p.suspended === true;
        var actionBtn = '';
        if (!isSelf) {
          var promoPart = '';
          if (p.account_type === 'pro') {
            promoPart = '<button class="btn-demote" onclick="changePro(\'' + p.id + '\', \'demote\')"><i class="fa fa-user-minus"></i> Rétrograder</button>';
          } else if (p.role !== 'admin') {
            promoPart = '<button class="btn-promote" onclick="changePro(\'' + p.id + '\', \'promote\')"><i class="fa fa-user-plus"></i> Promouvoir Pro</button>';
          }
          var suspPartPro = isSuspPro
            ? '<button class="btn-unsuspend" onclick="suspendUser(\'' + p.id + '\',false)"><i class="fa fa-play"></i> Réactiver</button>'
            : '<button class="btn-suspend" onclick="suspendUser(\'' + p.id + '\',true)"><i class="fa fa-ban"></i> Suspendre</button>';
          var delPartPro = '<button class="btn-delete" onclick="deleteUser(\'' + p.id + '\', \'' + esc(p.name||p.email) + '\')" title="Supprimer le compte"><i class="fa fa-trash"></i></button>';
          actionBtn = '<div class="actions-cell">' + promoPart + suspPartPro + delPartPro + '</div>';
        }
        var suspBadgePro = isSuspPro ? ' <span class="badge-suspended"><i class="fa fa-ban"></i> Suspendu</span>' : '';
        return '<tr>'
          + '<td><div style="display:flex;align-items:center;gap:10px">'
          + av
          + '<div><div class="client-name">' + esc(p.name || '—') + suspBadgePro + '</div><div class="client-email">' + esc(p.email) + '</div></div>'
          + '</div></td>'
          + '<td><div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">' + roleBadge + ' ' + typeBadge + '</div></td>'
          + '<td style="font-weight:600">' + clients + '</td>'
          + '<td style="color:var(--green);font-weight:600">' + (revenue > 0 ? '$' + revenue.toFixed(0) : '—') + '</td>'
          + '<td style="color:var(--muted);font-size:12px">' + date + '</td>'
          + '<td>' + (actionBtn || (isSelf ? '<span style="color:var(--muted);font-size:12px">Vous</span>' : '—')) + '</td>'
          + '</tr>';
      }).join('');
      tbody.dataset.loaded = '1';
    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="6" style="color:var(--red);padding:20px">Erreur de connexion</td></tr>';
    }
  }

  async function changePro(userId, action) {
    var label = action === 'promote' ? 'Promouvoir en Pro' : 'Rétrograder en Client';
    if (!confirm(label + ' ?')) return;
    try {
      const r = await fetch('/api/admin/pros-list', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: userId, action }),
      });
      const d = await r.json();
      if (r.ok && d.ok) {
        toast(label + ' effectué ✓');
        // Recharger la liste
        document.getElementById('pros-body').dataset.loaded = '';
        loadPros();
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch {
      toast('Erreur de connexion', true);
    }
  }

  function debounceSearch() {
    clearTimeout(_debounceTimer);
    _debounceTimer = setTimeout(function() {
      _search = document.getElementById('client-search').value;
      _page = 1;
      loadClients();
    }, 350);
  }

  // ── Drawer ────────────────────────────────────────────────────────────────
  async function openClient(id) {
    _currentClient = id;
    _currentTab = 'messages';
    document.getElementById('drawer-overlay').classList.add('open');
    document.getElementById('client-drawer').classList.add('open');
    document.getElementById('drawer-body').innerHTML = '<div class="spinner"></div>';
    document.getElementById('dr-name').textContent  = 'Chargement…';
    document.getElementById('dr-email').textContent = '';

    const r = await fetch('/api/admin/client/' + id);
    if (!r.ok) {
      let msg = 'Erreur';
      try {
        const j = await r.json();
        msg = j && j.error ? j.error : msg;
      } catch {}
      document.getElementById('drawer-body').innerHTML = '<p style="color:var(--red);padding:20px">' + esc(msg) + '</p>';
      toast(msg, true);
      return;
    }
    _clientData = await r.json();

    var u = _clientData.user;
    document.getElementById('dr-name').textContent  = u.name || '—';
    document.getElementById('dr-email').textContent = u.email;
    setAvatarEl(document.getElementById('dr-avatar'), u.avatar_key, (u.name || u.email));

    renderDrawerTab('messages');
    // Activer le 1er onglet
    document.querySelectorAll('.dtab').forEach(function(el, i){ el.classList.toggle('active', i===0); });
  }

  function closeDrawer() {
    document.getElementById('drawer-overlay').classList.remove('open');
    document.getElementById('client-drawer').classList.remove('open');
    _currentClient = null;
    _clientData = null;
  }

  function switchDTab(tab) {
    _currentTab = tab;
    document.querySelectorAll('.dtab').forEach(function(el){
      el.classList.toggle('active', el.textContent.trim().toLowerCase().includes(tab.slice(0,5)));
    });
    var replyBar = document.getElementById('reply-bar');
    replyBar.style.display = tab === 'messages' ? '' : 'none';
    renderDrawerTab(tab);
  }

  function renderDrawerTab(tab) {
    var body = document.getElementById('drawer-body');
    if (!_clientData) return;
    if (tab === 'messages')  body.innerHTML = renderMessages();
    if (tab === 'projet')    body.innerHTML = renderProjet();
    if (tab === 'profil')    body.innerHTML = renderProfil();
    if (tab === 'paiements') body.innerHTML = renderPaiements();
    // Scroll messages vers le bas
    if (tab === 'messages') body.scrollTop = body.scrollHeight;
  }

  function renderMessages() {
    var msgs = _clientData.messages || [];
    if (!msgs.length) return '<div class="empty-state"><i class="fa fa-comment-slash"></i>Aucun message</div>';
    return '<div class="msg-list">' + msgs.map(function(m) {
      var cls = m.sender === 'user' ? 'user' : m.sender === 'admin' ? 'admin' : 'bot';
      var label = m.sender === 'user' ? '' : m.sender === 'admin' ? '<small>Admin</small> ' : '<small>Bot</small> ';
      var time = new Date(m.created_at).toLocaleString('fr-CA', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
      return '<div class="msg-item ' + cls + '">' + label + esc(m.content) + '<span class="msg-time">' + time + '</span></div>';
    }).join('') + '</div>';
  }

  function renderProjet() {
    var projs = _clientData.projects || [];
    if (!projs.length) return '<div class="empty-state"><i class="fa fa-folder-open"></i>Aucun projet</div>';
    return projs.map(function(p) {
      var status = p.status || 'en_cours';
      var pillClass = 'pill-' + status;
      var statusLabels = { soumis:'Soumis', en_cours:'En cours', termine:'Terminé', annule:'Annulé' };
      return '<div class="drawer-section">'
        + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">'
        + '<span class="drawer-section-title">Projet</span>'
        + '<div style="display:flex;align-items:center;gap:10px">'
        + '<span class="status-pill '+pillClass+'">'+esc(statusLabels[status]||status)+'</span>'
        + '<select class="status-select" onchange="updateStatus(\''+p.id+'\', this.value)">'
        + ['en_cours','soumis','termine','annule'].map(function(s) {
            return '<option value="'+s+'"'+(s===status?' selected':'')+'>'+statusLabels[s]+'</option>';
          }).join('')
        + '</select></div></div>'
        + '<div class="info-grid">'
        + infoCell('Type', p.type) + infoCell('Province', p.province) + infoCell('Pays cible', p.pays)
        + infoCell('Diplôme', p.diplome) + infoCell('Délai', p.delai) + infoCell('Personnes', p.nbpersonnes)
        + (p.pack_id ? infoCell('Pack', p.pack_id + ' — $' + p.pack_price) : '')
        + '</div>'
        + (p.notes ? '<div style="margin-top:12px;background:var(--card);border-radius:8px;padding:14px;font-size:13px;color:var(--muted)"><strong style="color:var(--text)">Notes :</strong> ' + esc(p.notes) + '</div>' : '')
        + '</div>';
    }).join('');
  }

  function renderProfil() {
    var u = _clientData.user;
    return '<div class="drawer-section"><div class="drawer-section-title">Informations</div>'
      + '<div class="info-grid">'
      + infoCell('Nom', u.name) + infoCell('Email', u.email)
      + infoCell('Téléphone', u.phone || '—') + infoCell('Ville / Pays', u.location || '—')
      + infoCell('Rôle', u.role) + infoCell('Inscrit le', new Date(u.created_at).toLocaleDateString('fr-CA'))
      + '</div>'
      + '<div class="drawer-section" style="margin-top:18px">'
      +   '<div class="drawer-section-title">Accès</div>'
      +   '<div style="display:flex;align-items:center;justify-content:space-between;gap:12px;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:12px 14px">'
      +     '<div style="min-width:0">'
      +       '<div style="font-weight:700">Autonomie (étapes)</div>'
      +       '<div style="color:var(--muted);font-size:12px;margin-top:2px">'
      +         (u.autonomie_unlocked ? 'Débloqué' : 'Bloqué (paiement requis)')
      +       '</div>'
      +     '</div>'
      +     '<button class="btn-sm" onclick="toggleAutonomieUnlock()">'
      +       (u.autonomie_unlocked ? 'Rebloquer' : 'Débloquer')
      +     '</button>'
      +   '</div>'
      + '</div>'
      + (u.bio ? '<div style="margin-top:12px;background:var(--card);border-radius:8px;padding:14px;font-size:13px;color:var(--muted)"><strong style="color:var(--text)">Bio :</strong> ' + esc(u.bio) + '</div>' : '')
      + '</div>';
  }

  async function toggleAutonomieUnlock() {
    if (!_clientData || !_currentClient) return;
    var u = _clientData.user || {};
    var next = !u.autonomie_unlocked;
    var label = next ? 'Débloquer Autonomie (voir les étapes)' : 'Rebloquer Autonomie (paiement requis)';
    if (!confirm(label + ' ?')) return;

    try {
      const r = await fetch('/api/admin/autonomie-unlock', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: _currentClient, unlocked: next }),
      });
      const d = await r.json().catch(() => ({}));
      if (r.ok && d.ok) {
        _clientData.user.autonomie_unlocked = !!d.unlocked;
        toast('Accès Autonomie mis à jour ✓');
        renderDrawerTab('profil');
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch {
      toast('Erreur de connexion', true);
    }
  }

  function renderPaiements() {
    var pays = _clientData.payments || [];
    if (!pays.length) return '<div class="empty-state"><i class="fa fa-receipt"></i>Aucun paiement</div>';
    return '<div class="drawer-section"><div class="drawer-section-title">Paiements</div>'
      + pays.map(function(p) {
          var stPill = p.status === 'paid' ? 'pill-termine' : p.status === 'failed' ? 'pill-annule' : 'pill-en_cours';
          var stLabel = { paid:'Payé', failed:'Échoué', pending:'En attente', refunded:'Remboursé' }[p.status] || p.status;
          return '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:var(--card);border-radius:8px;margin-bottom:8px">'
            + '<div><div style="font-weight:600">' + esc(p.method) + '</div><div style="color:var(--muted);font-size:11px">' + new Date(p.created_at).toLocaleDateString('fr-CA') + '</div></div>'
            + '<div style="display:flex;align-items:center;gap:12px">'
            + '<span style="font-weight:700;color:var(--green)">$' + Number(p.amount).toFixed(2) + ' ' + esc(p.currency) + '</span>'
            + '<span class="status-pill '+stPill+'">'+stLabel+'</span>'
            + '</div></div>';
        }).join('')
      + '</div>';
  }

  function infoCell(label, value) {
    return '<div class="info-cell"><label>' + label + '</label><span>' + esc(String(value || '—')) + '</span></div>';
  }

  // ── Actions ───────────────────────────────────────────────────────────────
  async function sendReply() {
    var input = document.getElementById('reply-input');
    var content = input.value.trim();
    if (!content || !_currentClient) return;
    input.value = '';
    const r = await fetch('/api/admin/reply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: _currentClient, content }),
    });
    if (r.ok) {
      // Ajouter le message localement sans recharger
      if (!_clientData.messages) _clientData.messages = [];
      _clientData.messages.push({ sender: 'admin', content, created_at: new Date().toISOString() });
      renderDrawerTab('messages');
      toast('Message envoyé ✓');
    } else {
      let msg = 'Erreur envoi';
      try {
        const j = await r.json();
        msg = j && j.error ? j.error : msg;
      } catch {}
      toast(msg, true);
    }
  }

  async function suggestReply() {
    if (!_clientData || !_currentClient) return;
    var btn = document.getElementById('btn-ai-suggest');
    var input = document.getElementById('reply-input');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="ai-spin"></span>'; }

    // Récupérer les messages + les infos projet
    var messages = (_clientData.messages || []).map(function(m) {
      return { sender: m.sender, content: m.content };
    });
    var project = {};
    var projs = _clientData.projects || [];
    if (projs.length) {
      var p = projs[0];
      if (p.type)      project.type     = p.type;
      if (p.province)  project.province = p.province;
      if (p.pays)      project.pays     = p.pays;
      if (p.pack_id)   project.pack_id  = p.pack_id;
      if (p.status)    project.status   = p.status;
    }

    try {
      const r = await fetch('/api/ai-suggest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages, project }),
      });
      const data = await r.json();
      if (r.ok && data.suggestion) {
        input.value = data.suggestion;
        input.focus();
        // Ajuster la hauteur du textarea
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 140) + 'px';
        toast('Suggestion IA prête ✓');
      } else {
        toast(data.error || 'Erreur IA', true);
      }
    } catch (err) {
      toast('Erreur de connexion IA', true);
    }
    if (btn) { btn.disabled = false; btn.innerHTML = '✨'; }
  }

  async function assignClient(clientId) {
    var payload = { client_id: clientId };
    var sel = document.getElementById('assign-pro-select');
    var selectedProId = (_isSuper && _scope === 'unassigned' && sel) ? String(sel.value || '') : '';
    if (_isSuper && selectedProId && selectedProId !== _meId) {
      payload.pro_id = selectedProId;
    }
    const r = await fetch('/api/admin/assign', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      if (_isSuper && selectedProId && selectedProId !== _meId) {
        toast('Client assigné à un pro ✓');
        if (document.getElementById('scope-all')) setScope('all'); else setScope('me');
        openClient(clientId);
        return;
      }
      toast('Client assigné ✓');
      setScope('me');
      openClient(clientId);
      return;
    }
    let msg = 'Impossible d\'assigner';
    try {
      const j = await r.json();
      msg = j && j.error ? j.error : msg;
    } catch {}
    toast(msg, true);
  }

  async function updateStatus(projectId, status) {
    const r = await fetch('/api/admin/project/' + projectId + '/status', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    if (r.ok) {
      toast('Statut mis à jour ✓');
      // Mettre à jour localement
      var proj = _clientData.projects.find(function(p){ return p.id === projectId; });
      if (proj) proj.status = status;
    } else {
      toast('Erreur mise à jour', true);
    }
  }

  // ── Utils ─────────────────────────────────────────────────────────────────
  async function suspendUser(userId, doSuspend) {
    var label = doSuspend ? 'Suspendre' : 'Réactiver';
    var warning = doSuspend ? 'L\'utilisateur ne pourra plus se connecter.' : 'L\'utilisateur pourra se reconnecter.';
    if (!confirm(label + ' ce compte ?\n' + warning)) return;
    try {
      const r = await fetch('/api/admin/user/' + userId + '/suspend', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ suspend: !!doSuspend }),
      });
      const d = await r.json();
      if (r.ok && d.ok) {
        toast(label + ' effectué ✓');
        // Recharger la liste active
        var prosBody = document.getElementById('pros-body');
        if (prosBody && prosBody.dataset.loaded) { prosBody.dataset.loaded = ''; loadPros(); }
        var clientsBody = document.getElementById('clients-body');
        if (clientsBody && clientsBody.dataset.loaded) { loadClients(); }
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch { toast('Erreur de connexion', true); }
  }

  async function deleteUser(userId, userName) {
    var msg = 'Supprimer définitivement le compte de « ' + userName + ' » ?\n\nCette action est IRRÉVERSIBLE. Tous ses projets, messages et paiements seront supprimés.';
    if (!confirm(msg)) return;
    // Double confirmation
    var confirm2 = prompt('Tapez SUPPRIMER pour confirmer :');
    if ((confirm2 || '').trim().toUpperCase() !== 'SUPPRIMER') { toast('Annulé', false); return; }
    try {
      const r = await fetch('/api/admin/user/' + userId + '/suspend', {
        method: 'DELETE',
      });
      const d = await r.json();
      if (r.ok && d.ok) {
        toast('Compte supprimé ✓');
        // Fermer le drawer si c'est ce client
        if (_currentClient === userId) closeDrawer();
        // Recharger
        var prosBody = document.getElementById('pros-body');
        if (prosBody && prosBody.dataset.loaded) { prosBody.dataset.loaded = ''; loadPros(); }
        var clientsBody = document.getElementById('clients-body');
        if (clientsBody && clientsBody.dataset.loaded) { loadClients(); }
        // Dashboard stats
        loadStats();
      } else {
        toast(d.error || 'Erreur', true);
      }
    } catch { toast('Erreur de connexion', true); }
  }

  function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function isValidAvatarKey(v) {
    if (!v) return false;
    var s = String(v).trim();
    return /^https?:\/\//i.test(s) || /^data:image\//i.test(s);
  }

  function avatarSmHtml(avatarKey, fallbackText) {
    var fb = (fallbackText || '?').charAt(0).toUpperCase();
    if (isValidAvatarKey(avatarKey)) {
      return '<div class="avatar-sm"><img src="' + esc(avatarKey) + '" alt="Avatar" /></div>';
    }
    return '<div class="avatar-sm">' + esc(fb) + '</div>';
  }

  function setAvatarEl(el, avatarKey, fallbackText) {
    if (!el) return;
    var fb = (fallbackText || '?').charAt(0).toUpperCase();
    if (!isValidAvatarKey(avatarKey)) {
      el.textContent = fb;
      return;
    }
    try {
      el.innerHTML = '';
      var img = document.createElement('img');
      img.alt = 'Avatar';
      img.src = String(avatarKey);
      img.onerror = function() {
        el.textContent = fb;
      };
      el.appendChild(img);
    } catch (e) {
      el.textContent = fb;
    }
  }

  function toast(msg, error) {
    var t = document.getElementById('adm-toast');
    t.textContent = msg;
    t.style.background = error ? '#e74c3c' : '#2ecc71';
    t.style.display = 'block';
    clearTimeout(t._timer);
    t._timer = setTimeout(function(){ t.style.display = 'none'; }, 3000);
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  loadStats();

  // ── Event delegation (remplace tous les onclick= statiques du HTML) ────────
  document.addEventListener('click', function(e) {
    var el = e.target;

    // Remonte jusqu'à 4 niveaux pour trouver l'élément portant le data-*
    for (var i = 0; i < 4; i++) {
      if (!el || el === document) break;

      // Navigation sidebar : data-section
      if (el.hasAttribute && el.hasAttribute('data-section')) {
        e.preventDefault();
        showSection(el.getAttribute('data-section'));
        return;
      }
      // Scope clients : data-scope
      if (el.hasAttribute && el.hasAttribute('data-scope')) {
        setScope(el.getAttribute('data-scope'));
        return;
      }
      // Actions génériques : data-action
      if (el.hasAttribute && el.hasAttribute('data-action')) {
        var action = el.getAttribute('data-action');
        if (action === 'closeDrawer')  { closeDrawer();  return; }
        if (action === 'sendReply')    { sendReply();    return; }
        if (action === 'suggestReply') { suggestReply(); return; }
        return;
      }
      // Onglets drawer : data-tab
      if (el.hasAttribute && el.hasAttribute('data-tab')) {
        var tab = el.getAttribute('data-tab');
        switchDTab(tab);
        document.getElementById('reply-bar').style.display = tab === 'messages' ? '' : 'none';
        return;
      }

      el = el.parentElement;
    }
  });

  // Recherche client (input)
  var searchEl = document.getElementById('client-search');
  if (searchEl) searchEl.addEventListener('input', function() { debounceSearch(); });

  // Textarea reply : Enter pour envoyer
  var replyInput = document.getElementById('reply-input');
  if (replyInput) replyInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendReply(); }
  });
</script>
</body>
</html>
