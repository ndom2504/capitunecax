  function renderTrafficOverview(daily, totals, days) {
    var host = document.getElementById('traffic-overview-panel');
    if (!host) return;

    var rows = Array.isArray(daily) ? daily : [];
    var values = rows.map(function(item){ return Number(item.pageviews || 0); });
    var max = Math.max.apply(null, values.concat([1]));
    var min = Math.min.apply(null, values.concat([0]));
    var points = values.length
      ? values.map(function(v, i) {
          var x = values.length === 1 ? 24 : 24 + (i * (312 / (values.length - 1)));
          var y = 118 - ((Number(v || 0) - min) / Math.max(1, max - min)) * 84;
          return x.toFixed(1) + ',' + y.toFixed(1);
        }).join(' ')
      : '24,118 336,118';

    var last = rows.length ? rows[rows.length - 1] : null;
    var peak = null;
    for (var i = 0; i < rows.length; i++) {
      if (!peak || Number(rows[i].pageviews || 0) > Number(peak.pageviews || 0)) peak = rows[i];
    }

    host.innerHTML = ''
      + '<div class="traffic-overview-grid">'
      +   '<div class="traffic-overview-top">'
      +     '<div class="traffic-mini-stat"><label>CTR global</label><strong>' + ((Number((totals||{}).pageviews || 0) > 0) ? ((Number((totals||{}).clicks || 0) / Number((totals||{}).pageviews || 1)) * 100).toFixed(1) : '0.0') + '%</strong></div>'
      +     '<div class="traffic-mini-stat"><label>Pic journalier</label><strong>' + Number((peak||{}).pageviews || 0).toLocaleString('fr-CA') + '</strong></div>'
      +     '<div class="traffic-mini-stat"><label>Dernier jour</label><strong>' + Number((last||{}).pageviews || 0).toLocaleString('fr-CA') + '</strong></div>'
      +   '</div>'
      +   '<div class="traffic-trend-chart">'
      +     '<div class="traffic-trend-head"><div><div class="traffic-trend-title">Activité sur ' + Number(days || 7) + ' jours</div><div class="traffic-trend-sub">Pages vues quotidiennes</div></div></div>'
      +     '<svg class="sparkline-svg" viewBox="0 0 360 150" preserveAspectRatio="none" aria-label="Tendance des pages vues">'
      +       '<defs>'
      +         '<linearGradient id="trafficSparkLine" x1="0" x2="1" y1="0" y2="0"><stop offset="0%" stop-color="#5b8cff"></stop><stop offset="100%" stop-color="#ff9408"></stop></linearGradient>'
      +         '<linearGradient id="trafficSparkFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="rgba(91,140,255,.34)"></stop><stop offset="100%" stop-color="rgba(91,140,255,0)"></stop></linearGradient>'
      +       '</defs>'
      +       '<path d="M24 118 L336 118" stroke="rgba(255,255,255,.07)" stroke-width="1"></path>'
      +       '<polyline fill="none" stroke="url(#trafficSparkLine)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" points="' + points + '"></polyline>'
      +       '<polygon fill="url(#trafficSparkFill)" points="' + points + ' 336,118 24,118"></polygon>'
      +     '</svg>'
      +     '<div class="sparkline-meta">'
      +       '<span class="sparkline-pill"><strong>' + Number((totals||{}).pageviews || 0).toLocaleString('fr-CA') + '</strong> pages vues</span>'
      +       '<span class="sparkline-pill"><strong>' + Number((totals||{}).clicks || 0).toLocaleString('fr-CA') + '</strong> clics</span>'
      +       '<span class="sparkline-pill"><strong>' + esc(String((peak||{}).day || '—')) + '</strong> meilleur jour</span>'
      +     '</div>'
      +   '</div>'
      + '</div>';
  }

  function renderTopPages(pages) {
    var host = document.getElementById('traffic-top-pages');
    if (!host) return;
    host.innerHTML = trafficRankListHtml((pages || []).slice(0, 6), function(item, index) {
      var clicks = Number(item.clicks || 0);
      var pageviews = Number(item.pageviews || 0);
      var max = Math.max.apply(null, (pages || []).map(function(p){ return Number(p.clicks || 0); }).concat([1]));
      var pct = Math.max(6, Math.round((clicks / max) * 100));
      return '<div class="rank-item">'
        + '<div class="rank-index">' + (index + 1) + '</div>'
        + '<div class="rank-main">'
        +   '<div class="rank-title" title="' + esc(String(item.path || '/')) + '">' + esc(String(item.path || '/')) + '</div>'
        +   '<div class="rank-sub">' + pageviews.toLocaleString('fr-CA') + ' vues · CTR ' + Number(item.ctr || 0).toFixed(1) + '%</div>'
        +   '<div class="rank-progress"><span style="width:' + pct + '%"></span></div>'
        + '</div>'
        + '<div class="rank-value"><strong>' + clicks.toLocaleString('fr-CA') + '</strong><span class="rank-sub">clics</span></div>'
        + '</div>';
    });
  }

  function renderTopZones(zones) {
    var host = document.getElementById('traffic-top-zones');
    if (!host) return;
    host.innerHTML = trafficRankListHtml((zones || []).slice(0, 6), function(item, index) {
      var clicks = Number(item.clicks || 0);
      var events = Number(item.events || 0);
      var max = Math.max.apply(null, (zones || []).map(function(z){ return Number(z.clicks || 0); }).concat([1]));
      var pct = Math.max(6, Math.round((clicks / max) * 100));
      return '<div class="rank-item">'
        + '<div class="rank-index">' + (index + 1) + '</div>'
        + '<div class="rank-main">'
        +   '<div class="rank-title" title="' + esc(String(item.zone || '—')) + '">' + esc(String(item.zone || '—')) + '</div>'
        +   '<div class="rank-sub">' + events.toLocaleString('fr-CA') + ' interactions enregistrées</div>'
        +   '<div class="rank-progress"><span style="width:' + pct + '%"></span></div>'
        + '</div>'
        + '<div class="rank-value"><strong>' + clicks.toLocaleString('fr-CA') + '</strong><span class="rank-sub">clics</span></div>'
        + '</div>';
    });
