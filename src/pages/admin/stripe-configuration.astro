---
import { getUserFromSessionFullAny } from '../../lib/db';
const db = (Astro.locals.runtime?.env as Env | undefined)?.DB ?? null;
const token = Astro.cookies.get('capitune_session')?.value ?? '';
const adminUser = await getUserFromSessionFullAny(db, token);
const adminName = adminUser?.name ?? 'Admin';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stripe — Admin CAPITUNE</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    :root {
      --bg:      #0f1117;
      --surface: #1a1d27;
      --card:    #20243a;
      --border:  #2e3349;
      --text:    #e6e9f4;
      --muted:   #8891b4;
      --accent:  #ff9408;
      --green:   #2ecc71;
      --red:     #e74c3c;
      --blue:    #3498db;
      --yellow:  #f1c40f;
      --radius:  12px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; font-size: 14px; min-height: 100vh; display: flex; }

    /* Sidebar */
    .sidebar {
      width: 220px; min-height: 100vh; background: var(--surface);
      border-right: 1px solid var(--border); display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0; z-index: 100;
    }
    .sidebar-logo { padding: 24px 20px; border-bottom: 1px solid var(--border); }
    .sidebar-logo span { font-size: 18px; font-weight: 700; color: var(--accent); letter-spacing: 1px; }
    .sidebar-nav { flex: 1; padding: 16px 0; }
    .nav-item {
      display: flex; align-items: center; gap: 12px; padding: 11px 20px;
      color: var(--muted); cursor: pointer; transition: all .18s;
      font-weight: 500; text-decoration: none;
    }
    .nav-item:hover, .nav-item.active { background: rgba(255,148,8,.1); color: var(--accent); }
    .nav-item i { width: 18px; text-align: center; font-size: 15px; }
    .sidebar-footer { padding: 16px 20px; border-top: 1px solid var(--border); color: var(--muted); font-size: 12px; }
    .sidebar-footer strong { display: block; color: var(--text); margin-bottom: 4px; font-size: 13px; }

    /* Main */
    .main { margin-left: 220px; flex: 1; min-height: 100vh; }
    .topbar {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 50;
    }
    .topbar h1 { font-size: 18px; font-weight: 600; }
    .topbar-right { display: flex; align-items: center; gap: 16px; }
    .content { padding: 28px 32px; max-width: 820px; }

    /* Cards */
    .card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 24px; margin-bottom: 20px;
    }
    .card-title { font-size: 15px; font-weight: 700; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
    .card-title i { color: var(--accent); }

    /* Form elements */
    .field { margin-bottom: 18px; }
    .field label { display: block; font-size: 12px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 7px; }
    .field label span.req { color: var(--red); margin-left: 2px; }
    .field-input {
      width: 100%; background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 14px; color: var(--text);
      font-family: 'Courier New', monospace; font-size: 13px; outline: none; transition: border-color .18s;
    }
    .field-input:focus { border-color: var(--accent); }
    .field-hint { font-size: 11px; color: var(--muted); margin-top: 5px; }
    .field-hint code { background: var(--surface); padding: 1px 5px; border-radius: 4px; font-size: 11px; }

    .input-wrap { position: relative; }
    .input-wrap .field-input { padding-right: 44px; }
    .toggle-btn {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; color: var(--muted); cursor: pointer; padding: 0; line-height: 1;
    }
    .toggle-btn:hover { color: var(--text); }
    .toggle-btn svg { width: 18px; height: 18px; display: block; }

    /* Radio env */
    .radio-group { display: flex; gap: 12px; }
    .radio-opt { flex: 1; cursor: pointer; }
    .radio-opt input { display: none; }
    .radio-card {
      border: 2px solid var(--border); border-radius: 10px; padding: 12px 16px;
      transition: all .18s; background: var(--bg);
    }
    .radio-opt input:checked + .radio-card {
      border-color: var(--accent); background: rgba(255,148,8,.07);
    }
    .radio-card-head { display: flex; align-items: center; gap: 8px; font-weight: 600; }
    .radio-card p { font-size: 11px; color: var(--muted); margin-top: 4px; margin-left: 24px; }

    /* Alert */
    .alert { border-radius: 10px; padding: 14px 16px; margin-bottom: 20px; display: flex; align-items: flex-start; gap: 10px; }
    .alert-yellow { background: rgba(241,196,15,.1); border: 1px solid rgba(241,196,15,.3); color: var(--yellow); }
    .alert-blue   { background: rgba(52,152,219,.1);  border: 1px solid rgba(52,152,219,.3);  color: var(--blue); }
    .alert svg { flex-shrink: 0; width: 18px; height: 18px; margin-top: 1px; }
    .alert-body strong { display: block; font-size: 13px; margin-bottom: 3px; }
    .alert-body p, .alert-body ol { font-size: 12px; opacity: .9; }
    .alert-body ol { padding-left: 16px; }
    .alert-body ol li { margin-bottom: 3px; }
    .alert-body a { color: inherit; text-decoration: underline; }

    /* Env preview */
    .env-preview {
      background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
      padding: 14px 16px; font-family: 'Courier New', monospace; font-size: 12px;
      color: var(--muted); overflow-x: auto; white-space: pre;
    }
    .preview-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .preview-header span { font-size: 13px; font-weight: 600; color: var(--text); }

    /* Success banner */
    .success-banner {
      background: rgba(46,204,113,.12); border: 1px solid rgba(46,204,113,.3);
      border-radius: 10px; padding: 12px 16px; color: var(--green);
      display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 13px;
    }
    .success-banner svg { width: 18px; height: 18px; flex-shrink: 0; }

    /* Buttons */
    .btn-row { display: flex; gap: 10px; margin-top: 6px; }
    .btn-primary {
      background: var(--accent); color: #fff; border: none; border-radius: 8px;
      padding: 10px 22px; font-size: 13px; font-weight: 600; cursor: pointer;
      display: flex; align-items: center; gap: 7px; transition: background .18s;
    }
    .btn-primary:hover { background: #e08400; }
    .btn-secondary {
      background: var(--surface); color: var(--text); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 18px; font-size: 13px; font-weight: 600;
      cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 7px;
      transition: border-color .18s;
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
    .btn-copy {
      background: var(--surface); border: 1px solid var(--border); color: var(--muted);
      border-radius: 7px; padding: 5px 12px; font-size: 12px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px; transition: all .18s;
    }
    .btn-copy:hover { border-color: var(--accent); color: var(--accent); }
    .btn-copy svg { width: 14px; height: 14px; }
  </style>
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <span>CAPITUNE</span><br>
    <small style="color:var(--muted);font-size:11px;font-weight:400;">Panneau Admin</small>
  </div>
  <nav class="sidebar-nav">
    <a class="nav-item" href="/admin">
      <i class="fa fa-chart-pie"></i> Tableau de bord
    </a>
    <a class="nav-item" href="/admin#clients">
      <i class="fa fa-users"></i> Clients
    </a>
    <a class="nav-item active" href="/admin/stripe-configuration">
      <i class="fa fa-credit-card"></i> Stripe
    </a>
    <a class="nav-item" href="/dashboard">
      <i class="fa fa-arrow-left"></i> Espace client
    </a>
    <a class="nav-item" href="/api/oauth/signout" style="margin-top:auto;">
      <i class="fa fa-sign-out-alt"></i> Déconnexion
    </a>
  </nav>
  <div class="sidebar-footer">
    <strong>{adminName}</strong>
    Administrateur
  </div>
</aside>

<!-- Main -->
<main class="main">
  <div class="topbar">
    <h1><i class="fa fa-credit-card" style="color:var(--accent);margin-right:10px;"></i>Configuration Stripe</h1>
    <div class="topbar-right">
      <a href="/api/oauth/signout" style="color:var(--muted);font-size:12px;text-decoration:none;">
        <i class="fa fa-sign-out-alt"></i> Déconnexion
      </a>
    </div>
  </div>

  <div class="content">

    <!-- Alerte sécurité -->
    <div class="alert alert-yellow">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div class="alert-body">
        <strong>Informations sensibles</strong>
        <p>Ces clés API sont confidentielles. Ne les partagez jamais publiquement.</p>
      </div>
    </div>

    <!-- Formulaire -->
    <div class="card">
      <div class="card-title"><i class="fa fa-key"></i> Clés API</div>
      <form id="stripe-config-form" autocomplete="off">

        <div class="field">
          <label>Clé Publique (Publishable Key) <span class="req">*</span></label>
          <input type="text" id="publishable-key" name="publishableKey"
            placeholder="pk_test_..." class="field-input" autocomplete="off" required />
          <div class="field-hint">Commence par <code>pk_test_</code> (test) ou <code>pk_live_</code> (production)</div>
        </div>

        <div class="field">
          <label>Clé Secrète (Secret Key) <span class="req">*</span></label>
          <div class="input-wrap">
            <input type="password" id="secret-key" name="secretKey"
              placeholder="sk_test_..." class="field-input" autocomplete="new-password" required />
            <button type="button" id="toggle-secret" class="toggle-btn" aria-label="Afficher/Masquer">
              <svg id="eye-open" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <svg id="eye-closed" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
            </button>
          </div>
          <div class="field-hint">Commence par <code>sk_test_</code> (test) ou <code>sk_live_</code> (production)</div>
        </div>

        <div class="field">
          <label>Webhook Secret (Optionnel)</label>
          <div class="input-wrap">
            <input type="password" id="webhook-secret" name="webhookSecret"
              placeholder="whsec_..." class="field-input" autocomplete="new-password" />
            <button type="button" id="toggle-webhook" class="toggle-btn" aria-label="Afficher/Masquer">
              <svg id="webhook-eye-open" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <svg id="webhook-eye-closed" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
            </button>
          </div>
          <div class="field-hint">Nécessaire pour les webhooks. Commence par <code>whsec_</code></div>
        </div>

        <div class="field">
          <label>Environnement</label>
          <div class="radio-group">
            <label class="radio-opt">
              <input type="radio" name="environment" value="test" checked />
              <div class="radio-card">
                <div class="radio-card-head">🧪 Test</div>
                <p>Pour les tests de développement</p>
              </div>
            </label>
            <label class="radio-opt">
              <input type="radio" name="environment" value="live" />
              <div class="radio-card">
                <div class="radio-card-head">🚀 Production</div>
                <p>Pour les vrais paiements</p>
              </div>
            </label>
          </div>
        </div>

        <div id="success-message" class="success-banner" style="display:none;margin-bottom:16px;">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Configuration enregistrée avec succès !
        </div>

        <div class="btn-row">
          <button type="submit" class="btn-primary">
            <svg style="width:15px;height:15px" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Enregistrer
          </button>
          <a href="/admin" class="btn-secondary">
            <i class="fa fa-arrow-left"></i> Retour
          </a>
        </div>
      </form>
    </div>

    <!-- Aide Stripe -->
    <div class="alert alert-blue">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <div class="alert-body">
        <strong>Où trouver vos clés Stripe ?</strong>
        <ol>
          <li>Connectez-vous sur <a href="https://dashboard.stripe.com" target="_blank">dashboard.stripe.com</a></li>
          <li>Allez dans <strong>Développeurs → Clés API</strong></li>
          <li>Copiez la <strong>Clé publique</strong> et la <strong>Clé secrète</strong></li>
          <li>Pour le webhook : <strong>Développeurs → Webhooks → Créer un endpoint</strong></li>
        </ol>
      </div>
    </div>

    <!-- Aperçu .env -->
    <div class="card">
      <div class="preview-header">
        <span><i class="fa fa-file-code" style="color:var(--accent);margin-right:6px;"></i>Aperçu .env</span>
        <button id="copy-env" class="btn-copy" type="button">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          Copier
        </button>
      </div>
      <div id="env-preview" class="env-preview"># Ajoutez ces lignes dans votre fichier .env

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=</div>
    </div>

  </div><!-- /.content -->
</main><!-- /.main -->

<script>
  // Toggle visibility secret key
  const secretInput = document.getElementById('secret-key');
  document.getElementById('toggle-secret')?.addEventListener('click', () => {
    if (!(secretInput instanceof HTMLInputElement)) return;
    const show = secretInput.type === 'password';
    secretInput.type = show ? 'text' : 'password';
    const open = document.getElementById('eye-open');
    const closed = document.getElementById('eye-closed');
    if (open) open.style.display = show ? 'none' : 'block';
    if (closed) closed.style.display = show ? 'block' : 'none';
  });

  // Toggle visibility webhook
  const webhookInput = document.getElementById('webhook-secret');
  document.getElementById('toggle-webhook')?.addEventListener('click', () => {
    if (!(webhookInput instanceof HTMLInputElement)) return;
    const show = webhookInput.type === 'password';
    webhookInput.type = show ? 'text' : 'password';
    const open = document.getElementById('webhook-eye-open');
    const closed = document.getElementById('webhook-eye-closed');
    if (open) open.style.display = show ? 'none' : 'block';
    if (closed) closed.style.display = show ? 'block' : 'none';
  });

  // Live preview .env
  function updateEnvPreview() {
    const pub = document.getElementById('publishable-key');
    const sec = document.getElementById('secret-key');
    const whk = document.getElementById('webhook-secret');
    const pubVal = pub instanceof HTMLInputElement ? pub.value : '';
    const secVal = sec instanceof HTMLInputElement ? sec.value : '';
    const whkVal = whk instanceof HTMLInputElement ? whk.value : '';
    const preview = document.getElementById('env-preview');
    if (preview) {
      preview.textContent =
        `# Ajoutez ces lignes dans votre fichier .env\n\nSTRIPE_PUBLIC_KEY=${pubVal || 'pk_test_...'}\nSTRIPE_SECRET_KEY=${secVal || 'sk_test_...'}\nSTRIPE_WEBHOOK_SECRET=${whkVal || 'whsec_...'}`;
    }
  }
  ['publishable-key', 'secret-key', 'webhook-secret'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', updateEnvPreview)
  );

  // Copy .env
  document.getElementById('copy-env')?.addEventListener('click', () => {
    const preview = document.getElementById('env-preview');
    if (!preview) return;
    navigator.clipboard.writeText(preview.textContent || '');
    const btn = document.getElementById('copy-env');
    if (!btn) return;
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa fa-check"></i> Copié !';
    setTimeout(() => { btn.innerHTML = orig; }, 2000);
  });

  // Form submit
  const form = document.getElementById('stripe-config-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!(e.target instanceof HTMLFormElement)) return;
    const fd = new FormData(e.target);
    console.log('Stripe Config:', Object.fromEntries(fd));
    const msg = document.getElementById('success-message');
    if (msg) {
      msg.style.display = 'flex';
      msg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      setTimeout(() => { msg.style.display = 'none'; }, 5000);
    }
    updateEnvPreview();
  });
</script>
</body>
</html>
