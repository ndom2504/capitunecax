    window.sendMessage = async function() {
      var input=document.getElementById('msgInput');
      var val=input&&input.value.trim();
      if(!val) return;
      appendSentMessage(val,null);
      input.value='';
      // Persistance D1
      dbSync('/api/messages', 'POST', { content: val, sender: 'user' });

      // Réponse automatique de l'agent (basée KB locale)
      try {
        var tip = showTypingIndicator();
        var resp = await fetch('/api/agent/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: val,
            project: ST && ST.projet ? {
              type: ST.projet.type,
              province: ST.projet.province,
              pays: ST.projet.pays,
              langues: ST.projet.langues,
            } : null,
          }),
        });
        var data = await resp.json();
        if (tip) tip.remove();
        if (data && data.replyHtml) {
          appendBotMessage(data.replyHtml);
        }
      } catch(_) {
        // silence : la messagerie reste utilisable même si l'agent échoue
      }
    };

