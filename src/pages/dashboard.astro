    //  Rendu dynamique des packs (Style Bootstrap)
    function renderPacks() {
      var grid = document.getElementById('packsGrid');
      if (!grid) return;
      
      grid.innerHTML = PACKS.map(function(p) {
        var isPremium = p.id === 'premium';
        var isPopular = p.popular;
        
        var detailSvcs = p.services.map(function(s) {
          return '<label class="pack-svc-item">'
            + '<input type="checkbox" class="option" data-pid="'+p.id+'" data-sid="'+s.id+'" data-price="'+s.price+'" onchange="togglePackSvc(\''+p.id+'\',\''+s.id+'\','+s.price+', this)">'
            + ' ' + s.name
            + '<span class="option-price">'+s.price.toLocaleString('fr-CA')+'\u00a0$</span>'
            + '</label>';
        }).join('');

        var descHtml = (p.desc || '');
        descHtml = descHtml.replace(/de\s+(A\s+(?:à|a)\s+Z)/gi, function(_m, grp) {
          return 'de <span class="nowrap">' + grp + '</span>';
        });

        return (
          '<div class="pack-card" data-pack="'+p.id+'" id="pack-'+p.id+'" onclick="if(!event.target.closest(\'.pack-svc-item\')) setPackMode(\''+p.id+'\','+p.price+',\'full\')">'
          + '<div class="pack-head">'
          + '<h4>'+p.name+'</h4>'
          + '<p class="text-muted">'+descHtml+'</p>'
          + '</div>'
          + '<div class="pack-body">'
          + '<div class="pack-price" data-base="'+p.price+'">'+p.price.toLocaleString('fr-CA')+' $</div>'
          + '<hr>'
          + '<div>'
          + detailSvcs
          + '</div>'
          + '</div>'
          + '</div>'
        );
      }).join('');
    }

