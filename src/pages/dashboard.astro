    //  Navigation 
    window.switchTab = function(tabId) {
      document.querySelectorAll('.tab-section').forEach(function(s){s.classList.remove('active');});
      document.querySelectorAll('.dash-nav-item').forEach(function(n){n.classList.remove('active');});
      var sec = document.getElementById('tab-'+tabId);
      if (sec) { sec.style.display = ''; sec.classList.add('active'); }
      document.querySelectorAll('.dash-nav-item[data-tab="'+tabId+'"]').forEach(function(n){n.classList.add('active');});
      window.scrollTo({top:0,behavior:'smooth'});
      if (tabId==='dashboard') refreshDashboardView();
      if (tabId==='services') refreshServicesView();
      if (tabId==='paiements') refreshPaiementsView();
      if (tabId==='equipe') loadTeam();
      if (tabId==='inside') loadInsideTab();
      if (tabId==='documents') loadDocumentsTab();
      if (tabId==='projet') loadProjetTab();
    };

    async function refreshDashboardView(){
      var box = document.getElementById('dashboardHint');
      var boxText = box ? box.querySelector('span') : null;
      function showHint(msg){ if(!box||!boxText) return; box.style.display=''; boxText.textContent=msg||''; }
      function hideHint(){ if(!box) return; box.style.display='none'; }
      function setTxt(id, v){ var el=document.getElementById(id); if(el) el.textContent=String(v ?? ''); }
      function setHtml(id, html){ var el=document.getElementById(id); if(el) el.innerHTML=html; }
      function fmtPct(x){ var n=Number(x||0); if(!Number.isFinite(n)) n=0; return Math.round(n*100)+'%'; }
      function fmtMoneyValue(x){
        try { return (typeof formatMoney==='function') ? formatMoney(Number(x||0)) : String(x||0); }
        catch(_e){ return String(x||0); }
      }

      try {
        hideHint();
        var resp = await fetch('/api/dashboard/stats' + (window.location.search||''), { headers: { 'Accept':'application/json' } });
        var payload = await resp.json().catch(function(){ return {}; });
        if (!resp.ok || payload.error) throw new Error(payload.error || 'Impossible de charger le dashboard');

        var isPro = payload.mode === 'pro';
        var proBlock = document.getElementById('dashboardProBlock');
        var clBlock = document.getElementById('dashboardClientBlock');
        if (proBlock) proBlock.style.display = isPro ? '' : 'none';
        if (clBlock) clBlock.style.display = isPro ? 'none' : '';

        if (isPro) {
          var s = payload.pro || {};
          setTxt('dashProServicesCatalog', s.services_catalog ?? 0);
          setTxt('dashProServicesOffered', s.services_offered ?? 0);
          setTxt('dashProClients', s.clients ?? 0);
          setTxt('dashProTransactions', s.transactions_paid ?? 0);
          setTxt('dashProRevenue', fmtMoneyValue(s.revenue_paid ?? 0));
          setTxt('dashProProjectsTotal', s.projects_total ?? 0);
          setTxt('dashProProjectsCompleted', s.projects_completed ?? 0);
          setTxt('dashProPending', s.pending_conversations ?? 0);
          setTxt('dashProScore', s.operational_score ?? 0);
          setTxt('dashProProcessingRate', fmtPct(s.processing_rate ?? 0));
          setTxt('dashProReactivityRate', fmtPct(s.reactivity_rate ?? 0));
          loadProInbox();
          return;
        }

        var c = payload.client || {};
        setTxt('dashClientRequests', c.my_requests_total ?? 0);
        var bs = c.my_requests_by_status || {};
        setTxt('dashClientEnCours', bs.en_cours ?? 0);
        setTxt('dashClientSoumis', bs.soumis ?? 0);
        setTxt('dashClientTermine', bs.termine ?? 0);
        setTxt('dashClientTransactions', c.my_transactions_paid ?? 0);
        setTxt('dashClientRevenue', fmtMoneyValue(c.my_revenue_paid ?? 0));
        setTxt('dashClientPlatform30d', c.platform_requests_30d ?? 0);

        var dest = Array.isArray(c.trending_destinations) ? c.trending_destinations : [];
        var dom = Array.isArray(c.trending_domains) ? c.trending_domains : [];
        setHtml('dashTrendingDestinations', dest.length
          ? dest.map(function(it){
              var label = String((it && it.label) ? it.label : '').trim() || '—';
              var count = Number((it && it.count) ? it.count : 0) || 0;
              return '<li class="trend-item"><span>'+label+'</span><small>'+count+' demande(s)</small></li>';
            }).join('')
          : '<li class="trend-item"><span>Pas encore de données</span><small>—</small></li>'
        );
        setHtml('dashTrendingDomains', dom.length
          ? dom.map(function(it){
              var label = String((it && it.label) ? it.label : '').trim() || '—';
              var count = Number((it && it.count) ? it.count : 0) || 0;
              return '<li class="trend-item"><span>'+label+'</span><small>'+count+' demande(s)</small></li>';
            }).join('')
          : '<li class="trend-item"><span>Pas encore de données</span><small>—</small></li>'
        );
      } catch (e) {
        showHint((e && e.message) ? e.message : 'Erreur lors du chargement du dashboard');
      }
    }

    // ============================================================
    //  PRO INBOX — liste clients avec search + onglets
    // ============================================================
    var _proInboxAll = [];

    async function loadProInbox() {
      var loading = document.getElementById('proInboxLoading');
      var list    = document.getElementById('proInboxList');
      var empty   = document.getElementById('proInboxEmpty');
      if (!list) return;
      if (loading) loading.style.display = '';
      if (list)   list.innerHTML = '';
      if (empty)  empty.style.display = 'none';
      try {
        var res = await fetch('/api/admin/clients?scope=me&page=1&limit=50', { headers: { Accept: 'application/json' } });
        var data = await res.json().catch(function(){ return {}; });
        var clients = (data && Array.isArray(data.clients)) ? data.clients : [];
        _proInboxAll = clients;
        var withProject = clients.filter(function(c){ var s=String(c.project_status||'').toLowerCase(); return s && s !== 'annule'; }).length;
        var propositions= clients.filter(function(c){ return String(c.project_status||'').toLowerCase()==='proposition'; }).length;
        var actifs      = clients.filter(function(c){ var s=String(c.project_status||'').toLowerCase(); return s==='demarre'||s==='en_cours'; }).length;
        var setT = function(id, v){ var el=document.getElementById(id); if(el) el.textContent=String(v); };
        setT('pmsClients', clients.length);
        setT('pmsDossiers', withProject);
        setT('pmsPropositions', propositions);
        setT('pmsActifs', actifs);
        renderProInbox(clients);
      } catch(e) {
        renderProInbox([]);
      } finally {
        if (loading) loading.style.display = 'none';
      }
    }

    function renderProInbox(clients) {
      var list       = document.getElementById('proInboxList');
      var empty      = document.getElementById('proInboxEmpty');
      var storiesRow = document.getElementById('proStoriesRow');
      var storiesWrap= document.getElementById('proStoriesWrap');
      if (!list) return;
      if (!clients.length) {
        list.innerHTML = '';
        if (empty) empty.style.display = '';
        if (storiesWrap) storiesWrap.style.display = 'none';
        return;
      }
      if (empty) empty.style.display = 'none';

      var statusLabel = function(s) {
        if (!s) return '';
        var map = { proposition: 'Proposition', demarre: 'Démarré', en_cours: 'En cours', soumis: 'Soumis', termine: 'Terminé' };
        return map[s.toLowerCase()] || s;
      };

      // ── Stories (style Facebook) ──────────────────────────
      if (storiesRow && storiesWrap) {
        storiesWrap.style.display = '';
        var statusDotColor = function(s) {
          if (s === 'soumis' || s === 'en_cours') return '#ff9408';
          if (s === 'proposition') return '#2980b9';
          if (s === 'demarre' || s === 'termine') return '#27ae60';
          return '#bbb';
        };
        storiesRow.innerHTML = clients.map(function(c) {
          var name    = String(c.name || c.email || 'Client').trim();
          var displayName = name.length > 9 ? name.slice(0, 8) + '…' : name;
          var initial = (name[0] || 'C').toUpperCase();
          var status  = String(c.project_status || '').toLowerCase();
          var dotColor= statusDotColor(status);
          var onclick = 'switchTab(\'messagerie\'); window._openProConv(\''+c.id+'\',\''+encodeURIComponent(name)+'\',\''+encodeURIComponent(c.email||'')+'\')';
          return '<button class="pro-story-bubble" onclick="'+onclick+'" title="'+escHtml(name)+(statusLabel(status) ? ' – '+statusLabel(status) : '')+'" aria-label="Ouvrir conversation avec '+escHtml(name)+'">'
            + '<div class="pro-story-ring-wrap">'
            +   '<div class="pro-story-ring '+status+'">'
            +     '<div class="pro-story-ring-inner">'
            +       '<div class="pro-story-initials">'+initial+'</div>'
            +     '</div>'
            +   '</div>'
            +   '<span class="pro-story-status-dot" style="background:'+dotColor+';"></span>'
            + '</div>'
            + '<span class="pro-story-name">'+escHtml(displayName)+'</span>'
            + '</button>';
        }).join('');
      }

      // ── Liste complète ────────────────────────────────────
      list.innerHTML = clients.map(function(c) {
        var name = String(c.name || c.email || 'Client').trim();
        var initial = (name[0] || 'C').toUpperCase();
        var preview = String(c.last_msg || 'Aucun message').slice(0, 75);
        var status = String(c.project_status || '').toLowerCase();
        var slabel = statusLabel(status);
        var statusHtml = slabel ? '<span class="pro-inbox-status '+status+'">'+slabel+'</span>' : '';
        var href = '#';
        return '<a class="pro-inbox-card" href="'+href+'" onclick="switchTab(\'messagerie\'); window._openProConv(\''+c.id+'\',\''+encodeURIComponent(name)+'\',\''+encodeURIComponent(c.email||'')+'\'); return false;">'
          + '<div class="pro-inbox-avatar">'+initial+'</div>'
          + '<div class="pro-inbox-info">'
          +   '<div class="pro-inbox-name">'+name+'</div>'
          +   '<div class="pro-inbox-preview">'+preview+'</div>'
          + '</div>'
          + statusHtml
          + '<i class="fa fa-chevron-right" style="color:#ccc;font-size:13px;flex-shrink:0;margin-left:6px;"></i>'
          + '</a>';
      }).join('');
    }

    window.filterProInbox = function(q) {
      var filtered = !q ? _proInboxAll : _proInboxAll.filter(function(c) {
        var s = (String(c.name||'')+' '+String(c.email||'')).toLowerCase();
        return s.indexOf(q.toLowerCase()) !== -1;
      });
      renderProInbox(filtered);
    };

