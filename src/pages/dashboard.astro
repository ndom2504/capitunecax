    var _teamLoaded = false;
    function loadTeam() {
      if (_teamLoaded) return;
      var container = document.getElementById('team-grid-container');
      if (!container) return;

      function esc(s){
        return String(s||'').replace(/[&<>"']/g, function(c){
          return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;';
        });
      }
      function getAvatarSrc(u){ var s=String(u||'').trim(); return (/^https?:\/\//i.test(s)||/^data:image\//i.test(s))&&s.length>4 ? s : ''; }
      function locationToFlag(loc) {
        var raw = String(loc||'').trim();
        if (!raw) return '';
        var parts = raw.split(',');
        var key = parts[parts.length-1].trim().toLowerCase()
          .normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/['\u2019]/g,"'");
        var MAP = {
          'canada':'CA','qc':'CA','ontario':'CA','montreal':'CA','quebec':'CA','levis':'CA','laval':'CA','gatineau':'CA','ottawa':'CA','toronto':'CA','vancouver':'CA','calgary':'CA','edmonton':'CA',
          'france':'FR','paris':'FR','maroc':'MA','morocco':'MA','algerie':'DZ','algeria':'DZ','tunisie':'TN','tunisia':'TN','senegal':'SN',
          "cote d'ivoire":'CI','ivory coast':'CI','cameroun':'CM','cameroon':'CM','congo':'CG','rdc':'CD','gabon':'GA','madagascar':'MG','mali':'ML','guinee':'GN','guinea':'GN',
          'togo':'TG','benin':'BJ','burkina faso':'BF','niger':'NE','tchad':'TD','chad':'TD','mauritanie':'MR','mauritania':'MR',
          'etats-unis':'US','usa':'US','united states':'US','mexique':'MX','mexico':'MX','haiti':'HT','bresil':'BR','brazil':'BR',
          'belgique':'BE','belgium':'BE','suisse':'CH','switzerland':'CH','luxembourg':'LU','espagne':'ES','spain':'ES',
          'portugal':'PT','italie':'IT','italy':'IT','allemagne':'DE','germany':'DE','royaume-uni':'GB','uk':'GB','liban':'LB'
        };
        var iso = MAP[key]; if (!iso) return '';
        return iso.split('').map(function(c){ return String.fromCodePoint(c.charCodeAt(0)-65+0x1F1E6); }).join('');
      }

      fetch('/api/team')
        .then(function(r){ return r.json(); })
        .then(function(data){
          _teamLoaded = true;
          var members = data.team || [];
          window.__teamMembers = members;
          if (!members.length) {
            container.innerHTML = '<div class="team-loading"><i class="fa fa-users"></i><br><br>Aucun profil disponible pour le moment.</div>';
            return;
          }
          var html = '<div class="team-grid">';
          members.forEach(function(m, idx){
            var initials = (m.name||'?').split(' ').map(function(w){return w[0]||'';}).slice(0,2).join('').toUpperCase();
            var avatarUrl = getAvatarSrc(m.avatar_key);
            var flag = locationToFlag(m.location);
            var expYears = m.pro_experience_years ? parseInt(m.pro_experience_years, 10) : 0;
            var locStr = m.location ? m.location.split(',').pop().trim() : '';

            html += '<div class="team-card" onclick="openTeamProfile('+idx+'); return false;">';
            
            // Image de fond ou fallback
            if (avatarUrl) {
              html += '<img src="'+esc(avatarUrl)+'" class="team-card-bg" alt="avatar">';
            } else {
              html += '<div class="team-card-fallback">'+esc(initials||'?')+'</div>';
            }
            
            // Ombre dégradée pour lisibilité du texte
            html += '<div class="team-card-shade"></div>';
            
            // Contenu superposé (en bas)
            html += '<div class="team-card-body">';
            html += '<span class="team-badge"><i class="fa fa-star"></i> Pro</span>';
            html += '<h3 class="team-name">' + esc(m.name||'Conseiller') + '</h3>';
            
            if (locStr || expYears > 0 || (m.avg_rating && m.avg_rating > 0)) {
              html += '<div style="display:flex;align-items:center;flex-wrap:wrap;gap:10px;font-size:12px;color:#ddd;margin-bottom:6px;">';
              if (m.avg_rating && m.avg_rating > 0) {
                html += '<span style="color:#ffd700;font-weight:700;"><i class="fa fa-star"></i> ' + m.avg_rating.toFixed(1) + '</span>';
              }
              if (locStr) html += '<span><i class="fa fa-map-marker"></i> ' + esc(locStr) + (flag ? (' '+flag) : '') + '</span>';
              if (expYears > 0) html += '<span><i class="fa fa-briefcase"></i> ' + expYears + ' an' + (expYears > 1 ? 's' : '') + '</span>';
              html += '</div>';
            }
            
            if (m.bio) html += '<p class="team-bio">' + esc(m.bio) + '</p>';
            
            html += '<div style="display:flex;gap:10px;width:100%;margin-top:16px;">';
            html += '<button class="team-contact-btn secondary" onclick="event.stopPropagation(); openTeamProfile('+idx+');"><i class="fa fa-eye"></i> Voir</button>';
            html += '<button class="team-contact-btn" onclick="event.stopPropagation(); switchTab(\'messagerie\');"><i class="fa fa-envelope"></i> Message</button>';
            html += '</div>';
            
            html += '</div>'; // end body
            html += '</div>'; // end card
          });
          html += '</div>';
          container.innerHTML = html;
        })
        .catch(function(){
          container.innerHTML = '<div class="team-loading" style="color:#e74c3c;"><i class="fa fa-exclamation-circle"></i> Impossible de charger l\'\u00e9quipe.</div>';
        });
    }
