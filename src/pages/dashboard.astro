      var bubble = document.createElement('div');
      bubble.className = 'msg-bubble';
      bubble.innerHTML = '<div class="typing-dot"><span></span><span></span><span></span></div>';
      div.appendChild(bubble);
      chat.appendChild(div);
      chat.scrollTop = chat.scrollHeight;
      return div;
    }

    function addMsgBadge(count) {
      var link = document.querySelector('.dash-nav-item[data-tab="messagerie"] a');
      if (!link) return;
      var badge = document.getElementById('msg-notif-badge');
      if (!badge) {
        badge = document.createElement('span');
        badge.id = 'msg-notif-badge';
        badge.className = 'tab-badge';
        link.appendChild(badge);
      }
      var n = parseInt(String(count || 1), 10);
      badge.textContent = String(isNaN(n) || n <= 0 ? 1 : n);
    }

    function removeMsgBadge() {
      var b = document.getElementById('msg-notif-badge');
      if (b) b.remove();
    }

    function flushBotMessages() {
      _pendingBotMsgs.forEach(function(html) { appendBotMessage(html); });
      _pendingBotMsgs = [];
      removeMsgBadge();
    }

    async function triggerOrientation(source) {
      try {
        // Signature simple : évite de spammer la même orientation
        var sig = JSON.stringify({
          projet: (ST && ST.projet) ? {
            type: ST.projet.type || '',
            province: ST.projet.province || '',
            pays: ST.projet.pays || '',
            langues: ST.projet.langues || [],
          } : null,
          soumis: !!(ST && ST.soumis),
          pack: (ST && ST.pack) ? ST.pack : null,
        });
        var lastSig = localStorage.getItem('capitune_agent_orientation_sig') || '';
        if (lastSig === sig && source !== 'open') return;
        localStorage.setItem('capitune_agent_orientation_sig', sig);

        var msgActive = document.getElementById('tab-messagerie')
          && document.getElementById('tab-messagerie').classList.contains('active');

        // Notification dès qu'une orientation est prête
        if (!msgActive) addMsgBadge((_pendingBotMsgs.length || 0) + 1);

        var resp = await fetch('/api/agent/orientation', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            project: (ST && ST.projet) ? ST.projet : null,
            state: { soumis: !!(ST && ST.soumis), packId: (ST && ST.pack) ? ST.pack : null },
          }),
        });
        var data = await resp.json();
        if (!data || !data.replyHtml) return;

        if (msgActive) {
          var tip = showTypingIndicator();
          setTimeout(function(){
            if (tip) tip.remove();
            appendBotMessage(data.replyHtml);
          }, 900);
        } else {
          _pendingBotMsgs.push(data.replyHtml);
          addMsgBadge(_pendingBotMsgs.length);
        }
      } catch(_) {
        // silence
      }
    }

    async function triggerAutoReponse(projType) {
      var info = IMMIG_INFO[projType];
      if (!info) return;
      addMsgBadge((_pendingBotMsgs.length || 0) + 1);

      // Si messagerie déjà ouverte, afficher les dots puis le message
      var msgActive = document.getElementById('tab-messagerie')
        && document.getElementById('tab-messagerie').classList.contains('active');

      function buildBotHtml(liveExcerpt) {
        var docsHtml = info.docs.map(function(d){ return '<li>'+d+'</li>'; }).join('');
        var progHtml = info.programmes.map(function(p){ return '<li>'+p+'</li>'; }).join('');
        var liveBlock = liveExcerpt
          ? '<div class="msg-bot-section" style="margin-top:10px;padding:8px 10px;background:#f0f8e8;border-radius:6px;font-size:11px;color:#555;">'
            + '<strong style="color:#27ae60;">📡 Mise à jour canada.ca</strong><br>'
            + liveExcerpt.substring(0,400)+'…<br>'
            + '<a href="'+info.officialUrl+'" target="_blank" style="color:#2980b9;font-size:11px;">Voir la page officielle</a>'
            + '</div>'
          : '<a href="https://www.canada.ca/fr/immigration-refugies-citoyennete.html" target="_blank" style="font-size:11px;color:#2980b9;display:block;margin-top:8px;">📎 Site officiel Immigration Canada</a>';
        return '<div class="msg-bot-section"><strong>'+info.emoji+' Analyse de votre projet : '+info.label+'</strong></div>'
          + '<div class="msg-bot-section"><strong>⏱️ Délai moyen</strong><br>'+info.delai+'</div>'
          + '<div class="msg-bot-section"><strong>💰 Frais gouvernementaux estimés</strong><br>'+info.frais+'</div>'
          + '<div class="msg-bot-section"><strong>📄 Pièces principales à fournir</strong>'
          + '<ul class="msg-bot-list">'+docsHtml+'</ul></div>'
          + '<div class="msg-bot-section"><strong>📋 Programmes disponibles</strong>'
          + '<ul class="msg-bot-list">'+progHtml+'</ul></div>'
          + liveBlock;
      }

      // Appel API (données enrichies + optionnellement scrape canada.ca)
      try {
        var resp = await fetch('/api/immigration-info?type='+projType);
        var json = await resp.json();
        var liveEx = json.live || null;
        // Fusionner avec les données statiques locales pour complétude
        var finalInfo = Object.assign({}, info, { officialUrl: json.officialUrl || '' });
        info = finalInfo;
        var html = buildBotHtml(liveEx);
        if (msgActive) {
          var tipDiv = showTypingIndicator();
          setTimeout(function(){
            if(tipDiv) tipDiv.remove();
            appendBotMessage(html);
          }, 1800);
        } else {
          _pendingBotMsgs.push(html);
          addMsgBadge(_pendingBotMsgs.length);
        }
      } catch(_) {
        // Fallback statique sans live
        var html2 = buildBotHtml(null);
        if (msgActive) {
          var tipDiv2 = showTypingIndicator();
          setTimeout(function(){
            if(tipDiv2) tipDiv2.remove();
            appendBotMessage(html2);
          }, 1200);
        } else {
          _pendingBotMsgs.push(html2);
          addMsgBadge(_pendingBotMsgs.length);
        }
      }
    }

    // Patch switchTab pour vider les messages en attente à l'ouverture de messagerie
    var _origSwitchTab = window.switchTab;
    window.switchTab = function(tabId) {
      // Bloquer uniquement la création de projet CAPI avec un professionnel (reason === 'projet') si paiement requis.
      // La messagerie reste libre d'accès pour tous (le bouton "Contacter" de l'équipe y emmène d'ailleurs).
      if (tabId === 'projet' && premiumRequired() && window.__forcePremiumProjet) {
        window.openPremiumModal('projet');
        return;
      }
      _origSwitchTab(tabId);
      if (tabId === 'messagerie' && _pendingBotMsgs.length > 0) {
        var tipDiv3 = showTypingIndicator();
        setTimeout(function(){
          if(tipDiv3) tipDiv3.remove();
          flushBotMessages();
        }, 1400);
      }
      if (tabId === 'messagerie') removeMsgBadge();
      // Pro mode : charger les clients au premier clic
      if (tabId === 'messagerie' && document.getElementById('pro-mode-messages') && document.getElementById('pro-mode-messages').style.display !== 'none') {
        if (!window.__proClientsLoaded) loadProClients();
      }
      // Client mode : afficher une proposition tarifaire si dispo
      if (tabId === 'messagerie' && document.getElementById('client-mode-messages') && document.getElementById('client-mode-messages').style.display !== 'none') {
        if (typeof loadClientQuote === 'function') loadClientQuote();
      }
      if (tabId === 'paiements' && document.getElementById('pro-mode-payments') && document.getElementById('pro-mode-payments').style.display !== 'none') {
        if (!window.__proPayLoaded) loadProPayments();
      }
    };

    // ============================================================
    //  CLIENT MODE — PROPOSITION TARIFAIRE
    // ============================================================
    var _latestQuote = null;

    function renderClientQuoteNotice(quote) {
      var box = document.getElementById('quote-notice');
      if (!box) return;
      if (!quote || String(quote.status || '') !== 'sent') {
        box.style.display = 'none';
        _latestQuote = null;
        return;
      }

      _latestQuote = quote;

      var titleEl = document.getElementById('quote-notice-title');
      var descEl = document.getElementById('quote-notice-desc');
      var btn = document.getElementById('btnAcceptQuote');

      var total = Number(quote.total || 0);
      var currency = String(quote.currency || 'CAD');
      var delay = String(quote.estimated_delay || '').trim();
      var note = String(quote.note || '').trim();

      if (titleEl) titleEl.textContent = 'Proposition tarifaire reçue';

      var desc = 'Total: ' + (Number.isFinite(total) ? total.toLocaleString('fr-CA') : String(quote.total || '')) + ' ' + currency;
      if (delay) desc += ' • Délai estimé: ' + delay;
      if (note) desc += ' • ' + note;
      if (descEl) descEl.textContent = desc;
      if (btn) { btn.disabled = false; btn.style.opacity = '1'; }

      box.style.display = 'flex';
    }

    async function loadClientQuote() {
      if (typeof isProModeUI === 'function' && isProModeUI()) return;
      try {
        var r = await fetch('/api/quote');
        var d = await r.json().catch(function(){ return {}; });
        if (!r.ok) {
          renderClientQuoteNotice(null);
          return;
        }
        renderClientQuoteNotice(d && d.quote ? d.quote : null);
      } catch(_) {
        renderClientQuoteNotice(null);
      }
    }

    async function acceptLatestQuote() {
      if (!_latestQuote || !_latestQuote.id) return;
      var btn = document.getElementById('btnAcceptQuote');
      if (btn) { btn.disabled = true; btn.style.opacity = '.7'; }
      try {
        var r = await fetch('/api/quote/accept', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quote_id: _latestQuote.id })
        });
        var d = await r.json().catch(function(){ return {}; });
        if (!r.ok || (d && d.error)) throw new Error((d && d.error) || ('Erreur ' + r.status));
        renderClientQuoteNotice(null);
        showToast('Proposition acceptée ✓', 'success');
        // Afficher un feedback dans le chat (sans bloquer si ça échoue)
        try {
          if (typeof appendBotMessage === 'function') {
            appendBotMessage('<div class="msg-bot-section"><strong>✅ Proposition acceptée</strong><br>Votre dossier est maintenant démarré.</div>');
          }
        } catch(_) {}
      } catch(e) {
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
        showToast(e.message || 'Erreur', 'error');
      }
    }

    // ============================================================
    //  PRO MODE — MESSAGERIE
    // ============================================================
    var _proCurrentClient = null;
    var _proClientData = null;
    window.__proClientsLoaded = false;

    function escP(s) { return String(s||'').replace(/[&<>"']/g,function(c){return c==='&'?'&amp;':c==='<'?'&lt;':c==='>'?'&gt;':c==='"'?'&quot;':'&#39;';}); }

    async function loadProClients() {
      var spin = document.getElementById('pro-msg-spin');
      var list = document.getElementById('pro-client-list');
      if (!list) return;
      if (spin) spin.style.display = '';
      try {
        var r = await fetch('/api/admin/clients?scope=me&page=1');
        if (!r.ok) throw new Error('Erreur ' + r.status);
        var d = await r.json();
        if (!d.clients || !d.clients.length) {
          list.innerHTML = '<li style="padding:20px;text-align:center;color:#bbb;font-size:13px;"><i class="fa fa-info-circle"></i> Aucun client assigné</li>';
          window.__proClientsLoaded = true;
          return;
        }
        list.innerHTML = d.clients.map(function(c) {
          var init = (c.name || c.email || '?').charAt(0).toUpperCase();
          var preview = c.last_msg ? escP(String(c.last_msg).slice(0,40)) : 'Aucun message';
          var susp = c.suspended == 1 ? ' sus' : '';
          return '<li class="pro-client-item" data-cid="'+c.id+'" data-cname="'+escP(c.name||'—')+'" data-cemail="'+escP(c.email)+'" onclick="openProConv(this)">'
            + '<div class="pro-cav'+susp+'">'+init+'</div>'
            + '<div class="pro-cdetails"><div class="pro-cname">'+escP(c.name||c.email)+'</div><div class="pro-cpreview">'+preview+'</div></div>'
            + '</li>';
        }).join('');
        window.__proClientsLoaded = true;
        // Raffraichir la recherche
        var searchEl = document.getElementById('pro-msg-search');
        if (searchEl) searchEl.addEventListener('input', function() {
          var q = this.value.toLowerCase();
          document.querySelectorAll('.pro-client-item').forEach(function(li){
            var nm = (li.getAttribute('data-cname')||'').toLowerCase();
            var em = (li.getAttribute('data-cemail')||'').toLowerCase();
            li.style.display = (!q || nm.includes(q) || em.includes(q)) ? '' : 'none';
          });
        });
      } catch(e) {
        list.innerHTML = '<li style="padding:16px;color:#e74c3c;font-size:13px;"><i class="fa fa-exclamation-circle"></i> ' + escP(e.message) + '</li>';
      }
      if (spin) spin.style.display = 'none';
    }

    async function openProConv(el) {
      // Active le client dans la liste
      document.querySelectorAll('.pro-client-item').forEach(function(li){ li.classList.remove('active'); });
      el.classList.add('active');
      var cid = el.getAttribute('data-cid');
      var cname = el.getAttribute('data-cname');
      var cemail = el.getAttribute('data-cemail');
      _proCurrentClient = cid;

      // Affichage
      var emptyEl = document.getElementById('pro-empty-conv');
      var activeEl = document.getElementById('pro-chat-active');
      if (emptyEl) emptyEl.style.display = 'none';
      if (activeEl) { activeEl.style.display = 'flex'; }

      var avEl = document.getElementById('pro-chat-av');
      var nmEl = document.getElementById('pro-chat-name');
      var emEl = document.getElementById('pro-chat-email');
      if (avEl) avEl.textContent = (cname || cemail || '?').charAt(0).toUpperCase();
      if (nmEl) nmEl.textContent = cname || '—';
      if (emEl) emEl.textContent = cemail || '';

      var msgsEl = document.getElementById('pro-chat-msgs');
      if (msgsEl) msgsEl.innerHTML = '<div style="text-align:center;padding:24px;color:#bbb"><i class="fa fa-spinner fa-spin"></i></div>';

      try {
        var r = await fetch('/api/admin/client/' + cid);
        if (!r.ok) throw new Error('Erreur ' + r.status);
        _proClientData = await r.json();
        renderProMessages();
        renderProProject();
      } catch(e) {
        if (msgsEl) msgsEl.innerHTML = '<div style="padding:20px;color:#e74c3c;"><i class="fa fa-exclamation-circle"></i> ' + escP(e.message) + '</div>';
      }
    }

    function renderProMessages() {
      var msgsEl = document.getElementById('pro-chat-msgs');
      if (!msgsEl || !_proClientData) return;
      var msgs = _proClientData.messages || [];
      if (!msgs.length) {
        msgsEl.innerHTML = '<div style="text-align:center;padding:30px;color:#bbb;font-size:13px;"><i class="fa fa-comment-o" style="font-size:28px;display:block;margin-bottom:8px;"></i>Aucun message</div>';
        return;
      }
      msgsEl.innerHTML = msgs.map(function(m) {
        var cls = m.sender === 'user' ? 'user' : m.sender === 'admin' ? 'admin' : 'bot';
        var lbl = m.sender === 'admin' ? '<small style="font-size:10px;opacity:.7;display:block;margin-bottom:2px;">Vous</small>' : '';
        var time = new Date(m.created_at).toLocaleString('fr-CA',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
        return '<div class="pro-mi '+cls+'">'+lbl+escP(m.content)+'<span class="pro-mi-time">'+time+'</span></div>';
      }).join('');
      msgsEl.scrollTop = msgsEl.scrollHeight;
    }

    function getProActiveProject() {
      var projs = (_proClientData && _proClientData.projects) ? _proClientData.projects : [];
      if (!projs || !projs.length) return null;
      return projs[0];
    }

    function parseProjectMetadata(p) {
      if (!p) return {};
      var mdStr = p.metadata || p.METADATA || '';
      if (!mdStr) return {};
      try { return JSON.parse(String(mdStr)); } catch { return {}; }
    }

    function renderProProject() {
      var panel = document.getElementById('pro-project-panel');
      if (!panel) return;
      var p = getProActiveProject();
      if (!p) { panel.style.display = 'none'; return; }

      var titleEl = document.getElementById('pro-project-title');
      var statusEl = document.getElementById('pro-project-status');
      var tlEl = document.getElementById('pro-project-timeline');
      var svcEl = document.getElementById('pro-project-services');
      var hintEl = document.getElementById('pro-quote-hint');

      var title = String(p.title || '').trim();
      if (!title) {
        title = String(p.type || 'Projet').replace(/_/g, ' ');
      }

      var status = String(p.status || p.project_status || '—');
      var statusLabels = {
        soumis: 'Soumis',
        en_cours: 'En cours',
        proposition: 'Proposition envoyée',
        demarre: 'Démarré',
        termine: 'Terminé',
        annule: 'Annulé'
      };

      if (titleEl) titleEl.textContent = title;
      if (statusEl) statusEl.textContent = statusLabels[status] || status || '—';

      var md = parseProjectMetadata(p);
      var timeline = Array.isArray(md.timeline) ? md.timeline : [];
      var services = Array.isArray(md.services) ? md.services : [];

      if (tlEl) {
        if (!timeline.length) {
          tlEl.innerHTML = '<li style="color:#bbb">Aucune étape</li>';
        } else {
          tlEl.innerHTML = timeline.map(function(s, idx) {
            var t = (s && s.titre) ? String(s.titre) : ('Étape ' + (idx + 1));
            var dur = (s && s.dureeEstimee) ? String(s.dureeEstimee) : '';
            return '<li>' + escP(t) + (dur ? ' <span style="color:#aaa">(' + escP(dur) + ')</span>' : '') + '</li>';
          }).join('');
        }
      }

      if (svcEl) {
        if (!services.length) {
          svcEl.innerHTML = '<li style="color:#bbb">Aucun service</li>';
        } else {
          svcEl.innerHTML = services.map(function(s) {
            var nm = s && s.nom ? String(s.nom) : 'Service';
            var pr = s && s.priorite ? String(s.priorite) : '';
            var prLbl = pr === 'obligatoire' ? 'Obligatoire' : pr === 'recommande' ? 'Recommandé' : pr === 'optionnel' ? 'Optionnel' : '';
            return '<li>' + escP(nm) + (prLbl ? ' <span style="color:#aaa">— ' + escP(prLbl) + '</span>' : '') + '</li>';
          }).join('');
        }
      }

      if (hintEl) {
        hintEl.textContent = (timeline.length || services.length)
          ? 'Base: étapes & services du dossier'
          : '';
      }

      panel.style.display = 'flex';
    }

    async function proRefreshProject() {
      if (!_proCurrentClient) return;
      try {
        var r = await fetch('/api/admin/client/' + _proCurrentClient);
        if (!r.ok) throw new Error('Erreur ' + r.status);
        _proClientData = await r.json();
        renderProMessages();
        renderProProject();
      } catch {
        // silent
      }
    }

