    function parseMoney(value){
      var s=String(value||'').trim().replace(/\s/g,'').replace(',', '.');
      if(!s) return null;
      var n=Number(s);
      return Number.isFinite(n) && n >= 0 ? n : null;
    }

    async function initProMode(){
      if(!isProModeUI()) return;
      try {
        var r = await fetch('/api/pro/profile', { headers: { 'Accept': 'application/json' } });
        if (!r.ok) return;
        var payload = await r.json();
        var p = (payload && payload.me) ? payload.me : payload;
        var loc = document.getElementById('proLocation'); if (loc) loc.value = p.location || '';
        var bio = document.getElementById('proBio'); if (bio) bio.value = p.bio || '';
        var services = Array.isArray(p.pro_services) ? p.pro_services : [];
        document.querySelectorAll('input[type=checkbox][id^="proSvc-"]').forEach(function(cb){
          var id = cb.id.replace('proSvc-','');
          cb.checked = services.indexOf(id) !== -1;
        });
        var prices = p.pro_pack_prices && typeof p.pro_pack_prices === 'object' ? p.pro_pack_prices : {};
        var map = { essentiel:'price-essentiel', standard:'price-standard', premium:'price-premium', tourisme:'price-tourisme' };
        Object.keys(map).forEach(function(k){
          var el=document.getElementById(map[k]);
          if(!el) return;
          var v = prices[k];
          el.value = (typeof v === 'number' && Number.isFinite(v)) ? String(v) : '';
        });
      } catch(e) {}
    }

    window.saveProProfile = async function(){
      if(!isProModeUI()) return;
      try {
        setHint('proProfileHint', 'Enregistrement…', true);
        var services=[];
        document.querySelectorAll('input[type=checkbox][id^="proSvc-"]:checked').forEach(function(cb){
          services.push(cb.id.replace('proSvc-',''));
        });
        var body = {
          location: (document.getElementById('proLocation')||{}).value || '',
          bio: (document.getElementById('proBio')||{}).value || '',
          pro_services: services
        };
        var r = await fetch('/api/pro/profile', {
          method:'PATCH',
          headers:{'Content-Type':'application/json','Accept':'application/json'},
          body: JSON.stringify(body)
        });
        var j = await r.json().catch(function(){ return {}; });
        if(!r.ok || j.error){ setHint('proProfileHint', j.error || 'Erreur lors de l\'enregistrement.', false); return; }
        setHint('proProfileHint', 'Profil enregistré.', true);
      } catch(e){ setHint('proProfileHint', 'Erreur réseau.', false); }
    };

    window.saveProTarifs = async function(){
      if(!isProModeUI()) return;
      try {
        setHint('proTarifsHint', 'Enregistrement…', true);
        var prices = {};
        var e = parseMoney((document.getElementById('price-essentiel')||{}).value); if (e !== null) prices.essentiel = e;
        var s = parseMoney((document.getElementById('price-standard')||{}).value); if (s !== null) prices.standard = s;
        var p = parseMoney((document.getElementById('price-premium')||{}).value); if (p !== null) prices.premium = p;
        var t = parseMoney((document.getElementById('price-tourisme')||{}).value); if (t !== null) prices.tourisme = t;
        var r = await fetch('/api/pro/profile', {
          method:'PATCH',
          headers:{'Content-Type':'application/json','Accept':'application/json'},
          body: JSON.stringify({ pro_pack_prices: prices })
        });
        var j = await r.json().catch(function(){ return {}; });
        if(!r.ok || j.error){ setHint('proTarifsHint', j.error || 'Erreur lors de l\'enregistrement.', false); return; }
        setHint('proTarifsHint', 'Tarifs enregistrés.', true);
      } catch(e){ setHint('proTarifsHint', 'Erreur réseau.', false); }
