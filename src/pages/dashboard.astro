    function _startInsidePresence() {
      var dot = document.getElementById('insidePresenceDot');
      var txt = document.getElementById('insidePresenceText');
      function updatePresence() {
        fetch('/api/presence', { method: 'POST' })
          .then(function(r){ return r.ok ? r.json() : null; })
          .then(function(d){
            if (!d) return;
            var count = (d.online || d.count || 1);
            if (dot) { dot.classList.remove('offline'); }
            if (txt) txt.textContent = count + ' membre' + (count > 1 ? 's' : '') + ' en ligne';
          })
          .catch(function(){
            if (dot) dot.classList.add('offline');
            if (txt) txt.textContent = 'Hors ligne';
          });
      }
      updatePresence();
      if (!window._insidePresenceTimer) {
        window._insidePresenceTimer = setInterval(updatePresence, 25000);
      }
    }

