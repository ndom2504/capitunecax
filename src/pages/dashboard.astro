              <button id="tarifs-btn-packs" onclick="switchTarifsMode('packs')" style="padding:9px 22px;border-radius:9px;border:none;background:var(--cap-orange);color:#fff;font-weight:700;font-size:13px;cursor:pointer;transition:.2s;"><i class="fa fa-cube"></i> Packs</button>
              <button id="tarifs-btn-services" onclick="switchTarifsMode('services')" style="padding:9px 22px;border-radius:9px;border:1.5px solid #ddd;background:#f9f9f9;color:#555;font-weight:700;font-size:13px;cursor:pointer;transition:.2s;"><i class="fa fa-list"></i> Services à la carte</button>
