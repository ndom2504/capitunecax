    async function proSendMsg() {
      var ta = document.getElementById('pro-reply-ta');
      var content = (ta ? ta.value : '').trim();
      if (!content || !_proCurrentClient) return;
      ta.value = '';
      ta.style.height = 'auto';
      try {
        var r = await fetch('/api/admin/reply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: _proCurrentClient, content: content }),
        });
        var d = await r.json();
        if (r.ok && d.ok !== false) {
          if (!_proClientData) _proClientData = { messages: [] };
          if (!_proClientData.messages) _proClientData.messages = [];
          _proClientData.messages.push({ sender: 'admin', content: content, created_at: new Date().toISOString() });
          renderProMessages();
        } else {
          showToast(d.error || 'Erreur envoi', 'error');
        }
      } catch(e) { showToast('Erreur réseau', 'error'); }
    }

    async function proSuggestMsg() {
      if (!_proClientData || !_proCurrentClient) return;
      var btn = document.getElementById('pro-ai-btn');
      var ta = document.getElementById('pro-reply-ta');
      if (btn) { btn.disabled = true; btn.innerHTML = '<span style="display:inline-block;width:12px;height:12px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;"></span>'; }
      var messages = (_proClientData.messages || []).map(function(m){ return { sender: m.sender, content: m.content }; });
      var project = {};
      var projs = _proClientData.projects || [];
      if (projs.length) { var p0 = projs[0]; if(p0.type) project.type=p0.type; if(p0.province) project.province=p0.province; if(p0.pays) project.pays=p0.pays; }
      try {
        var r = await fetch('/api/ai-suggest', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ messages, project }) });
        var d = await r.json();
        if (r.ok && d.suggestion) {
