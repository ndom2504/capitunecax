    async function proSendQuote() {
      if (!_proCurrentClient) return;
      var totalEl = document.getElementById('pro-quote-total');
      var curEl = document.getElementById('pro-quote-currency');
      var delayEl = document.getElementById('pro-quote-delay');
      var noteEl = document.getElementById('pro-quote-note');
      var totalRaw = (totalEl ? totalEl.value : '').trim().replace(',', '.');
      var total = Number(totalRaw);
      var currency = (curEl ? curEl.value : 'CAD');
      var estimated_delay = (delayEl ? delayEl.value : '').trim();
      var note = (noteEl ? noteEl.value : '').trim();
      if (!Number.isFinite(total) || total <= 0) {
        showToast('Total invalide', 'error');
        return;
      }
      try {
        var r = await fetch('/api/pro/quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ client_id: _proCurrentClient, total: total, currency: currency, estimated_delay: estimated_delay, note: note })
        });
        var j = await r.json().catch(function(){ return {}; });
        if (!r.ok || j.error) throw new Error(j.error || ('Erreur ' + r.status));
        if (totalEl) totalEl.value = '';
        if (delayEl) delayEl.value = '';
        if (noteEl) noteEl.value = '';
        await proRefreshProject();
        showToast('Proposition envoyée ✓', 'success');
      } catch(e) {
        showToast(e.message || 'Erreur', 'error');
      }
