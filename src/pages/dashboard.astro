    window.carouselGoTo = function(idx) {
      if (idx < 0 || idx >= PACKS.length) return;
      _carIdx = idx;
      var track = document.getElementById('carouselTrack');
      if (track) track.style.transform = 'translateX(-' + (_carIdx * 100) + '%)';
      _updateCarouselArrows();
    };

