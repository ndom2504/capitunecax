    function restoreState() {
      try {
        var rp = localStorage.getItem('capitune_projet');
        if (rp) {
          ST.projet = JSON.parse(rp);
          ST.soumis = localStorage.getItem('capitune_soumis')==='true';
          restoreProjetForm(ST.projet);
          if (ST.projet.type) markStepDone('step-projet');
          // Réafficher le bouton annulation si projet existant
          var btnC = document.getElementById('btnCancelProjet');
          if (btnC) btnC.style.display = '';
        }
        var rs = localStorage.getItem('capitune_service');
        if (rs) {
          var sv = JSON.parse(rs);
          // Démarrer à 0 par défaut : on ne restaure la sélection que si le projet a été soumis.
          if (ST.soumis) {
            // Protection anti-anciennes valeurs (ancienne logique) :
            // si un pack est sauvegardé avec un prix < prix de base actuel, on considère l'état comme obsolète.
            var savedPackId = sv.packId || null;
            var savedPackPrice = Number(sv.packPrice || 0);
            var basePack = savedPackId && typeof PACKS !== 'undefined'
              ? (PACKS.find(function(p){ return p.id === savedPackId; }) || null)
              : null;

            if (basePack && savedPackPrice > 0 && savedPackPrice < Number(basePack.price || 0)) {
              // État obsolète -> reset
              ST.pack = null;
              ST.packPrice = 0;
              ST.carte = {};
              ST.packItemsSelected = {};
              try {
                localStorage.removeItem('capitune_service');
                localStorage.removeItem('capitune_soumis');
              } catch(_e) {}
            } else {
              ST.pack = savedPackId;
              ST.packPrice = savedPackPrice || 0;
              ST.carte = sv.carte || {};
            }
            markStepDone('step-services');
            markStepActive('step-messagerie');
          } else {
            ST.pack=null;
            ST.packPrice=0;
            ST.carte={};
            ST.packItemsSelected={};
            // Empêche une restauration automatique du navigateur sur les checkbox
            try {
              document.querySelectorAll('.option').forEach(function(cb){cb.checked=false;});
              document.querySelectorAll('.pack-card,.service-carte-item').forEach(function(el){el.classList.remove('selected');});
            } catch(_e) {}
          }
        }
        // Onglet de depart
        // En mode PRO, l'onglet "projet" est caché : on démarre sur le dashboard.
        var isProUI = document.body && document.body.classList.contains('is-pro-mode');
        if (isProUI) {
          switchTab('dashboard');
          return;
        }
        switchTab('dashboard');
      } catch(e) {
        switchTab('dashboard');
      }
    }

    function restoreProjetForm(d) {
      if (!d) return;
      var ids=['proj-type','proj-province','proj-pays','proj-nbpersonnes','proj-delai','proj-diplome','proj-domaine','proj-experience','proj-famille','proj-enfants','proj-conjoint','proj-notes'];
      ids.forEach(function(id) {
        var k=id.replace('proj-',''); var el=document.getElementById(id);
        if (el && d[k] !== undefined) el.value=d[k];
      });
      // Mettre à jour le filtre pays
      var pf=document.getElementById('pays-filter');
      if(pf && d['pays']) { pf.value=d['pays']; filterPays(d['pays']); }
      // Domaine autre
      if(d.domaine && !document.querySelector('#proj-domaine option[value="'+d.domaine+'"]')){
        var autre=document.getElementById('proj-domaine-autre');
        if(autre){autre.value=d.domaine;autre.style.display='block';
          var sel=document.getElementById('proj-domaine');if(sel)sel.value='autre';}
      }
      // Langues
      if (d.langues) d.langues.forEach(function(lang) {
        document.querySelectorAll('.langue-checkbox input[type=checkbox]').forEach(function(inp){
          if(inp.value===lang){inp.checked=true;inp.closest('.langue-checkbox').classList.add('checked');}
        });
      });
