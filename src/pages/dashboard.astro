    // ============================================================
    //  PARAMÈTRES — PHOTO + INFOS + NOTIFICATIONS
    // ============================================================

    window.handleAvatarUpload = function handleAvatarUpload(input) {
      if (!input.files || !input.files[0]) return;
      var file = input.files[0];
      // Limite brute 10 Mo avant compression
      if (file.size > 10 * 1024 * 1024) {
        showToast('Image trop lourde (maximum 10 Mo).', 'error');
        return;
      }
      // Aperçu de chargement
      var imgEl = document.getElementById('avatarUploadImg');
      if (imgEl) imgEl.innerHTML = '<i class="fa fa-spinner fa-spin" style="font-size:36px;color:#ff9408;"></i>';

      var reader = new FileReader();
      reader.onload = function(e) {
        var originalSrc = e.target.result;
        // Compression via canvas
        var image = new Image();
        image.onload = function() {
          var MAX = 280; // px max côté
          var w = image.width, h = image.height;
          if (w > h) { if (w > MAX) { h = Math.round(h * MAX / w); w = MAX; } }
          else        { if (h > MAX) { w = Math.round(w * MAX / h); h = MAX; } }
          var canvas = document.createElement('canvas');
          canvas.width = w; canvas.height = h;
          var ctx = canvas.getContext('2d');
          ctx.drawImage(image, 0, 0, w, h);
          var compressed = canvas.toDataURL('image/jpeg', 0.82);
          // Sauvegarder et afficher
          try {
            localStorage.setItem('capitune_avatar', compressed);
          } catch(storageErr) {
            // Si localStorage plein, essayer qualité réduite
            try { localStorage.setItem('capitune_avatar', canvas.toDataURL('image/jpeg', 0.55)); } catch(e2) {}
          }
          applyAvatar(compressed);
          var btnRm = document.getElementById('btnRemovePhoto');
          if (btnRm) btnRm.style.display = '';
          showToast('Photo de profil mise à jour ✓');
        };
        image.onerror = function() { showToast('Format non supporté.', 'error'); };
        image.src = originalSrc;
      };
      reader.readAsDataURL(file);
    }

    window.applyAvatar = function applyAvatar(dataUrl) {
      // Uploader dans l'onglet paramètres
      var img = document.getElementById('avatarUploadImg');
      if (img) img.innerHTML = '<img src="'+dataUrl+'" alt="avatar">';
      // Header nav
      var hd = document.getElementById('avatarDisplay');
      if (hd) hd.innerHTML = '<img src="'+dataUrl+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" alt="avatar">';
      // Dropdown
      var da = document.getElementById('dropdownAvatar');
      if (da) da.innerHTML = '<img src="'+dataUrl+'" style="width:44px;height:44px;object-fit:cover;border-radius:50%;" alt="avatar">';
    }

    window.removeProfilePhoto = function removeProfilePhoto() {
      localStorage.removeItem('capitune_avatar');
      var img = document.getElementById('avatarUploadImg');
      if (img) img.innerHTML = '<i class="fa fa-user" style="font-size:44px;color:#bbb;"></i>';
      var hd = document.getElementById('avatarDisplay');
      if (hd) hd.innerHTML = '<i class="fa fa-user"></i>';
      var da = document.getElementById('dropdownAvatar');
      if (da) da.innerHTML = '<i class="fa fa-user" style="font-size:20px;"></i>';
      var btnRm = document.getElementById('btnRemovePhoto');
      if (btnRm) btnRm.style.display = 'none';
    }

    window.saveParametres = function saveParametres() {
      var name     = (document.getElementById('settings-name')     ||{}).value || '';
      var phone    = (document.getElementById('settings-phone')    ||{}).value || '';
      var location = (document.getElementById('settings-location') ||{}).value || '';
      var bio      = (document.getElementById('settings-bio')      ||{}).value || '';
      var prefs = { name: name, phone: phone, location: location, bio: bio };
      localStorage.setItem('capitune_prefs', JSON.stringify(prefs));
      // Persistance D1
      dbSync('/api/user/profile', 'PUT', { name: name, phone: phone, location: location, bio: bio });
      // Mettre à jour le nom affiché dans le header
      if (name) {
        document.querySelectorAll('#headerName,#dropdownName').forEach(function(el){ el.textContent = name; });
        var an = document.getElementById('avatarName');
        if (an) an.textContent = name;
      }
      // Toast
      showToast('Paramètres enregistrés ✓');
    }

    window.saveNotifPrefs = function saveNotifPrefs() {
      var notifs = {
        email: document.getElementById('notif-email') ? document.getElementById('notif-email').checked : true,
        rdv:   document.getElementById('notif-rdv')   ? document.getElementById('notif-rdv').checked   : true,
        msg:   document.getElementById('notif-msg')   ? document.getElementById('notif-msg').checked   : true
      };
      localStorage.setItem('capitune_notifs', JSON.stringify(notifs));
      // Persistance D1
      dbSync('/api/user/profile', 'PUT', { notif_email: notifs.email, notif_rdv: notifs.rdv, notif_msg: notifs.msg });
      showToast('Préférences notifications enregistrées ✓');
    }

    function loadParametres() {
      // Avatar
      var avatar = localStorage.getItem('capitune_avatar');
      if (avatar) {
        applyAvatar(avatar);
        var btnRm = document.getElementById('btnRemovePhoto');
        if (btnRm) btnRm.style.display = '';
      }
      // Infos perso
      try {
        var prefs = JSON.parse(localStorage.getItem('capitune_prefs') || '{}');
        if (document.getElementById('settings-name'))     document.getElementById('settings-name').value     = prefs.name     || '';
        if (document.getElementById('settings-phone'))    document.getElementById('settings-phone').value    = prefs.phone    || '';
        if (document.getElementById('settings-location')) document.getElementById('settings-location').value = prefs.location || '';
        if (document.getElementById('settings-bio'))      document.getElementById('settings-bio').value      = prefs.bio      || '';
        if (prefs.name) {
          document.querySelectorAll('#headerName,#dropdownName').forEach(function(el){ el.textContent = prefs.name; });
          var an = document.getElementById('avatarName'); if (an) an.textContent = prefs.name;
        }
      } catch(e) {}
      // Email depuis cookie session
      try {
        var c = document.cookie.split(';').map(function(x){return x.trim();}).find(function(x){return x.startsWith('capitune_user=');});
        if (c) {
          var u = JSON.parse(decodeURIComponent(c.split('=').slice(1).join('=')));
          if (u.email && document.getElementById('settings-email')) document.getElementById('settings-email').value = u.email;
          if (u.name && !document.getElementById('settings-name').value) document.getElementById('settings-name').value = u.name;
        }
      } catch(e) {}
      // Notifs
      try {
        var notifs = JSON.parse(localStorage.getItem('capitune_notifs') || '{}');
        if (document.getElementById('notif-email') && notifs.email !== undefined) document.getElementById('notif-email').checked = notifs.email;
        if (document.getElementById('notif-rdv')   && notifs.rdv   !== undefined) document.getElementById('notif-rdv').checked   = notifs.rdv;
        if (document.getElementById('notif-msg')   && notifs.msg   !== undefined) document.getElementById('notif-msg').checked   = notifs.msg;
      } catch(e) {}
      // Synchronisation D1 → écraser localStorage si données serveur disponibles
      fetch('/api/user/profile').then(function(r){ return r.ok ? r.json() : null; }).then(function(profile) {
        if (!profile) return;
        var fields = [['settings-name','name'],['settings-phone','phone'],['settings-location','location'],['settings-bio','bio'],['settings-email','email']];
        fields.forEach(function(pair) {
          var el = document.getElementById(pair[0]);
          if (el && profile[pair[1]]) el.value = profile[pair[1]];
        });
        if (profile.name) {
          document.querySelectorAll('#headerName,#dropdownName').forEach(function(el){ el.textContent = profile.name; });
          var an = document.getElementById('avatarName'); if (an) an.textContent = profile.name;
          localStorage.setItem('capitune_prefs', JSON.stringify({ name: profile.name, phone: profile.phone, location: profile.location, bio: profile.bio }));
        }
        if (profile.notif_email !== undefined && document.getElementById('notif-email')) document.getElementById('notif-email').checked = profile.notif_email;
        if (profile.notif_rdv   !== undefined && document.getElementById('notif-rdv'))   document.getElementById('notif-rdv').checked   = profile.notif_rdv;
        if (profile.notif_msg   !== undefined && document.getElementById('notif-msg'))   document.getElementById('notif-msg').checked   = profile.notif_msg;
      }).catch(function(){});
      // Bouton cancel si projet existant
      var projet = localStorage.getItem('capitune_projet');
      var btnCancel = document.getElementById('btnCancelProjet');
      if (btnCancel && projet) btnCancel.style.display = '';
    }

    // ============================================================
    //  ANNULATION / SUPPRESSION DEMANDE
    // ============================================================

    window.confirmCancelDemande = function() {
      var modal = document.getElementById('modalCancelDemande');
      if (modal) modal.classList.add('open');
    };

    window.executeCancelDemande = function() {
      // Effacer toutes les données client
      localStorage.removeItem('capitune_projet');
      localStorage.removeItem('capitune_cart');
      localStorage.removeItem('capitune_pack');
      // Persistance D1
      dbSync('/api/projet', 'DELETE', null);
      // Réinitialiser l'état en mémoire
      ST.projet = null; ST.pack = null; ST.carte = {}; ST.soumis = false; ST.paye = false;
      // Réinitialiser les étapes visuelles
      ['step-projet','step-services','step-messagerie','step-paiements','step-suivi'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) { el.classList.remove('done','active'); var n=el.querySelector('.step-num'); if(n && id==='step-projet')n.textContent='1'; }
      });
      markStepActive('step-projet');
      // Cacher le bouton annuler
      var btnC = document.getElementById('btnCancelProjet');
      if (btnC) btnC.style.display = 'none';
      // Réinitialiser le formulaire projet
      ['proj-type','proj-province','proj-pays','proj-diplome','proj-domaine','proj-experience','proj-famille','proj-enfants','proj-conjoint','proj-delai','proj-nbpersonnes'].forEach(function(id) {
        var el = document.getElementById(id); if (el) el.value = '';
      });
      var notes = document.getElementById('proj-notes'); if (notes) notes.value = '';
      document.querySelectorAll('.langue-checkbox input:checked').forEach(function(i){ i.checked=false; i.closest('.langue-checkbox').classList.remove('checked'); });
      // Retirer badge soumis si affiché
      var badge = document.getElementById('badge-projet-soumis'); if (badge) badge.style.display = 'none';
      closeModal();
      switchTab('projet');
      showToast('Demande annulée. Vous pouvez démarrer un nouveau projet.', 'info');
    };

    // ============================================================
    //  NOTRE ÉQUIPE — chargement des profils pros/admins
    // ============================================================
    var _teamLoaded = false;
    function loadTeam() {
      if (_teamLoaded) return;
      var container = document.getElementById('team-grid-container');
      if (!container) return;

      function esc(s){
        return String(s||'').replace(/[&<>"']/g, function(c){
          return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;';
        });
      }
      function isHttpUrl(u){ return /^https?:\/\//i.test(String(u||'')); }

      fetch('/api/team')
        .then(function(r){ return r.json(); })
        .then(function(data){
          _teamLoaded = true;
          var members = data.team || [];
          window.__teamMembers = members;
          if (!members.length) {
            container.innerHTML = '<div class="team-loading"><i class="fa fa-users"></i><br><br>Aucun profil disponible pour le moment.</div>';
            return;
          }
          var html = '<div class="team-grid">';
          members.forEach(function(m, idx){
            var initials = (m.name||'?').split(' ').map(function(w){return w[0]||'';}).slice(0,2).join('').toUpperCase();
            var avatarUrl = isHttpUrl(m.avatar_key) ? String(m.avatar_key) : '';
            html += '<div class="team-card">';
            html += '<div class="team-avatar">' + (avatarUrl ? ('<img src="'+esc(avatarUrl)+'" alt="avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">') : (initials||'<i class="fa fa-user"></i>')) + '</div>';
            html += '<p class="team-name">' + esc(m.name||'Conseiller CAPITUNE') + '</p>';
            html += '<span class="team-badge"><i class="fa fa-star"></i> Conseiller Pro</span>';
            if (m.location) html += '<p class="team-location"><i class="fa fa-map-marker"></i> ' + esc(m.location) + '</p>';
            if (m.bio) html += '<p class="team-bio">' + esc(m.bio) + '</p>';
            html += '<div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:20px;">';
            html += '<button class="team-contact-btn" style="margin-top:0;" onclick="openTeamProfile('+idx+'); return false;"><i class="fa fa-eye"></i> Voir</button>';
            html += '<button class="team-contact-btn" style="margin-top:0;" onclick="switchTab(\'messagerie\'); return false;"><i class="fa fa-envelope"></i> Contacter</button>';
            html += '</div>';
            html += '</div>';
          });
          html += '</div>';
          container.innerHTML = html;
        })
        .catch(function(){
          container.innerHTML = '<div class="team-loading" style="color:#e74c3c;"><i class="fa fa-exclamation-circle"></i> Impossible de charger l\'\u00e9quipe.</div>';
        });
    }
    window.loadTeam = loadTeam;

    window.closeTeamProfile = function(){
      if (window.closeModal) window.closeModal();
      var modal = document.getElementById('teamProfileModal');
      if (modal) modal.classList.remove('open');
    };

    window.openTeamProfile = function(idx){
      try {
        var members = window.__teamMembers || [];
        var m = members[idx];
        if (!m) return;
        var modal = document.getElementById('teamProfileModal');
        if (!modal) return;

        function esc(s){
          return String(s||'').replace(/[&<>"']/g, function(c){
            return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;';
          });
        }
        function isHttpUrl(u){ return /^https?:\/\//i.test(String(u||'')); }
        var avatarUrl = isHttpUrl(m.avatar_key) ? String(m.avatar_key) : '';
        var initials = (m.name||'?').split(' ').map(function(w){return w[0]||'';}).slice(0,2).join('').toUpperCase();
        var tpA = document.getElementById('tpAvatar');
        if (tpA) {
          tpA.innerHTML = avatarUrl
            ? ('<img src="'+esc(avatarUrl)+'" alt="avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">')
            : esc(initials||'?');
        }
        setText('tpName', m.name || 'Conseiller CAPITUNE');
        setText('tpLocation', m.location ? ('📍 ' + m.location) : '');
        setText('tpBio', m.bio || '');

        var svcWrap = document.getElementById('tpServices');
        var serviceLabels = {
          consultation: 'Consultation stratégique',
          orientation: 'Orientation programme',
          dossier: 'Montage du dossier',
          suivi: 'Suivi administratif',
          recherche: 'Recherche employeur',
          integration: 'Aide à l\'installation'
        };
        var svcs = Array.isArray(m.pro_services) ? m.pro_services : [];
        if (svcWrap) {
          if (!svcs.length) svcWrap.innerHTML = '<span style="color:#888;font-size:13px;">—</span>';
          else svcWrap.innerHTML = svcs.map(function(id){
            return '<span class="service-pill">'+esc(serviceLabels[id] || id)+'</span>';
          }).join('');
        }

        var tarifsWrap = document.getElementById('tpTarifs');
        var prices = (m.pro_pack_prices && typeof m.pro_pack_prices === 'object') ? m.pro_pack_prices : {};
        var packs = [
          { id:'essentiel', name:'Essentiel' },
          { id:'standard', name:'Standard' },
          { id:'premium', name:'Premium' },
          { id:'tourisme', name:'Tourisme' }
        ];
        if (tarifsWrap) {
          tarifsWrap.innerHTML = packs.map(function(pk){
            var v = prices[pk.id];
            var priceTxt = (typeof v === 'number' && Number.isFinite(v)) ? (v.toLocaleString('fr-CA') + ' $') : '—';
            return '<div class="tarif-card">'
              + '<div class="tarif-name">'+esc(pk.name)+'</div>'
              + '<div class="tarif-price">'+esc(priceTxt)+' <span>CAD</span></div>'
              + '</div>';
          }).join('');
        }

        modal.classList.add('open');
      } catch(e) {}
    };

    // ============================================================
    //  TOAST NOTIFICATION
    // ============================================================
    function showToast(message, type) {
      var existing = document.getElementById('cap-toast');
      if (existing) existing.remove();
      var toast = document.createElement('div');
      toast.id = 'cap-toast';
      var bg = (type === 'info') ? '#2980b9' : (type === 'error') ? '#e74c3c' : '#27ae60';
      toast.style.cssText = 'position:fixed;bottom:28px;right:28px;background:'+bg+';color:#fff;padding:13px 22px;border-radius:10px;font-size:14px;font-weight:600;z-index:9999;box-shadow:0 6px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:10px;animation:slideInToast .3s ease;max-width:340px;';
      toast.innerHTML = '<i class="fa fa-'+(type==='error'?'times-circle':type==='info'?'info-circle':'check-circle')+'"></i> ' + message;
      if (!document.getElementById('toast-style')) {
        var s = document.createElement('style'); s.id = 'toast-style';
        s.textContent = '@keyframes slideInToast{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}';
        document.head.appendChild(s);
      }
      document.body.appendChild(toast);
      setTimeout(function(){ toast.style.opacity='0'; toast.style.transition='opacity .4s'; setTimeout(function(){ toast.remove(); }, 400); }, 3500);
    }
    window.showToast = showToast;

    </script>
