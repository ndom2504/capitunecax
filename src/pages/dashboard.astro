      if(document.getElementById('paypal-sdk-script')) return; // déjà en cours
      var s=document.createElement('script');
      s.id='paypal-sdk-script';
      s.src='https://www.paypal.com/sdk/js?client-id='+cid+'&currency=CAD&intent=capture';
      s.onload=function(){window._paypalReady=true;renderPayPalButtons();};
      s.onerror=function(){document.getElementById('paypal-buttons-container').innerHTML='<p style="color:#e74c3c;font-size:13px;">Impossible de charger PayPal. Vérifiez votre connexion.</p>';};
      document.head.appendChild(s);
