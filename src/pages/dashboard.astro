      try {
        var check = el.querySelector('.capi-svc-check');
        if (check) check.textContent = svc.sel ? '✓' : '';
      } catch(_e) {}
      try {
        var total = (_capiState.services||[]).filter(function(s){return s && s.sel;}).reduce(function(a,s){return a + (Number(s.prix||0)||0);}, 0);
        var totalEl = document.getElementById('capiSvcTotal');
        if (totalEl) totalEl.textContent = (typeof formatMoney==='function') ? formatMoney(total) : (total + ' $');
      } catch(_e) {}
    };

