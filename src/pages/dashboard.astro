    function loadParametres() {
      // Avatar
      var avatar = localStorage.getItem('capitune_avatar');
      if (avatar) {
        applyAvatar(avatar);
        var btnRm = document.getElementById('btnRemovePhoto');
        if (btnRm) btnRm.style.display = '';
      }
      // Infos perso
      try {
        var prefs = JSON.parse(localStorage.getItem('capitune_prefs') || '{}');
        if (document.getElementById('settings-name'))     document.getElementById('settings-name').value     = prefs.name     || '';
        if (document.getElementById('settings-phone'))    document.getElementById('settings-phone').value    = prefs.phone    || '';
        if (document.getElementById('settings-location')) document.getElementById('settings-location').value = prefs.location || '';
        if (document.getElementById('settings-bio'))      document.getElementById('settings-bio').value      = prefs.bio      || '';
        if (prefs.name) {
          document.querySelectorAll('#headerName,#dropdownName').forEach(function(el){ el.textContent = prefs.name; });
          var an = document.getElementById('avatarName'); if (an) an.textContent = prefs.name;
        }
      } catch(e) {}
      // Email depuis cookie session
      try {
        var c = document.cookie.split(';').map(function(x){return x.trim();}).find(function(x){return x.startsWith('capitune_user=');});
        if (c) {
          var u = JSON.parse(decodeURIComponent(c.split('=').slice(1).join('=')));
          if (u.email && document.getElementById('settings-email')) document.getElementById('settings-email').value = u.email;
          if (u.name && !document.getElementById('settings-name').value) document.getElementById('settings-name').value = u.name;
        }
      } catch(e) {}
      // Notifs
      try {
        var notifs = JSON.parse(localStorage.getItem('capitune_notifs') || '{}');
        if (document.getElementById('notif-email') && notifs.email !== undefined) document.getElementById('notif-email').checked = notifs.email;
        if (document.getElementById('notif-rdv')   && notifs.rdv   !== undefined) document.getElementById('notif-rdv').checked   = notifs.rdv;
        if (document.getElementById('notif-msg')   && notifs.msg   !== undefined) document.getElementById('notif-msg').checked   = notifs.msg;
      } catch(e) {}
      // Synchronisation D1 → écraser localStorage si données serveur disponibles
      fetch('/api/user/profile').then(function(r){ return r.ok ? r.json() : null; }).then(function(profile) {
        if (!profile) return;
        var fields = [['settings-name','name'],['settings-phone','phone'],['settings-location','location'],['settings-bio','bio'],['settings-email','email']];
        fields.forEach(function(pair) {
          var el = document.getElementById(pair[0]);
          if (el && profile[pair[1]]) el.value = profile[pair[1]];
        });
        if (profile.name) {
          document.querySelectorAll('#headerName,#dropdownName').forEach(function(el){ el.textContent = profile.name; });
          var an = document.getElementById('avatarName'); if (an) an.textContent = profile.name;
          localStorage.setItem('capitune_prefs', JSON.stringify({ name: profile.name, phone: profile.phone, location: profile.location, bio: profile.bio }));
        }
        if (profile.notif_email !== undefined && document.getElementById('notif-email')) document.getElementById('notif-email').checked = profile.notif_email;
        if (profile.notif_rdv   !== undefined && document.getElementById('notif-rdv'))   document.getElementById('notif-rdv').checked   = profile.notif_rdv;
        if (profile.notif_msg   !== undefined && document.getElementById('notif-msg'))   document.getElementById('notif-msg').checked   = profile.notif_msg;

        // Avatar : DB prioritaire sur localStorage ; si DB vide → syncer le localStorage vers DB
        var dbAvatar = String(profile.avatar_key || '').trim();
        var lsAvatar = String(localStorage.getItem('capitune_avatar') || '').trim();
        if (dbAvatar && (/^https?:\/\//i.test(dbAvatar) || /^data:image\//i.test(dbAvatar))) {
          // DB a un avatar valide → appliquer et mettre à jour localStorage
          applyAvatar(dbAvatar);
          try { localStorage.setItem('capitune_avatar', dbAvatar); } catch(e) {}
          var btnRm = document.getElementById('btnRemovePhoto');
          if (btnRm) btnRm.style.display = '';
        } else if (lsAvatar && (/^data:image\//i.test(lsAvatar) || /^https?:\/\//i.test(lsAvatar))) {
          // localStorage a un avatar mais DB est vide → syncer vers DB maintenant
          dbSync('/api/user/profile', 'PUT', { avatar_key: lsAvatar });
        }

        // Devise + premium
        if (profile.currency_code) {
          window.__currencyCode = String(profile.currency_code || 'CAD').toUpperCase();
          var cur = document.getElementById('settings-currency');
          if (cur) cur.value = window.__currencyCode;
        }
        window.__premiumActive = !!profile.premium_active;
        window.__premiumExpiresAt = profile.premium_expires_at || null;
        try { rerenderServicesUI(); } catch(_e) {}
      }).catch(function(){});
      // Bouton cancel si projet existant
      var projet = localStorage.getItem('capitune_projet');
      var btnCancel = document.getElementById('btnCancelProjet');
      if (btnCancel && projet) btnCancel.style.display = '';
    }

