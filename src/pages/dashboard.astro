                  <a href="#" onclick="switchTab('projet'); return false;"><i class="fa fa-folder-open"></i> Projet</a>
                </li>
                <li class="dash-nav-item" data-tab="services">
                  <a href="#" onclick="switchTab('services'); return false;"><i class="fa fa-briefcase"></i> Services</a>
                </li>
                <li class="dash-nav-item" data-tab="messagerie">
                  <a href="#" onclick="switchTab('messagerie'); return false;"><i class="fa fa-envelope"></i> Messagerie</a>
                </li>
                <li class="dash-nav-item" data-tab="paiements">
