    //  Rendu dynamique des packs (Style Bootstrap)
// ─── Carousel state ─────────────────────────────────────────────────────
    var _carIdx = 0;

    function renderPacks() {
      var track = document.getElementById('carouselTrack');
      var dotsEl = document.getElementById('carouselDots');
      if (!track) return;

      _carIdx = 0;

      track.innerHTML = PACKS.map(function(p, i) {
        var svcsHtml = p.services.map(function(s) {
          return '<li class="cs-svc-item" onclick="event.stopPropagation()">' +
            '<input type="checkbox" class="option" id="cs-cb-'+p.id+'-'+s.id+'" data-pid="'+p.id+'" data-sid="'+s.id+'" data-price="'+s.price+'" onchange="togglePackSvc(\''+p.id+'\',\''+s.id+'\','+s.price+', this)">' +
            '<span class="cs-svc-name">'+escHtml(s.name)+'</span>' +
            '<span class="cs-svc-price cs-svc-price-tag">'+formatMoney(s.price)+'</span>' +
            '</li>';
        }).join('');

        var popularBadge = p.popular
          ? '<div class="cs-popular-badge">&#11088; Le plus populaire</div>'
          : '';

        return '<div class="carousel-slide">' +
          '<div class="cs-card">' +
            '<div class="cs-left" data-pack="'+p.id+'">' +
              '<div>' +
                '<div class="cs-emoji">'+escHtml(p.badge||'📦')+'</div>' +
                '<div class="cs-name">'+escHtml(p.name)+'</div>' +
                '<div class="cs-desc">'+escHtml(p.desc||'')+'</div>' +
              '</div>' +
              '<div class="cs-price-block">' +
                '<div class="cs-price"><sub>$</sub>'+p.price.toLocaleString('fr-CA')+'<sub style="font-size:13px"> CAD</sub></div>' +
                popularBadge +
              '</div>' +
              '<button class="cs-btn pack-price" id="pack-'+p.id+'" data-base="'+p.price+'" onclick="setPackMode(\''+p.id+'\','+p.price+',\'full\')">' +
                '&#10003; Choisir ce pack' +
              '</button>' +
            '</div>' +
            '<div class="cs-right">' +
              '<div class="cs-right-label">Services inclus &mdash; personnalisez votre sélection</div>' +
              '<ul class="cs-svc-list">' + svcsHtml + '</ul>' +
              '<div class="cs-bottom">' +
                '<span class="cs-subtotal-label">Sous-total sélectionné</span>' +
                '<span class="cs-subtotal-val" id="cs-sub-'+p.id+'">'+formatMoney(0)+'</span>' +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');

      // Dots
      if (dotsEl) {
        dotsEl.innerHTML = PACKS.map(function(_p, i) {
          return '<button class="carousel-dot' + (i===0?' active':'') + '" onclick="carouselGoTo('+i+')" aria-label="Pack '+(i+1)+'"></button>';
        }).join('');
      }

      // Reset position
      track.style.transform = 'translateX(0)';
      _updateCarouselArrows();
    }

    function _updateCarouselArrows() {
      var prev = document.getElementById('carouselPrev');
      var next = document.getElementById('carouselNext');
      if (prev) prev.disabled = _carIdx === 0;
      if (next) next.disabled = _carIdx === PACKS.length - 1;
      // Active dot
      document.querySelectorAll('.carousel-dot').forEach(function(d, i) {
        d.classList.toggle('active', i === _carIdx);
      });
    }

    window.carouselNav = function(dir) {
      carouselGoTo(_carIdx + dir);
    };

    window.carouselGoTo = function(idx) {
      if (idx < 0 || idx >= PACKS.length) return;
      _carIdx = idx;
      var track = document.getElementById('carouselTrack');
      if (track) track.style.transform = 'translateX(-' + (_carIdx * 100) + '%)';
      _updateCarouselArrows();
    };

    function restorePackOptionChecks() {
      try {
        var items = ST.packItemsSelected || {};
        document.querySelectorAll('.option').forEach(function(cb){
          var pid = cb.getAttribute('data-pid');
          var sid = cb.getAttribute('data-sid');
          if (!pid || !sid) return;
          cb.checked = !!(items[pid] && items[pid][sid]);
        });
      } catch(_e) {}
    }

    function renderCarteServicesFromCatalog() {
      var grid = document.getElementById('servicesCarteGrid');
      if (!grid) return;
      var catalog = window.__catalog;
      if (!catalog || !Array.isArray(catalog.services)) return;
      grid.innerHTML = catalog.services.map(function(s){
        var id = s.id;
        var price = Number(s.basePrice || 0);
        var icon = s.icon || '🧩';
        var desc = s.description || '';
        return '<div class="service-carte-item" id="carte-'+id+'" onclick="toggleCarte(\''+id+'\','+price+')">'
          + '<div class="service-carte-icon">'+escHtml(icon)+'</div>'
          + '<div class="service-carte-name">'+escHtml(s.name)+'</div>'
          + (desc ? ('<div style="font-size:11px;color:#999;margin-bottom:6px;">'+escHtml(desc)+'</div>') : '')
          + '<div class="service-carte-price">'+formatMoney(price)+'</div>'
          + '</div>';
      }).join('');
    }

    async function loadCatalog() {
      try {
        var r = await fetch('/api/catalog', { headers: { 'Accept': 'application/json' } });
        if (!r.ok) return null;
        var j = await r.json().catch(function(){ return null; });
        if (!j) return null;
        window.__catalog = j;
        // Construire map services
        try {
          window.__catalogServiceMap = {};
          if (Array.isArray(j.services)) {
            j.services.forEach(function(s){ if (s && s.id) window.__catalogServiceMap[s.id] = s; });
          }
        } catch(_e) {}

        // Convertir en PACKS pour la vue client
        if (Array.isArray(j.packages) && Array.isArray(j.services)) {
          var svcMap = {};
          j.services.forEach(function(s){ svcMap[s.id] = s; });
          PACKS = j.packages.map(function(p){
            var services = Array.isArray(p.services) ? p.services : [];
            return {
              id: p.id,
              name: p.name,
              badge: p.badge || '📦',
              desc: p.description || '',
              price: Number(p.price || 0),
              popular: !!p.popular,
              services: services.map(function(sid){
                var s = svcMap[sid] || { id: sid, name: sid, basePrice: 0 };
                return { id: sid, name: s.name || sid, price: Number(s.basePrice || 0) };
              })
            };
          });
        }
        return j;
      } catch(_e) {
        return null;
      }
    }

