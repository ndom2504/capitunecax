      if(card) card.classList.add('selected');
      ST.pack=packId; ST.packMode='full'; // Always full base price + options
      
      ST.packPrice=parseInt(packPrice,10); 
      ST.packItemsSelected={};
      document.querySelectorAll('.option').forEach(function(cb){cb.checked=false;});
      
      updateServiceTotal();
    };

    window.togglePackSvc = function(packId, svcId, price, cb) {
      if(!cb) return;
      
      // Select the pack if not already selected
      if (ST.pack !== packId) {
        var pack = PACKS.find(function(p){return p.id===packId;});
        if(pack) setPackMode(packId, pack.price, 'full');
        // Re-check the checkbox since setPackMode clears all checkboxes
        cb.checked = true;
      }
      
      if (!ST.packItemsSelected[packId]) ST.packItemsSelected[packId]={};
      if (cb.checked) ST.packItemsSelected[packId][svcId]=price;
      else delete ST.packItemsSelected[packId][svcId];
      recalcPackItems(packId);
      updateServiceTotal();
    };

    function recalcPackItems(packId) {
      var items=ST.packItemsSelected[packId]||{};
      var sub=Object.values(items).reduce(function(a,b){return a+b;},0);
      var pack = PACKS.find(function(p){return p.id===packId;});
      var basePrice = pack ? pack.price : 0;
      ST.packPrice = basePrice + sub;
    }

    window.toggleCarte = function(id, price) {
      if (ST.pack) {
        document.querySelectorAll('.pack-card').forEach(function(c){c.classList.remove('selected');});
        ST.pack=null; ST.packPrice=0;
      }
      var el=document.getElementById('carte-'+id);
      if (ST.carte[id]) { delete ST.carte[id]; if(el) el.classList.remove('selected'); }
      else { ST.carte[id]=price; if(el) el.classList.add('selected'); }
      updateServiceTotal();
    };

