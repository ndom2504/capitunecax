        </div>
        <div class="dash-container">
          <div id="pro-mode-payments" style={isProMode ? '' : 'display:none'}><div id="pro-pay-loading" style="text-align:center;padding:40px 0;"><i class="fa fa-spinner fa-spin" style="font-size:22px;color:var(--cap-orange);"></i></div><div id="pro-pay-content" style="display:none"><div class="pro-pay-stats"><div class="pro-pay-stat-card"><div class="pro-pay-stat-icon"><i class="fa fa-dollar"></i></div><div><div class="pro-pay-stat-label">Revenus recus</div><div class="pro-pay-stat-value" id="pro-stat-revenue">&#x2014;</div></div></div><div class="pro-pay-stat-card"><div class="pro-pay-stat-icon green"><i class="fa fa-check-circle"></i></div><div><div class="pro-pay-stat-label">Clients avec paiement</div><div class="pro-pay-stat-value" id="pro-stat-paid-clients">&#x2014;</div></div></div><div class="pro-pay-stat-card"><div class="pro-pay-stat-icon blue"><i class="fa fa-users"></i></div><div><div class="pro-pay-stat-label">Total clients</div><div class="pro-pay-stat-value" id="pro-stat-total-clients">&#x2014;</div></div></div></div><div class="pro-pay-table-wrap"><h3 style="margin:0 0 16px;"><i class="fa fa-list" style="color:var(--cap-orange);"></i> Detail par client</h3><table class="pro-pay-table"><thead><tr><th>Client</th><th>Service</th><th>Statut projet</th><th>Montant recu</th></tr></thead><tbody id="pro-pay-rows"></tbody></table></div></div></div>

          <div id="client-mode-payments" style={isProMode ? 'display:none' : ''}>

            <!-- Bannière contextuelle (visible si aucun service sélectionné) -->
            <div id="paiement-locked-notice" style="display:none;margin-bottom:24px;background:linear-gradient(135deg,#fff8f0,#fff3e6);border:2px solid var(--cap-orange);border-radius:14px;padding:20px 24px;align-items:center;gap:18px;">
              <i class="fa fa-info-circle" style="font-size:1.8rem;color:var(--cap-orange);flex-shrink:0;"></i>
              <div style="flex:1;">
                <strong style="color:var(--cap-dark);font-size:15px;">Aucun service sélectionné</strong>
                <p style="margin:4px 0 0;color:#777;font-size:13px;">Choisissez d'abord un pack dans l'onglet Services pour activer le paiement.</p>
              </div>
              <button onclick="switchTab('services')" style="background:var(--cap-orange);color:#fff;border:none;border-radius:9px;padding:10px 20px;cursor:pointer;font-weight:700;font-size:13px;white-space:nowrap;">
                <i class="fa fa-briefcase"></i> Choisir un service
              </button>
            </div>

            <div id="paiement-active-view">
            <!-- Récapitulatif (masqué si total = 0) -->
            <div id="payment-summary-card-wrap" style="display:none;">
            <div class="payment-summary-card">
              <h3><i class="fa fa-shopping-cart" style="color:var(--cap-orange);"></i> Récapitulatif de commande</h3>
              <div id="payment-lines"></div>
              <div class="payment-line">
                <span>Total</span>
                <span id="payment-total-amount">0 $</span>
              </div>
            </div>
            </div>
            <div class="section-title-block">
              <h2>Méthode de paiement</h2>
              <div class="title-line"></div>
            </div>
            <div class="payment-methods">
              <div class="pay-method-card selected" id="pay-card" onclick="selectPayMethod('card')">
                <i class="fa fa-credit-card"></i><h4>Carte bancaire</h4><p>Visa, Mastercard, Amex<br>Paiement securise Stripe</p>
              </div>
              <div class="pay-method-card" id="pay-paypal" onclick="selectPayMethod('paypal')">
                <i class="fa fa-paypal"></i><h4>PayPal</h4><p>Compte PayPal ou carte<br>Protection acheteur incluse</p>
              </div>
              <div class="pay-method-card" id="pay-transfer" onclick="selectPayMethod('transfer')">
                <i class="fa fa-university"></i><h4>Virement / Interac</h4><p>Interac ou virement SWIFT<br>Traitement sous 24h</p>
              </div>
            </div>

            <!-- === FORMULAIRES PAR METHODE === -->

            <!-- Stripe : carte bancaire -->
            <div id="form-card" class="pay-form-block">
              <p style="font-size:13px;color:#888;margin:0 0 10px;"><i class="fa fa-lock"></i> Informations de carte chiffrées SSL</p>
              <div class="stripe-field-wrap" id="stripe-card-element"></div>
              <div id="stripe-errors"></div>
            </div>

            <!-- PayPal -->
            <div id="form-paypal" class="pay-form-block" style="display:none;">
              <div id="paypal-buttons-container"><p class="paypal-loading"><i class="fa fa-spinner fa-spin"></i> Chargement PayPal...</p></div>
            </div>

            <!-- Virement bancaire -->
            <div id="form-transfer" class="pay-form-block" style="display:none;">
              <div class="transfer-info-box">
                <h4><i class="fa fa-university"></i> Instructions de virement</h4>
                <div class="transfer-row"><span class="transfer-label">Institution</span><span class="transfer-value" id="transfer-institution">--</span></div>
                <div class="transfer-row">
                  <span class="transfer-label">Courriel Interac</span>
                  <span class="transfer-value"><span id="transfer-interac-email">--</span> <button class="copy-btn" onclick="copyText(document.getElementById('transfer-interac-email').textContent)">Copier</button></span>
                </div>
                <div class="transfer-row"><span class="transfer-label">Référence</span><span class="transfer-value" id="transfer-ref">INV-...</span></div>
                <div class="transfer-row"><span class="transfer-label">Montant à virer</span><span class="transfer-value" id="transfer-amount">-- $</span></div>
                <p style="font-size:12px;color:#999;margin:16px 0 0;">Votre dossier sera activé sous 24h après réception du virement. Envoyez la preuve de transfert dans la messagerie.</p>
                <button class="btn-pay" style="margin-top:16px;width:100%;" onclick="confirmTransfer()">
                  <i class="fa fa-check"></i> Confirmer le virement
                </button>
