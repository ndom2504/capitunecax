    window.saveProProfile = async function(){
      if(!isProModeUI()) return;
      try {
        setHint('proProfileHint', 'Enregistrement…', true);
        var body = {
          location: (document.getElementById('proLocation')||{}).value || '',
          bio: (document.getElementById('proBio')||{}).value || '',
          pro_diploma: (document.getElementById('proDiploma')||{}).value || '',
          pro_competences: (document.getElementById('proCompetences')||{}).value || '',
          pro_experience_years: parseInt(((document.getElementById('proExperienceYears')||{}).value || ''), 10)
        };

        // Géoloc (optionnelle)
        var lat = (document.getElementById('proLocationLat')||{}).value;
        var lng = (document.getElementById('proLocationLng')||{}).value;
        if (lat !== undefined && lat !== null && String(lat).trim() !== '') body.location_lat = Number(lat);
        if (lng !== undefined && lng !== null && String(lng).trim() !== '') body.location_lng = Number(lng);

        // Packs -> services (5 packs fixes)
        var packs = ['essentiel','standard','premium','tourisme','emploi'];
        var svcIds = ['consultation','orientation','dossier','suivi','recherche','integration'];
        var packServices = {};
        var anyChecked = false;
        packs.forEach(function(pk){
          var arr = [];
          svcIds.forEach(function(sid){
            var cb = document.getElementById('proPackSvc-'+pk+'-'+sid);
            if (cb && cb.checked) { arr.push(sid); anyChecked = true; }
          });
          if (arr.length) packServices[pk] = arr;
        });

        // Packs -> prix (4 packs fixes)
        var prices = {};
        var anyPrice = false;
        packs.forEach(function(pk){
          var el = document.getElementById('proPackPrice-'+pk);
          if (!el) return;
          var v = parseMoney(el.value);
          if (v !== null) { prices[pk] = v; anyPrice = true; }
        });

        // N'envoyer pack_services que si on a des données (pour éviter d'écraser un profil existant par inadvertance)
        if (anyChecked || (window.__proInitialPackServices && Object.keys(window.__proInitialPackServices).length)) {
          body.pro_pack_services = packServices;
          // Maintenir pro_services (ancien champ) comme union
          var union = [];
          Object.keys(packServices).forEach(function(pk){ (packServices[pk]||[]).forEach(function(s){ union.push(s); }); });
          body.pro_services = Array.from(new Set(union));
        }
        if (anyPrice || (window.__proInitialPackPrices && Object.keys(window.__proInitialPackPrices).length)) {
          body.pro_pack_prices = prices;
        }

        var btn = document.getElementById('btnSaveProProfile');
        if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Enregistrement…'; }
        var r = await fetch('/api/pro/profile', {
          method:'PATCH',
          headers:{'Content-Type':'application/json','Accept':'application/json'},
          body: JSON.stringify(body)
        });
        var j = await r.json().catch(function(){ return {}; });
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-save"></i> Enregistrer packs &amp; tarifs'; }
        if(!r.ok || j.error){
          setHint('proProfileHint', j.error || 'Erreur lors de l\'enregistrement.', false);
          showToast(j.error || 'Erreur lors de l\'enregistrement.', 'error');
          return;
        }
        setHint('proProfileHint', 'Profil enregistré.', true);
        showToast('✅ Packs & tarifs enregistrés avec succès !');
      } catch(e){
        var btn2 = document.getElementById('btnSaveProProfile');
        if (btn2) { btn2.disabled = false; btn2.innerHTML = '<i class="fa fa-save"></i> Enregistrer packs &amp; tarifs'; }
        setHint('proProfileHint', 'Erreur réseau.', false);
        showToast('Erreur réseau. Veuillez réessayer.', 'error');
      }
    };

    window.useMyLocation = function(){
      try {
        if (!navigator.geolocation) { showToast('Géolocalisation non supportée sur ce navigateur.', 'error'); return; }
        try {
          if (window.isSecureContext === false) { showToast('La géolocalisation nécessite HTTPS.', 'error'); return; }
        } catch(_e0) {}

        // Best-effort: si Permission API disponible, éviter un appel inutile quand c'est explicitement refusé.
        try {
          if (navigator.permissions && navigator.permissions.query) {
            navigator.permissions.query({ name: 'geolocation' }).then(function(res){
              if (res && res.state === 'denied') {
                showToast('Autorisation refusée. Autorisez la localisation dans les réglages du navigateur puis réessayez.', 'error');
              }
            }).catch(function(){ /* ignore */ });
          }
        } catch(_eP) {}

        function applyPosition(pos){
          var lat = pos && pos.coords ? pos.coords.latitude : null;
          var lng = pos && pos.coords ? pos.coords.longitude : null;
          if (typeof lat !== 'number' || typeof lng !== 'number') { showToast('Impossible de récupérer la position.', 'error'); return; }
          var latEl = document.getElementById('proLocationLat'); if (latEl) latEl.value = String(lat);
          var lngEl = document.getElementById('proLocationLng'); if (lngEl) lngEl.value = String(lng);

          // Best-effort reverse geocoding (sans clé)
          (async function(){
            try {
              var url = 'https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=' + encodeURIComponent(lat) + '&lon=' + encodeURIComponent(lng);
              var r = await fetch(url, { headers: { 'Accept': 'application/json' } });
              var j = await r.json().catch(function(){ return null; });
              var label = '';
              if (j && j.address) {
                var city = j.address.city || j.address.town || j.address.village || '';
                var state = j.address.state || '';
                var country = j.address.country || '';
                label = [city, state].filter(Boolean).join(', ') || [state, country].filter(Boolean).join(', ');
              }
              var loc = document.getElementById('proLocation');
              if (loc && label) loc.value = label;
            } catch(_e) {}
          })();

          showToast('Position enregistrée (vous pouvez sauvegarder).', 'success');
        }

        function formatGeoError(err){
          var msg = 'Erreur de géolocalisation.';
          try {
            if (err && err.code === 1) msg = 'Autorisation refusée. Vérifiez les permissions du navigateur (et du système) puis réessayez.';
            else if (err && err.code === 2) msg = 'Position indisponible. Vérifiez votre connexion et vos services de localisation.';
            else if (err && err.code === 3) msg = 'Délai dépassé. Réessayez (ou désactivez le mode économie d\'énergie).';
          } catch(_e) {}
          try {
            var ua = (navigator && navigator.userAgent) ? navigator.userAgent : '';
            if (err && err.code === 2 && /Windows/i.test(ua)) {
              msg += ' (Windows : activez la Localisation dans Paramètres > Confidentialité et sécurité > Localisation.)';
            }
          } catch(_e2) {}
          return msg;
        }

        showToast('Localisation en cours…', 'info');

        // 1) D'abord en précision normale (souvent plus fiable sur desktop)
        navigator.geolocation.getCurrentPosition(function(pos){
          applyPosition(pos);
        }, function(err1){
          // 2) Retry en haute précision si indisponible/timeout
          try {
            if (err1 && (err1.code === 2 || err1.code === 3)) {
              navigator.geolocation.getCurrentPosition(function(pos2){
                applyPosition(pos2);
              }, function(err2){
                showToast(formatGeoError(err2 || err1), 'error');
              }, { enableHighAccuracy:true, timeout:20000, maximumAge:0 });
              return;
            }
          } catch(_eR) {}
          showToast(formatGeoError(err1), 'error');
        }, { enableHighAccuracy:false, timeout:20000, maximumAge:300000 });
      } catch(_e) {
        showToast('Erreur de géolocalisation.', 'error');
      }
    };

