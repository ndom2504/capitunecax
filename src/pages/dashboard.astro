                  <option value="NS">Nouvelle-Ecosse</option>
                  <option value="NB">Nouveau-Brunswick</option>
                  <option value="autre">Peu importe</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Pays de résidence actuel</label>
                <div class="pays-search-wrap">
                  <input type="text" id="pays-filter" placeholder="Rechercher un pays..." oninput="filterPays(this.value)" autocomplete="off">
                  <div class="alpha-btns" id="alphaBtns"></div>
                  <select id="proj-pays" size="5" ></select>
                </div>
              </div>
              <div class="form-group">
                <label>Délai souhaité pour partir</label>
                <select id="proj-delai">
                  <option value="">-- Choisir --</option>
                  <option value="6m">Moins de 6 mois</option>
                  <option value="1an">6 mois a 1 an</option>
                  <option value="2ans">1 a 2 ans</option>
                  <option value="flexible">Flexible</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Nombre de personnes concernées</label>
                <select id="proj-nbpersonnes">
                  <option value="1">1 personne (moi seul)</option>
                  <option value="2">2 personnes (moi + conjoint)</option>
                  <option value="3">3 personnes (famille)</option>
                  <option value="4">4 personnes</option>
                  <option value="5">5 personnes</option>
                  <option value="6+">6 personnes et plus</option>
                </select>
              </div>
            </div>
          </div>
          <div class="projet-form-card">
            <h3><i class="fa fa-graduation-cap" style="color:var(--cap-orange);"></i> Formation et Expérience</h3>
            <div class="form-row cols-3">
              <div class="form-group">
                <label>Niveau de diplôme</label>
                <select id="proj-diplome">
                  <option value="">-- Choisir --</option>
                  <option value="sans">Sans diplôme</option>
                  <option value="technique">Formation Technique / Métier</option>
                  <option value="college">Collège / CAP / BEP</option>
                  <option value="bac">Baccalauréat</option>
                  <option value="licence">Licence / BAC+3</option>
                  <option value="master">Master / BAC+5</option>
                  <option value="doctorat">Doctorat / PhD</option>
                </select>
              </div>
              <div class="form-group">
                <label>Domaine professionnel</label>
                <select id="proj-domaine" onchange="toggleDomaineAutre(this.value)">
                  <option value="">-- Choisir une catégorie --</option>
                  <optgroup label="&#x1F4BB; Technologie">
                    <option value="informatique">Informatique / Développement</option>
                    <option value="it-infra">Infrastructure / Réseaux</option>
                    <option value="cybersec">Cybersécurité</option>
                    <option value="ia-data">Intelligence Artificielle / Data</option>
                  </optgroup>
                  <optgroup label="&#x1F3E5; Santé">
                    <option value="medecine">Médecine / Chirurgie</option>
                    <option value="infirmerie">Soins infirmiers</option>
                    <option value="pharma">Pharmacie</option>
                    <option value="dentiste">Dentisterie</option>
                    <option value="psy">Psychologie / Thérapie</option>
                  </optgroup>
                  <optgroup label="&#x1F4BC; Finance &amp; Commerce">
                    <option value="finance">Finance / Banque / Assurance</option>
                    <option value="comptabilite">Comptabilité / Audit</option>
                    <option value="commerce">Commerce / Ventes</option>
                    <option value="marketing">Marketing / Communication</option>
                  </optgroup>
                  <optgroup label="&#x1F3EB; Éducation">
                    <option value="enseignement">Enseignement / Formation</option>
                    <option value="recherche">Recherche Académique</option>
                  </optgroup>
                  <optgroup label="&#x2696;&#xFE0F; Droit &amp; Juridique">
                    <option value="droit">Droit / Juriste</option>
                    <option value="notariat">Notariat / Huissier</option>
                  </optgroup>
                  <optgroup label="&#x1F3D7;&#xFE0F; Ingénierie &amp; BTP">
                    <option value="genie-civil">Génie Civil / Construction</option>
                    <option value="genie-meca">Génie Mécanique</option>
                    <option value="genie-elec">Génie Électrique</option>
                    <option value="architecture">Architecture</option>
                  </optgroup>
                  <optgroup label="&#x1F33F; Agriculture &amp; Environnement">
                    <option value="agriculture">Agriculture / Agroalimentaire</option>
                    <option value="environnement">Environnement / Écologie</option>
                  </optgroup>
                  <optgroup label="&#x1F3A8; Arts &amp; Médias">
                    <option value="arts">Arts / Design / Création</option>
                    <option value="medias">Médias / Journalisme</option>
                  </optgroup>
                  <optgroup label="&#x1F6F3;&#xFE0F; Transport &amp; Logistique">
                    <option value="transport">Transport / Logistique</option>
                    <option value="aviation">Aviation / Maritime</option>
                  </optgroup>
                  <optgroup label="&#x1F4CB; Autre">
                    <option value="securite">Sécurité / Défense</option>
                    <option value="restauration">Restauration / Hôtellerie</option>
                    <option value="service-public">Service Public / Administration</option>
                    <option value="autre">Autre domaine</option>
                  </optgroup>
                </select>
                <input type="text" id="proj-domaine-autre" style="display:none;margin-top:8px;" placeholder="Précisez votre domaine...">
              </div>
              <div class="form-group">
                <label>Annees d experience</label>
                <select id="proj-experience">
                  <option value="">-- Choisir --</option>
                  <option value="0">Moins de 1 an</option>
                  <option value="1-3">1 a 3 ans</option>
                  <option value="3-5">3 a 5 ans</option>
                  <option value="5-10">5 a 10 ans</option>
                  <option value="10+">Plus de 10 ans</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label>Langues maîtrisées</label>
              <div class="langues-row">
                <label class="langue-checkbox"><input type="checkbox" value="fr"> Français</label>
                <label class="langue-checkbox"><input type="checkbox" value="en"> Anglais</label>
                <label class="langue-checkbox"><input type="checkbox" value="es"> Espagnol</label>
                <label class="langue-checkbox"><input type="checkbox" value="ar"> Arabe</label>
                <label class="langue-checkbox"><input type="checkbox" value="pt"> Portugais</label>
                <label class="langue-checkbox"><input type="checkbox" value="zh"> Mandarin</label>
                <label class="langue-checkbox"><input type="checkbox" value="de"> Allemand</label>
                <label class="langue-checkbox"><input type="checkbox" value="it"> Italien</label>
              </div>
            </div>
          </div>
          <div class="projet-form-card">
            <h3><i class="fa fa-users" style="color:var(--cap-orange);"></i> Situation Familiale</h3>
            <div class="form-row cols-3">
              <div class="form-group">
                <label>Statut matrimonial</label>
                <select id="proj-famille">
                  <option value="">-- Choisir --</option>
                  <option value="celibataire">Celibataire</option>
                  <option value="marie">Marie(e) / Conjoint de fait</option>
                  <option value="divorce">Divorce(e)</option>
                </select>
              </div>
              <div class="form-group">
                <label>Enfants a charge</label>
                <select id="proj-enfants">
                  <option value="0">Aucun</option>
                  <option value="1">1 enfant</option>
                  <option value="2">2 enfants</option>
                  <option value="3">3 enfants</option>
                  <option value="4+">4 et plus</option>
                </select>
              </div>
              <div class="form-group">
                <label>Conjoint(e) vient aussi ?</label>
                <select id="proj-conjoint">
                  <option value="na">Non applicable</option>
                  <option value="oui">Oui, accompagne(e)</option>
                  <option value="plus-tard">Plus tard</option>
                  <option value="non">Non</option>
                </select>
              </div>
            </div>
          </div>
          <div class="projet-form-card">
            <h3><i class="fa fa-sticky-note" style="color:var(--cap-orange);"></i> Notes Complementaires</h3>
            <div class="form-group">
              <label>Precisions sur votre projet (optionnel)</label>
              <textarea id="proj-notes" placeholder="Ex: J ai deja une offre d emploi, mon conjoint est citoyen canadien..."></textarea>
            </div>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
            <button class="btn-cancel-demande" id="btnCancelProjet" onclick="confirmCancelDemande()" style="display:none;">
              <i class="fa fa-times-circle"></i> Annuler ma demande
            </button>
            <button class="btn-submit-projet" onclick="saveProject()">
              <i class="fa fa-arrow-right"></i> Enregistrer et choisir mon service
            </button>
          </div>
        </div>
      </section>

      <!-- ===== ONGLET 2 : SERVICES ===== -->
      <section class={"tab-section"} id="tab-services">
        <div class="tab-hero">
          <div class="tab-hero-inner">
            <h1><i class="fa fa-briefcase"></i> Choisir Mon Service</h1>
            <p>Selectionnez le pack adapte a votre projet et soumettez-le a un conseiller.</p>
          </div>
        </div>
        <div class="dash-container">
          <div id="pro-mode-services" style={isProMode ? '' : 'display:none'}>
            <div class="section-title-block">
              <h2><i class="fa fa-briefcase" style="color:var(--cap-orange);"></i> Mes services</h2>
              <p>Configurez vos packs (services inclus + tarif) et complétez votre profil public.</p>
            </div>
            <div class="projet-form-card">
              <h3><i class="fa fa-id-badge" style="color:var(--cap-orange);"></i> Profil public</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>Localisation</label>
                  <div style="display:flex;gap:10px;align-items:center;">
                    <div style="position:relative;flex:1;min-width:220px;">
                      <input id="proLocation" placeholder="Ex: Montréal, Canada" style="width:100%;" autocomplete="off" />
                      <div id="proLocationCountrySuggest" style="position:absolute;left:0;right:0;top:calc(100% + 6px);z-index:50;display:none;background:#fff;border:1px solid rgba(0,0,0,0.12);border-radius:10px;overflow:hidden;max-height:240px;overflow-y:auto;"></div>
                    </div>
                    <button class="btn-submit-projet" type="button" onclick="useMyLocation()" style="padding:10px 12px;font-size:12px;white-space:nowrap;">
                      <i class="fa fa-location-arrow"></i> Ma position
                    </button>
                  </div>
                  <input id="proLocationLat" type="hidden" />
                  <input id="proLocationLng" type="hidden" />
                </div>
                <div class="form-group">
                  <label>Description</label>
                  <textarea id="proBio" placeholder="Décrivez votre expertise (visible côté client)…" style="min-height:80px"></textarea>
                </div>
              </div>
              <div class="form-row cols-3">
                <div class="form-group">
                  <label>Diplôme</label>
                  <input id="proDiploma" placeholder="Ex: Master, Licence, Certificat…" />
                </div>
                <div class="form-group">
                  <label>Années d'expérience</label>
                  <input id="proExperienceYears" type="number" min="0" max="80" step="1" placeholder="Ex: 5" />
                </div>
                <div class="form-group">
                  <label>Compétences</label>
                  <input id="proCompetences" placeholder="Ex: Entrée Express, PNP, CAQ…" />
                </div>
              </div>
              <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;">
                <button class="btn-submit-projet" type="button" onclick="saveProProfile()"><i class="fa fa-save"></i> Enregistrer</button>
              </div>
              <p id="proProfileHint" style="margin:12px 0 0;color:#888;font-size:12px;"></p>
            </div>

            <div class="projet-form-card">
              <h3><i class="fa fa-tags" style="color:var(--cap-orange);"></i> Packs, services & tarifs</h3>
              <p style="margin:0 0 18px;color:#777;font-size:13px;">Configurez vos prix par pack et les services inclus dans chaque offre. Ces informations s'affichent côté client.</p>

              <!-- ── Toggle Packs / Services ── -->
              <div style="display:flex;gap:5px;background:#f1f3f5;border-radius:12px;padding:5px;margin-bottom:24px;">
                <button id="proTarifsBtn-packs" onclick="switchProTarifsMode('packs')"
                  style="flex:1;padding:9px 14px;border-radius:9px;border:none;background:var(--cap-orange);color:#fff;font-weight:700;font-size:13px;cursor:pointer;transition:.2s;">
                  <i class="fa fa-cube"></i> Packs tout inclus
                </button>
                <button id="proTarifsBtn-services" onclick="switchProTarifsMode('services')"
                  style="flex:1;padding:9px 14px;border-radius:9px;border:none;background:transparent;color:#888;font-weight:700;font-size:13px;cursor:pointer;transition:.2s;">
                  <i class="fa fa-list"></i> Services à la carte
                </button>
              </div>

              <!-- ══ PANEL PACKS ══ -->
              <div id="proTarifsPanel-packs">
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:16px;">
                  {packagesCatalog.map((pkg) => (
                    <div style={`background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,0.09);overflow:hidden;display:flex;flex-direction:column;border:2px solid ${pkg.popular ? 'var(--cap-orange)' : '#eee'};position:relative;`}>
                      {pkg.popular && (
                        <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--cap-orange);color:#fff;font-size:10px;font-weight:800;padding:3px 12px;border-radius:0 0 9px 9px;white-space:nowrap;z-index:1;">⭐ PLUS POPULAIRE</div>
                      )}
                      <div style={`background:${pkg.popular ? 'linear-gradient(135deg,var(--cap-orange),#e67e00)' : 'linear-gradient(135deg,#1a1a2e,#0f3460)'};color:#fff;padding:${pkg.popular ? '28px 16px 14px' : '16px'};`}>
                        <div style="font-size:1.6rem;margin-bottom:5px;">{pkg.badge}</div>
                        <div style="font-size:.95rem;font-weight:800;margin-bottom:3px;">{pkg.name}</div>
                        <div style="font-size:11px;opacity:0.8;">{pkg.description}</div>
                      </div>
                      <div style="padding:12px 14px;background:#fafafa;border-bottom:1px solid #f0f0f0;">
                        <label style="font-size:10px;font-weight:700;color:#aaa;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:4px;">Mon prix (CAD)</label>
                        <div style="display:flex;align-items:center;gap:5px;">
                          <input id={`proPackPrice-${pkg.id}`} type="number" min="0" step="1" placeholder={String(pkg.price)}
                            style="flex:1;min-width:0;border:2px solid #e0e0e0;border-radius:8px;padding:6px 8px;font-size:1.2rem;font-weight:900;color:var(--cap-dark);outline:none;transition:.2s;"
                            onfocus="this.style.borderColor='var(--cap-orange)'" onblur="this.style.borderColor='#e0e0e0'" />
                          <span style="font-size:13px;font-weight:700;color:#bbb;flex-shrink:0;">$</span>
                        </div>
                        <div style="font-size:10px;color:#ccc;margin-top:3px;">Réf. Capitune : {pkg.price.toLocaleString('fr-CA')} $</div>
                      </div>
                      <div style="padding:12px 14px;flex:1;">
                        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">
                          {pkg.features.slice(0, 5).map((feat) => (
                            <li style="display:flex;align-items:flex-start;gap:7px;font-size:11px;color:#444;">
                              <span style="color:var(--cap-orange);font-weight:800;flex-shrink:0;margin-top:1px;">✓</span>
                              {feat}
                            </li>
                          ))}
                          {pkg.features.length > 5 && (
                            <li style="font-size:10px;color:#bbb;padding-top:2px;">+{pkg.features.length - 5} autres…</li>
                          )}
                        </ul>
                      </div>
                      <div style="padding:10px 14px;border-top:1px solid #f0f0f0;">
                        <button onclick="switchProTarifsMode('services')"
                          style="width:100%;padding:7px;border-radius:8px;border:1.5px solid #eee;background:#f9f9f9;color:#888;font-size:11px;font-weight:700;cursor:pointer;transition:.15s;"
                          onmouseover="this.style.borderColor='var(--cap-orange)';this.style.color='var(--cap-orange)'"
                          onmouseout="this.style.borderColor='#eee';this.style.color='#888'">
                          <i class="fa fa-cog"></i> Configurer les services →
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- ══ PANEL SERVICES À LA CARTE ══ -->
              <div id="proTarifsPanel-services" style="display:none;">
                <p style="margin:0 0 14px;font-size:13px;color:#777;"><i class="fa fa-info-circle" style="color:var(--cap-orange);margin-right:6px;"></i>Cochez les services inclus dans chaque pack. Les prix se configurent dans l'onglet "Packs".</p>
                <div style="overflow-x:auto;border-radius:14px;border:1px solid #eee;box-shadow:0 2px 12px rgba(0,0,0,0.06);">
                  <table style="width:100%;border-collapse:collapse;min-width:580px;">
                    <thead>
                      <tr style="background:linear-gradient(135deg,#1a1a2e,#0f3460);">
                        <th style="padding:14px 16px;text-align:left;color:#fff;font-size:12px;font-weight:800;border-radius:14px 0 0 0;">Service</th>
                        {packagesCatalog.map((pkg) => (
                          <th style="padding:12px 8px;text-align:center;color:#fff;font-size:11px;font-weight:800;min-width:90px;">
                            <div style="font-size:1.3rem;">{pkg.badge}</div>
                            <div style="margin-top:2px;">{pkg.name.replace('Pack ','')}</div>
                          </th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {proSvcList.map((svc, svcIdx) => (
                        <tr style={svcIdx % 2 === 0 ? 'background:#fafafa;' : 'background:#fff;'}>
                          <td style="padding:12px 16px;font-size:13px;font-weight:700;color:#333;">
                            <span style="margin-right:7px;">{svc.icon}</span>{svc.label}
                          </td>
                          {packagesCatalog.map((pkg) => (
                            <td style="padding:12px 8px;text-align:center;">
                              <label style="cursor:pointer;display:inline-flex;align-items:center;justify-content:center;">
                                <input type="checkbox"
                                  id={`proPackSvc-${pkg.id}-${svc.id}`}
                                  value={svc.id}
                                  style="accent-color:var(--cap-orange);width:18px;height:18px;cursor:pointer;" />
                              </label>
                            </td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                <p style="margin:10px 0 0;font-size:11px;color:#bbb;"><i class="fa fa-check-square-o"></i> Ces cases correspondent aux services proposés côté client lors de l'achat d'un pack.</p>
              </div>

              <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;margin-top:18px;">
                <button id="btnSaveProProfile" class="btn-submit-projet" type="button" onclick="saveProProfile()"><i class="fa fa-save"></i> Enregistrer packs & tarifs</button>
              </div>
            </div>
              <h2>Services a la Carte</h2>
              <div class="title-line"></div>
              <p>Composez votre accompagnement selon vos besoins specifiques.</p>
            </div>
            <div class="services-carte-grid" id="servicesCarteGrid">
              <!-- Services injectés par JS via /api/catalog -->
            </div>
          </div>
          <div class="submit-service-bar" id="serviceSubmitBar">
            <div>
              <div class="total-label">Total sélectionné</div>
              <div class="total-amount" id="serviceTotalAmount">0 $</div>
            </div>
            <button class="btn-submit-service" id="btnSubmitService" onclick="submitService()" disabled>
              Soumettre mon projet
            </button>
          </div>
          </div>
        </div>
      </section>

      <!-- ===== ONGLET 3 : MESSAGERIE ===== -->
      <section class="tab-section" id="tab-messagerie">
        <div class="tab-hero">
          <div class="tab-hero-inner">
            <h1><i class="fa fa-envelope"></i> Messagerie</h1>
            <p>Echangez avec votre conseiller et convenez d une rencontre.</p>
          </div>
        </div>
        <div class="dash-container">
          <div id="pro-mode-messages" style={isProMode ? '' : 'display:none'}>
            <div class="projet-form-card">
              <h3><i class="fa fa-envelope" style="color:var(--cap-orange);"></i> Messagerie</h3>
              <p style="margin:0 0 16px;color:#777;">Ouvrez la messagerie clients depuis votre panneau pro.</p>
              <a href="/admin" class="btn-submit-projet" style="display:inline-flex;align-items:center;gap:10px;text-decoration:none;"><i class="fa fa-arrow-right"></i> Ouvrir la messagerie</a>
            </div>
          </div>

          <div id="client-mode-messages" style={isProMode ? 'display:none' : ''}>
          <div id="rdv-notice" style="display:none;" class="rdv-notice">
            <i class="fa fa-calendar-check-o"></i>
            <div>
              <h4>Prochaine etape : convenir d une rencontre</h4>
              <p>Votre projet a ete transmis. Votre conseiller vous contactera sous 24-48h pour fixer un rendez-vous.</p>
            </div>
          </div>
          <div class="messaging-layout">
            <div class="msg-sidebar">
              <div class="msg-search">
                <input type="text" placeholder="Rechercher...">
                <i class="fa fa-search"></i>
              </div>
              <ul class="conversation-list">
                <li class="conv-item active">
                  <div class="conv-avatar team"><i class="fa fa-users"></i></div>
                  <div class="conv-info">
                    <span class="conv-name">Equipe CAPITUNE</span>
                    <span class="conv-preview" id="convPreview">Bonjour, comment pouvons-nous vous aider ?</span>
                  </div>
                  <div class="conv-meta"><span class="conv-time"></span></div>
                </li>
              </ul>
            </div>
            <div class="msg-chat">
              <div class="chat-header">
                <div class="chat-header-avatar team"><i class="fa fa-users"></i></div>
                <div class="chat-header-info">
                  <h3>Equipe CAPITUNE</h3>
                  <span class="online-dot"><i class="fa fa-circle"></i> En ligne</span>
                </div>
                <div class="chat-actions">
                  <button title="Visio (a venir)"><i class="fa fa-video-camera"></i></button>
                  <button title="Joindre un document" onclick="document.getElementById('fileInput').click()"><i class="fa fa-paperclip"></i></button>
                </div>
              </div>
              <div class="chat-messages" id="chatMessages">
                <div class="chat-empty-state" id="chatEmptyState">
                  <i class="fa fa-comments-o"></i>
                  <p>Aucun message pour le moment.</p>
                  <p class="sub">Envoyez un message ou une piece jointe a votre conseiller.</p>
                </div>
              </div>
              <div class="chat-input-area">
                <button class="attach-btn" type="button" onclick="document.getElementById('fileInput').click()"><i class="fa fa-paperclip"></i></button>
                <input type="file" id="fileInput" style="display:none" multiple>
                <input type="text" id="msgInput" placeholder="Ecrire un message..." onkeydown="if(event.key==='Enter') sendMessage()">
                <button class="send-btn" onclick="sendMessage()"><i class="fa fa-paper-plane"></i></button>
              </div>
            </div>
          </div>
          </div>
        </div>
      </section>

      <!-- ===== ONGLET 4 : PAIEMENTS ===== -->
