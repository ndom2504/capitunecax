                      'onchange="applyCapService(\'' + pid + '\',\'' + svc.id + '\',this.checked)" />' +
                  '</label></td>';
              }).join('');
              return '<tr style="border-bottom:1px solid #f0f0f0;">' +
                '<td style="padding:9px 12px;font-weight:700;color:#333;">' + svc.icon + ' ' + svc.name + '</td>' +
