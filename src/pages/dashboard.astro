            <!-- Bouton Stripe (masqué pour paypal) -->
            <button class="btn-pay" id="btn-pay-stripe" onclick="processPayment()" style="margin-top:8px;">
              <i class="fa fa-lock"></i> Payer maintenant &mdash; <span id="pay-btn-amount">0 $</span>
            </button>
            <p style="text-align:center;font-size:12px;color:#aaa;margin-top:12px;">
              <i class="fa fa-shield"></i> Paiement 100% sécurisé &mdash; Données chiffrées SSL
            </p>
          </div>
          </div>
          </div>
        </div>
      </section>

      <!-- ===== ONGLET TARIFS : GRILLE TARIFAIRE CAPITUNE ===== -->
      <section class="tab-section" id="tab-tarifs">
        <div class="tab-hero">
          <div class="tab-hero-inner">
            <h1><i class="fa fa-tag"></i> Grille Tarifaire Capitune</h1>
            <p>Tarifs officiels mis à jour — choisissez la formule adaptée à votre projet.</p>
          </div>
        </div>
        <div class="dash-container">

          <!-- Toggle mode -->
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:32px;background:#fff;border-radius:14px;padding:18px 24px;box-shadow:0 2px 16px rgba(0,0,0,0.07);border:1px solid #eee;">
            <span style="font-size:14px;font-weight:700;color:#555;">Mode d'affichage :</span>
            <div style="display:flex;gap:8px;">
              <button id="tarifs-btn-packs" onclick="switchTarifsMode('packs')" style="padding:9px 22px;border-radius:9px;border:none;background:var(--cap-orange);color:#fff;font-weight:700;font-size:13px;cursor:pointer;transition:.2s;"><i class="fa fa-cube"></i> Packs</button>
              <button id="tarifs-btn-services" onclick="switchTarifsMode('services')" style="padding:9px 22px;border-radius:9px;border:1.5px solid #ddd;background:#f9f9f9;color:#555;font-weight:700;font-size:13px;cursor:pointer;transition:.2s;"><i class="fa fa-list"></i> Services à la carte</button>
            </div>
            <span style="margin-left:auto;font-size:12px;color:#999;"><i class="fa fa-info-circle"></i> Frais gouvernementaux non inclus</span>
          </div>

          <!-- MODE PACKS -->
          <div id="tarifs-packs-panel">
            <div class="section-title-block">
              <div class="title-line"></div>
              <h2>🏆 Packs Recommandés</h2>
              <p>Solutions complètes et forfaitaires pour votre projet d'immigration</p>
            </div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:40px;">
              {packagesCatalog.map((pkg) => (
                <div style={`background:#fff;border-radius:18px;box-shadow:0 4px 24px rgba(0,0,0,0.09);overflow:hidden;display:flex;flex-direction:column;border:2px solid ${pkg.popular ? 'var(--cap-orange)' : '#eee'};position:relative;`}>
                  {pkg.popular && (
                    <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--cap-orange);color:#fff;font-size:11px;font-weight:800;padding:4px 16px;border-radius:0 0 10px 10px;letter-spacing:.5px;white-space:nowrap;">⭐ LE PLUS POPULAIRE</div>
                  )}
                  <div style={`background:${pkg.popular ? 'linear-gradient(135deg,var(--cap-orange),#e67e00)' : 'linear-gradient(135deg,#1a1a2e,#0f3460)'};color:#fff;padding:${pkg.popular ? '32px 24px 24px' : '24px'};`}>
                    <div style="font-size:2rem;margin-bottom:8px;">{pkg.badge}</div>
                    <div style="font-size:1.25rem;font-weight:800;margin-bottom:6px;">{pkg.name}</div>
                    <div style="font-size:13px;opacity:0.85;">{pkg.description}</div>
                  </div>
                  <div style="padding:24px;display:flex;flex-direction:column;flex:1;">
                    <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid #f0f0f0;">
                      <span style="font-size:2.5rem;font-weight:900;color:var(--cap-dark);">{pkg.price.toLocaleString('fr-CA')}&nbsp;$</span>
                      <span style="font-size:13px;color:#999;font-weight:600;">CAD</span>
                    </div>
                    <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;flex:1;">
                      {pkg.features.map((feat) => (
                        <li style="display:flex;align-items:flex-start;gap:10px;font-size:13px;color:#444;">
                          <span style="color:var(--cap-orange);font-weight:800;flex-shrink:0;margin-top:1px;">✓</span>
                          {feat}
                        </li>
                      ))}
                    </ul>
                    <div style="margin-top:20px;padding:12px 16px;background:#f8f9fa;border-radius:10px;display:flex;justify-content:space-between;align-items:center;">
                      <span style="font-size:12px;color:#888;">Services inclus :</span>
                      <span style="font-size:12px;font-weight:700;color:var(--cap-orange);">{pkg.services.length} service{pkg.services.length > 1 ? 's' : ''}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Support Premium -->
            <div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:16px;padding:28px 32px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;">
              <div>
                <div style="font-size:1.5rem;margin-bottom:6px;">💬</div>
                <div style="font-size:1.1rem;font-weight:800;color:#fff;margin-bottom:6px;">Messagerie Premium / Support Illimité</div>
                <div style="font-size:13px;color:rgba(255,255,255,0.7);">Accès illimité au chat et support dédié pour toutes les questions clients</div>
              </div>
              <div style="text-align:right;">
                <div style="font-size:2rem;font-weight:900;color:var(--cap-orange);">70 <span style="font-size:1rem;">$ / mois</span></div>
                <div style="font-size:12px;color:rgba(255,255,255,0.5);margin-top:4px;">par client abonné</div>
              </div>
            </div>
          </div>

          <!-- MODE SERVICES À LA CARTE -->
          <div id="tarifs-services-panel" style="display:none;">
            <div class="section-title-block">
              <div class="title-line"></div>
              <h2>🔧 Services à la carte</h2>
              <p>Tarifs détaillés par service et sous-service — choisissez uniquement ce dont vos clients ont besoin</p>
            </div>
            <div style="display:flex;flex-direction:column;gap:20px;">
              {servicesCatalog.map((service) => (
                <div style="background:#fff;border-radius:16px;box-shadow:0 2px 16px rgba(0,0,0,0.07);overflow:hidden;border:1px solid #eee;">
                  <div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;">
                    <div style="display:flex;align-items:center;gap:12px;">
                      <span style="font-size:1.5rem;">{service.icon}</span>
                      <div>
                        <div style="font-size:1rem;font-weight:800;color:#fff;">{service.name}</div>
                        <div style="font-size:12px;color:rgba(255,255,255,0.65);">{service.description}</div>
                      </div>
                    </div>
                    <div style="text-align:right;">
                      <div style="font-size:1.4rem;font-weight:900;color:var(--cap-orange);">{service.subServices.reduce((s, sub) => s + sub.price, 0).toLocaleString('fr-CA')}&nbsp;$</div>
                      <div style="font-size:11px;color:rgba(255,255,255,0.5);">total (tous sous-services)</div>
                    </div>
                  </div>
                  <div style="padding:16px 24px;">
                    <table style="width:100%;border-collapse:collapse;">
                      <thead>
                        <tr style="border-bottom:2px solid #f0f0f0;">
                          <th style="text-align:left;padding:8px 10px;font-size:11px;font-weight:800;color:#888;text-transform:uppercase;letter-spacing:.6px;">Sous-service</th>
                          <th style="text-align:left;padding:8px 10px;font-size:11px;font-weight:800;color:#888;text-transform:uppercase;letter-spacing:.6px;">Description</th>
                          <th style="text-align:right;padding:8px 10px;font-size:11px;font-weight:800;color:#888;text-transform:uppercase;letter-spacing:.6px;">Prix</th>
                          <th style="text-align:center;padding:8px 10px;font-size:11px;font-weight:800;color:#888;text-transform:uppercase;letter-spacing:.6px;">Type</th>
                        </tr>
                      </thead>
                      <tbody>
                        {service.subServices.map((sub) => (
                          <tr style="border-bottom:1px solid #f5f5f5;">
                            <td style="padding:10px;font-size:13px;font-weight:700;color:#333;white-space:nowrap;">{sub.name}</td>
                            <td style="padding:10px;font-size:12px;color:#777;">{sub.description}</td>
                            <td style="padding:10px;font-size:14px;font-weight:800;color:var(--cap-orange);text-align:right;white-space:nowrap;">{sub.price.toLocaleString('fr-CA')}&nbsp;$</td>
                            <td style="padding:10px;text-align:center;">
                              {sub.automated
                                ? <span style="background:#e8f8ef;color:#27ae60;font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;">Auto</span>
                                : <span style="background:#fff3e0;color:#e67e00;font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;">Manuel</span>
                              }
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              ))}
            </div>

            <!-- Note frais gouvernementaux -->
            <div style="margin-top:28px;background:#fff8f0;border:1.5px solid #ffd899;border-radius:12px;padding:20px 24px;display:flex;gap:14px;align-items:flex-start;">
              <i class="fa fa-info-circle" style="color:var(--cap-orange);font-size:1.2rem;flex-shrink:0;margin-top:2px;"></i>
              <div>
                <div style="font-weight:800;color:#7a4e00;margin-bottom:6px;">Frais gouvernementaux non inclus</div>
                <div style="font-size:13px;color:#9a6e20;line-height:1.6;">Nos tarifs excluent les frais officiels payables à IRCC (traitement, biométrie, permis, etc.). Ces montants sont communiqués lors de la consultation initiale et varient selon le programme.</div>
              </div>
            </div>
          </div>

        </div>
      </section>

      <script is:inline>
        function switchTarifsMode(mode) {
          const packsPanel = document.getElementById('tarifs-packs-panel');
          const servicesPanel = document.getElementById('tarifs-services-panel');
          const btnPacks = document.getElementById('tarifs-btn-packs');
          const btnServices = document.getElementById('tarifs-btn-services');
          if (mode === 'packs') {
            packsPanel.style.display = 'block';
            servicesPanel.style.display = 'none';
            btnPacks.style.background = 'var(--cap-orange)';
            btnPacks.style.color = '#fff';
            btnPacks.style.border = 'none';
            btnServices.style.background = '#f9f9f9';
            btnServices.style.color = '#555';
            btnServices.style.border = '1.5px solid #ddd';
          } else {
            packsPanel.style.display = 'none';
            servicesPanel.style.display = 'block';
            btnServices.style.background = 'var(--cap-orange)';
            btnServices.style.color = '#fff';
            btnServices.style.border = 'none';
            btnPacks.style.background = '#f9f9f9';
            btnPacks.style.color = '#555';
            btnPacks.style.border = '1.5px solid #ddd';
          }
        }

        // ── Capitune Reference Panel ──
        function toggleCapRef() {
          const panel = document.getElementById('capRefPanel');
          const chevron = document.getElementById('capRefChevron');
          const open = panel.style.display === 'none';
          panel.style.display = open ? 'block' : 'none';
          chevron.style.transform = open ? 'rotate(180deg)' : '';
        }

        function switchProTarifsMode(mode) {
          var pp = document.getElementById('proTarifsPanel-packs');
          var sp = document.getElementById('proTarifsPanel-services');
          var bp = document.getElementById('proTarifsBtn-packs');
          var bs = document.getElementById('proTarifsBtn-services');
          if (!pp || !sp) return;
          if (mode === 'packs') {
            pp.style.display = 'block'; sp.style.display = 'none';
            if (bp) { bp.style.background = 'var(--cap-orange)'; bp.style.color = '#fff'; }
            if (bs) { bs.style.background = 'transparent'; bs.style.color = '#888'; }
          } else {
            pp.style.display = 'none'; sp.style.display = 'block';
            if (bs) { bs.style.background = 'var(--cap-orange)'; bs.style.color = '#fff'; }
            if (bp) { bp.style.background = 'transparent'; bp.style.color = '#888'; }
          }
        }

        function switchCapRefMode(mode) {
          const pp = document.getElementById('capRefPacksPanel');
          const sp = document.getElementById('capRefServicesPanel');
          const bp = document.getElementById('capRefBtnPacks');
          const bs = document.getElementById('capRefBtnServices');
          if (mode === 'packs') {
            pp.style.display='block'; sp.style.display='none';
            bp.style.cssText += ';background:var(--cap-orange);color:#fff;border:none;';
            bs.style.cssText += ';background:#f9f9f9;color:#555;border:1.5px solid #ddd;';
          } else {
            pp.style.display='none'; sp.style.display='block';
            bs.style.cssText += ';background:var(--cap-orange);color:#fff;border:none;';
            bp.style.cssText += ';background:#f9f9f9;color:#555;border:1.5px solid #ddd;';
          }
        }

        function applyCapPack(packId, price, services) {
          // 1. Remplir le prix
          var priceInput = document.getElementById('proPackPrice-' + packId);
          if (priceInput) priceInput.value = price;

          // 2. Cocher/décocher les services
          var allSvcIds = ['consultation','orientation','dossier','suivi','recherche','integration'];
          allSvcIds.forEach(function(svcId) {
            var cb = document.getElementById('proPackSvc-' + packId + '-' + svcId);
            if (!cb) return;
            var shouldCheck = services.indexOf(svcId) !== -1;
            cb.checked = shouldCheck;
            var lbl = cb.closest('label');
            if (lbl) {
              if (shouldCheck) lbl.classList.add('checked');
              else lbl.classList.remove('checked');
            }
          });

          // 3. Feedback visuel sur le bouton Appliquer
          var badge = document.getElementById('capApplyBadge-' + packId);
          var btn = document.getElementById('capApplyBtn-' + packId);
          if (badge) { badge.innerHTML = '✓'; badge.style.background = 'var(--cap-orange)'; badge.style.color = '#fff'; }
          if (btn) { btn.style.borderColor = 'var(--cap-orange)'; btn.style.background = '#fff0d6'; }
          setTimeout(function() {
            if (badge) { badge.innerHTML = ''; badge.style.background = '#fff'; badge.style.color = ''; }
            if (btn) { btn.style.background = ''; }
          }, 2000);
        }

        function applyCapService(packId, serviceId, checked) {
          var cb = document.getElementById('proPackSvc-' + packId + '-' + serviceId);
          if (!cb) return;
          cb.checked = checked;
          var lbl = cb.closest('label');
          if (lbl) {
            if (checked) lbl.classList.add('checked');
            else lbl.classList.remove('checked');
          }
        }

        function initCapRef() {
          var pkgs = window.CAP_PACKAGES_CATALOG || [];
          var svcs = window.CAP_SERVICES_CATALOG || [];

          // Rendre les cartes packs
          var cardsEl = document.getElementById('capRefPacksCards');
          if (cardsEl && pkgs.length) {
            cardsEl.innerHTML = pkgs.map(function(pkg) {
              var total = pkg.price.toLocaleString('fr-CA');
              var featList = pkg.features.map(function(f) {
                return '<li style="font-size:11px;color:#555;display:flex;align-items:flex-start;gap:6px;"><span style="color:var(--cap-orange);font-weight:800;flex-shrink:0;">\u2713</span>' + f + '</li>';
              }).join('');
              var borderColor = pkg.popular ? 'var(--cap-orange)' : '#eee';
              var headBg = pkg.popular ? 'var(--cap-orange)' : '#1a1a2e';
              var btnBorder = pkg.popular ? 'var(--cap-orange)' : '#ddd';
              var btnBg = pkg.popular ? '#fff8f0' : '#f9f9f9';
              var servicesJSON = JSON.stringify(pkg.services).replace(/"/g, '\u0027');
              return '<div style="border-radius:12px;overflow:hidden;border:1.5px solid ' + borderColor + ';background:#fff;display:flex;flex-direction:column;">' +
                '<div style="background:' + headBg + ';color:#fff;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;">' +
                  '<span style="font-weight:800;font-size:13px;">' + pkg.badge + ' ' + pkg.name + '</span>' +
                  '<span style="font-size:15px;font-weight:900;">' + total + ' $</span>' +
                '</div>' +
                '<div style="padding:12px 14px;display:flex;flex-direction:column;flex:1;">' +
                  '<ul style="list-style:none;margin:0 0 12px;padding:0;display:flex;flex-direction:column;gap:5px;flex:1;">' + featList + '</ul>' +
                  '<button id="capApplyBtn-' + pkg.id + '" onclick="applyCapPack(\'' + pkg.id + '\',' + pkg.price + ',' + servicesJSON + ')" ' +
                    'style="width:100%;display:flex;align-items:center;justify-content:center;gap:8px;padding:8px 12px;border-radius:8px;cursor:pointer;border:1.5px solid ' + btnBorder + ';background:' + btnBg + ';font-weight:700;font-size:12px;color:var(--cap-dark);transition:.15s;">' +
                    '<span id="capApplyBadge-' + pkg.id + '" style="width:16px;height:16px;border-radius:4px;border:2px solid var(--cap-orange);display:inline-flex;align-items:center;justify-content:center;background:#fff;flex-shrink:0;font-size:11px;"></span>' +
                    '&#10003; Appliquer \u2192 ' + pkg.name.replace('Pack ','') +
                  '</button>' +
                '</div>' +
              '</div>';
            }).join('');
          }

          // Rendre les lignes services
          var tbody = document.getElementById('capRefServicesTbody');
          if (tbody && svcs.length) {
            var packIds = ['essentiel','standard','premium','tourisme','emploi'];
            tbody.innerHTML = svcs.map(function(svc) {
              var refPrice = svc.subServices.reduce(function(s,sub){ return s+sub.price; }, 0);
              var cells = packIds.map(function(pid) {
                return '<td style="padding:9px 12px;text-align:center;">' +
                  '<label style="cursor:pointer;display:inline-flex;align-items:center;justify-content:center;">' +
                    '<input type="checkbox" id="capSvcApply-' + pid + '-' + svc.id + '" ' +
                      'style="accent-color:var(--cap-orange);width:15px;height:15px;cursor:pointer;" ' +
                      'onchange="applyCapService(\'' + pid + '\',\'' + svc.id + '\',this.checked)" />' +
                  '</label></td>';
              }).join('');
              return '<tr style="border-bottom:1px solid #f0f0f0;">' +
                '<td style="padding:9px 12px;font-weight:700;color:#333;">' + svc.icon + ' ' + svc.name + '</td>' +
                '<td style="padding:9px 12px;text-align:right;font-weight:800;color:var(--cap-orange);white-space:nowrap;">' + refPrice.toLocaleString('fr-CA') + ' $</td>' +
                cells +
              '</tr>';
            }).join('');
          }
        }

        document.addEventListener('DOMContentLoaded', function() { initCapRef(); });
      </script>

