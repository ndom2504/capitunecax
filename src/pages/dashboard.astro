    function _updateCarouselArrows() {
      var prev = document.getElementById('carouselPrev');
      var next = document.getElementById('carouselNext');
      if (prev) prev.disabled = _carIdx === 0;
      if (next) next.disabled = _carIdx === PACKS.length - 1;
      // Active dot
      document.querySelectorAll('.carousel-dot').forEach(function(d, i) {
        d.classList.toggle('active', i === _carIdx);
      });
    }

    window.carouselNav = function(dir) {
      carouselGoTo(_carIdx + dir);
