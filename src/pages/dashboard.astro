    var _currentAlpha = '';
    function initPaysSelect() {
      var alphaCont = document.getElementById('alphaBtns');
      var sel = document.getElementById('proj-pays');
      if (!alphaCont || !sel) return;
      // Bouton "Tous"
      var allBtn = document.createElement('button');
      allBtn.type='button'; allBtn.className='alpha-btn active'; allBtn.textContent='Tous';
      allBtn.onclick=function(){filterPaysAlpha('',this);};
      alphaCont.appendChild(allBtn);
      // Lettres A-Z
      'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').forEach(function(l){
        var btn=document.createElement('button');
        btn.type='button'; btn.className='alpha-btn'; btn.textContent=l;
        btn.onclick=function(){filterPaysAlpha(l,this);};
        alphaCont.appendChild(btn);
      });
      renderPaysOptions('','');
      sel.addEventListener('change', function(){
        document.getElementById('pays-filter').value = this.value;
      });
    }
    window.filterPays = function filterPays(txt) {
      renderPaysOptions(txt, _currentAlpha);
