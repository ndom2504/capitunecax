    <script type="text/javascript" src="/templatemo_473_november/js/jquery-1.11.0.min.js"></script>
    <script>
    // ============================================================
    // CAPITUNE DASHBOARD  Logique complete du flux utilisateur
    // Ordre : Projet -> Services -> Messagerie -> Paiements -> Suivi
    // ============================================================

    // État utilisateur (devise + premium)
    window.__currencyCode = 'CAD';
    window.__premiumActive = false;
    window.__premiumExpiresAt = null;

    function formatMoney(amount) {
      var n = Number(amount);
      if (!Number.isFinite(n)) n = 0;
      var code = String(window.__currencyCode || 'CAD').toUpperCase();
      try {
        return new Intl.NumberFormat('fr-CA', { style: 'currency', currency: code }).format(n);
      } catch (_e) {
        return n.toLocaleString('fr-CA') + ' ' + code;
      }
    }

    function escHtml(s) {
      return String(s || '').replace(/[&<>"']/g, function(c) {
        return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;';
      });
    }

    function setPremiumHint(msg, ok) {
      var el = document.getElementById('premiumHint');
      if (!el) return;
      el.textContent = msg || '';
      el.style.color = ok ? '#27ae60' : '#e74c3c';
    }

    function premiumRequired() {
      if (typeof isProModeUI === 'function' && isProModeUI()) return false;
      return !window.__premiumActive;
    }

    window.showPremiumInterac = function() {
      var box = document.getElementById('premiumInteracBox');
      var ref = document.getElementById('premiumInteracRef');
      var emailElP = document.getElementById('premiumInteracEmail');
      var instElP = document.getElementById('premiumInteracInstitution');
      if (ref) ref.textContent = 'PREM-' + Date.now().toString().slice(-7);
      if (emailElP) emailElP.textContent = window.CAP_INTERAC_EMAIL || 'paiements@capitune.ca';
      if (instElP) instElP.textContent = window.CAP_INTERAC_INSTITUTION || 'Desjardins';
      if (box) box.style.display = 'block';
    };

    window.confirmPremiumInterac = function() {
      setPremiumHint('✅ Merci ! Votre virement a été enregistré. Accès activé sous 24h après réception.', true);
      var box = document.getElementById('premiumInteracBox');
      if (box) box.style.display = 'none';
      // Enregistrer la demande dans le chat
      try {
        var ref = document.getElementById('premiumInteracRef');
        var refTxt = ref ? ref.textContent : 'PREM-?';
        dbSync('/api/messages', 'POST', { content: 'Virement Interac Premium envoyé — Référence : ' + refTxt + ' — En attente de validation.', sender: 'user' });
      } catch(_e) {}
      setTimeout(function(){ closeModal(); showToast('⏳ Virement enregistré — activation sous 24h', 'info'); }, 1200);
    };

    window.openPremiumModal = function(reason) {
      var modal = document.getElementById('modalPaiement');
      if (modal) modal.classList.add('open');
      setPremiumHint('', true);
      // Initialiser PayPal boutons (si SDK disponible)
      setTimeout(function(){
        try { if (window.ensurePremiumPayPalButtons) window.ensurePremiumPayPalButtons(); } catch(_e) {}
      }, 50);
    };

    window.startPremiumStripe = async function() {
      try {
        setPremiumHint('Redirection vers Stripe…', true);
        var r = await fetch('/api/premium/stripe-checkout', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        var j = await r.json().catch(function(){ return {}; });
        if (!r.ok || !j.url) { setPremiumHint(j.error || 'Impossible de démarrer le paiement Stripe.', false); return; }
        window.location.href = j.url;
      } catch (e) {
        setPremiumHint('Erreur réseau.', false);
      }
    };

    window.ensurePremiumPayPalButtons = function() {
      var wrap = document.getElementById('premiumPayPalWrap');
      var root = document.getElementById('premiumPayPalButtons');
      if (!wrap || !root) return;
      if (!window.paypal || typeof window.paypal.Buttons !== 'function') {
        // Si PayPal n'est pas chargé/configuré, on cache simplement le bloc
        wrap.style.display = 'none';
        return;
      }
      wrap.style.display = 'flex';
      if (root.getAttribute('data-rendered') === '1') return;
      root.setAttribute('data-rendered', '1');

      window.paypal.Buttons({
        style: { layout: 'vertical', label: 'paypal' },
        createOrder: function() {
          return fetch('/api/premium/paypal-create-order', { method: 'POST' })
            .then(function(res){ return res.json().then(function(j){ return { ok: res.ok, j: j }; }); })
            .then(function(out){
              if (!out.ok || !out.j || !out.j.id) throw new Error(out.j && out.j.error ? out.j.error : 'Création PayPal impossible');
              return out.j.id;
            });
        },
        onApprove: function(data) {
          setPremiumHint('Confirmation PayPal…', true);
          return fetch('/api/premium/paypal-capture-order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderId: data.orderID })
          })
            .then(function(res){ return res.json().then(function(j){ return { ok: res.ok, j: j }; }); })
            .then(function(out){
              if (!out.ok || !out.j || !out.j.ok) throw new Error(out.j && out.j.error ? out.j.error : 'Capture PayPal impossible');
              window.__premiumActive = true;
              window.__premiumExpiresAt = out.j.premium_expires_at || null;
              setPremiumHint('Premium activé ✓', true);
              try { if (window.closeModal) window.closeModal(); } catch(_e) {}
              showToast('Premium activé ✓', 'success');
            })
            .catch(function(err){ setPremiumHint(err.message || 'Erreur PayPal.', false); });
        },
        onError: function(err) {
          setPremiumHint((err && err.message) ? err.message : 'Erreur PayPal.', false);
        }
      }).render('#premiumPayPalButtons');
    };

    async function confirmStripePremiumIfNeeded() {
      try {
        var params = new URLSearchParams(window.location.search || '');
        var status = params.get('premium');
        var sessionId = params.get('session_id');
        if (status !== 'success' || !sessionId) return;
        var r = await fetch('/api/premium/stripe-confirm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId: sessionId })
        });
        var j = await r.json().catch(function(){ return {}; });
        if (!r.ok || !j.ok) return;
        window.__premiumActive = true;
        window.__premiumExpiresAt = j.premium_expires_at || null;
        showToast('Premium activé ✓', 'success');
        // Nettoyer l'URL
        try {
          params.delete('premium');
          params.delete('session_id');
          var clean = window.location.pathname + (params.toString() ? ('?' + params.toString()) : '');
          window.history.replaceState({}, '', clean);
        } catch (_e) {}
      } catch (_e) {
        // ignore
      }
    }

    var PACKS = [
      /* ===================== TOURISME ===================== */
      { id:'tourisme', name:'Pack Tourisme', badge:'&#9992;&#65039;', desc:'Visa visiteur &amp; guide sur place', price:250, popular:false,
        services:[
          {id:'admis-tour', name:'Analyse admissibilité visa touriste/visiteur',      price: 45},
          {id:'montage-tour',name:'Montage dossier visiteur complet (AVE / TRV)',     price: 70},
          {id:'lettre-inv',  name:'Lettre d\'invitation professionnelle rédigée',      price: 50},
          {id:'guide-arr',   name:'Guide procédures arrivée &amp; frontière CBSA',    price: 40},
          {id:'assist-place',name:'Assistance démarches admin sur place (1 mois)',    price: 45}
        ]},
      /* ===================== EMPLOI (800 $) ===================== */
      { id:'emploi', name:'Pack Emploi', badge:'&#128188;', desc:'Trouver et obtenir un emploi au Canada', price:800, popular:false,
        services:[
          {id:'admis-emp',   name:'Analyse admissibilité permis de travail',           price: 70},
          {id:'orient-lmia', name:'Orientation LMIA, permis fermé/ouvert',            price: 80},
          {id:'montage-emp', name:'Montage complet du dossier permis travail',         price:220},
          {id:'rech-emp',    name:'Recherche d\'employeurs qualifiés avec LMIA',       price:200},
          {id:'suivi-emp',   name:'Suivi dossier &amp; réponses autorités',           price:150},
