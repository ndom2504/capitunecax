    window.__proPayLoaded = false;

    async function loadProPayments() {
      var loading = document.getElementById('pro-pay-loading');
      var content = document.getElementById('pro-pay-content');
      if (!loading || !content) return;
      loading.style.display = '';
      content.style.display = 'none';
      try {
        var r = await fetch('/api/admin/clients?scope=me&page=1');
        if (!r.ok) throw new Error('Erreur ' + r.status);
        var d = await r.json();
        var clients = d.clients || [];
        var totalRevenue = clients.reduce(function(s, c){ return s + Number(c.total_paid || 0); }, 0);
        var paidCount = clients.filter(function(c){ return Number(c.total_paid || 0) > 0; }).length;
        var setV = function(id, v){ var el=document.getElementById(id); if(el) el.textContent=v; };
        setV('pro-stat-revenue', (totalRevenue > 0 ? '$' + totalRevenue.toFixed(0) + ' CAD' : '0 $'));
        setV('pro-stat-paid-clients', String(paidCount));
        setV('pro-stat-total-clients', String(clients.length));

        var statusLabels = { soumis:'Soumis', en_cours:'En cours', termine:'Terminé', annule:'Annulé', aucun:'' };
        var rows = document.getElementById('pro-pay-rows');
        if (rows) {
          if (!clients.length) {
            rows.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:30px;color:#bbb;">Aucun client assigné</td></tr>';
          } else {
            rows.innerHTML = clients.map(function(c) {
              var init = (c.name || c.email || '?').charAt(0).toUpperCase();
              var paid = Number(c.total_paid || 0);
              var paidHtml = paid > 0
                ? '<span class="pro-pay-pill paid"><i class="fa fa-check"></i> $'+paid.toFixed(0)+' CAD</span>'
                : '<span class="pro-pay-pill none">—</span>';
              var status = c.project_status || '';
              var sLabel = statusLabels[status] || status || '—';
              var svcType = c.project_type ? c.project_type.replace(/_/g,' ') : '—';
              return '<tr>'
                + '<td><div style="display:flex;align-items:center;gap:9px;"><div style="width:30px;height:30px;border-radius:50%;background:var(--cap-orange);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;">'+init+'</div><div><div style="font-weight:600;">'+escP(c.name||'—')+'</div><div style="font-size:11px;color:#aaa;">'+escP(c.email)+'</div></div></div></td>'
                + '<td style="font-size:12px;color:#666;">'+escP(svcType)+'</td>'
                + '<td style="font-size:12px;">'+escP(sLabel)+'</td>'
                + '<td>'+paidHtml+'</td>'
                + '</tr>';
            }).join('');
          }
        }
        window.__proPayLoaded = true;
        loading.style.display = 'none';
        content.style.display = '';
      } catch(e) {
        loading.innerHTML = '<div style="color:#e74c3c;padding:20px;"><i class="fa fa-exclamation-circle"></i> ' + escP(e.message) + '</div>';
      }
    }

    //  PAIEMENTS 
    function refreshPaiementsView() {
      var total=computeTotal();
      var notice=document.getElementById('paiement-locked-notice');
      var summaryWrap=document.getElementById('payment-summary-card-wrap');
      var btnPay=document.getElementById('btn-pay-stripe');
      var hasTotal=(total>0);
      // Bannière d'avertissement si aucun service
      if(notice) notice.style.display=hasTotal?'none':'flex';
      // Récapitulatif seulement si service sélectionné
      if(summaryWrap) summaryWrap.style.display=hasTotal?'':'none';
      // Bouton Payer : désactivé + grisé si total = 0
      if(btnPay){ btnPay.disabled=!hasTotal; btnPay.style.opacity=hasTotal?'1':'0.45'; btnPay.style.cursor=hasTotal?'pointer':'not-allowed'; }
      if(!hasTotal) return;
      var linesEl=document.getElementById('payment-lines');
      if(linesEl){
        linesEl.innerHTML='';
        if(ST.pack) {
          var pk = PACKS.find(function(p){return p.id===ST.pack;});
          linesEl.innerHTML+='<div class="payment-line"><span>'+(pk ? pk.name : ST.pack)+'</span><span>'+formatMoney(ST.packPrice)+'</span></div>';
        }
        Object.entries(ST.carte).forEach(function(e){
          var sid = e[0];
          var svc = window.__catalogServiceMap && window.__catalogServiceMap[sid] ? window.__catalogServiceMap[sid] : null;
          var label = svc && svc.name ? svc.name : sid;
          linesEl.innerHTML+='<div class="payment-line"><span>'+label+'</span><span>'+formatMoney(e[1])+'</span></div>';
        });
      }
      var ts=formatMoney(total);
      var te=document.getElementById('payment-total-amount'); if(te) te.textContent=ts;
      var ba=document.getElementById('pay-btn-amount'); if(ba) ba.textContent=ts;
      // Mettre \u00e0 jour montant virement
      var tamt=document.getElementById('transfer-amount'); if(tamt) tamt.textContent=ts + ' ' + String(window.__currencyCode||'CAD').toUpperCase();
      var tref=document.getElementById('transfer-ref');
      if(tref&&tref.textContent==='INV-...') { var pc=(ST.projet&&ST.projet.type)?ST.projet.type.toUpperCase().slice(0,3):'SRV'; tref.textContent='INV-'+pc+'-'+(Date.now().toString().slice(-6)); }
      markStepActive('step-paiements');
    }

    window.selectPayMethod = function(m) {
      document.querySelectorAll('.pay-method-card').forEach(function(c){c.classList.remove('selected');});
      var el=document.getElementById('pay-'+m); if(el) el.classList.add('selected');
      ST.payMethod=m;
      // Afficher le bon formulaire
      ['card','paypal','transfer'].forEach(function(x){
        var f=document.getElementById('form-'+x);
        if(f) f.style.display=(x===m?'block':'none');
      });
      // Peupler les coordonnées Interac depuis les variables d'environnement
      var emailEl=document.getElementById('transfer-interac-email');
      var instEl=document.getElementById('transfer-institution');
      if(emailEl) emailEl.textContent = window.CAP_INTERAC_EMAIL || 'paiements@capitune.ca';
      if(instEl) instEl.textContent = window.CAP_INTERAC_INSTITUTION || 'Desjardins';
      // Bouton Stripe : masqué pour PayPal (PayPal a ses propres boutons)
      var btnStripe=document.getElementById('btn-pay-stripe');
      if(btnStripe) btnStripe.style.display=(m==='paypal'?'none':'');
      // Lazy-load PayPal SDK
      if(m==='paypal') initPayPal();
      // Mise à jour montant dans le bouton transfer/crypto
      var total=computeTotal();
      var tref=document.getElementById('transfer-ref');
      var tamt=document.getElementById('transfer-amount');
      var projCode = (ST.projet && ST.projet.type) ? ST.projet.type.toUpperCase().slice(0,3) : 'SRV';
      if(tref) tref.textContent = 'INV-' + projCode + '-' + Date.now().toString().slice(-6);
      if(tamt) tamt.textContent = total > 0 ? (total.toLocaleString('fr-CA') + ' $ CAD') : 'À définir après sélection de service';
    };

    window.processPayment = async function() {
      var total = computeTotal();
      if (total <= 0) { showToast('Veuillez sélectionner au moins un service avant de payer.', 'info'); return; }
      if (ST.paye) { showToast('✅ Ce dossier a déjà été payé.', 'info'); return; }
      var method = ST.payMethod;
      var btn = document.getElementById('btn-pay-stripe');
      if (method === 'card') {
        if (!window._stripe || !window._cardEl) {
          document.getElementById('stripe-errors').textContent = 'Clé Stripe non configurée — contactez le support.';
          return;
        }
        if (btn) { btn.disabled=true; btn.innerHTML='<i class="fa fa-spinner fa-spin"></i> Traitement en cours...'; }
        try {
          var resp = await fetch('/api/payments/create-payment-intent', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({
              amount: total,
              invoiceId: 'INV-'+Date.now(),
              customerEmail: window.CAP_USER_EMAIL,
              customerName: window.CAP_USER_NAME,
              services: buildServicesList()
            })
          });
          var pi = await resp.json();
          if (!pi.clientSecret) throw new Error(pi.error||'Erreur serveur Stripe');
          var result = await window._stripe.confirmCardPayment(pi.clientSecret, {
            payment_method: { card: window._cardEl,
              billing_details: { name: window.CAP_USER_NAME, email: window.CAP_USER_EMAIL }
            }
          });
          if (result.error) throw new Error(result.error.message);
          onPaymentSuccess('stripe', result.paymentIntent.id);
        } catch(e) {
          var errEl=document.getElementById('stripe-errors');
          if(errEl) errEl.textContent=e.message;
          if (btn) { btn.disabled=false; btn.innerHTML='<i class="fa fa-lock"></i> Réessayer &mdash; <span>'+total.toLocaleString()+' $</span>'; }
        }
      }
      // PayPal géré par ses propres boutons — ne rien faire ici
    };

    window.confirmTransfer = function() {
      var total=computeTotal();
      if(total<=0){showToast('Veuillez sélectionner au moins un service avant de payer.','info');return;}
      onPaymentSuccess('transfer', null);
    };

    window.copyText = function(txt) {
      if(navigator.clipboard) navigator.clipboard.writeText(txt).then(function(){showToast('Copié !');});
      else { var t=document.createElement('textarea');t.value=txt;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);showToast('Copié !');}
    };

    function computeTotal() {
      return ST.packPrice + Object.values(ST.carte).reduce(function(a,b){return a+b;},0);
    }

    function buildServicesList() {
      var list=[];
      if(ST.pack) list.push({id:ST.pack,price:ST.packPrice});
      Object.keys(ST.carte).forEach(function(k){list.push({id:k,price:ST.carte[k]});});
      return list;
    }

    function onPaymentSuccess(method, txId) {
      ST.paye=true;
      var total=computeTotal();
      localStorage.setItem('capitune_paye', JSON.stringify({method:method,txId:txId,amount:total,ts:Date.now()}));
      markStepDone('step-paiements');
      markStepActive('step-suivi');
      // Remplacer la vue active par confirmation
      var av=document.getElementById('paiement-active-view');
      if(av) av.innerHTML='<div class="payment-success-badge"><i class="fa fa-check-circle"></i><h3>Paiement confirmé !</h3><p>Montant : '+total.toLocaleString('fr-CA')+' $ CAD &mdash; Méthode : '+method+'</p><p style="margin-top:8px;">Notre équipe a été notifiée et commence à traiter votre dossier.</p><button onclick="switchTab(\"messagerie\")" style="margin-top:16px;background:rgba(255,255,255,0.2);color:#fff;border:2px solid #fff;border-radius:8px;padding:10px 24px;cursor:pointer;font-weight:600;"><i class="fa fa-comments"></i> Ouvrir la messagerie</button></div>';
      // Message automatique dans la messagerie
      var methodLabels={stripe:'carte bancaire',paypal:'PayPal',transfer:'virement bancaire',crypto:'crypto-monnaie'};
      appendReceivedMessage('✅ Paiement reçu via '+(methodLabels[method]||method)+' — '+total.toLocaleString('fr-CA')+' $ CAD. Votre dossier est maintenant actif. Nous vous contacterons dans les 24h pour planifier votre première consultation.');
    }

    function initPayPal() {
      var cid=window.CAP_PAYPAL_CID||'sb';
