    async function triggerAutoReponse(projType) {
      var info = IMMIG_INFO[projType];
      if (!info) return;
      addMsgBadge();

      // Si messagerie déjà ouverte, afficher les dots puis le message
      var msgActive = document.getElementById('tab-messagerie')
        && document.getElementById('tab-messagerie').classList.contains('active');

      function buildBotHtml(liveExcerpt) {
        var docsHtml = info.docs.map(function(d){ return '<li>'+d+'</li>'; }).join('');
        var progHtml = info.programmes.map(function(p){ return '<li>'+p+'</li>'; }).join('');
        var liveBlock = liveExcerpt
          ? '<div class="msg-bot-section" style="margin-top:10px;padding:8px 10px;background:#f0f8e8;border-radius:6px;font-size:11px;color:#555;">'
            + '<strong style="color:#27ae60;">📡 Mise à jour canada.ca</strong><br>'
            + liveExcerpt.substring(0,400)+'…<br>'
            + '<a href="'+info.officialUrl+'" target="_blank" style="color:#2980b9;font-size:11px;">Voir la page officielle</a>'
            + '</div>'
          : '<a href="https://www.canada.ca/fr/immigration-refugies-citoyennete.html" target="_blank" style="font-size:11px;color:#2980b9;display:block;margin-top:8px;">📎 Site officiel Immigration Canada</a>';
        return '<div class="msg-bot-section"><strong>'+info.emoji+' Analyse de votre projet : '+info.label+'</strong></div>'
          + '<div class="msg-bot-section"><strong>⏱️ Délai moyen</strong><br>'+info.delai+'</div>'
          + '<div class="msg-bot-section"><strong>💰 Frais gouvernementaux estimés</strong><br>'+info.frais+'</div>'
