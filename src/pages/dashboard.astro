    window.filterPaysAlpha = function(letter, btn) {
      _currentAlpha = letter;
      document.querySelectorAll('.alpha-btn').forEach(function(b){b.classList.remove('active');});
      if(btn) btn.classList.add('active');
      else { var b=document.querySelector('.alpha-btn:first-child'); if(b)b.classList.add('active');}
      renderPaysOptions(document.getElementById('pays-filter')?.value||'', letter);
    };
    function renderPaysOptions(search, alpha) {
      var sel=document.getElementById('proj-pays');
      if(!sel) return;
      var prev=sel.value;
      var filtered=PAYS_LIST.filter(function(p){
        var matchAlpha = !alpha || p.toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').charAt(0)===alpha;
        var matchSearch = !search || p.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').includes(search.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,''));
        return matchAlpha && matchSearch;
      });
      sel.innerHTML = filtered.map(function(p){
        return '<option value="'+p+'"'+(p===prev?' selected':'')+'>'+p+'</option>';
      }).join('');
      if(!sel.value && prev && filtered.length===0) sel.innerHTML='<option value="'+prev+'">'+prev+'</option>';
    }

