        function renderInsideFeed(posts) {
      var feed = document.getElementById('insideFeedList');
      if (!feed) return;
      if (!posts.length) {
        feed.innerHTML = '<div class="fb-post-card" style="padding:40px;text-align:center;color:#65676b;"><div style="font-size:40px;margin-bottom:12px;">&#x1F4ED;</div><strong>Aucune publication</strong><br><span style="font-size:13px;">Les mises \u00e0 jour appara\u00eetront ici.</span></div>';
        return;
      }
      var isAdm = document.body.dataset.isAdmin === 'true';
      feed.innerHTML = posts.map(function(p) {
        var initial = (p.authorName||'C')[0].toUpperCase();
        var dateObj = p.createdAt ? new Date(p.createdAt) : null;
        var dateStr = dateObj ? dateObj.toLocaleDateString('fr-CA',{day:'numeric',month:'short',year:'numeric'}) : '';
        var mediaHtml = '';
        if (p.mediaUrl) {
          if ((p.mediaType||'').startsWith('video')) {
            mediaHtml = '<div class="fb-post-media"><video src="'+_escHtml(p.mediaUrl)+'" controls style="width:100%;max-height:400px;display:block;"></video></div>';
          } else {
            mediaHtml = '<div class="fb-post-media"><img src="'+_escHtml(p.mediaUrl)+'" alt="media" loading="lazy" style="width:100%;max-height:400px;object-fit:cover;display:block;"></div>';
          }
        }
        var r = _insideReactions[p.id] || { like:0, fire:0, clap:0 };
        var totalR = r.like + r.fire + r.clap;
        var linkHtml = '';
        if (p.linkUrl && p.linkUrl.startsWith('http')) {
          var domain = '';
          try { domain = new URL(p.linkUrl).hostname.replace('www.',''); } catch(e){}
          linkHtml = '<a class="fb-post-link-preview" href="'+_escHtml(p.linkUrl)+'" target="_blank" rel="noopener">'
            +'<div class="fb-post-link-icon"><i class="fa fa-link"></i></div>'
            +'<div class="fb-post-link-info"><div>'+_escHtml(p.title||domain||'Lien externe')+'</div><div>'+_escHtml(domain)+'</div></div>'
            +'</a>';
        }
        var adminDel = isAdm ? '<button class="fb-post-del-btn" onclick="deleteInsidePost(\''+p.id+'\')" title="Supprimer"><i class="fa fa-trash"></i> Supprimer</button>' : '';
        var statsHtml = (totalR > 0 || adminDel)
          ? '<div class="fb-post-stats"><div class="fb-post-stats-reactions">'+(totalR>0?(''+r.like+' \ud83d\udc4d  '+r.fire+' \ud83d\udd25  '+r.clap+' \ud83d\udc4f'):'')+'</div>'+adminDel+'</div>'
          : '';
        return '<div class="fb-post-card" id="inside-post-'+p.id+'">'
          +'<div class="fb-post-header">'
          +'<div class="fb-post-avatar">'+_escHtml(initial)+'</div>'
          +'<div class="fb-post-meta">'
          +'<div class="fb-post-author">'+_escHtml(p.authorName||'\u00c9quipe CAPITUNE')+'</div>'
          +'<div class="fb-post-date">\ud83c\udf10 '+dateStr+'</div>'
          +'</div>'
          +'<button class="fb-post-options" title="Options">\u22ef</button>'
          +'</div>'
          +(p.title ? '<div class="fb-post-title">'+_escHtml(p.title)+'</div>' : '')
          +(p.content ? '<div class="fb-post-content">'+_escHtml(p.content)+'</div>' : '')
          +mediaHtml
          +linkHtml
          +statsHtml
          +'<div class="fb-post-actions">'
          +'<button class="fb-post-action-btn" id="ir-like-'+p.id+'" onclick="reactInside(\''+p.id+'\',\'like\')">\ud83d\udc4d J\'aime</button>'
          +'<button class="fb-post-action-btn" id="ir-fire-'+p.id+'" onclick="reactInside(\''+p.id+'\',\'fire\')">\ud83d\udd25 Bravo</button>'
          +'<button class="fb-post-action-btn" id="ir-clap-'+p.id+'" onclick="reactInside(\''+p.id+'\',\'clap\')">\ud83d\udc4f Super</button>'
          +'</div>'
          +'</div>';
      }).join('');
    }

function _escHtml(s){ return String(s||'').replace(/[&<>"']/g,function(c){return c==='&'?'&amp;':c==='<'?'&lt;':c==='>'?'&gt;':c==='"'?'&quot;':'&#39;';}); }

    window.toggleInsideOfficial = function() {
      var p = document.getElementById('insideOfficialPanel');
      if (p) p.classList.toggle('open');
    };

    window.openInsideCompose = function() {
      document.getElementById('insideComposeForm').style.display = 'block';
      document.getElementById('insideComposeTitle').focus();
    };

    window.submitInsidePost = function() {
      var title   = (document.getElementById('insideComposeTitle').value||'').trim();
      var content = (document.getElementById('insideComposeContent').value||'').trim();
      var linkUrl = (document.getElementById('insideComposeLinkUrl').value||'').trim();
      if (title.length < 3)  { alert('Titre trop court (min. 3 caractères).'); return; }
      if (content.length < 10){ alert('Contenu trop court (min. 10 caractères).'); return; }
      var btn = document.querySelector('#insideComposeForm .btn-primary');
      if (btn) { btn.disabled=true; btn.textContent='Publication...'; }
      fetch('/api/inside', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ title: title, content: content, linkUrl: linkUrl||'' })
      })
        .then(function(r){ return r.json(); })
        .then(function(data){
          if (data.error) { alert(data.error); return; }
          _insideLoaded = false;
          document.getElementById('insideComposeForm').style.display = 'none';
          document.getElementById('insideComposeTitle').value = '';
          document.getElementById('insideComposeContent').value = '';
          document.getElementById('insideComposeLinkUrl').value = '';
          loadInsideTab();
        })
        .catch(function(){ alert('Erreur lors de la publication.'); })
        .finally(function(){ if(btn){ btn.disabled=false; btn.innerHTML='<i class="fa fa-send"></i> Publier'; } });
    };

    window.reactInside = function(postId, reaction) {
      if (!_insideReactions[postId]) _insideReactions[postId] = { like:0, fire:0, clap:0 };
      _insideReactions[postId][reaction] = (_insideReactions[postId][reaction]||0) + 1;
      var emojiMap = { like:'&#x1F44D;', fire:'&#x1F525;', clap:'&#x1F44F;' };
      var el = document.getElementById('ir-'+reaction+'-'+postId);
      if (el) {
        el.innerHTML = emojiMap[reaction]+' '+_insideReactions[postId][reaction];
        el.classList.add('reacted');
      }
    };

    window.deleteInsidePost = function(postId) {
      if (!confirm('Supprimer cette publication ?')) return;
      fetch('/api/inside/'+postId, { method:'DELETE' })
        .then(function(){ _insideLoaded=false; loadInsideTab(); })
        .catch(function(){ alert('Erreur lors de la suppression.'); });
    };

    window.loadInsideTab = loadInsideTab;

    // ============================================================
    //  DOCUMENTS — checklist dossier
    // ============================================================
    var _docsLoaded = false;
    var _allDocs = [];

    function loadDocumentsTab() {
      if (_docsLoaded) return;
      var container = document.getElementById('documentsChecklist');
      if (!container) return;
      container.innerHTML = '<div style="text-align:center;padding:40px;color:#888;"><i class="fa fa-spinner fa-spin fa-2x"></i></div>';
      fetch('/api/documents')
        .then(function(r){ return r.json(); })
        .then(function(data){
          _docsLoaded = true;
          _allDocs = data.documents || [];
          renderDocs(_allDocs, 'all');
        })
        .catch(function(){
          container.innerHTML = '<div style="text-align:center;padding:40px;color:#e74c3c;"><i class="fa fa-exclamation-circle"></i> Impossible de charger la liste des documents.</div>';
        });
    }

    function renderDocs(docs, filter) {
      var container = document.getElementById('documentsChecklist');
      if (!container) return;
      var filtered = filter === 'all' ? docs : docs.filter(function(d){ return d.status === filter; });
      if (!filtered.length) {
        container.innerHTML = '<div style="text-align:center;padding:40px;color:#888;"><i class="fa fa-check-circle fa-2x" style="color:#28a745"></i><br><br>' + (filter==='all' ? 'Aucun document requis.' : 'Aucun document dans cette catégorie.') + '</div>';
        return;
      }
      var statusMeta = {
        validated: {label:'Validé',icon:'fa-check-circle'},
        pending:   {label:'En attente',icon:'fa-clock-o'},
        rejected:  {label:'Refusé',icon:'fa-times-circle'},
        missing:   {label:'Manquant',icon:'fa-exclamation-triangle'}
      };
      container.innerHTML = filtered.map(function(d){
        var meta = statusMeta[d.status] || {label:d.status||'Inconnu',icon:'fa-file'};
        var actionHtml = (d.status==='missing'||d.status==='rejected') ? '<div class="doc-item-action"><button onclick="alert(\'Fonctionnalité d\\\'upload à venir.\')"><i class="fa fa-upload"></i> Déposer</button></div>' : '';
        return '<div class="doc-item '+_escHtml(d.status)+'">'
          +'<div class="doc-item-icon"><i class="fa '+meta.icon+'"></i></div>'
          +'<div class="doc-item-info"><div class="doc-item-name">'+_escHtml(d.name||d.type||'Document')+'</div><div class="doc-item-status">'+meta.label+(d.note?' — '+_escHtml(d.note):'')+'</div></div>'
          +actionHtml
          +'</div>';
      }).join('');
    }

    window.filterDocs = function(filter, btn) {
      document.querySelectorAll('.doc-filter-btn').forEach(function(b){ b.classList.remove('active'); });
      if (btn) btn.classList.add('active');
      renderDocs(_allDocs, filter);
    };

    window.loadDocumentsTab = loadDocumentsTab;
    // ============================================================
    window.__teamStoryIndex = 0;

    window.renderTeamStoryProgress = function() {
      try {
        var members = window.__teamMembers || [];
        var wrap = document.getElementById('tpStoryProgress');
        if (!wrap) return;
        if (!members.length) { wrap.innerHTML = ''; return; }

        var idx = Number(window.__teamStoryIndex || 0);
        if (!Number.isFinite(idx)) idx = 0;
        idx = Math.max(0, Math.min(members.length - 1, idx));
        window.__teamStoryIndex = idx;

        wrap.innerHTML = members.map(function(_m, i) {
          var cls = (i < idx) ? 'done' : (i === idx ? 'active' : '');
          return '<div class="team-story-bar ' + cls + '"><span></span></div>';
        }).join('');
      } catch(_e) {}
    };

    window.teamProfilePrev = function() {
      try {
        var members = window.__teamMembers || [];
        if (!members.length) return;
        var idx = Number(window.__teamStoryIndex || 0) - 1;
        if (idx < 0) idx = 0;
        window.openTeamProfile(idx);
      } catch(_e) {}
    };

    window.teamProfileNext = function() {
      try {
        var members = window.__teamMembers || [];
        if (!members.length) return;
        var idx = Number(window.__teamStoryIndex || 0) + 1;
        if (idx > members.length - 1) idx = members.length - 1;
        window.openTeamProfile(idx);
      } catch(_e) {}
    };

    window.closeTeamProfile = function(){
      if (window.closeModal) window.closeModal();
      var modal = document.getElementById('teamProfileModal');
      if (modal) modal.classList.remove('open');
    };

    window.openTeamProfile = function(idx){
      try {
        var members = window.__teamMembers || [];
        var m = members[idx];
        if (!m) return;
        var modal = document.getElementById('teamProfileModal');
        if (!modal) return;

        function esc(s){
          return String(s||'').replace(/[&<>"']/g, function(c){
            return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;';
          });
        }
        function getAvatarSrc(u){ var s=String(u||'').trim(); return (/^https?:\/\//i.test(s)||/^data:image\//i.test(s))&&s.length>4 ? s : ''; }
        var avatarUrl = getAvatarSrc(m.avatar_key);
        var initials = (m.name||'?').split(' ').map(function(w){return w[0]||'';}).slice(0,2).join('').toUpperCase();
        var tpA = document.getElementById('tpAvatar');
        if (tpA) {
          tpA.innerHTML = avatarUrl
            ? ('<img src="'+esc(avatarUrl)+'" alt="avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">')
            : esc(initials||'?');
        }
        setText('tpName', m.name || 'Conseiller CAPITUNE');
        setText('tpLocation', m.location ? ('📍 ' + m.location) : '');
        setText('tpBio', m.bio || '');

        // Drapeau du pays déduit depuis le champ location
        (function(){
          var flagEl = document.getElementById('tpCountryFlag');
          if (!flagEl) return;
          var loc = String(m.location || '').trim();
          if (!loc) { flagEl.style.display = 'none'; flagEl.textContent = ''; return; }
          // Cherche la partie pays : après la dernière virgule, sinon toute la chaîne
          var parts = loc.split(',');
          var raw = parts[parts.length - 1].trim().toLowerCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[''\u2019]/g, "'");
          var MAP = {
            'canada':'CA','qc':'CA','ontario':'CA','montreal':'CA','quebec':'CA','levis':'CA','laval':'CA','gatineau':'CA','ottawa':'CA','toronto':'CA','vancouver':'CA','calgary':'CA','edmonton':'CA',
            'france':'FR','paris':'FR',
            'maroc':'MA','morocco':'MA',
            'algerie':'DZ','algeria':'DZ',
            'tunisie':'TN','tunisia':'TN',
            'senegal':'SN',
            "cote d'ivoire":'CI','ivory coast':'CI',
            'cameroun':'CM','cameroon':'CM',
            'congo':'CG','rdc':'CD','democratic republic of congo':'CD',
            'gabon':'GA','madagascar':'MG','mali':'ML',
            'guinee':'GN','guinea':'GN',
            'togo':'TG','benin':'BJ','burkina faso':'BF','niger':'NE','tchad':'TD','chad':'TD',
            'mauritanie':'MR','mauritania':'MR',
            'etats-unis':'US','usa':'US','united states':'US',
            'mexique':'MX','mexico':'MX',
            'haiti':'HT','guadeloupe':'GP','martinique':'MQ','reunion':'RE',
            'bresil':'BR','brazil':'BR',
            'belgique':'BE','belgium':'BE',
            'suisse':'CH','switzerland':'CH',
            'luxembourg':'LU',
            'espagne':'ES','spain':'ES',
            'portugal':'PT','italie':'IT','italy':'IT',
            'allemagne':'DE','germany':'DE',
            'royaume-uni':'GB','uk':'GB','united kingdom':'GB',
            'liban':'LB','lebanon':'LB',
            'chine':'CN','china':'CN','inde':'IN','india':'IN'
          };
          var iso = MAP[raw];
          if (!iso) {
            flagEl.style.display = 'none'; flagEl.textContent = '';
            return;
          }
          var flag = iso.split('').map(function(c){ return String.fromCodePoint(c.charCodeAt(0)-65+0x1F1E6); }).join('');
          var countryNames = { CA:'Canada', FR:'France', MA:'Maroc', DZ:'Algérie', TN:'Tunisie', SN:'Sénégal', CI:"Côte d'Ivoire", CM:'Cameroun', CG:'Congo', CD:'RD Congo', GA:'Gabon', MG:'Madagascar', ML:'Mali', GN:'Guinée', TG:'Togo', BJ:'Bénin', BF:'Burkina Faso', NE:'Niger', TD:'Tchad', MR:'Mauritanie', US:'États-Unis', MX:'Mexique', HT:'Haïti', GP:'Guadeloupe', MQ:'Martinique', RE:'Réunion', BR:'Brésil', BE:'Belgique', CH:'Suisse', LU:'Luxembourg', ES:'Espagne', PT:'Portugal', IT:'Italie', DE:'Allemagne', GB:'Royaume-Uni', LB:'Liban', CN:'Chine', IN:'Inde' };
          flagEl.textContent = flag;
          flagEl.title = countryNames[iso] || iso;
          flagEl.style.display = '';
        })();

        // Meta (diplôme / compétences / expérience)
        var metaWrap = document.getElementById('tpMeta');
        var hasMeta = false;
        var diploma = (m.pro_diploma || '').trim();
        var competences = (m.pro_competences || '').trim();
        var expYears = (typeof m.pro_experience_years === 'number') ? m.pro_experience_years : Number(m.pro_experience_years);
        var expTxt = (Number.isFinite(expYears) && expYears > 0) ? (String(Math.trunc(expYears)) + ' an(s)') : '';
        if (diploma) { setText('tpDiploma', diploma); hasMeta = true; } else { setText('tpDiploma', '—'); }
        if (expTxt) { setText('tpExperience', expTxt); hasMeta = true; } else { setText('tpExperience', '—'); }
        if (competences) { setText('tpCompetences', competences); hasMeta = true; } else { setText('tpCompetences', '—'); }
        if (metaWrap) metaWrap.style.display = hasMeta ? '' : 'none';

        // Résolution de label : pro service IDs (consultation…) ou catalog service IDs
        function svcLabel(id) {
          if (window.__proSvcLabelMap && window.__proSvcLabelMap[id]) return window.__proSvcLabelMap[id];
          try {
            if (window.__catalogServiceMap && window.__catalogServiceMap[id] && window.__catalogServiceMap[id].name) return window.__catalogServiceMap[id].name;
          } catch(_e) {}
          // Fallback lisible : capitalize
          return String(id).charAt(0).toUpperCase() + String(id).slice(1);
        }

        var packSvcs  = (m.pro_pack_services && typeof m.pro_pack_services === 'object') ? m.pro_pack_services : {};
        var pkgCatalog = window.CAP_PACKAGES_CATALOG || [];

        // ── Rendu des cartes packs — services uniquement, sans prix ──────────────
        var tarifsWrap = document.getElementById('tpTarifs');
        var noOffersEl = document.getElementById('tpNoOffers');
        if (tarifsWrap) {
          var cardsHtml = '';
          pkgCatalog.forEach(function(pkg) {
            var included = Array.isArray(packSvcs[pkg.id]) ? packSvcs[pkg.id] : [];
            // Services à afficher : ceux configurés par le pro, sinon features du catalogue
            var feats = included.length
              ? included.map(function(id) { return svcLabel(id); })
              : (pkg.features || []);
            var headBg    = pkg.popular ? 'linear-gradient(135deg,var(--cap-orange),#e67e00)' : 'linear-gradient(135deg,#1a1a2e,#0f3460)';
            var borderCol = pkg.popular ? 'var(--cap-orange)' : '#eee';
            var featHtml  = feats.map(function(f) {
              return '<li style="display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#444;">'
                + '<span style="color:var(--cap-orange);font-weight:800;flex-shrink:0;">\u2713</span>'
                + esc(String(f))
                + '</li>';
            }).join('');
            cardsHtml +=
              '<div style="background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,0.09);overflow:hidden;'
              + 'display:flex;flex-direction:column;border:2px solid '+borderCol+';position:relative;">'
              + (pkg.popular ? '<div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--cap-orange);'
                + 'color:#fff;font-size:10px;font-weight:800;padding:3px 12px;border-radius:0 0 9px 9px;white-space:nowrap;z-index:1;">⭐ PLUS POPULAIRE</div>' : '')
              + '<div style="background:'+headBg+';color:#fff;padding:'+(pkg.popular?'28px 16px 14px':'16px')+'">'
                + '<div style="font-size:1.6rem;margin-bottom:5px;">'+esc(pkg.badge)+'</div>'
                + '<div style="font-size:.95rem;font-weight:800;margin-bottom:3px;">'+esc(pkg.name)+'</div>'
                + '<div style="font-size:11px;opacity:.8;">'+esc(pkg.description)+'</div>'
              + '</div>'
              + '<div style="padding:12px 14px;flex:1;">'
                + '<ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;">'
                + featHtml
                + '</ul>'
              + '</div>'
              + '</div>';
          });
          tarifsWrap.innerHTML = cardsHtml;
          if (noOffersEl) noOffersEl.style.display = pkgCatalog.length ? 'none' : '';
        }

        window.__teamStoryIndex = idx;
        if (typeof window.renderTeamStoryProgress === 'function') window.renderTeamStoryProgress();

        modal.classList.add('open');

        // ---- AVIS ----
        window._reviewProId = m.id;
        window._reviewRating = 0;
        var isProUI = document.body && document.body.classList.contains('is-pro-mode');
        var reviewsBlock = document.getElementById('tpReviewsBlock');
        if (reviewsBlock) reviewsBlock.style.display = isProUI ? 'none' : '';
        if (!isProUI) {
          // Reset form
          window._reviewRating = 0;
          setReviewStar(0);
          var commentEl = document.getElementById('tpReviewComment');
          var hintEl = document.getElementById('tpReviewHint');
          var submitBtn = document.getElementById('tpReviewSubmitBtn');
          if (commentEl) commentEl.value = '';
          if (hintEl) hintEl.textContent = '';
          if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Soumettre ma note'; }
          loadProReviews(m.id);
        }
      } catch(e) {}
    };

    // ============================================================
    //  NOTATION DES PROS
    // ============================================================
    window._reviewProId = null;
    window._reviewRating = 0;

    window.setReviewStar = function(v) {
      window._reviewRating = v;
      var btns = document.querySelectorAll('#tpStarRow .star-btn');
      btns.forEach(function(btn) {
        var bv = parseInt(btn.getAttribute('data-v'), 10);
        btn.classList.toggle('filled', bv <= v);
      });
      var submitBtn = document.getElementById('tpReviewSubmitBtn');
      if (submitBtn) submitBtn.disabled = (v < 1);
    };

    window.loadProReviews = function(proId) {
      var summEl = document.getElementById('tpReviewsSummary');
      var listEl = document.getElementById('tpReviewsList');
      if (summEl) summEl.innerHTML = '<span style="color:#aaa;font-size:13px;"><i class="fa fa-spinner fa-spin"></i> Chargement des avis...</span>';
      if (listEl) listEl.innerHTML = '';

      fetch('/api/reviews?pro_id=' + encodeURIComponent(proId))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var avg = data.avg || 0;
          var count = data.count || 0;
          var reviews = data.reviews || [];
          var mine = data.mine;

          // Summary
          if (summEl) {
            var stars = '';
            for (var s = 1; s <= 5; s++) { stars += '<span style="color:' + (s <= Math.round(avg) ? '#ffd700' : '#ddd') + ';font-size:20px;">&#9733;</span>'; }
            summEl.innerHTML = count > 0
              ? stars + '<strong style="font-size:22px;color:var(--cap-dark);">' + avg.toFixed(1) + '</strong><span style="color:#999;font-size:13px;">&nbsp;(' + count + ' avis)</span>'
              : '<span style="color:#aaa;font-size:13px;">Aucun avis pour le moment</span>';
          }

          // Liste des avis (5 derniers)
          if (listEl) {
            if (!reviews.length) {
              listEl.innerHTML = '';
            } else {
              listEl.innerHTML = reviews.slice(0, 5).map(function(r) {
                var rStars = '';
                for (var s = 1; s <= 5; s++) { rStars += '<span style="color:' + (s <= r.rating ? '#ffd700' : '#ddd') + ';">&#9733;</span>'; }
                var date = r.created_at ? new Date(r.created_at).toLocaleDateString('fr-CA',{year:'numeric',month:'short',day:'numeric'}) : '';
                var initials = (r.client_name||'?').split(' ').map(function(w){return w[0]||'';}).slice(0,2).join('').toUpperCase();
                return '<div class="review-card">'
                  + '<div class="review-card-stars">' + rStars + '</div>'
                  + (r.comment ? '<p class="review-card-comment">' + String(r.comment).replace(/[<>&]/g, function(c){return c==='<'?'&lt;':c==='>'?'&gt;':'&amp;';}) + '</p>' : '')
                  + '<div class="review-card-author"><strong>' + String(initials).replace(/[<>&]/g,'') + '</strong> &bull; ' + date + '</div>'
                  + '</div>';
              }).join('');
            }
          }

          // Pré-remplir si l'utilisateur a déjà un avis
          if (mine) {
            setReviewStar(mine.rating);
            var commentEl = document.getElementById('tpReviewComment');
            var hintEl = document.getElementById('tpReviewHint');
            if (commentEl) commentEl.value = mine.comment || '';
            if (hintEl) hintEl.textContent = 'Vous avez déjà donné une note. Vous pouvez la modifier.';
            var submitBtn = document.getElementById('tpReviewSubmitBtn');
            if (submitBtn) submitBtn.textContent = 'Mettre à jour ma note';
          }
        })
        .catch(function() {
          if (summEl) summEl.innerHTML = '<span style="color:#e74c3c;font-size:13px;">Impossible de charger les avis</span>';
        });
    };

    window.submitProReview = function() {
      var proId = window._reviewProId;
      var rating = window._reviewRating || 0;
      if (!proId || rating < 1) return;
      var commentEl = document.getElementById('tpReviewComment');
      var hintEl = document.getElementById('tpReviewHint');
      var submitBtn = document.getElementById('tpReviewSubmitBtn');
      var comment = commentEl ? commentEl.value.trim() : '';

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Envoi...'; }
      if (hintEl) hintEl.textContent = '';

      fetch('/api/reviews', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pro_id: proId, rating: rating, comment: comment })
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) {
            if (hintEl) hintEl.textContent = '\u2705 Avis enregistré !';
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Mettre à jour ma note'; }
            loadProReviews(proId);
            showToast('Votre avis a été enregistré.', 'success');
          } else {
            if (hintEl) hintEl.textContent = data.error || 'Erreur lors de l\'enregistrement';
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Soumettre ma note'; }
          }
        })
        .catch(function() {
          if (hintEl) hintEl.textContent = 'Erreur réseau';
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Soumettre ma note'; }
        });
    };

    // ============================================================
    //  TOAST NOTIFICATION
    // ============================================================
    function showToast(message, type) {
      var existing = document.getElementById('cap-toast');
      if (existing) existing.remove();
      var toast = document.createElement('div');
      toast.id = 'cap-toast';
      var bg = (type === 'info') ? '#2980b9' : (type === 'error') ? '#e74c3c' : '#27ae60';
      toast.style.cssText = 'position:fixed;bottom:28px;right:28px;background:'+bg+';color:#fff;padding:13px 22px;border-radius:10px;font-size:14px;font-weight:600;z-index:9999;box-shadow:0 6px 24px rgba(0,0,0,0.2);display:flex;align-items:center;gap:10px;animation:slideInToast .3s ease;max-width:340px;';
      toast.innerHTML = '<i class="fa fa-'+(type==='error'?'times-circle':type==='info'?'info-circle':'check-circle')+'"></i> ' + message;
      if (!document.getElementById('toast-style')) {
        var s = document.createElement('style'); s.id = 'toast-style';
        s.textContent = '@keyframes slideInToast{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}';
        document.head.appendChild(s);
      }
      document.body.appendChild(toast);
      setTimeout(function(){ toast.style.opacity='0'; toast.style.transition='opacity .4s'; setTimeout(function(){ toast.remove(); }, 400); }, 3500);
    }
    window.showToast = showToast;

    </script>
  </body>
</html>

