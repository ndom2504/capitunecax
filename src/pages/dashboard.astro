    //  ETAPES BREADCRUMB 
    function markStepDone(id) {
      var el=document.getElementById(id);
      if(el){el.classList.add('done');el.classList.remove('active');var n=el.querySelector('.step-num');if(n)n.innerHTML='<i class="fa fa-check"></i>';}
    }
    function markStepActive(id) {
      var el=document.getElementById(id);
      if(el){el.classList.add('active');el.classList.remove('done');}
