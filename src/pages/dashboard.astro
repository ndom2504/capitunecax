    window.setPackMode = function(packId, packPrice, mode) {
      // Toggle : si le pack est déjà sélectionné, on le désélectionne
      if (ST.pack === packId) {
        var btnDe = document.getElementById('pack-'+packId);
        if(btnDe){btnDe.classList.remove('selected-pack');btnDe.textContent='\u2713 Choisir ce pack';}
        var subElDe = document.getElementById('cs-sub-'+packId);
        if(subElDe) subElDe.textContent = formatMoney(0);
        ST.pack=null; ST.packPrice=0; ST.packItemsSelected={};
        document.querySelectorAll('.option').forEach(function(cb){cb.checked=false;});
        updateServiceTotal();
        return;
      }
      // Sélection d'un nouveau pack
      document.querySelectorAll('.cs-btn').forEach(function(b){b.classList.remove('selected-pack');b.textContent='\u2713 Choisir ce pack';});
      // Remettre à 0 le sous-total de l'ancien pack s'il y en avait un
      if (ST.pack) {
        var subElOld = document.getElementById('cs-sub-'+ST.pack);
        if(subElOld) subElOld.textContent = formatMoney(0);
      }
      document.querySelectorAll('.service-carte-item').forEach(function(c){c.classList.remove('selected');});
      ST.carte={};
      var btn = document.getElementById('pack-'+packId);
      if(btn){btn.classList.add('selected-pack');btn.textContent='\u2705 Pack s\u00e9lectionn\u00e9';}
      ST.pack=packId; ST.packMode='full';
      ST.packPrice=parseInt(packPrice,10);
      ST.packItemsSelected={};
      document.querySelectorAll('.option').forEach(function(cb){cb.checked=false;});
      // Mettre à jour le sous-total affiché dans la carte du carousel
      var subElPack = document.getElementById('cs-sub-'+packId);
      if (subElPack) subElPack.textContent = formatMoney(ST.packPrice);
      updateServiceTotal();
    };

    window.togglePackSvc = function(packId, svcId, price, cb) {
      if(!cb) return;
      
      // Select the pack if not already selected
      if (ST.pack !== packId) {
        var pack = PACKS.find(function(p){return p.id===packId;});
        if(pack) setPackMode(packId, pack.price, 'full');
        // Re-check the checkbox since setPackMode clears all checkboxes
        cb.checked = true;
      }
      
      if (!ST.packItemsSelected[packId]) ST.packItemsSelected[packId]={};
      if (cb.checked) ST.packItemsSelected[packId][svcId]=price;
      else delete ST.packItemsSelected[packId][svcId];
      recalcPackItems(packId);
      updateServiceTotal();
    };

    function recalcPackItems(packId) {
      var items=ST.packItemsSelected[packId]||{};
      var sub=Object.values(items).reduce(function(a,b){return a+b;},0);
      var pack = PACKS.find(function(p){return p.id===packId;});
      var basePrice = pack ? pack.price : 0;
      ST.packPrice = basePrice + sub;
      // Mise à jour du sous-total visible dans le carousel
      var subEl = document.getElementById('cs-sub-'+packId);
      if (subEl) subEl.textContent = formatMoney(ST.packPrice);
    }

    window.toggleCarte = function(id, price) {
      if (ST.pack) {
        document.querySelectorAll('.pack-card').forEach(function(c){c.classList.remove('selected');});
        // Remettre le sous-total du pack désélectionné à 0
        var subElC = document.getElementById('cs-sub-'+ST.pack);
        if(subElC) subElC.textContent = formatMoney(0);
        var btnC = document.getElementById('pack-'+ST.pack);
        if(btnC){btnC.classList.remove('selected-pack');btnC.textContent='\u2713 Choisir ce pack';}
        ST.pack=null; ST.packPrice=0; ST.packItemsSelected={};
        document.querySelectorAll('.option').forEach(function(cb){cb.checked=false;});
      }
      var el=document.getElementById('carte-'+id);
      if (ST.carte[id]) { delete ST.carte[id]; if(el) el.classList.remove('selected'); }
      else { ST.carte[id]=price; if(el) el.classList.add('selected'); }
      updateServiceTotal();
    };

