---
import MainLayout from '../../../layouts/main.astro';
import { HeaderNav } from '../../../components/HeaderNav';
import { FooterCustom } from '../../../components/FooterCustom';

type Link = { name: string; url: string; note?: string };

const links: Link[] = [
  { name: 'SCHL / CMHC — Société canadienne d’hypothèques et de logement (officiel)', url: 'https://www.cmhc-schl.gc.ca/' },
  { name: 'Kijiji — logements (site officiel)', url: 'https://www.kijiji.ca/' },
  { name: 'Realtor.ca — annonces (site officiel)', url: 'https://www.realtor.ca/' },
  { name: 'Tribunal administratif du logement (Québec) — officiel', url: 'https://www.tal.gouv.qc.ca/' },
  { name: 'Landlord and Tenant Board (Ontario) — officiel', url: 'https://tribunalsontario.ca/ltb/' },
  { name: 'Residential Tenancy Branch (British Columbia) — officiel', url: 'https://www2.gov.bc.ca/gov/content/housing-tenancy/residential-tenancies' },
];

const title = 'Logement — Ressources nouvel arrivant';
const desc = 'Liens officiels et utiles pour chercher un logement et comprendre vos droits.';
---

<MainLayout>
  <HeaderNav client:only="react" />

  <section class="relative bg-gradient-to-br from-primary/5 to-primary/10 py-14 md:py-20">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <a href="/ressources/nouvel-arrivant" class="text-primary hover:underline">← Retour aux ressources</a>
        <h1 class="text-3xl md:text-5xl font-bold mt-4 mb-4 text-foreground">{title}</h1>
        <p class="text-muted-foreground text-lg md:text-xl">{desc}</p>
      </div>
    </div>
  </section>

  <section class="py-14 bg-background">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <div class="bg-card border border-border rounded-lg p-6 mb-8">
          <h2 class="text-lg font-bold text-foreground mb-2">Points d’attention</h2>
          <ul class="text-muted-foreground space-y-2">
            <li>Demandez un bail/contrat écrit et gardez des copies.</li>
            <li>Vérifiez ce qui est inclus (chauffage, électricité, internet).</li>
            <li>Méfiez‑vous des demandes de paiement “avant visite” ou des offres trop belles.</li>
            <li>Vos droits/recours dépendent de la province: utilisez la ressource officielle locale.</li>
          </ul>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {links.map((l) => (
            <a href={l.url} target="_blank" rel="noopener noreferrer" class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition block">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-bold text-foreground">{l.name}</h3>
                  {l.note && <p class="text-sm text-muted-foreground mt-1">{l.note}</p>}
                </div>
                <span class="text-primary">↗</span>
              </div>
              <p class="text-xs text-muted-foreground mt-3 break-all">{l.url}</p>
            </a>
          ))}
        </div>

        <div class="mt-10 bg-muted/30 rounded-lg p-6">
          <p class="text-sm text-muted-foreground">
            Astuce: si vous êtes étudiant, vérifiez aussi les ressources “housing” de votre établissement (souvent via le portail campus).
          </p>
        </div>
      </div>
    </div>
  </section>

  <FooterCustom client:only="react" />
</MainLayout>
