---
import MainLayout from '../../../layouts/main.astro';
import { HeaderNav } from '../../../components/HeaderNav';
import { FooterCustom } from '../../../components/FooterCustom';

type Link = { name: string; url: string; note?: string };

const links: Link[] = [
  { name: 'STM (Montréal) — site officiel', url: 'https://www.stm.info/' },
  { name: 'TTC (Toronto) — site officiel', url: 'https://www.ttc.ca/' },
  { name: 'TransLink (Vancouver) — site officiel', url: 'https://www.translink.ca/' },
  { name: 'OC Transpo (Ottawa) — site officiel', url: 'https://www.octranspo.com/' },
  { name: 'Calgary Transit — site officiel', url: 'https://www.calgarytransit.com/' },
  { name: 'Edmonton Transit Service — site officiel', url: 'https://www.edmonton.ca/ets' },
];

const title = 'Transports — Ressources nouvel arrivant';
const desc = 'Liens officiels vers des réseaux de transport en commun (exemples) et conseils.';
---

<MainLayout>
  <HeaderNav client:only="react" />

  <section class="relative bg-gradient-to-br from-primary/5 to-primary/10 py-14 md:py-20">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <a href="/ressources/nouvel-arrivant" class="text-primary hover:underline">← Retour aux ressources</a>
        <h1 class="text-3xl md:text-5xl font-bold mt-4 mb-4 text-foreground">{title}</h1>
        <p class="text-muted-foreground text-lg md:text-xl">{desc}</p>
      </div>
    </div>
  </section>

  <section class="py-14 bg-background">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <div class="bg-card border border-border rounded-lg p-6 mb-8">
          <h2 class="text-lg font-bold text-foreground mb-2">À faire rapidement</h2>
          <ul class="text-muted-foreground space-y-2">
            <li>Identifiez le réseau de votre ville et créez un compte si nécessaire.</li>
            <li>Vérifiez les tarifs étudiants (carte/abonnement mensuel).</li>
            <li>Installez l’appli officielle du réseau (horaires, perturbations, rechargements).</li>
          </ul>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {links.map((l) => (
            <a href={l.url} target="_blank" rel="noopener noreferrer" class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition block">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-bold text-foreground">{l.name}</h3>
                  {l.note && <p class="text-sm text-muted-foreground mt-1">{l.note}</p>}
                </div>
                <span class="text-primary">↗</span>
              </div>
              <p class="text-xs text-muted-foreground mt-3 break-all">{l.url}</p>
            </a>
          ))}
        </div>

        <div class="mt-10 bg-muted/30 rounded-lg p-6">
          <p class="text-sm text-muted-foreground">
            Votre ville n’est pas listée ? Recherchez “transport en commun + nom de votre ville” et privilégiez le site officiel de l’autorité locale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <FooterCustom client:only="react" />
</MainLayout>
