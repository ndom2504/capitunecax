      firstName: (document.getElementById('firstName') as HTMLInputElement).value,
      lastName: (document.getElementById('lastName') as HTMLInputElement).value,
      email: (document.getElementById('email') as HTMLInputElement).value,
      phone: (document.getElementById('phone') as HTMLInputElement).value,
      country: (document.getElementById('country') as HTMLSelectElement).value,
      password: password
    };

    try {
      const response = await fetch(`${baseUrl}/api/auth/signup`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (response.ok) {
        alert('Compte créé avec succès ! Vous allez être redirigé vers la page de connexion.');
        window.location.href = `${baseUrl}/connexion`;
      } else {
        const error = await response.json();
        alert(error.message || 'Une erreur est survenue lors de la création du compte.');
      }
    } catch (error) {
      console.error('Signup error:', error);
      alert('Une erreur est survenue. Veuillez réessayer.');
    }
    */
  });
</script>

