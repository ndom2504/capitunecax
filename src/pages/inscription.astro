---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
---

<MainLayout>
  <link rel="stylesheet" href="/templatemo_473_november/css/theme.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/media.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/font-awesome.min.css" />
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,300,600,600italic,400italic,800,700" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Oswald:400,700,300" rel="stylesheet" type="text/css" />

  <div class="DesignHolder auth-page">
    <div class="LayoutFrame">
      <header class="auth-header">
        <div class="Center">
          <div class="site-logo">
            <h1><a href={`${baseUrl}/`}>CAPI<span>TUNE</span></a></h1>
          </div>
          <nav class="Navigation auth-nav">
            <ul>
              <li><a href={`${baseUrl}/`}>Accueil</a></li>
              <li><a href={`${baseUrl}/connexion`}>Connexion</a></li>
              <li class="active"><a href={`${baseUrl}/inscription`}>Inscription</a></li>
            </ul>
          </nav>
          <div class="clear"></div>
        </div>
      </header>

      <section class="AuthHero_sec">
        <div class="Center">
          <h1>Créer Votre Compte CAPITUNE</h1>
          <p>Démarrez votre projet Canada avec un espace personnel sécurisé.</p>
        </div>
      </section>

      <section class="Get_sec auth-sec">
        <div class="Mid">
          <div class="Leftside auth-form-side auth-form-wide">
            <form id="signupForm">
              <fieldset>
                <div class="auth-grid-2">
                  <p><input type="text" id="firstName" required placeholder="PRÉNOM" class="field" /></p>
                  <p><input type="text" id="lastName" required placeholder="NOM" class="field" /></p>
                </div>

                <p><input type="email" id="email" required placeholder="EMAIL" class="field" /></p>
                <p><input type="tel" id="phone" required placeholder="TÉLÉPHONE" class="field" /></p>

                <p>
                  <select id="country" required class="field auth-select">
                    <option value="">PAYS DE RÉSIDENCE</option>
                    <option value="CA">Canada</option>
                    <option value="FR">France</option>
                    <option value="SN">Sénégal</option>
                    <option value="CM">Cameroun</option>
                    <option value="CI">Côte d'Ivoire</option>
                    <option value="MA">Maroc</option>
                    <option value="DZ">Algérie</option>
                    <option value="TN">Tunisie</option>
                    <option value="BE">Belgique</option>
                    <option value="CH">Suisse</option>
                    <option value="OTHER">Autre</option>
                  </select>
                </p>

                <p><input type="password" id="password" required minlength="8" placeholder="MOT DE PASSE" class="field" /></p>
                <p><input type="password" id="confirmPassword" required placeholder="CONFIRMER LE MOT DE PASSE" class="field" /></p>

                <p class="password-note">Minimum 8 Caractères</p>

                <p class="auth-terms">
                  <label for="terms" class="terms-wrap">
                    <input type="checkbox" id="terms" required class="remember-check" />
                    <span>J'accepte Les <a href="#">Conditions</a> Et La <a href="#">Politique De Confidentialité</a></span>
                  </label>
                </p>

                <p><input type="submit" value="Créer Mon Compte" class="button" /></p>
              </fieldset>
            </form>

            <div class="auth-subline">
              <p>Vous Avez Déjà Un Compte ? <a href={`${baseUrl}/connexion`}>Se Connecter</a></p>
            </div>

            <div class="auth-divider"><span>Ou Via</span></div>

            <div class="auth-social-grid">
              <button type="button" id="googleSignupBtn" class="auth-social-btn">
                <svg class="auth-social-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                <span>Google</span>
              </button>

              <button type="button" id="microsoftSignupBtn" class="auth-social-btn">
                <svg class="auth-social-icon" viewBox="0 0 23 23" aria-hidden="true">
                  <path fill="#f35325" d="M1 1h10v10H1z"/>
                  <path fill="#81bc06" d="M12 1h10v10H12z"/>
                  <path fill="#05a6f0" d="M1 12h10v10H1z"/>
                  <path fill="#ffba08" d="M12 12h10v10H12z"/>
                </svg>
                <span>Microsoft</span>
              </button>
            </div>
          </div>

          <div class="Rightside auth-info-side">
            <h3>Votre Espace Personnel</h3>
            <address>Suivi De Dossier En Temps Réel</address>
            <address class="Number">Documents Sécurisés Et Historique</address>
            <address class="Email"><a href={`${baseUrl}/connexion`}>Messagerie Directe Avec Nos Consultants</a></address>
          </div>
        </div>
      </section>
    </div>
  </div>
</MainLayout>

<script>
  document.getElementById('googleSignupBtn')?.addEventListener('click', () => {
    window.location.href = '/dashboard';
  });

  document.getElementById('microsoftSignupBtn')?.addEventListener('click', () => {
    window.location.href = '/dashboard';
  });

  document.getElementById('signupForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

    if (password !== confirmPassword) {
      alert('Les mots de passe ne correspondent pas.');
      return;
    }

    window.location.href = '/dashboard';
  });
</script>

<style is:global>
  .auth-page {
    background: #1f4b6e;
    min-height: 100vh;
  }

  .auth-header {
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .auth-nav {
    float: right;
    margin-top: 20px;
  }

  .auth-nav ul {
    display: flex;
    gap: 18px;
  }

  .auth-nav ul li a {
    color: #fff;
    font-size: 14px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .AuthHero_sec {
    padding: 86px 0 36px;
    text-align: center;
  }

  .AuthHero_sec h1 {
    color: #fff;
    font-family: 'Oswald', sans-serif;
    font-size: 50px;
    line-height: 1.05;
    white-space: normal !important;
    margin-bottom: 18px;
  }

  .AuthHero_sec p {
    color: #e8edf3;
    font-size: 20px;
    max-width: 760px;
    margin: 0 auto;
  }

  .auth-sec {
    background: url('/templatemo_473_november/img/Get-bg.jpg') center center no-repeat;
    background-size: cover;
  }

  .auth-form-side {
    width: 54% !important;
  }

  .auth-form-wide {
    width: 58% !important;
  }

  .auth-info-side {
    width: 36% !important;
  }

  .auth-form-side .field {
    background: rgba(255, 255, 255, 0.95) !important;
    color: #102a43 !important;
    font-weight: 600;
    border: 1px solid rgba(16, 42, 67, 0.18) !important;
  }

  .auth-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .auth-select {
    appearance: none;
    -webkit-appearance: none;
  }

  .password-note {
    margin-top: -10px !important;
    margin-bottom: 14px !important;
    color: #fff;
    font-size: 12px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.4px;
  }

  .auth-terms {
    margin-bottom: 16px !important;
  }

  .terms-wrap {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    line-height: 1.5;
  }

  .terms-wrap a {
    color: #ffb049;
  }

  .remember-check {
    width: 14px;
    height: 14px;
    margin-top: 2px;
  }

  .auth-subline {
    margin-top: 10px;
    text-align: center;
  }

  .auth-subline p {
    color: #d9e4ef;
    font-size: 14px;
  }

  .auth-subline a {
    color: #ffb049;
    font-weight: 700;
  }

  .auth-divider {
    margin: 20px 0 18px;
    text-align: center;
    position: relative;
  }

  .auth-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.22);
  }

  .auth-divider span {
    position: relative;
    z-index: 1;
    color: #fff;
    background: rgba(20, 55, 84, 0.75);
    padding: 0 14px;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 700;
  }

  .auth-social-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .auth-social-btn {
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    transition: all 0.25s ease;
  }

  .auth-social-btn:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .auth-social-icon {
    width: 18px;
    height: 18px;
  }

  .auth-info-side h3 {
    font-size: 42px !important;
    line-height: 1.03 !important;
    white-space: normal !important;
    padding-bottom: 24px !important;
  }

  @media (max-width: 980px) {
    .auth-nav {
      float: none;
      margin: 14px 0 18px;
    }

    .auth-nav ul {
      justify-content: center;
      flex-wrap: wrap;
    }

    .AuthHero_sec h1 {
      font-size: 38px;
    }

    .AuthHero_sec p {
      font-size: 17px;
      padding: 0 12px;
    }

    .auth-form-side,
    .auth-form-wide,
    .auth-info-side {
      width: 100% !important;
    }

    .auth-grid-2,
    .auth-social-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
