---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
import '../styles/auth.css';
---

<MainLayout>
<div class="auth-root">

  <!-- ── Panneau gauche : branding ── -->
  <div class="auth-panel-left">
    <a href={`${baseUrl}/`} class="auth-brand">
      <img src="/logo/capitune.png" alt="CAPITUNE" style="height:44px; width:auto; display:block; margin-bottom:10px;" />
      <span class="auth-brand-sub">Votre partenaire de confiance pour votre projet au Canada</span>
    </a>

    <div class="auth-benefits">
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Suivi de dossier en temps réel</div>
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Documents sécurisés et historique</div>
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Messagerie directe avec nos consultants</div>
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Paiements sécurisés par tranches</div>
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Accès à la FAQ et aux ressources</div>
    </div>

    <div class="auth-left-footer">
      <a href={`${baseUrl}/`}>Accueil</a>
      <a href={`${baseUrl}/a-propos`}>À Propos</a>
      <a href={`${baseUrl}/contact`}>Contact</a>
    </div>
  </div>

  <!-- ── Panneau droit : formulaire ── -->
  <div class="auth-panel-right">
    <div class="auth-form-wrap auth-form-wrap--wide">

      <div class="auth-form-header">
        <h1 class="auth-form-title">Créer un compte</h1>
        <p class="auth-form-sub">Démarrez votre projet Canada avec un espace personnel sécurisé.</p>
      </div>

      <!-- Alertes -->
      <div id="loginError" class="auth-alert auth-alert--error" style="display:none;"></div>
      <div id="loginSuccess" class="auth-alert auth-alert--success" style="display:none;"></div>

      <!-- Type de compte -->
      <div class="auth-type-picker" style="margin-bottom:20px;">
        <label class="auth-type-option">
          <input type="radio" name="accountType" value="client" checked />
          <span class="auth-type-label">
            <strong>Particulier</strong>
            <small>Demande de service</small>
          </span>
        </label>
        <label class="auth-type-option">
          <input type="radio" name="accountType" value="pro" />
          <span class="auth-type-label">
            <strong>Professionnel</strong>
            <small>Offre de service</small>
          </span>
        </label>
      </div>

      <!-- Formulaire -->
      <form id="signupForm" class="auth-form">
        <div class="auth-grid-2">
          <div class="auth-field-group">
            <label class="auth-label">Prénom</label>
            <input type="text" id="firstName" required placeholder="Jean" class="auth-input" />
          </div>
          <div class="auth-field-group">
            <label class="auth-label">Nom</label>
            <input type="text" id="lastName" required placeholder="Dupont" class="auth-input" />
          </div>
        </div>

        <div class="auth-field-group">
          <label class="auth-label">Email</label>
          <input type="email" id="email" required placeholder="votre@email.com" class="auth-input" />
        </div>

        <div class="auth-field-group">
          <label class="auth-label">Téléphone</label>
          <input type="tel" id="phone" required placeholder="+1 514 000 0000" class="auth-input" />
        </div>

        <div class="auth-field-group">
          <label class="auth-label">Pays de résidence</label>
          <select id="country" required class="auth-input auth-select">
            <option value="">Sélectionner...</option>
            <option value="CA">Canada</option>
            <option value="FR">France</option>
            <option value="SN">Sénégal</option>
            <option value="CM">Cameroun</option>
            <option value="CI">Côte d'Ivoire</option>
            <option value="MA">Maroc</option>
            <option value="DZ">Algérie</option>
            <option value="TN">Tunisie</option>
            <option value="BE">Belgique</option>
            <option value="CH">Suisse</option>
            <option value="OTHER">Autre</option>
          </select>
        </div>

        <div class="auth-field-group">
          <label class="auth-label">Mot de passe <small class="auth-label-hint">(min. 8 caractères)</small></label>
          <input type="password" id="password" required minlength="8" placeholder="••••••••" class="auth-input" />
        </div>

        <div class="auth-field-group">
          <label class="auth-label">Confirmer le mot de passe</label>
          <input type="password" id="confirmPassword" required placeholder="••••••••" class="auth-input" />
        </div>

        <label class="auth-terms-label">
          <input type="checkbox" id="terms" required class="auth-terms-check" />
          <span>J'accepte les <a href="/mentions-legales" target="_blank">conditions d'utilisation</a> et la <a href="/confidentialite" target="_blank">politique de confidentialité</a></span>
        </label>

        <button type="submit" class="auth-btn-primary" id="submitBtn">
          Créer mon compte
        </button>
      </form>

      <div class="auth-divider"><span>Ou continuer avec</span></div>

      <div class="auth-social-row">
        <button type="button" id="googleSignupBtn" class="auth-social-btn">
          <svg class="auth-social-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Google
        </button>
        <button type="button" id="microsoftSignupBtn" class="auth-social-btn">
          <svg class="auth-social-icon" viewBox="0 0 23 23" aria-hidden="true">
            <path fill="#f35325" d="M1 1h10v10H1z"/>
            <path fill="#81bc06" d="M12 1h10v10H12z"/>
            <path fill="#05a6f0" d="M1 12h10v10H1z"/>
            <path fill="#ffba08" d="M12 12h10v10H12z"/>
          </svg>
          Microsoft
        </button>
      </div>

      <p class="auth-switch">
        Déjà un compte ? <a href={`${baseUrl}/connexion`}>Se connecter</a>
      </p>

    </div>
  </div>

</div>
</MainLayout>

<script>
  const getSelectedAccountType = () => {
    return (document.querySelector('input[name="accountType"]:checked') as HTMLInputElement | null)?.value || 'client';
  };

  document.getElementById('googleSignupBtn')?.addEventListener('click', () => {
    const t = getSelectedAccountType();
    window.location.href = `/api/oauth/signin/google?accountType=${encodeURIComponent(t)}`;
  });

  document.getElementById('microsoftSignupBtn')?.addEventListener('click', () => {
    const t = getSelectedAccountType();
    window.location.href = `/api/oauth/signin/microsoft?accountType=${encodeURIComponent(t)}`;
  });

  document.getElementById('signupForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const errorDiv = document.getElementById('loginError') as HTMLDivElement;
    const successDiv = document.getElementById('loginSuccess') as HTMLDivElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    const showError = (msg: string) => {
      errorDiv.textContent = msg;
      errorDiv.style.display = 'flex';
      successDiv.style.display = 'none';
    };
    const showSuccess = (msg: string) => {
      successDiv.textContent = msg;
      successDiv.style.display = 'flex';
      errorDiv.style.display = 'none';
    };

    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

    if (password !== confirmPassword) {
      showError('Les mots de passe ne correspondent pas.');
      return;
    }

    const firstName = (document.getElementById('firstName') as HTMLInputElement).value;
    const lastName = (document.getElementById('lastName') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const phone = (document.getElementById('phone') as HTMLInputElement).value;
    const country = (document.getElementById('country') as HTMLSelectElement).value;
    const accountType = (document.querySelector('input[name="accountType"]:checked') as HTMLInputElement | null)?.value || 'client';

    submitBtn.disabled = true;
    submitBtn.textContent = 'Création en cours...';

    try {
      const res = await fetch('/api/oauth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ firstName, lastName, email, phone, country, password, accountType }),
      });

      const data = await res.json().catch(() => ({})) as Record<string, string | boolean | undefined>;
      if (!res.ok) {
        showError((data?.message as string) || 'Une erreur est survenue lors de la création du compte.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Créer mon compte';
        return;
      }

      if ((data as Record<string, unknown>)?.error) {
        showError((data?.message as string) || "Compte créé, mais l'envoi de l'email de confirmation a échoué. Contactez le support.");
        window.location.href = '/connexion';
        return;
      }

      if ((data as Record<string, unknown>)?.pending) {
        showSuccess("Compte créé ! Vérifiez votre email.");
        window.location.href = '/verification-envoyee?email=' + encodeURIComponent((data as Record<string, string>)?.email || email);
      } else {
        window.location.href = '/dashboard';
      }
    } catch (err) {
      showError('Une erreur est survenue. Réessayez.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Créer mon compte';
    }
  });
</script>

<style is:global>
  /* inscription-specific overrides */
  .auth-form-wrap--wide { max-width: 520px; }
  .auth-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .auth-select { appearance: none; -webkit-appearance: none; }
  .auth-label-hint { font-weight: 400; color: #8fa3ba; font-size: 11px; }
  .auth-terms-label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: #4a6880;
    margin-bottom: 20px;
    cursor: pointer;
    line-height: 1.5;
  }
  .auth-terms-label a { color: #1f4b6e; font-weight: 600; }
  .auth-terms-label a:hover { color: #ff9408; }
  .auth-terms-check { width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0; accent-color: #ff9408; }
  @media (max-width: 600px) {
    .auth-grid-2 { grid-template-columns: 1fr; }
  }
</style>
