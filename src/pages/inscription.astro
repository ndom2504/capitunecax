
---
import MainLayout from '../layouts/main.astro';
import { HeaderNav } from '../components/HeaderNav';
import { FooterCustom } from '../components/FooterCustom';
---

<MainLayout>
  <HeaderNav client:only="react" />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary/10 to-primary/5 py-16 md:py-20">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-md mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-foreground">Créer un compte</h1>
        <p class="text-lg text-muted-foreground">
          Démarrez votre projet d'immigration avec CAPITUNE
        </p>
      </div>
    </div>
  </section>

  <!-- Signup Section -->
  <section class="py-20 bg-background">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-md mx-auto">
        <div class="bg-card border border-border rounded-lg p-8">
          <!-- Signup Form -->
          <form id="signupForm" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">Prénom *</label>
                <input 
                  type="text" 
                  id="firstName"
                  required
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                  placeholder="Jean" 
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">Nom *</label>
                <input 
                  type="text" 
                  id="lastName"
                  required
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                  placeholder="Dupont" 
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium mb-2 text-foreground">Email *</label>
              <input 
                type="email" 
                id="email"
                required
                class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                placeholder="jean.dupont@email.com" 
              />
            </div>

            <div>
              <label class="block text-sm font-medium mb-2 text-foreground">Téléphone *</label>
              <input 
                type="tel" 
                id="phone"
                required
                class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                placeholder="+1 (514) 123-4567" 
              />
            </div>

            <div>
              <label class="block text-sm font-medium mb-2 text-foreground">Pays de résidence *</label>
              <select 
                id="country"
                required
                class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring"
              >
                <option value="">Sélectionnez votre pays</option>
                <option value="CA">Canada</option>
                <option value="FR">France</option>
                <option value="SN">Sénégal</option>
                <option value="CM">Cameroun</option>
                <option value="CI">Côte d'Ivoire</option>
                <option value="MA">Maroc</option>
                <option value="DZ">Algérie</option>
                <option value="TN">Tunisie</option>
                <option value="BE">Belgique</option>
                <option value="CH">Suisse</option>
                <option value="OTHER">Autre</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium mb-2 text-foreground">Mot de passe *</label>
              <input 
                type="password" 
                id="password"
                required
                minlength="8"
                class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                placeholder="••••••••" 
              />
              <p class="text-xs text-muted-foreground mt-1">Minimum 8 caractères</p>
            </div>

            <div>
              <label class="block text-sm font-medium mb-2 text-foreground">Confirmer le mot de passe *</label>
              <input 
                type="password" 
                id="confirmPassword"
                required
                class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                placeholder="••••••••" 
              />
            </div>

            <div class="flex items-start gap-3">
              <input 
                type="checkbox" 
                id="terms"
                required
                class="mt-1 w-4 h-4 text-primary border-input rounded focus:ring-2 focus:ring-ring"
              />
              <label for="terms" class="text-sm text-muted-foreground">
                J'accepte les <a href="#" class="text-primary hover:underline">conditions d'utilisation</a> 
                et la <a href="#" class="text-primary hover:underline">politique de confidentialité</a> de CAPITUNE
              </label>
            </div>

            <button 
              type="submit" 
              class="w-full bg-primary text-primary-foreground py-3 rounded-lg font-semibold hover:bg-primary/90 transition"
            >
              Créer mon compte
            </button>
          </form>

          <!-- Login link -->
          <div class="mt-6 text-center">
            <p class="text-sm text-muted-foreground">
              Vous avez déjà un compte ?
              <a href="/connexion" class="text-primary font-semibold hover:underline ml-1">Se connecter</a>
            </p>
          </div>

          <!-- Divider -->
          <div class="relative my-6">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-border"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-4 bg-card text-muted-foreground">ou via</span>
            </div>
          </div>

          <!-- Social Signup Buttons (Below) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <button 
              type="button"
              id="googleSignupBtn"
              class="w-full flex items-center justify-center gap-3 bg-background border border-input hover:border-primary/50 hover:bg-muted/40 text-foreground py-3 px-4 rounded-xl font-semibold transition"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              <span>Google</span>
            </button>

            <button 
              type="button"
              id="microsoftSignupBtn"
              class="w-full flex items-center justify-center gap-3 bg-background border border-input hover:border-primary/50 hover:bg-muted/40 text-foreground py-3 px-4 rounded-xl font-semibold transition"
            >
              <svg class="w-5 h-5" viewBox="0 0 23 23" aria-hidden="true">
                <path fill="#f35325" d="M1 1h10v10H1z"/>
                <path fill="#81bc06" d="M12 1h10v10H12z"/>
                <path fill="#05a6f0" d="M1 12h10v10H1z"/>
                <path fill="#ffba08" d="M12 12h10v10H12z"/>
              </svg>
              <span>Microsoft</span>
            </button>
          </div>
        </div>

        <!-- Why create account -->
        <div class="mt-8 bg-muted/30 border border-border rounded-lg p-6">
          <h3 class="font-bold text-foreground mb-4 text-center">Pourquoi créer un compte ?</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <p class="font-medium text-foreground text-sm">Suivi en temps réel</p>
                <p class="text-xs text-muted-foreground">Suivez l'avancement de votre dossier 24/7</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <p class="font-medium text-foreground text-sm">Documents sécurisés</p>
                <p class="text-xs text-muted-foreground">Stockez tous vos documents dans un espace crypté</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <p class="font-medium text-foreground text-sm">Communication directe</p>
                <p class="text-xs text-muted-foreground">Échangez directement avec nos consultants</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <p class="font-medium text-foreground text-sm">Rendez-vous en ligne</p>
                <p class="text-xs text-muted-foreground">Prenez rendez-vous facilement depuis votre espace</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FooterCustom client:only="react" />
</MainLayout>

<script>
  import { baseUrl } from '../lib/base-url';

  document.getElementById('googleSignupBtn')?.addEventListener('click', () => {
    window.location.href = `${baseUrl}/dashboard`;
  });

  document.getElementById('microsoftSignupBtn')?.addEventListener('click', () => {
    window.location.href = `${baseUrl}/dashboard`;
  });

  // Handle Email/Password Signup
  document.getElementById('signupForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

    if (password !== confirmPassword) {
      alert('Les mots de passe ne correspondent pas.');
      return;
    }

    // For testing: redirect directly to dashboard without authentication
    window.location.href = `${baseUrl}/dashboard`;

    /*
    // Production code (commented for testing):
