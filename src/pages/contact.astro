---
import MainLayout from '../layouts/main.astro';
import { HeaderNav } from '../components/HeaderNav';
import { FooterCustom } from '../components/FooterCustom';
import { packagesCatalog, servicesCatalog } from '../lib/service-catalog';
import { publicConfig } from '../lib/public-config';
---

<MainLayout>
  <HeaderNav client:only="react" />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary/10 to-primary/5 py-16 md:py-20">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-foreground">Vous avez un projet d'immigration ?</h1>
        <p class="text-xl text-muted-foreground">
          Contactez-nous dès aujourd'hui et recevez une réponse sous 24h
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 bg-background">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12">
          
          <!-- Contact Form -->
          <div>
            <div class="mb-8">
              <h2 class="text-3xl font-bold mb-4 text-foreground">Demander une consultation</h2>
              <p class="text-muted-foreground">
                Remplissez le formulaire ci-dessous et notre équipe vous contactera dans les plus brefs délais
              </p>
            </div>

            <form class="space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium mb-2 text-foreground">Prénom *</label>
                  <input 
                    type="text" 
                    required
                    class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                    placeholder="Jean" 
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium mb-2 text-foreground">Nom *</label>
                  <input 
                    type="text" 
                    required
                    class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                    placeholder="Dupont" 
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">Email *</label>
                <input 
                  type="email" 
                  required
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                  placeholder="jean.dupont@email.com" 
                />
              </div>

              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">Téléphone *</label>
                <input 
                  type="tel" 
                  required
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                  placeholder="+1 (555) 555-5555" 
                />
              </div>

              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">Pays de résidence *</label>
                <input 
                  type="text" 
                  required
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                  placeholder="France, Sénégal, Cameroun..." 
                />
              </div>

              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">Type de service souhaité *</label>
                <select 
                  required
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring"
                >
                  <option value="">Sélectionnez un service</option>
                  <optgroup label="Packs">
                    {packagesCatalog.map((pkg) => (
                      <option value={`pack:${pkg.id}`}>{pkg.name}</option>
                    ))}
                  </optgroup>
                  <optgroup label="Services">
                    {servicesCatalog.map((service) => (
                      <option value={`service:${service.id}`}>{service.name}</option>
                    ))}
                  </optgroup>
                  <option value="autre">Autre / À discuter</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">
                  Objectif d'immigration
                </label>
                <select 
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring"
                >
                  <option value="">Sélectionnez votre objectif</option>
                  <option value="etudes">Études</option>
                  <option value="travail">Travail</option>
                  <option value="residence">Résidence permanente</option>
                  <option value="regroupement">Regroupement familial</option>
                  <option value="investisseur">Investisseur / Entrepreneur</option>
                  <option value="autre">Autre</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium mb-2 text-foreground">Message *</label>
                <textarea 
                  rows="5" 
                  required
                  class="w-full px-4 py-3 bg-background border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-ring" 
                  placeholder="Décrivez brièvement votre projet d'immigration, votre situation actuelle et vos objectifs..."
                ></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input 
                  type="checkbox" 
                  id="consent" 
                  required
                  class="mt-1 w-4 h-4 text-primary border-input rounded focus:ring-2 focus:ring-ring"
                />
                <label for="consent" class="text-sm text-muted-foreground">
                  J'accepte que mes données soient utilisées pour me recontacter concernant ma demande. 
                  Consultez notre politique de confidentialité pour plus d'informations.
                </label>
              </div>

              <button 
                type="submit" 
                class="w-full bg-primary text-primary-foreground py-4 rounded-lg font-semibold hover:bg-primary/90 transition"
              >
                Envoyer ma demande
              </button>

              <p class="text-sm text-muted-foreground text-center">
                Nous vous répondrons sous 24h (jours ouvrables)
              </p>
            </form>
          </div>

          <!-- Contact Information -->
          <div>
            <div class="mb-8">
              <h2 class="text-3xl font-bold mb-4 text-foreground">Informations de contact</h2>
              <p class="text-muted-foreground">
                Vous pouvez également nous contacter directement via ces canaux
              </p>
            </div>

            <div class="space-y-6">
              <!-- Email -->
              <div class="bg-card border border-border rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-bold text-foreground mb-1">Email</h3>
                    <p class="text-muted-foreground text-sm mb-2">Pour toute demande d'information</p>
                    <a href={`mailto:${publicConfig.contactEmail}`} class="text-primary hover:underline font-medium">
                      {publicConfig.contactEmail}
                    </a>
                  </div>
                </div>
              </div>

              <!-- Téléphone -->
              <div class="bg-card border border-border rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-bold text-foreground mb-1">Téléphone</h3>
                    <p class="text-muted-foreground text-sm mb-2">Lun-Ven: 9h00 - 18h00 (HNE)</p>
                    <a href={`tel:${publicConfig.contactPhone.replace(/\s+/g, '')}`} class="text-primary hover:underline font-medium">
                      {publicConfig.contactPhone}
                    </a>
                  </div>
                </div>
              </div>

              <!-- WhatsApp -->
              <div class="bg-card border border-border rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-bold text-foreground mb-1">WhatsApp</h3>
                    <p class="text-muted-foreground text-sm mb-2">Réponse rapide 24/7</p>
                    <a href="https://wa.me/15141234567" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline font-medium">
                      Envoyer un message
                    </a>
                  </div>
                </div>
              </div>

              <!-- Adresse -->
              <div class="bg-card border border-border rounded-lg p-6">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-bold text-foreground mb-1">Localisation</h3>
                    <p class="text-muted-foreground text-sm mb-2">Sur rendez-vous uniquement</p>
                    <p class="text-foreground">
                      Montréal, Québec<br />
                      Canada
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Horaires -->
            <div class="mt-8 bg-muted/30 border border-border rounded-lg p-6">
              <h3 class="font-bold text-foreground mb-4">Heures d'ouverture</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-muted-foreground">Lundi - Vendredi</span>
                  <span class="text-foreground font-medium">9h00 - 18h00</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-muted-foreground">Samedi</span>
                  <span class="text-foreground font-medium">10h00 - 14h00</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-muted-foreground">Dimanche</span>
                  <span class="text-foreground font-medium">Fermé</span>
                </div>
              </div>
              <p class="text-xs text-muted-foreground mt-4">
                * Heure normale de l'Est (HNE)
              </p>
            </div>

            <!-- Social Media -->
            <div class="mt-8">
              <h3 class="font-bold text-foreground mb-4">Suivez-nous</h3>
              <div class="flex gap-3">
                <a href="#" class="w-11 h-11 bg-primary/10 rounded-lg flex items-center justify-center hover:bg-primary/20 transition" aria-label="Facebook">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
                <a href="#" class="w-11 h-11 bg-primary/10 rounded-lg flex items-center justify-center hover:bg-primary/20 transition" aria-label="LinkedIn">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
                <a href="#" class="w-11 h-11 bg-primary/10 rounded-lg flex items-center justify-center hover:bg-primary/20 transition" aria-label="Instagram">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-muted/30">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-foreground">Questions Fréquentes</h2>
          <p class="text-muted-foreground">
            Vous trouverez peut-être votre réponse ici
          </p>
        </div>

        <div class="space-y-4">
          <details class="bg-card border border-border rounded-lg p-6 group">
            <summary class="font-bold text-foreground cursor-pointer list-none flex items-center justify-between">
              Combien de temps prend le processus d'immigration ?
              <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-muted-foreground text-sm">
              Les délais varient selon le type de demande : de 2-4 mois pour un permis d'études à 6-18 mois pour une résidence permanente. 
              Nous vous donnons une estimation réaliste dès la consultation initiale.
            </p>
          </details>

          <details class="bg-card border border-border rounded-lg p-6 group">
            <summary class="font-bold text-foreground cursor-pointer list-none flex items-center justify-between">
              Quels sont vos tarifs ?
              <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-muted-foreground text-sm">
              Nous proposons des plans adaptés à différents budgets, de 150$ pour une consultation à 2 500$ pour un accompagnement complet. 
              Consultez notre <a href="/tarifs" class="text-primary hover:underline">page Tarifs</a> pour plus de détails.
            </p>
          </details>

          <details class="bg-card border border-border rounded-lg p-6 group">
            <summary class="font-bold text-foreground cursor-pointer list-none flex items-center justify-between">
              Garantissez-vous l'acceptation de ma demande ?
              <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-muted-foreground text-sm">
              Aucun consultant ne peut garantir l'acceptation. Toutefois, nous maximisons vos chances grâce à notre expertise et notre taux de succès de 95%. 
              Nous évaluons honnêtement votre profil dès la consultation.
            </p>
          </details>

          <details class="bg-card border border-border rounded-lg p-6 group">
            <summary class="font-bold text-foreground cursor-pointer list-none flex items-center justify-between">
              Dois-je être au Canada pour utiliser vos services ?
              <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-muted-foreground text-sm">
              Non ! Nous accompagnons des clients partout dans le monde. Toutes nos consultations et communications se font en ligne 
              (visioconférence, email, WhatsApp).
            </p>
          </details>

          <details class="bg-card border border-border rounded-lg p-6 group">
            <summary class="font-bold text-foreground cursor-pointer list-none flex items-center justify-between">
              Comment se déroule la première consultation ?
              <svg class="w-5 h-5 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-muted-foreground text-sm">
              La consultation dure environ 1 heure. Nous analysons votre profil, discutons de vos objectifs, évaluons vos options d'immigration 
              et vous remettons un rapport détaillé avec des recommandations personnalisées.
            </p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <FooterCustom client:only="react" />
</MainLayout>
