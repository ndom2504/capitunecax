---
import MainLayout from '../layouts/main.astro';
import { HeaderNav } from '../components/HeaderNav';
import { FooterCustom } from '../components/FooterCustom';
import { publicConfig } from '../lib/public-config';
---

<MainLayout>
  <HeaderNav client:only="react" />

  <section class="bg-gradient-to-br from-primary/10 to-primary/5 py-16 md:py-20">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-foreground">Politique de confidentialité</h1>
        <p class="text-xl text-muted-foreground">
          Comprendre quelles données sont collectées et comment elles sont utilisées.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-background">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto space-y-10">
        <div class="bg-card border border-border rounded-lg p-8">
          <h2 class="text-2xl font-bold text-foreground mb-4">Résumé</h2>
          <p class="text-muted-foreground">
            CAPITUNE traite vos informations afin de fournir le service (création de compte, gestion du projet, messagerie, paiements) et répondre à vos demandes.
          </p>
        </div>

        <div class="bg-card border border-border rounded-lg p-8">
          <h2 class="text-2xl font-bold text-foreground mb-4">Données collectées</h2>
          <ul class="list-disc pl-5 text-muted-foreground space-y-2">
            <li>Informations de compte (nom, email).</li>
            <li>Informations liées au projet (ex. type de projet, préférences) lorsque vous les saisissez.</li>
            <li>Messages échangés via la messagerie.</li>
            <li>Données techniques nécessaires au fonctionnement (cookies de session, journaux techniques).</li>
          </ul>
        </div>

        <div class="bg-card border border-border rounded-lg p-8">
          <h2 class="text-2xl font-bold text-foreground mb-4">Finalités</h2>
          <ul class="list-disc pl-5 text-muted-foreground space-y-2">
            <li>Fournir et sécuriser l’accès à votre espace (authentification, session).</li>
            <li>Permettre le suivi de votre projet et la communication avec l’équipe.</li>
            <li>Gérer les transactions et justificatifs liés aux paiements.</li>
            <li>Améliorer le service (diagnostic, prévention des abus).</li>
          </ul>
        </div>

        <div class="bg-card border border-border rounded-lg p-8">
          <h2 class="text-2xl font-bold text-foreground mb-4">Contact</h2>
          <p class="text-muted-foreground">
            Pour toute question relative à vos données, vous pouvez nous écrire à
            <a class="text-primary hover:underline" href={`mailto:${publicConfig.contactEmail}`}> {publicConfig.contactEmail}</a>.
          </p>
        </div>

        <div class="text-sm text-muted-foreground text-center">
          Dernière mise à jour : février 2026.
        </div>
      </div>
    </div>
  </section>

  <FooterCustom />
</MainLayout>
