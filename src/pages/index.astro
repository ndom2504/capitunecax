---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
import { getServiceById } from '../lib/service-catalog';
import { publicConfig, getContactAddressLines } from '../lib/public-config';

const consultation = getServiceById('consultation');
const orientation = getServiceById('orientation');
const dossier = getServiceById('dossier');
const suivi = getServiceById('suivi');
const integration = getServiceById('integration');

const addressLines = getContactAddressLines();

const landingServices = [
  {
    key: 'analyse',
    liClass: 'Development',
    navLabel: 'ANALYSE DU PROJET',
    title: 'Analyse du projet',
    description:
      `${consultation?.description ?? "Analyser votre profil"} et ${orientation?.description ?? 'choisir le bon programme'} pour construire une stratégie claire et réaliste.`,
  },
  {
    key: 'montage',
    liClass: 'Desdin',
    navLabel: 'MONTAGE DU DOSSIER',
    title: dossier?.name ?? 'Montage du dossier',
    description:
      dossier?.description ??
      'Nous structurons vos pièces, vérifions la conformité des documents et préparons un dossier solide.',
  },
  {
    key: 'suivi',
    liClass: 'Concept',
    navLabel: 'SUIVI ADMINISTRATIF',
    title: suivi?.name ?? 'Suivi administratif',
    description:
      suivi?.description ??
      'Nous assurons le suivi des étapes, délais et réponses attendues afin de vous garder informé et réactif.',
  },
  {
    key: 'integration',
    liClass: 'System',
    navLabel: 'INTÉGRATION',
    title: integration?.name ?? 'Aide à l’intégration',
    description:
      integration?.description ??
      'Nous vous accompagnons dans l’installation locale et les premières démarches pour une arrivée plus sereine.',
  },
];
---

<MainLayout>
  <link rel="stylesheet" href="/templatemo_473_november/css/theme.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/media.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/font-awesome.min.css" />
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,300,600,600italic,400italic,800,700" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Oswald:400,700,300" rel="stylesheet" type="text/css" />

  <style is:global>
    .site-logo a { display:inline-block; line-height:0; }
    .site-logo img { height: 64px; width: auto; display:block; }
    header .site-logo { padding: 0 !important; height: 105px; display:flex; align-items:center; }
    header.smaller .site-logo { height: 60px; }
    header.smaller .site-logo img { height: 36px; }

    /* Vidéo hero arrière-plan */
    .Banner_sec { position: relative; overflow: hidden; }
    .hero-video-bg {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      min-width: 100%; min-height: 100%;
      width: auto; height: auto;
      object-fit: cover;
      z-index: 0;
      pointer-events: none;
    }
    .hero-video-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(10,15,40,0.70) 0%, rgba(10,15,40,0.45) 60%, rgba(0,0,0,0.20) 100%);
      z-index: 1;
      pointer-events: none;
    }
    .Banner_sec .bannerside { position: relative; z-index: 2; }
  </style>

  <div class="DesignHolder">
    <div class="LayoutFrame">
      <header>
        <div class="Center">
          <div class="site-logo">
            <a href={`${baseUrl}/`}><img src="/templatemo_473_november/logo/Logo%20moderne%20de%20CAPITUNE%20avec%20halo%20lumineux.png" alt="CAPITUNE" /></a>
          </div>
          <div id="mobile_sec">
            <div class="mobile"><i class="fa fa-bars"></i><i class="fa fa-times"></i></div>
            <div class="menumobile">
              <nav class="Navigation">
                <ul>
                  <li class="active"><a href="#home">Accueil</a><span class="menu-item-bg"></span></li>
                  <li><a href="#about">À propos</a><span class="menu-item-bg"></span></li>
                  <li><a href="#services">Services</a><span class="menu-item-bg"></span></li>
                  <li><a href="#contact">Contact</a><span class="menu-item-bg"></span></li>
                  <li><a href={`${baseUrl}/connexion`}>Connexion</a><span class="menu-item-bg"></span></li>
                </ul>
              </nav>
            </div>
          </div>
          <div class="clear"></div>
        </div>
      </header>

      <div class="Banner_sec" id="home">
        <video class="hero-video-bg" autoplay muted loop playsinline preload="auto">
          <source src="/templatemo_473_november/video/hero-bg.mp4" type="video/mp4" />
        </video>
        <div class="hero-video-overlay"></div>
        <div class="bannerside">
          <div class="Center">
            <div class="leftside">
              <h3>Votre Projet Canada<span>avec CAPITUNE</span></h3>
              <p>Nous structurons votre démarche d'immigration au Canada : analyse du profil, montage du dossier, suivi administratif et intégration locale, étape par étape.</p>
              <a href="#about">DÉCOUVRIR</a>
              <a href="#contact" class="secondary-cta">NOUS CONTACTER</a>
            </div>
            <div class="rightside">
              <div class="hero-mini-screen">
                <video autoplay muted loop playsinline preload="auto" class="hero-mini-video">
                  <source src="/templatemo_473_november/video/integration-canada.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="hero-yt-cta">
                <a href="https://youtube.com/@capitune-b7n?si=ERrv2gwAnxKfn89x" target="_blank" rel="noopener" class="hero-yt-btn">
                  <i class="fa fa-youtube-play"></i> Lire notre guide d&rsquo;int&eacute;gration
                </a>
              </div>
              <figure><img src="/templatemo_473_november/img/Shadow-img.png" alt="shadow" class="Shadow" /></figure>
            </div>
          </div>
        </div>
        <div class="clear"></div>
      </div>

      <div class="bgcolor"></div>

      <div id="Container">
        <div class="About_sec cap-features-sec" id="about">
          <div class="Center">
            <h2>Notre accompagnement</h2>
            <p>Une initiative d&rsquo;Export Monde Prestige Inc. pour structurer votre projet Canada avec un accompagnement clair, professionnel et centr&eacute; sur vos objectifs.</p>
            <div class="Line"></div>
            <div class="cap-features-grid">
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-search"></i></div>
                  <h4>Analyse du profil</h4>
                  <p>Nous &eacute;valuons votre situation, vos objectifs et les programmes disponibles pour construire une strat&eacute;gie claire et r&eacute;aliste adapt&eacute;e &agrave; votre r&eacute;alit&eacute;.</p>
                </div>
              </div>
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-folder-open"></i></div>
                  <h4>Montage du dossier</h4>
                  <p>Nous structurons vos pi&egrave;ces, v&eacute;rifions la conformit&eacute; des documents et pr&eacute;parons un dossier solide, complet et pr&ecirc;t &agrave; &ecirc;tre d&eacute;pos&eacute;.</p>
                </div>
              </div>
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-tasks"></i></div>
                  <h4>Suivi administratif</h4>
                  <p>Nous assurons le suivi des &eacute;tapes, d&eacute;lais et r&eacute;ponses attendues afin de vous garder inform&eacute; et r&eacute;actif tout au long du processus.</p>
                </div>
              </div>
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-home"></i></div>
                  <h4>Int&eacute;gration locale</h4>
                  <p>Nous vous accompagnons dans votre installation locale et vos premi&egrave;res d&eacute;marches pour une arriv&eacute;e au Canada plus sereine et plus confiante.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="Services_sec" id="services">
          <div class="Center">
            <h2>Nos services</h2>
            <p>
              Un accompagnement complet pour bâtir, structurer et piloter votre projet Canada avec
              une vision claire et des actions concrètes.
            </p>
            <div class="Line"></div>
            <div class="Serviceside">
              <ul>
                {landingServices.map((service, index) => (
                  <li class={service.liClass}>
                    <a href="#services" class={`service-trigger ${index === 0 ? 'active' : ''}`} data-service={service.key}>
                      <h4>{service.navLabel}</h4>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <div class="service-detail-panels">
              {landingServices.map((service, index) => (
                <article class={`service-panel ${index === 0 ? 'is-visible' : ''}`} data-service-panel={service.key}>
                  <h3>{service.title}</h3>
                  <p>{service.description}</p>
                </article>
              ))}
            </div>
          </div>
        </div>

        <div class="Contact_sec" id="contact">
          <div class="Contactside">
            <div class="Center">
              <h2>Contact</h2>
              <p>Vous avez un projet Canada ? Écrivez-nous et recevez une réponse rapide<br />pour cadrer vos prochaines étapes avec CAPITUNE.</p>
              <div class="Line"></div>
            </div>
          </div>

          <div class="Map" style="width:100%;height:360px;">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=-73.7%2C45.4%2C-73.45%2C45.6&layer=mapnik&marker=45.5017%2C-73.5673"
              width="100%" height="100%"
              style="border:0; display:block;"
              allowfullscreen
              loading="lazy"
              title="CAPITUNE — Montréal, Québec">
            </iframe>
          </div>

          <div class="Get_sec">
            <div class="Mid">
              <div class="Leftside">
                <form action="#">
                  <fieldset>
                    <p><input type="text" value="" placeholder="NOM COMPLET" class="field" /></p>
                    <p><input type="email" value="" placeholder="EMAIL" class="field" /></p>
                    <p><input type="text" value="" placeholder="TYPE DE PROJET" class="field" /></p>
                    <p><textarea cols="2" rows="2" placeholder="DÉCRIVEZ VOTRE BESOIN"></textarea></p>
                    <p><input type="submit" value="Envoyer" class="button" /></p>
                  </fieldset>
                </form>
              </div>

              <div class="Rightside">
                <h3>Parlons de votre projet !</h3>
                <address>
                  {addressLines.map((line, idx) => (
                    <span>
                      {line}
                      {idx < addressLines.length - 1 ? <br /> : null}
                    </span>
                  ))}
                </address>
                <address class="Number">
                  {publicConfig.contactPhone}
                </address>
                <address class="Email">
                  <a href={`mailto:${publicConfig.contactEmail}`}>{publicConfig.contactEmail}</a>
                </address>
                <div class="clear"></div>
                <ul>
                  <li><a href="https://www.facebook.com/profile.php?id=61587490209250&sk=about" target="_blank" rel="noopener"><img src="/templatemo_473_november/img/facebook-icn.png" alt="facebook" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/twitter-icn.png" alt="twitter" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/google-plus-icn.png" alt="google plus" /></a></li>
                </ul>
              </div>
            </div>

            <footer>
              <div class="Cntr">
                <p>© 2026 <strong>CAPITUNE</strong> – Tous droits réservés. | <a href={`${baseUrl}/connexion`} style="color:#a9abad;">Espace Client</a></p>
              </div>
            </footer>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="loader-wrapper">
    <div id="loader"></div>
    <div class="loader-section section-left"></div>
    <div class="loader-section section-right"></div>
  </div>

  <script is:inline src="/templatemo_473_november/js/jquery-1.11.0.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/jquery.sudoSlider.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/global.js"></script>
  <script is:inline src="/templatemo_473_november/js/modernizr.js"></script>
  <script is:inline>
    (() => {
      const initServicePanels = () => {
        const triggers = Array.from(document.querySelectorAll('.service-trigger'));
        const panels = Array.from(document.querySelectorAll('.service-panel'));

        if (!triggers.length || !panels.length) return;

        const showPanel = (serviceKey) => {
          triggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-service') === serviceKey;
            trigger.classList.toggle('active', isActive);
          });

          panels.forEach((panel) => {
            const shouldShow = panel.getAttribute('data-service-panel') === serviceKey;
            panel.classList.toggle('is-visible', shouldShow);
          });
        };

        triggers.forEach((trigger) => {
          trigger.addEventListener('click', (event) => {
            event.preventDefault();
            const serviceKey = trigger.getAttribute('data-service');
            if (!serviceKey) return;
            showPanel(serviceKey);
          });
        });

        const firstService = triggers[0]?.getAttribute('data-service');
        if (firstService) showPanel(firstService);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initServicePanels, { once: true });
      } else {
        initServicePanels();
      }

      document.addEventListener('astro:page-load', initServicePanels);
    })();
  </script>
</MainLayout>

<style is:global>
  #home .leftside {
    width: 34%;
    position: relative;
    z-index: 2;
  }

  #home .leftside h3,
  #home .leftside h3 span {
    white-space: normal !important;
    text-wrap: pretty;
    line-height: 1.1;
  }

  #home .rightside {
    width: 62%;
    transform: translateX(52px);
    position: relative;
  }

  #home .rightside .hero-yt-cta {
    text-align: center;
    margin-top: 16px;
    margin-bottom: 4px;
    position: relative;
    z-index: 5;
  }

  #home .rightside .hero-yt-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #ff0000;
    border: 2px solid #cc0000;
    color: #ffffff;
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 11px 26px;
    border-radius: 6px;
    cursor: pointer;
    pointer-events: all;
    box-shadow: 0 4px 18px rgba(255,0,0,0.45), 0 2px 8px rgba(0,0,0,0.30);
    transition: background .2s, border-color .2s, transform .15s, box-shadow .2s;
  }

  #home .rightside .hero-yt-btn .fa-youtube-play {
    font-size: 20px;
    color: #ffffff;
    transition: transform .2s;
  }

  #home .rightside .hero-yt-btn:hover {
    background: #cc0000;
    border-color: #aa0000;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(255,0,0,0.55), 0 4px 12px rgba(0,0,0,0.35);
    color: #ffffff;
  }

  #home .rightside .hero-yt-btn:hover .fa-youtube-play {
    transform: scale(1.15);
    color: #ffffff;
  }

  #home .rightside .hero-mini-screen {
    position: relative;
    width: 100%;
    border-radius: 10px;
    overflow: hidden;
    box-shadow:
      0 0 0 6px rgba(255,255,255,0.12),
      0 0 0 12px rgba(255,255,255,0.06),
      0 24px 64px rgba(0,0,0,0.55);
    aspect-ratio: 16/9;
    background: #000;
  }

  #home .rightside .hero-mini-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 10px;
  }

  #home .rightside .Shadow {
    margin-top: -10px;
    opacity: 0.5;
    pointer-events: none;
  }

  #home .rightside .Slider figure img {
    width: 100%;
    height: 500px;
    object-fit: cover;
  }

  #home .leftside a.secondary-cta {
    margin-left: 10px;
    background: transparent;
    border: 1px solid #ffffff;
    color: #ffffff;
  }

  #home .leftside a.secondary-cta:hover {
    background: #ffffff;
    color: #222;
  }

  #services .service-detail-panels {
    margin-top: 34px;
    min-height: 170px;
    position: relative;
  }

  #services .service-panel {
    display: none;
    opacity: 0;
    transform: translateY(16px) scale(0.98);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 10px;
    padding: 26px;
    backdrop-filter: blur(2px);
    transition: opacity 360ms ease, transform 360ms ease;
  }

  #services .service-panel.is-visible {
    display: block;
    opacity: 1;
    transform: translateY(0) scale(1);
    animation: servicePanelIn 360ms ease;
  }

  #services .service-panel h3 {
    white-space: normal !important;
    color: #ffffff;
    font-size: 28px;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  #services .service-panel p {
    color: rgba(255, 255, 255, 0.92);
    font-size: 16px;
    line-height: 1.65;
    margin: 0;
  }

  #services .service-trigger.active h4 {
    color: #ff9000;
  }

  @keyframes servicePanelIn {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  #contact .Get_sec .Leftside fieldset .button {
    text-transform: none;
  }

  #contact .Get_sec .Leftside input.field,
  #contact .Get_sec .Leftside textarea {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(15, 23, 42, 0.25);
    color: #0f172a !important;
    font-weight: 600;
  }

  #contact .Get_sec .Leftside input.field::placeholder,
  #contact .Get_sec .Leftside textarea::placeholder {
    color: #334155;
    opacity: 0.9;
  }

  #contact .Get_sec .Leftside input.field:focus,
  #contact .Get_sec .Leftside textarea:focus {
    background: #ffffff;
    border-color: #f88e04;
    box-shadow: 0 0 0 2px rgba(248, 142, 4, 0.15);
  }

  @media (max-width: 1200px) {
    #home .rightside {
      transform: none;
    }

    #services .service-panel {
      padding: 18px;
    }

    #services .service-panel h3 {
      font-size: 22px;
    }
  }

  /* ===== SECTION À PROPOS — FEATURES STYLE ===== */
  .cap-features-sec {
    background: #ffffff;
    padding-bottom: 90px;
  }

  /* Le h2 + p + Line héritent du style .About_sec natif */
  /* On surcharge juste ce qui diffère */
  .cap-features-sec h2 {
    font-size: 52px !important;
    color: #1a1a2e !important;
    margin-bottom: 0;
  }

  .cap-features-sec > .Center > p {
    color: #888 !important;
    font-size: 15px !important;
    padding-bottom: 30px !important;
  }

  .cap-features-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .cap-features-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
    margin-top: 60px;
  }

  .cap-feature-box {
    width: calc(25% - 18px);
    box-sizing: border-box;
    transition: transform .35s, box-shadow .35s;
  }

  .cap-feature-inner {
    border: 1px solid #e8e8e8;
    border-top: 4px solid #e8e8e8;
    background: #fafafa;
    padding: 40px 24px 36px;
    text-align: center;
    border-radius: 4px;
    height: 100%;
    box-sizing: border-box;
    transition: all .35s;
  }

  .cap-feature-box:hover {
    transform: translateY(-6px);
  }

  .cap-feature-box:hover .cap-feature-inner {
    border-top-color: #ff9408;
    background: #fff;
    box-shadow: 0 12px 40px rgba(255,148,8,0.13);
  }

  .cap-feature-icon {
    font-size: 46px;
    color: #1a1a2e;
    margin-bottom: 20px;
    transition: color .35s;
  }

  .cap-feature-box:hover .cap-feature-icon {
    color: #ff9408;
  }

  .cap-feature-inner h4 {
    font-family: 'Oswald', sans-serif;
    font-size: 16px;
    color: #1a1a2e;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 14px;
    font-weight: 500;
    transition: color .35s;
  }

  .cap-feature-box:hover .cap-feature-inner h4 {
    color: #ff9408;
  }

  .cap-feature-inner p {
    font-size: 13.5px;
    color: #777;
    line-height: 1.75;
    margin: 0 auto;
    transition: color .35s;
    font-family: 'Open Sans', sans-serif;
  }

  @media (max-width: 991px) {
    .cap-feature-box { width: calc(50% - 12px); }
  }

  @media (max-width: 540px) {
    .cap-feature-box { width: 100%; }
  }
</style>
