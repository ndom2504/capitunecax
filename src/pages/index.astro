---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
import { getServiceById } from '../lib/service-catalog';
import { FooterCustom } from '../components/FooterCustom';
import { publicConfig, getContactAddressLines } from '../lib/public-config';

const consultation = getServiceById('consultation');
const orientation = getServiceById('orientation');
const dossier = getServiceById('dossier');
const suivi = getServiceById('suivi');
const integration = getServiceById('integration');

const addressLines = getContactAddressLines();

const landingServices = [
  {
    key: 'analyse',
    liClass: 'Development',
    navLabel: 'ANALYSE DU PROJET',
    title: 'Analyse du projet',
    description:
      `${consultation?.description ?? "Analyser votre profil"} et ${orientation?.description ?? 'choisir le bon programme'} pour construire une stratégie claire et réaliste.`,
  },
  {
    key: 'montage',
    liClass: 'Desdin',
    navLabel: 'MONTAGE DU DOSSIER',
    title: dossier?.name ?? 'Montage du dossier',
    description:
      dossier?.description ??
      'Nous structurons vos pièces, vérifions la conformité des documents et préparons un dossier solide.',
  },
  {
    key: 'suivi',
    liClass: 'Concept',
    navLabel: 'SUIVI ADMINISTRATIF',
    title: suivi?.name ?? 'Suivi administratif',
    description:
      suivi?.description ??
      'Nous assurons le suivi des étapes, délais et réponses attendues afin de vous garder informé et réactif.',
  },
  {
    key: 'integration',
    liClass: 'System',
    navLabel: 'INTÉGRATION',
    title: integration?.name ?? 'Aide à l’intégration',
    description:
      integration?.description ??
      'Nous vous accompagnons dans l’installation locale et les premières démarches pour une arrivée plus sereine.',
  },
];
---

<MainLayout>
  <link rel="stylesheet" href="/templatemo_473_november/css/theme.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/media.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/font-awesome.min.css" />
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,300,600,600italic,400italic,800,700" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Oswald:400,700,300" rel="stylesheet" type="text/css" />

  <style is:global>
    /* ── Header layout fix ── */
    header .Center { display:flex !important; align-items:center; justify-content:space-between; }
    header .site-logo { float:none !important; padding:0 !important; height:auto !important; flex-shrink:0; }
    .site-logo a { display:inline-block; line-height:0; }
    .site-logo img { height: 56px; width: auto; display:block; }
    header.smaller .site-logo img { height: 36px; }
    #mobile_sec { flex:1; display:flex; align-items:center; justify-content:flex-end; }
    .Navigation { float:none !important; width:auto !important; margin-right:0 !important; }
    /* ── Bouton Connexion coin droit ── */
    .header-cta-connexion {
      display:inline-flex; align-items:center; gap:8px; flex-shrink:0;
      background:#ff9408; color:#fff !important;
      padding:10px 24px; border-radius:50px;
      font-weight:700; font-size:14px; font-family:'Open Sans',sans-serif;
      text-decoration:none; white-space:nowrap; margin-left:18px;
      box-shadow:0 4px 14px rgba(255,148,8,0.35);
      transition:background 0.2s, transform 0.15s;
    }
    .header-cta-connexion:hover { background:#e08300; transform:translateY(-1px); }
    header.smaller .header-cta-connexion { padding:7px 16px; font-size:13px; margin-left:12px; }
    .Navigation li a { padding:0 22px !important; line-height:105px !important; display:block; }
    header.smaller .Navigation li a { line-height:60px !important; }
    .Navigation li { height:105px !important; }
    header.smaller .Navigation li { height:60px !important; }
    /* Desktop : cacher le li connexion du nav, montrer le bouton CTA */
    @media (min-width: 769px) { .mobile-only-nav-item { display:none !important; } }
    /* Mobile : cacher le bouton CTA desktop, laisser le li du menu */
    @media (max-width: 768px) { .desktop-only-cta { display:none !important; } }

    /* Vidéo hero arrière-plan */
    .Banner_sec { position: relative; overflow: hidden; }
    .hero-video-bg {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      min-width: 100%; min-height: 100%;
      width: auto; height: auto;
      object-fit: cover;
      z-index: 0;
      pointer-events: none;
    }
    .hero-video-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(10,15,40,0.70) 0%, rgba(10,15,40,0.45) 60%, rgba(0,0,0,0.20) 100%);
      z-index: 1;
      pointer-events: none;
    }
    .Banner_sec .bannerside { position: relative; z-index: 2; }
  </style>

  <div class="DesignHolder">
    <div class="LayoutFrame">
      <header>
        <div class="Center">
          <div class="site-logo">
            <a href={`${baseUrl}/`}><img src="/logo/capitune.png" alt="CAPITUNE" /></a>
          </div>
          <div id="mobile_sec">
            <div class="mobile"><i class="fa fa-bars"></i><i class="fa fa-times"></i></div>
            <div class="menumobile">
              <nav class="Navigation">
                <ul>
                  <li class="active"><a href="#home">Accueil</a><span class="menu-item-bg"></span></li>
                  <li><a href="#about">À propos</a><span class="menu-item-bg"></span></li>
                  <li><a href="#services">Services</a><span class="menu-item-bg"></span></li>
                  <li><a href="#app-mobile">Application</a><span class="menu-item-bg"></span></li>
                  <li><a href="#contact">Contact</a><span class="menu-item-bg"></span></li>
                  <!-- Menu mobile : Connexion reste ici -->
                  <li class="mobile-only-nav-item"><a href={`${baseUrl}/connexion`}>Connexion</a><span class="menu-item-bg"></span></li>
                </ul>
              </nav>
            </div>
          </div>
          <!-- Bouton Connexion coin droit (desktop) -->
          <a href={`${baseUrl}/connexion`} class="header-cta-connexion desktop-only-cta">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
              <polyline points="10 17 15 12 10 7"/>
              <line x1="15" y1="12" x2="3" y2="12"/>
            </svg>
            Connexion
          </a>
          <div class="clear"></div>
        </div>
      </header>

      <div class="Banner_sec" id="home">
        <video class="hero-video-bg" autoplay muted loop playsinline preload="auto">
          <source src="/templatemo_473_november/video/hero-bg.mp4" type="video/mp4" />
        </video>
        <div class="hero-video-overlay"></div>
        <div class="bannerside">
          <div class="Center">
            <div class="leftside">
              <h3>Votre Projet Canada<span>avec CAPITUNE</span></h3>
              <p>Nous structurons votre démarche d'immigration au Canada : analyse du profil, montage du dossier, suivi administratif et intégration locale, étape par étape.</p>
              <a href="#about">DÉCOUVRIR</a>
              <a href="#contact" class="secondary-cta">NOUS CONTACTER</a>
            </div>
            <div class="rightside">
              <div class="hero-mini-screen">
                <video autoplay muted loop playsinline preload="auto" class="hero-mini-video">
                  <source src="/templatemo_473_november/video/integration-canada.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="hero-yt-cta">
                <a href="https://youtu.be/Z3BKJx1qy0I" target="_blank" rel="noopener" class="hero-yt-btn">
                  <i class="fa fa-youtube-play"></i> Lire notre guide d&rsquo;int&eacute;gration
                </a>
              </div>
              <figure><img src="/templatemo_473_november/img/Shadow-img.png" alt="shadow" class="Shadow" /></figure>
            </div>
          </div>
        </div>
        <div class="clear"></div>
      </div>

      <div class="bgcolor"></div>

      <div id="Container">
        <div class="About_sec cap-features-sec" id="about">
          <div class="Center">
            <h2>Notre accompagnement</h2>
            <p>Une initiative d&rsquo;Export Monde Prestige Inc. pour structurer votre projet Canada avec un accompagnement clair, professionnel et centr&eacute; sur vos objectifs.</p>
            <div class="Line"></div>
            <div class="cap-features-grid">
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-search"></i></div>
                  <h4>Analyse du profil</h4>
                  <p>Nous &eacute;valuons votre situation, vos objectifs et les programmes disponibles pour construire une strat&eacute;gie claire et r&eacute;aliste adapt&eacute;e &agrave; votre r&eacute;alit&eacute;.</p>
                </div>
              </div>
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-folder-open"></i></div>
                  <h4>Montage du dossier</h4>
                  <p>Nous structurons vos pi&egrave;ces, v&eacute;rifions la conformit&eacute; des documents et pr&eacute;parons un dossier solide, complet et pr&ecirc;t &agrave; &ecirc;tre d&eacute;pos&eacute;.</p>
                </div>
              </div>
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-tasks"></i></div>
                  <h4>Suivi administratif</h4>
                  <p>Nous assurons le suivi des &eacute;tapes, d&eacute;lais et r&eacute;ponses attendues afin de vous garder inform&eacute; et r&eacute;actif tout au long du processus.</p>
                </div>
              </div>
              <div class="cap-feature-box">
                <div class="cap-feature-inner">
                  <div class="cap-feature-icon"><i class="fa fa-home"></i></div>
                  <h4>Int&eacute;gration locale</h4>
                  <p>Nous vous accompagnons dans votre installation locale et vos premi&egrave;res d&eacute;marches pour une arriv&eacute;e au Canada plus sereine et plus confiante.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="Services_sec" id="services">
          <div class="Center">
            <h2>Nos services</h2>
            <p>
              Un accompagnement complet pour bâtir, structurer et piloter votre projet Canada avec
              une vision claire et des actions concrètes.
            </p>
            <div class="Line"></div>
            <div class="Serviceside">
              <ul>
                {landingServices.map((service, index) => (
                  <li class={service.liClass}>
                    <a href="#services" class={`service-trigger ${index === 0 ? 'active' : ''}`} data-service={service.key}>
                      <h4>{service.navLabel}</h4>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <div class="service-detail-panels">
              {landingServices.map((service, index) => (
                <article class={`service-panel ${index === 0 ? 'is-visible' : ''}`} data-service-panel={service.key}>
                  <h3>{service.title}</h3>
                  <p>{service.description}</p>
                </article>
              ))}
            </div>
          </div>
        </div>

        <!-- ═══════════ SECTION APP MOBILE ═══════════ -->
        <div class="cap-mobile-sec" id="app-mobile">
          <div class="Center">

            <div class="cap-mob-header">
              <span class="cap-mob-badge">
                <i class="fa fa-mobile"></i>&nbsp; Bientôt disponible
              </span>
              <h2>CAPITUNE dans votre poche</h2>
              <p>Gérez votre projet Canada où que vous soyez. Consultez vos documents, échangez avec votre conseiller et suivez chaque étape en temps réel depuis votre téléphone.</p>
              <div class="Line"></div>
            </div>

            <div class="cap-mob-layout">

              <!-- Maquette téléphone animée -->
              <div class="cap-mob-phone-wrap" aria-hidden="true">
                <div class="cap-mob-phone">
                  <div class="cap-mob-notch"></div>
                  <div class="cap-mob-screen">
                    <!-- Écran 1 : Dashboard -->
                    <div class="cap-mob-slide cap-mob-slide--active" data-slide="0">
                      <div class="cap-mob-topbar">
                        <span class="cap-mob-avatar"><i class="fa fa-user-circle"></i></span>
                        <span class="cap-mob-hello">Bonjour, Marc 👋</span>
                        <span class="cap-mob-notif"><i class="fa fa-bell"></i><em>2</em></span>
                      </div>
                      <div class="cap-mob-progress-card">
                        <p class="cap-mob-prog-label">Avancement du dossier</p>
                        <div class="cap-mob-prog-bar"><div class="cap-mob-prog-fill" style="width:68%"></div></div>
                        <p class="cap-mob-prog-pct">68%</p>
                      </div>
                      <div class="cap-mob-steps">
                        <div class="cap-mob-step cap-mob-step--done"><i class="fa fa-check-circle"></i> Analyse du profil</div>
                        <div class="cap-mob-step cap-mob-step--done"><i class="fa fa-check-circle"></i> Documents envoyés</div>
                        <div class="cap-mob-step cap-mob-step--active"><i class="fa fa-circle-o-notch fa-spin"></i> Révision du dossier</div>
                        <div class="cap-mob-step"><i class="fa fa-circle-o"></i> Dépôt officiel</div>
                      </div>
                    </div>
                    <!-- Écran 2 : Messagerie -->
                    <div class="cap-mob-slide" data-slide="1">
                      <div class="cap-mob-chat-header"><i class="fa fa-comments"></i> Messagerie</div>
                      <div class="cap-mob-chat-list">
                        <div class="cap-mob-msg cap-mob-msg--in">
                          <span>Votre dossier est en révision. Les pièces jointes sont conformes ✅</span>
                          <time>10:32</time>
                        </div>
                        <div class="cap-mob-msg cap-mob-msg--out">
                          <span>Merci ! Quand aura lieu le dépôt ?</span>
                          <time>10:35</time>
                        </div>
                        <div class="cap-mob-msg cap-mob-msg--in">
                          <span>Nous prévoyons le dépôt d'ici 5 jours ouvrables 📅</span>
                          <time>10:37</time>
                        </div>
                        <div class="cap-mob-typing"><span></span><span></span><span></span></div>
                      </div>
                    </div>
                    <!-- Écran 3 : Documents -->
                    <div class="cap-mob-slide" data-slide="2">
                      <div class="cap-mob-chat-header"><i class="fa fa-folder-open"></i> Mes documents</div>
                      <div class="cap-mob-doc-list">
                        <div class="cap-mob-doc cap-mob-doc--ok"><i class="fa fa-file-pdf-o"></i><span>Passeport.pdf</span><i class="fa fa-check cap-mob-doc-status"></i></div>
                        <div class="cap-mob-doc cap-mob-doc--ok"><i class="fa fa-file-image-o"></i><span>Photo_identité.jpg</span><i class="fa fa-check cap-mob-doc-status"></i></div>
                        <div class="cap-mob-doc cap-mob-doc--warn"><i class="fa fa-file-pdf-o"></i><span>Relevé_bancaire.pdf</span><i class="fa fa-exclamation cap-mob-doc-status"></i></div>
                        <div class="cap-mob-doc"><i class="fa fa-file-pdf-o"></i><span>Casier_judiciaire.pdf</span><i class="fa fa-upload cap-mob-doc-status"></i></div>
                        <div class="cap-mob-doc"><i class="fa fa-file-pdf-o"></i><span>Références_emploi.pdf</span><i class="fa fa-upload cap-mob-doc-status"></i></div>
                      </div>
                    </div>
                    <!-- Barre de navigation mobile -->
                    <div class="cap-mob-nav">
                      <button class="cap-mob-nav-btn cap-mob-nav-btn--active" data-goto="0"><i class="fa fa-home"></i></button>
                      <button class="cap-mob-nav-btn" data-goto="1"><i class="fa fa-comments"></i></button>
                      <button class="cap-mob-nav-btn" data-goto="2"><i class="fa fa-folder"></i></button>
                    </div>
                  </div>
                </div>
                <!-- Reflets décoratifs -->
                <div class="cap-mob-glow cap-mob-glow--1"></div>
                <div class="cap-mob-glow cap-mob-glow--2"></div>
              </div>

              <!-- Fonctionnalités listées -->
              <div class="cap-mob-features">
                <ul>
                  <li class="cap-mob-feat" data-delay="0">
                    <div class="cap-mob-feat-icon"><i class="fa fa-tasks"></i></div>
                    <div class="cap-mob-feat-text">
                      <h4>Suivi en temps réel</h4>
                      <p>Visualisez chaque étape de votre dossier, de l'analyse initiale jusqu'au dépôt officiel.</p>
                    </div>
                  </li>
                  <li class="cap-mob-feat" data-delay="120">
                    <div class="cap-mob-feat-icon"><i class="fa fa-comments"></i></div>
                    <div class="cap-mob-feat-text">
                      <h4>Messagerie directe</h4>
                      <p>Échangez instantanément avec votre conseiller Capitune depuis votre téléphone.</p>
                    </div>
                  </li>
                  <li class="cap-mob-feat" data-delay="240">
                    <div class="cap-mob-feat-icon"><i class="fa fa-folder-open"></i></div>
                    <div class="cap-mob-feat-text">
                      <h4>Gestion des documents</h4>
                      <p>Consultez, téléversez et suivez le statut de chaque pièce de votre dossier.</p>
                    </div>
                  </li>
                  <li class="cap-mob-feat" data-delay="360">
                    <div class="cap-mob-feat-icon"><i class="fa fa-bell"></i></div>
                    <div class="cap-mob-feat-text">
                      <h4>Notifications intelligentes</h4>
                      <p>Recevez des alertes dès qu'une action est requise ou qu'une étape est franchie.</p>
                    </div>
                  </li>
                  <li class="cap-mob-feat" data-delay="480">
                    <div class="cap-mob-feat-icon"><i class="fa fa-lock"></i></div>
                    <div class="cap-mob-feat-text">
                      <h4>Données sécurisées</h4>
                      <p>Vos informations personnelles et documents sont chiffrés et hébergés au Canada.</p>
                    </div>
                  </li>
                </ul>

                <!-- Statistiques animées -->
                <div class="cap-mob-stats">
                  <div class="cap-mob-stat">
                    <strong class="cap-count" data-target="98">0</strong><span>%</span>
                    <p>Satisfaction client</p>
                  </div>
                  <div class="cap-mob-stat">
                    <strong class="cap-count" data-target="500">0</strong><span>+</span>
                    <p>Dossiers traités</p>
                  </div>
                  <div class="cap-mob-stat">
                    <strong class="cap-count" data-target="24">0</strong><span>h</span>
                    <p>Accès continu</p>
                  </div>
                </div>

                <!-- CTAs stores -->
                <div class="cap-mob-stores">
                  <p class="cap-mob-stores-label">Disponible prochainement sur</p>
                  <div class="cap-mob-store-btns">
                    <a href="#app-mobile" class="cap-mob-store-btn" aria-label="App Store">
                      <i class="fa fa-apple"></i>
                      <span><small>Bientôt sur</small> App Store</span>
                    </a>
                    <a href="#app-mobile" class="cap-mob-store-btn" aria-label="Google Play">
                      <i class="fa fa-android"></i>
                      <span><small>Bientôt sur</small> Google Play</span>
                    </a>
                  </div>
                </div>
              </div>

            </div><!-- fin cap-mob-layout -->
          </div><!-- fin Center -->
        </div>
        <!-- ═══════════ FIN SECTION APP MOBILE ═══════════ -->

        <div class="Contact_sec" id="contact">
          <div class="Contactside">
            <div class="Center">
              <h2>Contact</h2>
              <p>Vous avez un projet Canada ? Écrivez-nous et recevez une réponse rapide<br />pour cadrer vos prochaines étapes avec CAPITUNE.</p>
              <div class="Line"></div>
            </div>
          </div>

          <div class="Map" style="width:100%;height:360px;">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=-73.7%2C45.4%2C-73.45%2C45.6&layer=mapnik&marker=45.5017%2C-73.5673"
              width="100%" height="100%"
              style="border:0; display:block;"
              allowfullscreen
              loading="lazy"
              title="CAPITUNE — Montréal, Québec">
            </iframe>
          </div>

          <div class="Get_sec">
            <div class="Mid">
              <div class="Leftside">
                <form action="#">
                  <fieldset>
                    <p><input type="text" value="" placeholder="NOM COMPLET" class="field" /></p>
                    <p><input type="email" value="" placeholder="EMAIL" class="field" /></p>
                    <p><input type="text" value="" placeholder="TYPE DE PROJET" class="field" /></p>
                    <p><textarea cols="2" rows="2" placeholder="DÉCRIVEZ VOTRE BESOIN"></textarea></p>
                    <p><input type="submit" value="Envoyer" class="button" /></p>
                  </fieldset>
                </form>
              </div>

              <div class="Rightside">
                <h3>Parlons de votre projet !</h3>
                <address>
                  {addressLines.map((line, idx) => (
                    <span>
                      {line}
                      {idx < addressLines.length - 1 ? <br /> : null}
                    </span>
                  ))}
                </address>
                <address class="Number">
                  {publicConfig.contactPhone}
                </address>
                <address class="Email">
                  <a href={`mailto:${publicConfig.contactEmail}`}>{publicConfig.contactEmail}</a>
                </address>
                <div class="clear"></div>
                <ul>
                  <li><a href="https://www.facebook.com/profile.php?id=61587490209250&sk=about" target="_blank" rel="noopener"><img src="/templatemo_473_november/img/facebook-icn.png" alt="facebook" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/twitter-icn.png" alt="twitter" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/google-plus-icn.png" alt="google plus" /></a></li>
                </ul>
              </div>
            </div>

            <footer style="display:none;">
              <div class="Cntr">
                <p>© 2026 <strong>CAPITUNE</strong> – Tous droits réservés. | <a href={`${baseUrl}/connexion`} style="color:#a9abad;">Espace Client</a></p>
              </div>
            </footer>
          </div>
        </div>
      </div>
    </div>
  </div>

  <FooterCustom client:only="react" />

  <div id="loader-wrapper">
    <div id="loader"></div>
    <div class="loader-section section-left"></div>
    <div class="loader-section section-right"></div>
  </div>

  <script is:inline src="/templatemo_473_november/js/jquery-1.11.0.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/jquery.sudoSlider.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/global.js"></script>
  <script is:inline src="/templatemo_473_november/js/modernizr.js"></script>
  <script is:inline>
    (() => {
      const initServicePanels = () => {
        const triggers = Array.from(document.querySelectorAll('.service-trigger'));
        const panels = Array.from(document.querySelectorAll('.service-panel'));

        if (!triggers.length || !panels.length) return;

        const showPanel = (serviceKey) => {
          triggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-service') === serviceKey;
            trigger.classList.toggle('active', isActive);
          });

          panels.forEach((panel) => {
            const shouldShow = panel.getAttribute('data-service-panel') === serviceKey;
            panel.classList.toggle('is-visible', shouldShow);
          });
        };

        triggers.forEach((trigger) => {
          trigger.addEventListener('click', (event) => {
            event.preventDefault();
            const serviceKey = trigger.getAttribute('data-service');
            if (!serviceKey) return;
            showPanel(serviceKey);
          });
        });

        const firstService = triggers[0]?.getAttribute('data-service');
        if (firstService) showPanel(firstService);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initServicePanels, { once: true });
      } else {
        initServicePanels();
      }

      document.addEventListener('astro:page-load', initServicePanels);
    })();
  </script>

  <script is:inline>
    (() => {
      /* ── Gestion des écrans du téléphone ── */
      function initMobileSection() {
        var slides = Array.from(document.querySelectorAll('.cap-mob-slide'));
        var navBtns = Array.from(document.querySelectorAll('.cap-mob-nav-btn'));
        if (!slides.length) return;

        var current = 0;
        var timer = null;

        function showSlide(idx) {
          slides.forEach(function(s, i) {
            s.classList.toggle('cap-mob-slide--active', i === idx);
          });
          navBtns.forEach(function(b, i) {
            b.classList.toggle('cap-mob-nav-btn--active', i === idx);
          });
          current = idx;
        }

        navBtns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            var goto = parseInt(btn.getAttribute('data-goto') || '0', 10);
            showSlide(goto);
            clearInterval(timer);
            timer = setInterval(function() {
              showSlide((current + 1) % slides.length);
            }, 4200);
          });
        });

        // Rotation automatique
        timer = setInterval(function() {
          showSlide((current + 1) % slides.length);
        }, 4200);
      }

      /* ── Compteurs animés ── */
      function animateCounters(root) {
        var counters = Array.from((root || document).querySelectorAll('.cap-count:not(.counted)'));
        counters.forEach(function(el) {
          el.classList.add('counted');
          var target = parseInt(el.getAttribute('data-target') || '0', 10);
          var start = 0;
          var duration = 1800;
          var step = duration / target;
          var interval = setInterval(function() {
            start += Math.ceil(target / 60);
            if (start >= target) { start = target; clearInterval(interval); }
            el.textContent = String(start);
          }, step < 16 ? 16 : step);
        });
      }

      /* ── Scroll reveal features + stats ── */
      function initMobileReveal() {
        var feats = Array.from(document.querySelectorAll('.cap-mob-feat'));
        var statsSection = document.querySelector('.cap-mob-stats');
        var statsTriggered = false;

        if (!feats.length) return;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;

            if (el.classList.contains('cap-mob-feat')) {
              var delay = parseInt(el.getAttribute('data-delay') || '0', 10);
              setTimeout(function() { el.classList.add('is-visible'); }, delay);
              observer.unobserve(el);
            }
          });
        }, { threshold: 0.2 });

        feats.forEach(function(f) { observer.observe(f); });

        // Observer séparé pour les stats (one-shot)
        if (statsSection) {
          var statsObs = new IntersectionObserver(function(entries) {
            if (entries[0].isIntersecting && !statsTriggered) {
              statsTriggered = true;
              animateCounters(statsSection.closest('.cap-mobile-sec'));
              statsObs.disconnect();
            }
          }, { threshold: 0.5 });
          statsObs.observe(statsSection);
        }
      }

      function init() {
        initMobileSection();
        initMobileReveal();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
      } else {
        init();
      }
      document.addEventListener('astro:page-load', init);
    })();
  </script>
</MainLayout>

