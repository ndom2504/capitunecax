---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
import { getServiceById } from '../lib/service-catalog';
import { publicConfig, getContactAddressLines } from '../lib/public-config';

const consultation = getServiceById('consultation');
const orientation = getServiceById('orientation');
const dossier = getServiceById('dossier');
const suivi = getServiceById('suivi');
const integration = getServiceById('integration');

const addressLines = getContactAddressLines();

const landingServices = [
  {
    key: 'analyse',
    liClass: 'Development',
    navLabel: 'ANALYSE DU PROJET',
    title: 'Analyse du projet',
    description:
      `${consultation?.description ?? "Analyser votre profil"} et ${orientation?.description ?? 'choisir le bon programme'} pour construire une stratégie claire et réaliste.`,
  },
  {
    key: 'montage',
    liClass: 'Desdin',
    navLabel: 'MONTAGE DU DOSSIER',
    title: dossier?.name ?? 'Montage du dossier',
    description:
      dossier?.description ??
      'Nous structurons vos pièces, vérifions la conformité des documents et préparons un dossier solide.',
  },
  {
    key: 'suivi',
    liClass: 'Concept',
    navLabel: 'SUIVI ADMINISTRATIF',
    title: suivi?.name ?? 'Suivi administratif',
    description:
      suivi?.description ??
      'Nous assurons le suivi des étapes, délais et réponses attendues afin de vous garder informé et réactif.',
  },
  {
    key: 'integration',
    liClass: 'System',
    navLabel: 'INTÉGRATION',
    title: integration?.name ?? 'Aide à l’intégration',
    description:
      integration?.description ??
      'Nous vous accompagnons dans l’installation locale et les premières démarches pour une arrivée plus sereine.',
  },
];
---

<MainLayout>
  <link rel="stylesheet" href="/templatemo_473_november/css/theme.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/media.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/font-awesome.min.css" />
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,300,600,600italic,400italic,800,700" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Oswald:400,700,300" rel="stylesheet" type="text/css" />

  <style is:global>
    .site-logo a { display:inline-block; line-height:0; }
    .site-logo img { height: 64px; width: auto; display:block; }
    header .site-logo { padding: 0 !important; height: 105px; display:flex; align-items:center; }
    header.smaller .site-logo { height: 60px; }
    header.smaller .site-logo img { height: 36px; }
  </style>

  <div class="DesignHolder">
    <div class="LayoutFrame">
      <header>
        <div class="Center">
          <div class="site-logo">
            <a href={`${baseUrl}/`}><img src="/templatemo_473_november/logo/Logo%20moderne%20de%20CAPITUNE%20avec%20halo%20lumineux.png" alt="CAPITUNE" /></a>
          </div>
          <div id="mobile_sec">
            <div class="mobile"><i class="fa fa-bars"></i><i class="fa fa-times"></i></div>
            <div class="menumobile">
              <nav class="Navigation">
                <ul>
                  <li class="active"><a href="#home">Accueil</a><span class="menu-item-bg"></span></li>
                  <li><a href="#about">À propos</a><span class="menu-item-bg"></span></li>
                  <li><a href="#services">Services</a><span class="menu-item-bg"></span></li>
                  <li><a href="#contact">Contact</a><span class="menu-item-bg"></span></li>
                  <li><a href={`${baseUrl}/connexion`}>Connexion</a><span class="menu-item-bg"></span></li>
                </ul>
              </nav>
            </div>
          </div>
          <div class="clear"></div>
        </div>
      </header>

      <div class="Banner_sec" id="home">
        <div class="bannerside">
          <div class="Center">
            <div class="leftside">
              <h3>Votre Projet Canada<span>avec CAPITUNE</span></h3>
              <p>Nous structurons votre démarche d'immigration au Canada : analyse du profil, montage du dossier, suivi administratif et intégration locale, étape par étape.</p>
              <a href="#about">DÉCOUVRIR</a>
              <a href="#contact" class="secondary-cta">NOUS CONTACTER</a>
            </div>
            <div class="rightside">
              <ul id="slider">
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/cn-tower-toronto.jpg" alt="Toronto" /></figure>
                    <div class="text"><div class="Lorem"><p>Toronto <span>Ontario</span></p></div></div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/canadian-flag-against-cloudy-sky.jpg" alt="Drapeau canadien" /></figure>
                    <div class="text"><div class="Lorem"><p>Rêve <span>canadien</span></p></div></div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/festivio-ottawa-815375_1920.jpg" alt="Ottawa" /></figure>
                    <div class="text"><div class="Lorem"><p>Ottawa <span>capitale</span></p></div></div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/photo-of-a-cityscape-with-a-ferris-wheel.jpg" alt="Paysage urbain" /></figure>
                    <div class="text"><div class="Lorem"><p>Ville <span>dynamique</span></p></div></div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/happy-canada-day.jpg" alt="Fête du Canada" /></figure>
                    <div class="text"><div class="Lorem"><p>Intégration <span>locale</span></p></div></div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/canada-flag-couple.jpg" alt="Couple au Canada" /></figure>
                    <div class="text"><div class="Lorem"><p>Nouveau <span>départ</span></p></div></div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/toronto-city-hall-sign.jpg" alt="Toronto City Hall" /></figure>
                    <div class="text"><div class="Lorem"><p>Montage <span>du dossier</span></p></div></div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/side/16301694-canada-5148191_1920.jpg" alt="Paysage Canada" /></figure>
                    <div class="text"><div class="Lorem"><p>Analyse <span>stratégique</span></p></div></div>
                  </div>
                </li>
              </ul>
              <figure><img src="/templatemo_473_november/img/Shadow-img.png" alt="shadow" class="Shadow" /></figure>
            </div>
          </div>
        </div>
        <div class="clear"></div>
      </div>

      <div class="bgcolor"></div>

      <div id="Container">
        <div class="About_sec" id="about">
          <div class="Center">
            <h2>À Propos De CAPITUNE</h2>
            <p>
              Une initiative d’Export Monde Prestige Inc. pour structurer votre projet Canada avec
              un accompagnement clair, professionnel et centré sur vos objectifs.
            </p>
            <div class="Line"></div>

            <div class="Tabside">
              <ul>
                <li><a href="javascript:;" class="tabLink activeLink" id="cont-1">Mission</a></li>
                <li><a href="javascript:;" class="tabLink" id="cont-2">Approche</a></li>
                <li><a href="javascript:;" class="tabLink" id="cont-3">Résultats</a></li>
              </ul>
              <div class="clear"></div>

              <div class="tabcontent" id="cont-1-1">
                <div class="TabImage">
                  <div class="img1">
                    <figure><img src="/templatemo_473_november/asset/ChatGPT Image 10 févr. 2026, 00 h 07 min 05 s.png" alt="Mission CAPITUNE" /></figure>
                  </div>
                  <div class="img2">
                    <figure><img src="/templatemo_473_november/asset/ChatGPT Image 20 févr. 2026, 08 h 22 min 48 s.png" alt="Accompagnement" /></figure>
                  </div>
                </div>
                <div class="Description">
                  <h3>Un cadre structuré <span>pour avancer avec confiance</span></h3>
                  <p>
                    Nous cadrons votre projet en fonction de votre profil, des programmes disponibles
                    et des exigences administratives à respecter.
                  </p>
                  <p>
                    L’objectif est simple : construire un dossier cohérent, réduire les erreurs et
                    accélérer vos prises de décision à chaque étape.
                  </p>
                </div>
              </div>

              <div class="tabcontent hide" id="cont-2-1">
                <div class="TabImage">
                  <div class="img1">
                    <figure><img src="/templatemo_473_november/asset/ChatGPT Image 20 févr. 2026, 08 h 22 min 48 s.png" alt="Approche CAPITUNE" /></figure>
                  </div>
                  <div class="img2">
                    <figure><img src="/templatemo_473_november/asset/télécharger.png" alt="Méthode" /></figure>
                  </div>
                </div>
                <div class="Description">
                  <h3>Accompagnement opérationnel <span>de l’idée à l’exécution</span></h3>
                  <p>
                    De l’analyse initiale au dépôt, vous bénéficiez d’un suivi continu avec des points
                    d’avancement, des checklists et des validations documentaires.
                  </p>
                  <p>
                    Nous restons disponibles pour répondre à vos questions et ajuster votre stratégie
                    selon les évolutions de votre situation.
                  </p>
                </div>
              </div>

              <div class="tabcontent hide" id="cont-3-1">
                <div class="TabImage">
                  <div class="img1">
                    <figure><img src="/templatemo_473_november/asset/télécharger.png" alt="Résultats" /></figure>
                  </div>
                  <div class="img2">
                    <figure><img src="/templatemo_473_november/asset/ChatGPT Image 10 févr. 2026, 00 h 07 min 05 s.png" alt="Suivi" /></figure>
                  </div>
                </div>
                <div class="Description">
                  <h3>Suivi et intégration <span>au-delà de la soumission</span></h3>
                  <p>
                    Nous vous aidons à suivre les délais, préparer les réponses demandées et organiser
                    votre arrivée pour une intégration plus fluide.
                  </p>
                  <p>
                    CAPITUNE combine conseil, méthode et proximité pour transformer votre projet en plan
                    concret et réalisable.
                  </p>
                </div>
              </div>

              <div class="clear"></div>
            </div>
          </div>
        </div>

        <div class="Services_sec" id="services">
          <div class="Center">
            <h2>Nos services</h2>
            <p>
              Un accompagnement complet pour bâtir, structurer et piloter votre projet Canada avec
              une vision claire et des actions concrètes.
            </p>
            <div class="Line"></div>
            <div class="Serviceside">
              <ul>
                {landingServices.map((service, index) => (
                  <li class={service.liClass}>
                    <a href="#services" class={`service-trigger ${index === 0 ? 'active' : ''}`} data-service={service.key}>
                      <h4>{service.navLabel}</h4>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <div class="service-detail-panels">
              {landingServices.map((service, index) => (
                <article class={`service-panel ${index === 0 ? 'is-visible' : ''}`} data-service-panel={service.key}>
                  <h3>{service.title}</h3>
                  <p>{service.description}</p>
                </article>
              ))}
            </div>
          </div>
        </div>

        <div class="Contact_sec" id="contact">
          <div class="Contactside">
            <div class="Center">
              <h2>Contact</h2>
              <p>Vous avez un projet Canada ? Écrivez-nous et recevez une réponse rapide<br />pour cadrer vos prochaines étapes avec CAPITUNE.</p>
              <div class="Line"></div>
            </div>
          </div>

          <div class="Map" style="width:100%;height:360px;">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=-73.7%2C45.4%2C-73.45%2C45.6&layer=mapnik&marker=45.5017%2C-73.5673"
              width="100%" height="100%"
              style="border:0; display:block;"
              allowfullscreen
              loading="lazy"
              title="CAPITUNE — Montréal, Québec">
            </iframe>
          </div>

          <div class="Get_sec">
            <div class="Mid">
              <div class="Leftside">
                <form action="#">
                  <fieldset>
                    <p><input type="text" value="" placeholder="NOM COMPLET" class="field" /></p>
                    <p><input type="email" value="" placeholder="EMAIL" class="field" /></p>
                    <p><input type="text" value="" placeholder="TYPE DE PROJET" class="field" /></p>
                    <p><textarea cols="2" rows="2" placeholder="DÉCRIVEZ VOTRE BESOIN"></textarea></p>
                    <p><input type="submit" value="Envoyer" class="button" /></p>
                  </fieldset>
                </form>
              </div>

              <div class="Rightside">
                <h3>Parlons de votre projet !</h3>
                <address>
                  {addressLines.map((line, idx) => (
                    <span>
                      {line}
                      {idx < addressLines.length - 1 ? <br /> : null}
                    </span>
                  ))}
                </address>
                <address class="Number">
                  {publicConfig.contactPhone}
                </address>
                <address class="Email">
                  <a href={`mailto:${publicConfig.contactEmail}`}>{publicConfig.contactEmail}</a>
                </address>
                <div class="clear"></div>
                <ul>
                  <li><a href="https://www.facebook.com/profile.php?id=61587490209250&sk=about" target="_blank" rel="noopener"><img src="/templatemo_473_november/img/facebook-icn.png" alt="facebook" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/twitter-icn.png" alt="twitter" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/google-plus-icn.png" alt="google plus" /></a></li>
                </ul>
              </div>
            </div>

            <footer>
              <div class="Cntr">
                <p>© 2026 <strong>CAPITUNE</strong> – Tous droits réservés. | <a href={`${baseUrl}/connexion`} style="color:#a9abad;">Espace Client</a></p>
              </div>
            </footer>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="loader-wrapper">
    <div id="loader"></div>
    <div class="loader-section section-left"></div>
    <div class="loader-section section-right"></div>
  </div>

  <script is:inline src="/templatemo_473_november/js/jquery-1.11.0.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/jquery.sudoSlider.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/global.js"></script>
  <script is:inline src="/templatemo_473_november/js/modernizr.js"></script>
  <script is:inline>
    (() => {
      const initServicePanels = () => {
        const triggers = Array.from(document.querySelectorAll('.service-trigger'));
        const panels = Array.from(document.querySelectorAll('.service-panel'));

        if (!triggers.length || !panels.length) return;

        const showPanel = (serviceKey) => {
          triggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-service') === serviceKey;
            trigger.classList.toggle('active', isActive);
          });

          panels.forEach((panel) => {
            const shouldShow = panel.getAttribute('data-service-panel') === serviceKey;
            panel.classList.toggle('is-visible', shouldShow);
          });
        };

        triggers.forEach((trigger) => {
          trigger.addEventListener('click', (event) => {
            event.preventDefault();
            const serviceKey = trigger.getAttribute('data-service');
            if (!serviceKey) return;
            showPanel(serviceKey);
          });
        });

        const firstService = triggers[0]?.getAttribute('data-service');
        if (firstService) showPanel(firstService);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initServicePanels, { once: true });
      } else {
        initServicePanels();
      }

      document.addEventListener('astro:page-load', initServicePanels);
    })();
  </script>
</MainLayout>

<style is:global>
  #home .leftside {
    width: 34%;
    position: relative;
    z-index: 2;
  }

  #home .leftside h3,
  #home .leftside h3 span {
    white-space: normal !important;
    text-wrap: pretty;
    line-height: 1.1;
  }

  #home .rightside {
    width: 62%;
    transform: translateX(52px);
  }

  #home .rightside .Slider figure img {
    width: 100%;
    height: 500px;
    object-fit: cover;
  }

  /* TabImage superposition fix */
  .About_sec .Tabside .TabImage { height: 320px !important; }
  .About_sec .Tabside .TabImage .img1 img,
  .About_sec .Tabside .TabImage .img2 img {
    width: 300px !important;
    height: auto !important;
    max-height: none !important;
    object-fit: unset !important;
    border: 4px solid #fff !important;
    box-shadow: 0 10px 32px rgba(0,0,0,0.22);
    border-radius: 4px;
  }
  .About_sec .Tabside .TabImage .img1 { animation: tabimg-swap-a 6s ease-in-out infinite alternate; }
  .About_sec .Tabside .TabImage .img2 { animation: tabimg-swap-b 6s ease-in-out infinite alternate; }
  @keyframes tabimg-swap-a {
    0%   { z-index:2; transform: scale(1)    translateY(0px);  opacity:1;    }
    42%  { z-index:2; transform: scale(1.04) translateY(-8px); opacity:1;    }
    52%  { z-index:1;                                           opacity:0.78; }
    100% { z-index:1; transform: scale(1)    translateY(0px);  opacity:0.78; }
  }
  @keyframes tabimg-swap-b {
    0%   { z-index:1; transform: scale(1)    translateY(0px);  opacity:0.78; }
    48%  { z-index:1;                                           opacity:0.78; }
    58%  { z-index:2; transform: scale(1.04) translateY(-8px); opacity:1;    }
    100% { z-index:2; transform: scale(1)    translateY(0px);  opacity:1;    }
  }

  #home .leftside a.secondary-cta {
    margin-left: 10px;
    background: transparent;
    border: 1px solid #ffffff;
    color: #ffffff;
  }

  #home .leftside a.secondary-cta:hover {
    background: #ffffff;
    color: #222;
  }

  #services .service-detail-panels {
    margin-top: 34px;
    min-height: 170px;
    position: relative;
  }

  #services .service-panel {
    display: none;
    opacity: 0;
    transform: translateY(16px) scale(0.98);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 10px;
    padding: 26px;
    backdrop-filter: blur(2px);
    transition: opacity 360ms ease, transform 360ms ease;
  }

  #services .service-panel.is-visible {
    display: block;
    opacity: 1;
    transform: translateY(0) scale(1);
    animation: servicePanelIn 360ms ease;
  }

  #services .service-panel h3 {
    white-space: normal !important;
    color: #ffffff;
    font-size: 28px;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  #services .service-panel p {
    color: rgba(255, 255, 255, 0.92);
    font-size: 16px;
    line-height: 1.65;
    margin: 0;
  }

  #services .service-trigger.active h4 {
    color: #ff9000;
  }

  @keyframes servicePanelIn {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  #contact .Get_sec .Leftside fieldset .button {
    text-transform: none;
  }

  #contact .Get_sec .Leftside input.field,
  #contact .Get_sec .Leftside textarea {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(15, 23, 42, 0.25);
    color: #0f172a !important;
    font-weight: 600;
  }

  #contact .Get_sec .Leftside input.field::placeholder,
  #contact .Get_sec .Leftside textarea::placeholder {
    color: #334155;
    opacity: 0.9;
  }

  #contact .Get_sec .Leftside input.field:focus,
  #contact .Get_sec .Leftside textarea:focus {
    background: #ffffff;
    border-color: #f88e04;
    box-shadow: 0 0 0 2px rgba(248, 142, 4, 0.15);
  }

  @media (max-width: 1200px) {
    #home .rightside {
      transform: none;
    }

    #services .service-panel {
      padding: 18px;
    }

    #services .service-panel h3 {
      font-size: 22px;
    }
  }
</style>
