---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
---

<MainLayout>
  <link rel="stylesheet" href="/templatemo_473_november/css/theme.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/media.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/font-awesome.min.css" />
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,300,600,600italic,400italic,800,700" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Oswald:400,700,300" rel="stylesheet" type="text/css" />

  <div class="DesignHolder">
    <div class="LayoutFrame">
      <header>
        <div class="Center">
          <div class="site-logo">
            <h1><a href={`${baseUrl}/`}>CAPI<span>TUNE</span></a></h1>
          </div>
          <div id="mobile_sec">
            <div class="mobile"><i class="fa fa-bars"></i><i class="fa fa-times"></i></div>
            <div class="menumobile">
              <nav class="Navigation">
                <ul>
                  <li class="active"><a href="#home">Accueil</a><span class="menu-item-bg"></span></li>
                  <li><a href="#about">À propos</a><span class="menu-item-bg"></span></li>
                  <li><a href="#services">Services</a><span class="menu-item-bg"></span></li>
                  <li><a href="#contact">Contact</a><span class="menu-item-bg"></span></li>
                  <li><a href={`${baseUrl}/connexion`}>Connexion</a><span class="menu-item-bg"></span></li>
                </ul>
              </nav>
            </div>
          </div>
          <div class="clear"></div>
        </div>
      </header>

      <div class="Banner_sec" id="home">
        <div class="bannerside">
          <div class="Center">
            <div class="leftside">
              <h3>Votre projet<span>Canada avec CAPITUNE</span></h3>
              <p>
                CAPITUNE vous accompagne dans l’analyse de votre projet, la préparation du dossier,
                le suivi administratif et votre intégration au Canada.
              </p>
              <a href="#about">DÉCOUVRIR</a>
              <a href={`${baseUrl}/contact`} class="secondary-cta">NOUS CONTACTER</a>
            </div>
            <div class="rightside">
              <ul id="slider">
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/img/Slider-img1.jpg" alt="CAPITUNE accompagnement" /></figure>
                    <div class="text">
                      <div class="Icon">
                        <ul>
                          <li><a href="#services"><i class="fa fa-check"></i>Projet</a></li>
                          <li><a href="#contact"><i class="fa fa-commenting"></i>Conseil</a></li>
                        </ul>
                      </div>
                      <div class="Lorem">
                        <p>Analyse stratégique <span>et plan d’action personnalisé</span></p>
                      </div>
                    </div>
                  </div>
                </li>
                <li>
                  <div class="Slider">
                    <figure><img src="/templatemo_473_november/img/Slider-img2.jpg" alt="CAPITUNE suivi" /></figure>
                    <div class="text">
                      <div class="Icon">
                        <ul>
                          <li><a href="#services"><i class="fa fa-file-text-o"></i>Dossier</a></li>
                          <li><a href="#contact"><i class="fa fa-phone"></i>Support</a></li>
                        </ul>
                      </div>
                      <div class="Lorem">
                        <p>Montage complet <span>et suivi de votre dossier</span></p>
                      </div>
                    </div>
                  </div>
                </li>
              </ul>
              <figure><img src="/templatemo_473_november/img/Shadow-img.png" alt="shadow" class="Shadow" /></figure>
            </div>
          </div>
        </div>
        <div class="clear"></div>
      </div>

      <div class="bgcolor"></div>

      <div id="Container">
        <div class="About_sec" id="about">
          <div class="Center">
            <h2>À propos de CAPITUNE</h2>
            <p>
              Une initiative d’Export Monde Prestige Inc. pour structurer votre projet Canada avec
              un accompagnement clair, professionnel et centré sur vos objectifs.
            </p>
            <div class="Line"></div>

            <div class="Tabside">
              <ul>
                <li><a href="javascript:;" class="tabLink activeLink" id="cont-1">Mission</a></li>
                <li><a href="javascript:;" class="tabLink" id="cont-2">Approche</a></li>
                <li><a href="javascript:;" class="tabLink" id="cont-3">Résultats</a></li>
              </ul>
              <div class="clear"></div>

              <div class="tabcontent" id="cont-1-1">
                <div class="TabImage">
                  <div class="img1">
                    <figure><img src="/templatemo_473_november/img/about-img2.jpg" alt="Mission" /></figure>
                  </div>
                  <div class="img2">
                    <figure><img src="/templatemo_473_november/img/about-img1.jpg" alt="Accompagnement" /></figure>
                  </div>
                </div>
                <div class="Description">
                  <h3>Un cadre structuré <span>pour avancer avec confiance</span></h3>
                  <p>
                    Nous cadrons votre projet en fonction de votre profil, des programmes disponibles
                    et des exigences administratives à respecter.
                  </p>
                  <p>
                    L’objectif est simple : construire un dossier cohérent, réduire les erreurs et
                    accélérer vos prises de décision à chaque étape.
                  </p>
                </div>
              </div>

              <div class="tabcontent hide" id="cont-2-1">
                <div class="TabImage">
                  <div class="img1">
                    <figure><img src="/templatemo_473_november/img/about-img2.jpg" alt="Approche" /></figure>
                  </div>
                  <div class="img2">
                    <figure><img src="/templatemo_473_november/img/about-img1.jpg" alt="Méthode" /></figure>
                  </div>
                </div>
                <div class="Description">
                  <h3>Accompagnement opérationnel <span>de l’idée à l’exécution</span></h3>
                  <p>
                    De l’analyse initiale au dépôt, vous bénéficiez d’un suivi continu avec des points
                    d’avancement, des checklists et des validations documentaires.
                  </p>
                  <p>
                    Nous restons disponibles pour répondre à vos questions et ajuster votre stratégie
                    selon les évolutions de votre situation.
                  </p>
                </div>
              </div>

              <div class="tabcontent hide" id="cont-3-1">
                <div class="TabImage">
                  <div class="img1">
                    <figure><img src="/templatemo_473_november/img/about-img2.jpg" alt="Résultats" /></figure>
                  </div>
                  <div class="img2">
                    <figure><img src="/templatemo_473_november/img/about-img1.jpg" alt="Suivi" /></figure>
                  </div>
                </div>
                <div class="Description">
                  <h3>Suivi et intégration <span>au-delà de la soumission</span></h3>
                  <p>
                    Nous vous aidons à suivre les délais, préparer les réponses demandées et organiser
                    votre arrivée pour une intégration plus fluide.
                  </p>
                  <p>
                    CAPITUNE combine conseil, méthode et proximité pour transformer votre projet en plan
                    concret et réalisable.
                  </p>
                </div>
              </div>

              <div class="clear"></div>
            </div>
          </div>
        </div>

        <div class="Services_sec" id="services">
          <div class="Center">
            <h2>Nos services</h2>
            <p>
              Un accompagnement complet pour bâtir, structurer et piloter votre projet Canada avec
              une vision claire et des actions concrètes.
            </p>
            <div class="Line"></div>
            <div class="Serviceside">
              <ul>
                <li class="Development"><a href="#services"><h4>ANALYSE DU PROJET</h4></a></li>
                <li class="Desdin"><a href="#services"><h4>MONTAGE DU DOSSIER</h4></a></li>
                <li class="Concept"><a href="#services"><h4>SUIVI ADMINISTRATIF</h4></a></li>
                <li class="System"><a href="#services"><h4>INTÉGRATION</h4></a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="Contact_sec" id="contact">
          <div class="Contactside">
            <div class="Center">
              <h2>Contact</h2>
              <p>
                Vous avez un projet Canada ? Écrivez-nous et recevez une réponse rapide pour cadrer
                vos prochaines étapes.
              </p>
              <div class="Line"></div>
            </div>
          </div>

          <div class="Get_sec">
            <div class="Mid">
              <div class="Leftside">
                <form action="#">
                  <fieldset>
                    <p><input type="text" value="" placeholder="NOM COMPLET" class="field" /></p>
                    <p><input type="email" value="" placeholder="EMAIL" class="field" /></p>
                    <p><input type="text" value="" placeholder="TYPE DE PROJET" class="field" /></p>
                    <p><textarea cols="2" rows="2" placeholder="DÉCRIVEZ VOTRE BESOIN"></textarea></p>
                    <p><input type="submit" value="Envoyer" class="button" /></p>
                  </fieldset>
                </form>
              </div>

              <div class="Rightside">
                <h3>Parlons de votre projet</h3>
                <address>
                  CAPITUNE – Export Monde Prestige Inc.<br />
                  Montréal, Québec, Canada.
                </address>
                <address class="Number">
                  +1 (514) 123-4567<br />
                  Support du lundi au vendredi
                </address>
                <address class="Email">
                  <a href="mailto:contact@capitune.com">contact@capitune.com</a>
                </address>
                <div class="clear"></div>
                <ul>
                  <li><a href="#"><img src="/templatemo_473_november/img/facebook-icn.png" alt="facebook" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/twitter-icn.png" alt="twitter" /></a></li>
                  <li><a href="#"><img src="/templatemo_473_november/img/google-plus-icn.png" alt="google plus" /></a></li>
                </ul>
              </div>
            </div>

            <footer>
              <div class="Cntr">
                <p>© {new Date().getFullYear()} CAPITUNE – Tous droits réservés.</p>
              </div>
            </footer>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="loader-wrapper">
    <div id="loader"></div>
    <div class="loader-section section-left"></div>
    <div class="loader-section section-right"></div>
  </div>

  <script is:inline src="/templatemo_473_november/js/jquery-1.11.0.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/jquery.sudoSlider.min.js"></script>
  <script is:inline src="/templatemo_473_november/js/global.js"></script>
  <script is:inline src="/templatemo_473_november/js/modernizr.js"></script>
</MainLayout>

<style is:global>
  #home .leftside a.secondary-cta {
    margin-left: 10px;
    background: transparent;
    border: 1px solid #ffffff;
    color: #ffffff;
  }

  #home .leftside a.secondary-cta:hover {
    background: #ffffff;
    color: #222;
  }

  #contact .Get_sec .Leftside fieldset .button {
    text-transform: none;
  }
</style>
