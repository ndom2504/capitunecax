---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
import '../styles/auth.css';
---

<MainLayout>
<div class="auth-root">

  <!-- ── Panneau gauche : branding ── -->
  <div class="auth-panel-left">
    <a href={`${baseUrl}/`} class="auth-brand">
      <img src="/logo/capitune.png" alt="CAPITUNE" style="height:44px; width:auto; display:block; margin-bottom:10px;" />
      <span class="auth-brand-sub">Votre partenaire de confiance pour votre projet au Canada</span>
    </a>

    <div class="auth-benefits">
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Suivi de dossier en temps réel</div>
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Accès sécurisé à vos documents</div>
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Messagerie et rendez-vous</div>
      <div class="auth-benefit"><span class="auth-benefit-icon">✓</span>Gestion des paiements</div>
    </div>

    <div class="auth-left-footer">
      <a href={`${baseUrl}/`}>Accueil</a>
      <a href={`${baseUrl}/a-propos`}>À Propos</a>
      <a href={`${baseUrl}/contact`}>Contact</a>
    </div>
  </div>

  <!-- ── Panneau droit : formulaire ── -->
  <div class="auth-panel-right">
    <div class="auth-form-wrap">

      <div class="auth-form-header">
        <h1 class="auth-form-title">Connexion</h1>
        <p class="auth-form-sub">Connectez-vous à votre espace Capitune.</p>
      </div>

      <!-- Erreur / Succès -->
      <div class="auth-alert auth-alert--error" id="loginError">
        <span class="auth-alert-icon">⚠</span>
        <span id="loginErrorMsg">Email ou mot de passe incorrect.</span>
      </div>
      <div class="auth-alert auth-alert--success" id="loginSuccess" style="display:none;">
        <span class="auth-alert-icon">✓</span>
        <span id="loginSuccessMsg"></span>
      </div>

      <!-- Notice email non vérifié -->
      <div id="verify-email-notice" style="display:none;" class="auth-alert auth-alert--warning">
        <p style="margin:0 0 6px;font-weight:700;font-size:13px;">📧 Courriel non vérifié</p>
        <p style="margin:0 0 10px;font-size:13px;">Email envoyé à <strong id="unverified-email-label"></strong> — cliquez sur le lien de confirmation.</p>
        <button id="resend-verify-btn" class="auth-resend-btn" type="button">
          <span id="resend-verify-icon">↺</span> Renvoyer l'email
        </button>
        <span id="resend-verify-msg" style="font-size:12px;margin-left:10px;vertical-align:middle;"></span>
      </div>

      <!-- Sélecteur type de compte -->
      <div class="auth-type-picker">
        <label class="auth-type-option">
          <input type="radio" name="accountType" value="client" checked />
          <span class="auth-type-label">
            <strong>Particulier</strong>
            <small>Demande de service</small>
          </span>
        </label>
        <label class="auth-type-option">
          <input type="radio" name="accountType" value="pro" />
          <span class="auth-type-label">
            <strong>Professionnel</strong>
            <small>Offre de service</small>
          </span>
        </label>
      </div>

      <!-- Formulaire -->
      <form id="loginForm" class="auth-form">
        <div class="auth-field-group">
          <label class="auth-label">Email</label>
          <input type="email" id="email" required placeholder="votre@email.com" class="auth-input" />
        </div>
        <div class="auth-field-group">
          <label class="auth-label">Mot de passe</label>
          <input type="password" id="password" required placeholder="••••••••" class="auth-input" />
        </div>
        <div class="auth-row-between">
          <label class="auth-check-wrap">
            <input type="checkbox" class="auth-checkbox" />
            <span>Se souvenir de moi</span>
          </label>
          <a href="#" class="auth-link-muted">Mot de passe oublié ?</a>
        </div>
        <button type="submit" class="auth-btn-primary">Se connecter →</button>
      </form>

      <p class="auth-switch">Pas de compte ? <a href={`${baseUrl}/inscription`} class="auth-link-orange">Créer un compte</a></p>

      <div class="auth-divider"><span>ou continuer avec</span></div>

      <div class="auth-social-row">
        <button type="button" id="googleLoginBtn" class="auth-social-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Google
        </button>
        <button type="button" id="microsoftLoginBtn" class="auth-social-btn">
          <svg width="18" height="18" viewBox="0 0 23 23" aria-hidden="true">
            <path fill="#f35325" d="M1 1h10v10H1z"/>
            <path fill="#81bc06" d="M12 1h10v10H12z"/>
            <path fill="#05a6f0" d="M1 12h10v10H1z"/>
            <path fill="#ffba08" d="M12 12h10v10H12z"/>
          </svg>
          Microsoft
        </button>
      </div>

    </div>
  </div>

</div>
</MainLayout>

<script>
  const getSelectedAccountType = () => {
    return (document.querySelector('input[name="accountType"]:checked') as HTMLInputElement | null)?.value || 'client';
  };

  const errorEl = document.getElementById('loginError');
  const showError = (message: string) => {
    if (!errorEl) return;
    const msgEl = document.getElementById('loginErrorMsg');
    if (msgEl) msgEl.textContent = message;
    errorEl.classList.add('show');
  };
  const hideError = () => {
    if (!errorEl) return;
    errorEl.classList.remove('show');
  };

  // Afficher les erreurs OAuth depuis l'URL (?error=)
  const params = new URLSearchParams(window.location.search);
  const oauthError = params.get('error');

  // Gestion ?verified=1 et ?verify_error=* (retour de /api/verify-email)
  const verifiedParam = params.get('verified');
  const verifyErrorParam = params.get('verify_error');
  const loginSuccessEl = document.getElementById('loginSuccess');
  const loginSuccessMsgEl = document.getElementById('loginSuccessMsg');
  if (verifiedParam === '1') {
    if (loginSuccessEl) (loginSuccessEl as HTMLElement).style.display = 'block';
    if (loginSuccessMsgEl) loginSuccessMsgEl.textContent = 'Compte vérifié avec succès ! Vous pouvez maintenant vous connecter.';
  } else if (verifiedParam === 'deja') {
    if (loginSuccessEl) (loginSuccessEl as HTMLElement).style.display = 'block';
    if (loginSuccessMsgEl) loginSuccessMsgEl.textContent = 'Votre compte est déjà vérifié. Connectez-vous ci-dessous.';
  } else if (verifyErrorParam === 'lien_expire') {
    showError('Ce lien de vérification est expiré. Reconnectez-vous pour en recevoir un nouveau.');
  } else if (verifyErrorParam) {
    showError('Lien de vérification invalide. Réessayez ou contactez le support.');
  }
  if (oauthError === 'OAuthAccountNotLinked') {
    showError('Ce compte est déjà associé à une autre méthode de connexion.');
  } else if (oauthError === 'access_denied') {
    showError('Accès refusé. Veuillez réessayer.');
  } else if (oauthError === 'InvalidState') {
    showError('Erreur de sécurité (CSRF). Veuillez réessayer.');
  } else if (oauthError === 'MissingEmail') {
    showError("Impossible de récupérer votre email depuis le fournisseur. Vérifiez que l'accès à l'email est autorisé et réessayez.");
  } else if (oauthError === 'MissingDatabaseUrl') {
    showError("Base de données non configurée (DATABASE_URL manquant). Ajoutez la variable d'environnement puis réessayez.");
  } else if (oauthError === 'DatabaseNotInitialized') {
    showError("Base de données configurée mais non initialisée (tables manquantes). Initialisez le schéma puis réessayez.");
  } else if (oauthError === 'CallbackErrorGoogle') {
    showError("Erreur serveur lors du retour Google. Réessayez dans quelques secondes (ou vérifiez les logs de déploiement).");
  } else if (oauthError === 'CallbackErrorMicrosoft') {
    showError("Erreur serveur lors du retour Microsoft. Réessayez dans quelques secondes (ou vérifiez les logs de déploiement).");
  } else if (oauthError?.includes('Configuration')) {
    showError(decodeURIComponent(oauthError));
  } else if (oauthError) {
    showError(`Erreur de connexion : ${decodeURIComponent(oauthError)}`);
  }

  // Connexion Google — navigation directe vers le handler GET
  document.getElementById('googleLoginBtn')?.addEventListener('click', () => {
    const t = getSelectedAccountType();
    window.location.href = `/api/oauth/signin/google?accountType=${encodeURIComponent(t)}`;
  });

  // Connexion Microsoft — navigation directe vers le handler GET
  document.getElementById('microsoftLoginBtn')?.addEventListener('click', () => {
    const t = getSelectedAccountType();
    window.location.href = `/api/oauth/signin/microsoft?accountType=${encodeURIComponent(t)}`;
  });

  // Connexion par email/mot de passe
  document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const email = (document.getElementById('email') as HTMLInputElement)?.value;
    const password = (document.getElementById('password') as HTMLInputElement)?.value;
    const accountType = getSelectedAccountType();

    try {
      const res = await fetch('/api/oauth/signin/credentials', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ email, password, accountType }),
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        if ((data as Record<string, unknown>).email_not_verified) {
          const notice = document.getElementById('verify-email-notice') as HTMLElement | null;
          const emailLbl = document.getElementById('unverified-email-label') as HTMLElement | null;
          if (notice) notice.style.display = 'block';
          if (emailLbl) emailLbl.textContent = (data as Record<string, string>).email || email;
          (window as unknown as Record<string, unknown>)._unverifiedEmail = (data as Record<string, string>).email || email;
          return;
        }
        showError((data as { message?: string })?.message || 'Email ou mot de passe incorrect.');
        return;
      }

      window.location.href = '/dashboard';
    } catch (err) {
      showError('Une erreur est survenue. Réessayez.');
    }
  });

  // Bouton renvoi de l'email de vérification
  async function resendVerifyEmail() {
    const unverifiedEmail = ((window as any)._unverifiedEmail as string)
      || (document.getElementById('email') as HTMLInputElement)?.value || '';
    const btn = document.getElementById('resend-verify-btn') as HTMLButtonElement | null;
    const icon = document.getElementById('resend-verify-icon') as HTMLElement | null;
    const msg = document.getElementById('resend-verify-msg') as HTMLElement | null;
    if (!unverifiedEmail || !btn) return;
    btn.disabled = true;
    if (icon) icon.className = 'fa fa-spinner fa-spin';
    if (msg) { msg.style.color = '#888'; msg.textContent = 'Envoi…'; }
    try {
      const res = await fetch('/api/resend-verification', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: unverifiedEmail }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        if (msg) { msg.style.color = '#27ae60'; msg.textContent = '✓ Email envoyé !'; }
      } else {
        if (msg) { msg.style.color = '#e74c3c'; msg.textContent = (data as Record<string, string>).error || 'Erreur.'; }
        btn.disabled = false;
        if (icon) icon.className = 'fa fa-refresh';
      }
    } catch {
      if (msg) { msg.style.color = '#e74c3c'; msg.textContent = 'Erreur réseau.'; }
      btn.disabled = false;
      if (icon) icon.className = 'fa fa-refresh';
    }
  }
  (window as any).resendVerifyEmail = resendVerifyEmail;
  document.getElementById('resend-verify-btn')?.addEventListener('click', resendVerifyEmail);
</script>

<style is:global>
/* styles importés via src/styles/auth.css */
</style>
