---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
---

<MainLayout>
  <link rel="stylesheet" href="/templatemo_473_november/css/theme.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/media.css" />
  <link rel="stylesheet" href="/templatemo_473_november/css/font-awesome.min.css" />
  <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,300,600,600italic,400italic,800,700" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/css?family=Oswald:400,700,300" rel="stylesheet" type="text/css" />

  <div class="DesignHolder auth-page">
    <div class="LayoutFrame">
      <header class="auth-header">
        <div class="Center">
          <div class="site-logo">
            <a href={`${baseUrl}/`}><img src="/templatemo_473_november/logo/Logo%20moderne%20de%20CAPITUNE%20avec%20halo%20lumineux.png" alt="CAPITUNE" /></a>
          </div>
          <nav class="Navigation auth-nav">
            <ul>
              <li><a href={`${baseUrl}/`}>Accueil</a></li>
              <li class="active"><a href={`${baseUrl}/connexion`}>Connexion</a></li>
              <li><a href={`${baseUrl}/inscription`}>Inscription</a></li>
            </ul>
          </nav>
          <div class="clear"></div>
        </div>
      </header>

      <section class="AuthHero_sec">
        <div class="Center">
          <h1>Connexion À Votre Espace Client</h1>
          <p>Accédez à votre suivi, vos documents et vos échanges avec CAPITUNE.</p>
        </div>
      </section>

      <section class="Get_sec auth-sec">
        <div class="Mid">
          <div class="Leftside auth-form-side">
            <div class="auth-error" id="loginError">
              <i class="fa fa-exclamation-circle"></i> Email ou mot de passe incorrect.
            </div>

            <form id="loginForm">
              <fieldset>
                <p><input type="email" id="email" required placeholder="EMAIL" class="field" /></p>
                <p><input type="password" id="password" required placeholder="MOT DE PASSE" class="field" /></p>

                <p class="auth-row">
                  <label class="remember-wrap">
                    <input type="checkbox" class="remember-check" />
                    <span>Se Souvenir De Moi</span>
                  </label>
                  <a href="#" class="forgot-link">Mot De Passe Oublié ?</a>
                </p>

                <p><input type="submit" value="Se Connecter" class="button" /></p>
              </fieldset>
            </form>

            <div class="auth-subline">
              <p>Vous N'avez Pas De Compte ? <a href={`${baseUrl}/inscription`}>Créer Un Compte</a></p>
            </div>

            <div class="auth-divider"><span>Ou Via</span></div>

            <div class="auth-social-grid">
              <button type="button" id="googleLoginBtn" class="auth-social-btn">
                <svg class="auth-social-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                <span>Google</span>
              </button>

              <button type="button" id="microsoftLoginBtn" class="auth-social-btn">
                <svg class="auth-social-icon" viewBox="0 0 23 23" aria-hidden="true">
                  <path fill="#f35325" d="M1 1h10v10H1z"/>
                  <path fill="#81bc06" d="M12 1h10v10H12z"/>
                  <path fill="#05a6f0" d="M1 12h10v10H1z"/>
                  <path fill="#ffba08" d="M12 12h10v10H12z"/>
                </svg>
                <span>Microsoft</span>
              </button>
            </div>
          </div>

          <div class="Rightside auth-info-side">
            <h3>Pourquoi Vous Connecter ?</h3>
            <address><i class="fa fa-check" style="color:#ff9408;margin-right:10px;"></i>Suivi de dossier en temps réel</address>
            <address class="Number"><i class="fa fa-check" style="color:#ff9408;margin-right:10px;"></i>Accès sécurisé à vos documents</address>
            <address class="Number"><i class="fa fa-check" style="color:#ff9408;margin-right:10px;"></i>Messagerie et rendez-vous</address>
            <address class="Number"><i class="fa fa-check" style="color:#ff9408;margin-right:10px;"></i>Gestion des paiements</address>
            <address class="Email"><a href={`${baseUrl}/inscription`}>Pas encore de compte ? →</a></address>
          </div>
        </div>
      </section>
    </div>
  </div>
</MainLayout>

<script>
  const errorEl = document.getElementById('loginError');
  const showError = (message: string) => {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.classList.add('show');
  };
  const hideError = () => {
    if (!errorEl) return;
    errorEl.classList.remove('show');
  };

  // Afficher les erreurs OAuth depuis l'URL (?error=)
  const params = new URLSearchParams(window.location.search);
  const oauthError = params.get('error');
  if (oauthError === 'OAuthAccountNotLinked') {
    showError('Ce compte est déjà associé à une autre méthode de connexion.');
  } else if (oauthError === 'access_denied') {
    showError('Accès refusé. Veuillez réessayer.');
  } else if (oauthError === 'InvalidState') {
    showError('Erreur de sécurité (CSRF). Veuillez réessayer.');
  } else if (oauthError === 'MissingEmail') {
    showError("Impossible de récupérer votre email depuis le fournisseur. Vérifiez que l'accès à l'email est autorisé et réessayez.");
  } else if (oauthError === 'MissingDatabaseUrl') {
    showError("Base de données non configurée (DATABASE_URL manquant). Ajoutez la variable d'environnement puis réessayez.");
  } else if (oauthError === 'DatabaseNotInitialized') {
    showError("Base de données configurée mais non initialisée (tables manquantes). Initialisez le schéma puis réessayez.");
  } else if (oauthError === 'CallbackErrorGoogle') {
    showError("Erreur serveur lors du retour Google. Réessayez dans quelques secondes (ou vérifiez les logs de déploiement).");
  } else if (oauthError === 'CallbackErrorMicrosoft') {
    showError("Erreur serveur lors du retour Microsoft. Réessayez dans quelques secondes (ou vérifiez les logs de déploiement).");
  } else if (oauthError?.includes('Configuration')) {
    showError(decodeURIComponent(oauthError));
  } else if (oauthError) {
    showError(`Erreur de connexion : ${decodeURIComponent(oauthError)}`);
  }

  // Connexion Google — navigation directe vers le handler GET
  document.getElementById('googleLoginBtn')?.addEventListener('click', () => {
    window.location.href = '/api/oauth/signin/google';
  });

  // Connexion Microsoft — navigation directe vers le handler GET
  document.getElementById('microsoftLoginBtn')?.addEventListener('click', () => {
    window.location.href = '/api/oauth/signin/microsoft';
  });

  // Connexion par email/mot de passe
  document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const email = (document.getElementById('email') as HTMLInputElement)?.value;
    const password = (document.getElementById('password') as HTMLInputElement)?.value;

    try {
      const res = await fetch('/api/oauth/signin/credentials', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ email, password }),
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        showError((data as { message?: string })?.message || 'Email ou mot de passe incorrect.');
        return;
      }

      window.location.href = '/dashboard';
    } catch (err) {
      showError('Une erreur est survenue. Réessayez.');
    }
  });
</script>

<style is:global>
  .auth-page {
    background: #1f4b6e;
    min-height: 100vh;
  }

  .auth-header {
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(0,0,0,0.35) !important;
  }

  .site-logo a { display:inline-block; line-height:0; }
  .site-logo img { height: 64px; width: auto; display:block; }
  header.auth-header .site-logo { padding: 0 !important; height: 105px; display:flex; align-items:center; }
  header.auth-header.smaller .site-logo { height: 60px; }
  header.auth-header.smaller .site-logo img { height: 36px; }

  .auth-error {
    background: rgba(231,76,60,0.15);
    border: 1px solid rgba(231,76,60,0.4);
    color: #ff6b6b;
    padding: 10px 14px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 14px;
    display: none;
  }
  .auth-error.show { display: block; }

  .auth-nav {
    float: right;
    margin-top: 20px;
  }

  .auth-nav ul {
    display: flex;
    gap: 18px;
  }

  .auth-nav ul li a {
    color: #fff;
    font-size: 14px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .AuthHero_sec {
    padding: 86px 0 36px;
    text-align: center;
  }

  .AuthHero_sec h1 {
    color: #fff;
    font-family: 'Oswald', sans-serif;
    font-size: 52px;
    line-height: 1.05;
    white-space: normal !important;
    margin-bottom: 18px;
  }

  .AuthHero_sec p {
    color: #e8edf3;
    font-size: 20px;
    max-width: 760px;
    margin: 0 auto;
  }

  .auth-sec {
    background: url('/templatemo_473_november/img/Get-bg.jpg') center center no-repeat;
    background-size: cover;
  }

  .auth-form-side {
    width: 54% !important;
  }

  .auth-info-side {
    width: 40% !important;
  }

  .auth-form-side .field {
    background: rgba(255, 255, 255, 0.95) !important;
    color: #102a43 !important;
    font-weight: 600;
    border: 1px solid rgba(16, 42, 67, 0.18) !important;
  }

  .auth-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .remember-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    font-size: 13px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .remember-check {
    width: 14px;
    height: 14px;
  }

  .forgot-link {
    color: #ffb049;
    font-size: 13px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .auth-subline {
    margin-top: 10px;
    text-align: center;
  }

  .auth-subline p {
    color: #d9e4ef;
    font-size: 14px;
  }

  .auth-subline a {
    color: #ffb049;
    font-weight: 700;
  }

  .auth-divider {
    margin: 20px 0 18px;
    text-align: center;
    position: relative;
  }

  .auth-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.22);
  }

  .auth-divider span {
    position: relative;
    z-index: 1;
    color: #fff;
    background: rgba(20, 55, 84, 0.75);
    padding: 0 14px;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 700;
  }

  .auth-social-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .auth-social-btn {
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    transition: all 0.25s ease;
  }

  .auth-social-btn:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .auth-social-icon {
    width: 18px;
    height: 18px;
  }

  .auth-info-side h3 {
    font-size: 44px !important;
    line-height: 1.03 !important;
    white-space: normal !important;
    padding-bottom: 24px !important;
  }

  @media (max-width: 980px) {
    .auth-nav {
      float: none;
      margin: 14px 0 18px;
    }

    .auth-nav ul {
      justify-content: center;
      flex-wrap: wrap;
    }

    .AuthHero_sec h1 {
      font-size: 38px;
    }

    .AuthHero_sec p {
      font-size: 17px;
      padding: 0 12px;
    }

    .auth-form-side,
    .auth-info-side {
      width: 100% !important;
    }

    .auth-social-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
