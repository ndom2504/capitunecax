---
import MainLayout from '../layouts/main.astro'
import { getUserFromSessionFullAny } from '../lib/auth'

const user = await getUserFromSessionFullAny(Astro.cookies)

// Rediriger si non connecté
if (!user) {
  return Astro.redirect('/connexion')
}

// Vérifier si c'est un client
if (user.account_type === 'pro' || user.email?.includes('@capitune.com')) {
  return Astro.redirect('/admin')
}
---

<MainLayout title="Équipe - Capitune">
  <main class="team-page">
    <!-- Header -->
    <section class="page-header">
      <div class="container">
        <div class="header-content">
          <div class="breadcrumb">
            <a href="/projets">Mes Projets</a>
            <span>/</span>
            <span>Choisir un conseiller</span>
          </div>
          <h1>Choisissez votre conseiller</h1>
          <p>Nos experts vous accompagnent dans votre projet d'immigration</p>
        </div>
      </div>
    </section>

    <!-- Filters -->
    <section class="filters-section">
      <div class="container">
        <div class="filters-grid">
          <div class="filter-group">
            <label>Spécialité</label>
            <select id="specialtyFilter" onchange="filterAdvisors()">
              <option value="">Toutes les spécialités</option>
              <option value="travail">Immigration Travail</option>
              <option value="etudes">Immigration Études</option>
              <option value="famille">Immigration Famille</option>
              <option value="affaires">Immigration Affaires</option>
              <option value="residence">Résidence Permanente</option>
            </select>
          </div>
          
          <div class="filter-group">
            <label>Langues</label>
            <select id="languageFilter" onchange="filterAdvisors()">
              <option value="">Toutes les langues</option>
              <option value="francais">Français</option>
              <option value="anglais">Anglais</option>
              <option value="espagnol">Espagnol</option>
              <option value="arabe">Arabe</option>
            </select>
          </div>

          <div class="filter-group">
            <label>Disponibilité</label>
            <select id="availabilityFilter" onchange="filterAdvisors()">
              <option value="">Toutes les disponibilités</option>
              <option value="immediate">Immédiate</option>
              <option value="week">Cette semaine</option>
              <option value="month">Ce mois-ci</option>
            </select>
          </div>

          <div class="filter-group">
            <label>Tarif</label>
            <select id="priceFilter" onchange="filterAdvisors()">
              <option value="">Tous les tarifs</option>
              <option value="economy">Économique</option>
              <option value="standard">Standard</option>
              <option value="premium">Premium</option>
            </select>
          </div>
        </div>
      </div>
    </section>

    <!-- Advisors Grid -->
    <section class="advisors-section">
      <div class="container">
        <div class="section-header">
          <h2>Nos conseillers disponibles</h2>
          <div class="results-count">
            <span id="resultsCount">12 conseillers trouvés</span>
          </div>
        </div>

        <div id="advisorsGrid" class="advisors-grid">
          <!-- Advisors will be loaded here -->
        </div>

        <!-- Load More -->
        <div class="load-more-container">
          <button id="loadMoreBtn" class="btn-secondary" onclick="loadMoreAdvisors()">
            Charger plus de conseillers
          </button>
        </div>
      </div>
    </section>

    <!-- Contact Modal -->
    <div id="contactModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Contacter un conseiller</h2>
          <button class="close-btn" onclick="closeContactModal()">&times;</button>
        </div>
        <div class="modal-body">
          <div class="advisor-preview">
            <div class="advisor-info">
              <img id="modalAdvisorAvatar" src="" alt="" class="advisor-avatar">
              <div class="advisor-details">
                <h3 id="modalAdvisorName"></h3>
                <p id="modalAdvisorTitle"></p>
                <div class="advisor-meta">
                  <span id="modalAdvisorSpecialty"></span>
                  <span id="modalAdvisorLanguages"></span>
                  <span id="modalAdvisorPrice"></span>
                </div>
              </div>
            </div>
          </div>

          <form id="contactForm" class="contact-form">
            <div class="form-group">
              <label>Votre message</label>
              <textarea name="message" rows="4" placeholder="Décrivez votre projet et vos besoins..." required></textarea>
            </div>

            <div class="form-group">
              <label>Préférence de contact</label>
              <div class="radio-group">
                <label>
                  <input type="radio" name="contactPreference" value="email" checked>
                  <span>Email</span>
                </label>
                <label>
                  <input type="radio" name="contactPreference" value="phone">
                  <span>Téléphone</span>
                </label>
                <label>
                  <input type="radio" name="contactPreference" value="video">
                  <span>Visioconférence</span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label>Disponibilité souhaitée</label>
              <select name="availability" required>
                <option value="">Choisissez une option</option>
                <option value="asap">Dès que possible</option>
                <option value="today">Aujourd'hui</option>
                <option value="week">Cette semaine</option>
                <option value="month">Ce mois-ci</option>
              </select>
            </div>

            <div class="subscription-notice">
              <div class="notice-icon">
                <i class="fas fa-lock"></i>
              </div>
              <div class="notice-content">
                <h4>Abonnement requis</h4>
                <p>Pour contacter un conseiller, vous devez souscrire à un abonnement Professionnel.</p>
                <div class="subscription-price">
                  <span class="price">$29.99</span>
                  <span class="period">/mois</span>
                </div>
              </div>
            </div>

            <div class="form-actions">
              <button type="button" class="btn-secondary" onclick="closeContactModal()">
                Annuler
              </button>
              <button type="submit" class="btn-primary">
                <i class="fas fa-lock"></i>
                S'abonner et contacter
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <style>
    .team-page {
      min-height: 100vh;
      background: var(--bg-light);
    }

    .page-header {
      background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
      color: white;
      padding: 3rem 0;
    }

    .breadcrumb {
      margin-bottom: 1rem;
      font-size: 0.9rem;
      opacity: 0.8;
    }

    .breadcrumb a {
      color: white;
      text-decoration: none;
    }

    .breadcrumb span {
      margin: 0 0.5rem;
    }

    .header-content h1 {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .header-content p {
      font-size: 1.2rem;
      opacity: 0.9;
    }

    .filters-section {
      padding: 2rem 0;
      background: white;
      border-bottom: 1px solid var(--border-color);
    }

    .filters-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
    }

    .filter-group label {
      display: block;
      font-weight: 600;
      color: var(--text-color);
      margin-bottom: 0.5rem;
    }

    .filter-group select {
      width: 100%;
      padding: 0.75rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      font-size: 0.9rem;
      transition: border-color 0.3s ease;
    }

    .filter-group select:focus {
      outline: none;
      border-color: var(--primary-color);
    }

    .advisors-section {
      padding: 3rem 0;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-size: 1.8rem;
      font-weight: 600;
      color: var(--text-color);
    }

    .results-count {
      color: var(--text-muted);
      font-weight: 500;
    }

    .advisors-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .advisor-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .advisor-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    }

    .advisor-card.featured {
      border: 2px solid var(--primary-color);
    }

    .featured-badge {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: var(--primary-color);
      color: white;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .advisor-header {
      display: flex;
      align-items: flex-start;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .advisor-avatar {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--border-color);
    }

    .advisor-info h3 {
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--text-color);
      margin-bottom: 0.5rem;
    }

    .advisor-info .title {
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .advisor-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .meta-tag {
      background: var(--bg-light);
      color: var(--text-muted);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 500;
    }

    .meta-tag.primary {
      background: var(--primary-color) + '20';
      color: var(--primary-color);
    }

    .advisor-description {
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .advisor-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .stat-item {
      text-align: center;
      padding: 1rem;
      background: var(--bg-light);
      border-radius: 8px;
    }

    .stat-number {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary-color);
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .advisor-price {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem;
      background: var(--bg-light);
      border-radius: 8px;
      margin-bottom: 1.5rem;
    }

    .price-amount {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary-color);
    }

    .price-period {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .availability-status {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .status-dot.available {
      background: var(--success-color);
    }

    .status-dot.busy {
      background: var(--warning-color);
    }

    .status-dot.unavailable {
      background: var(--error-color);
    }

    .advisor-actions {
      display: flex;
      gap: 1rem;
    }

    .advisor-actions .btn {
      flex: 1;
      padding: 0.75rem;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      text-align: center;
    }

    .load-more-container {
      text-align: center;
      margin-top: 2rem;
    }

    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
      z-index: 1000;
      overflow-y: auto;
    }

    .modal.active {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-content {
      background: white;
      border-radius: 20px;
      padding: 0;
      max-width: 600px;
      width: 90%;
      max-height: 90vh;
      overflow-y: auto;
      animation: modalSlideIn 0.3s ease;
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 2rem;
      border-bottom: 1px solid var(--border-color);
    }

    .modal-header h2 {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--text-color);
    }

    .close-btn {
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--text-muted);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
    }

    .close-btn:hover {
      background: var(--bg-light);
      color: var(--text-color);
    }

    .modal-body {
      padding: 2rem;
    }

    .advisor-preview {
      background: var(--bg-light);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .advisor-info {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .advisor-avatar {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      object-fit: cover;
    }

    .advisor-details h3 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .advisor-details .title {
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }

    .advisor-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .contact-form {
      max-width: 100%;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      font-weight: 600;
      color: var(--text-color);
      margin-bottom: 0.5rem;
    }

    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 0.75rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      font-size: 0.9rem;
      transition: border-color 0.3s ease;
    }

    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--primary-color);
    }

    .radio-group {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .radio-group label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }

    .subscription-notice {
      background: var(--primary-color) + '10';
      border: 2px solid var(--primary-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .notice-content {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .notice-icon {
      width: 50px;
      height: 50px;
      background: var(--primary-color);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
    }

    .notice-content h4 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .notice-content p {
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }

    .subscription-price {
      display: flex;
      align-items: baseline;
      gap: 0.25rem;
    }

    .price {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary-color);
    }

    .period {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      justify-content: flex-end;
    }

    @keyframes modalSlideIn {
      from {
        opacity: 0;
        transform: translateY(-50px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 768px) {
      .filters-grid {
        grid-template-columns: 1fr;
      }

      .advisors-grid {
        grid-template-columns: 1fr;
      }

      .section-header {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
      }

      .advisor-stats {
        grid-template-columns: 1fr;
      }

      .advisor-actions {
        flex-direction: column;
      }

      .modal-content {
        margin: 1rem;
        width: calc(100% - 2rem);
      }

      .notice-content {
        flex-direction: column;
        text-align: center;
      }
    }
  </style>
</MainLayout>

<script>
  let advisors = [];
  let filteredAdvisors = [];
  let selectedAdvisor = null;
  let currentPage = 1;
  const advisorsPerPage = 9;

  // Load advisors on page load
  document.addEventListener('DOMContentLoaded', async () => {
    await loadAdvisors();
  });

  async function loadAdvisors() {
    try {
      const response = await fetch('/api/team/advisors');
      const data = await response.json();
      
      if (data.ok) {
        advisors = data.advisors || [];
        filteredAdvisors = [...advisors];
        renderAdvisors();
        updateResultsCount();
      }
    } catch (error) {
      console.error('Error loading advisors:', error);
      // Load mock data for demo
      loadMockAdvisors();
    }
  }

  function loadMockAdvisors() {
    advisors = [
      {
        id: '1',
        name: 'Marie Dubois',
        title: 'Conseillère Senior en Immigration',
        avatar: '/images/team/marie-dubois.jpg',
        specialty: 'travail',
        languages: ['Français', 'Anglais', 'Espagnol'],
        price: '$29.99/mois',
        description: 'Expert en immigration travail avec plus de 10 ans d\'expérience. Spécialisée dans les permis PMR et les demandes de résidence permanente.',
        stats: { clients: 150, success: 92, rating: 4.9 },
        availability: 'immediate',
        featured: true
      },
      {
        id: '2',
        name: 'Pierre Martin',
        title: 'Consultant en Immigration Études',
        avatar: '/images/team/pierre-martin.jpg',
        specialty: 'etudes',
        languages: ['Français', 'Anglais'],
        price: '$24.99/mois',
        description: 'Spécialiste des permis d\'études et des bourses canadiennes. Aide les étudiants à naviguer le système éducatif canadien.',
        stats: { clients: 85, success: 88, rating: 4.8 },
        availability: 'week'
      },
      {
        id: '3',
        name: 'Sophie Laurent',
        title: 'Avocate en Immigration Familiale',
        avatar: '/images/team/sophie-laurent.jpg',
        specialty: 'famille',
        languages: ['Français', 'Anglais', 'Arabe'],
        price: '$34.99/mois',
        description: 'Avocate spécialisée en parrainage familial et réunification. Expert en droit de l\'immigration canadien.',
        stats: { clients: 120, success: 95, rating: 4.9 },
        availability: 'immediate',
        featured: true
      },
      // Add more mock advisors...
    ];
    
    filteredAdvisors = [...advisors];
    renderAdvisors();
    updateResultsCount();
  }

  function renderAdvisors() {
    const advisorsGrid = document.getElementById('advisorsGrid');
    const startIndex = (currentPage - 1) * advisorsPerPage;
    const endIndex = startIndex + advisorsPerPage;
    const advisorsToRender = filteredAdvisors.slice(startIndex, endIndex);
    
    advisorsGrid.innerHTML = advisorsToRender.map(advisor => `
      <div class="advisor-card ${advisor.featured ? 'featured' : ''}">
        ${advisor.featured ? '<div class="featured-badge">Recommandé</div>' : ''}
        
        <div class="advisor-header">
          <img src="${advisor.avatar || '/images/default-avatar.jpg'}" alt="${advisor.name}" class="advisor-avatar">
          <div class="advisor-info">
            <h3>${advisor.name}</h3>
            <p class="title">${advisor.title}</p>
            <div class="advisor-meta">
              <span class="meta-tag primary">${getSpecialtyText(advisor.specialty)}</span>
              ${advisor.languages.map(lang => `<span class="meta-tag">${lang}</span>`).join('')}
              <span class="meta-tag">${advisor.price}</span>
            </div>
          </div>
        </div>

        <p class="advisor-description">${advisor.description}</p>

        <div class="advisor-stats">
          <div class="stat-item">
            <div class="stat-number">${advisor.stats.clients}</div>
            <div class="stat-label">Clients</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">${advisor.stats.success}%</div>
            <div class="stat-label">Succès</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">${advisor.stats.rating}</div>
            <div class="stat-label">Note</div>
          </div>
        </div>

        <div class="advisor-price">
          <div>
            <div class="price-amount">${advisor.price}</div>
            <div class="price-period">Abonnement mensuel</div>
          </div>
          <div class="availability-status">
            <div class="status-dot ${getAvailabilityClass(advisor.availability)}"></div>
            <span>${getAvailabilityText(advisor.availability)}</span>
          </div>
        </div>

        <div class="advisor-actions">
          <button class="btn-secondary" onclick="viewProfile('${advisor.id}')">
            Voir le profil
          </button>
          <button class="btn-primary" onclick="contactAdvisor('${advisor.id}')">
            Contacter
          </button>
        </div>
      </div>
    `).join('');

    // Update load more button
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    if (endIndex >= filteredAdvisors.length) {
      loadMoreBtn.style.display = 'none';
    } else {
      loadMoreBtn.style.display = 'block';
    }
  }

  function getSpecialtyText(specialty) {
    const specialtyMap = {
      'travail': 'Immigration Travail',
      'etudes': 'Immigration Études',
      'famille': 'Immigration Familiale',
      'affaires': 'Immigration Affaires',
      'residence': 'Résidence Permanente'
    };
    return specialtyMap[specialty] || specialty;
  }

  function getAvailabilityClass(availability) {
    const classMap = {
      'immediate': 'available',
      'week': 'available',
      'month': 'busy',
      'unavailable': 'unavailable'
    };
    return classMap[availability] || 'busy';
  }

  function getAvailabilityText(availability) {
    const textMap = {
      'immediate': 'Disponible immédiatement',
      'week': 'Disponible cette semaine',
      'month': 'Disponible ce mois-ci',
      'unavailable': 'Non disponible'
    };
    return textMap[availability] || 'Disponible';
  }

  function filterAdvisors() {
    const specialty = document.getElementById('specialtyFilter').value;
    const language = document.getElementById('languageFilter').value;
    const availability = document.getElementById('availabilityFilter').value;
    const price = document.getElementById('priceFilter').value;

    filteredAdvisors = advisors.filter(advisor => {
      if (specialty && advisor.specialty !== specialty) return false;
      if (language && !advisor.languages.includes(language)) return false;
      if (availability && advisor.availability !== availability) return false;
      if (price) {
        // Simple price filtering logic
        const priceValue = parseInt(advisor.price.replace(/[^0-9]/g, ''));
        if (price === 'economy' && priceValue > 25) return false;
        if (price === 'standard' && (priceValue < 25 || priceValue > 35)) return false;
        if (price === 'premium' && priceValue < 35) return false;
      }
      return true;
    });

    currentPage = 1;
    renderAdvisors();
    updateResultsCount();
  }

  function updateResultsCount() {
    const count = filteredAdvisors.length;
    document.getElementById('resultsCount').textContent = `${count} conseiller${count > 1 ? 's' : ''} trouvé${count > 1 ? 's' : ''}`;
  }

  function loadMoreAdvisors() {
    currentPage++;
    renderAdvisors();
  }

  function viewProfile(advisorId) {
    window.location.href = `/team/${advisorId}`;
  }

  function contactAdvisor(advisorId) {
    selectedAdvisor = advisors.find(a => a.id === advisorId);
    if (selectedAdvisor) {
      populateContactModal();
      openContactModal();
    }
  }

  function populateContactModal() {
    if (!selectedAdvisor) return;

    document.getElementById('modalAdvisorAvatar').src = selectedAdvisor.avatar || '/images/default-avatar.jpg';
    document.getElementById('modalAdvisorName').textContent = selectedAdvisor.name;
    document.getElementById('modalAdvisorTitle').textContent = selectedAdvisor.title;
    document.getElementById('modalAdvisorSpecialty').textContent = getSpecialtyText(selectedAdvisor.specialty);
    document.getElementById('modalAdvisorLanguages').textContent = selectedAdvisor.languages.join(', ');
    document.getElementById('modalAdvisorPrice').textContent = selectedAdvisor.price;
  }

  function openContactModal() {
    document.getElementById('contactModal').classList.add('active');
  }

  function closeContactModal() {
    document.getElementById('contactModal').classList.remove('active');
  }

  // Handle contact form submission
  document.getElementById('contactForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (!selectedAdvisor) return;

    const formData = new FormData(e.target);
    const contactData = {
      advisorId: selectedAdvisor.id,
      message: formData.get('message'),
      contactPreference: formData.get('contactPreference'),
      availability: formData.get('availability')
    };

    try {
      // Redirect to subscription page
      const subscriptionUrl = `/subscription?advisor=${selectedAdvisor.id}&project=${new URLSearchParams(window.location.search).get('project') || ''}`;
      window.location.href = subscriptionUrl;
    } catch (error) {
      console.error('Error submitting contact form:', error);
      alert('Erreur lors de la prise de contact');
    }
  });

  // Close modal when clicking outside
  window.addEventListener('click', (e) => {
    if (e.target.classList.contains('modal')) {
      e.target.classList.remove('active');
    }
  });
</script>
