
---
import MainLayout from '../layouts/main.astro';
import { HeaderNav } from '../components/HeaderNav';
import { FooterCustom } from '../components/FooterCustom';
---

<MainLayout>
  <HeaderNav client:only="react" />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary/10 to-primary/5 py-16 md:py-20">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-foreground">Nos Tarifs</h1>
        <p class="text-lg md:text-xl text-muted-foreground">
          Des services transparents et adaptés à votre projet d'immigration
        </p>
        <p class="text-sm text-muted-foreground mt-2">
          Tous les prix sont en dollars canadiens (CAD)
        </p>
      </div>
    </div>
  </section>

  <!-- Packs Recommandés -->
  <section class="py-20 bg-background">
    <div class="container mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-foreground">Packs Recommandés</h2>
        <p class="text-muted-foreground">La solution complète pour votre projet</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        
        <!-- Pack Découverte -->
        <div class="bg-card border border-border rounded-lg p-8 hover:shadow-lg transition">
          <div class="mb-6">
            <h3 class="text-2xl font-bold text-foreground mb-2">Pack Découverte</h3>
            <p class="text-sm text-muted-foreground">
              Pour évaluer votre projet et obtenir un plan d'action
            </p>
          </div>
          
          <div class="mb-6">
            <div class="text-4xl font-bold text-foreground mb-1">250 $</div>
            <div class="text-sm text-muted-foreground">CAD</div>
          </div>

          <div class="space-y-3 mb-8">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Consultation d'orientation initiale</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Diagnostic approfondi</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Rapport personnalisé</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Plan d'action détaillé</span>
            </div>
          </div>

          <a href="/connexion" class="block w-full text-center bg-secondary text-secondary-foreground py-3 rounded-lg font-semibold hover:bg-secondary/90 transition">
            Choisir ce pack
          </a>
        </div>

        <!-- Pack Projet (Popular) -->
        <div class="bg-primary text-primary-foreground rounded-lg p-8 hover:shadow-2xl transition relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-secondary text-secondary-foreground px-4 py-1 rounded-full text-sm font-semibold">
            Le plus populaire
          </div>
          
          <div class="mb-6">
            <h3 class="text-2xl font-bold mb-2">Pack Projet</h3>
            <p class="text-sm opacity-90">
              Accompagnement complet du diagnostic à la soumission
            </p>
          </div>
          
          <div class="mb-6">
            <div class="text-4xl font-bold mb-1">1 000 $</div>
            <div class="text-sm opacity-90">CAD</div>
          </div>

          <div class="space-y-3 mb-8">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm">Diagnostic approfondi</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm">Montage complet du dossier</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm">Relecture et vérification</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm">Suivi du dossier (3 mois)</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm">Support prioritaire</span>
            </div>
          </div>

          <a href="/connexion" class="block w-full text-center bg-primary-foreground text-primary py-3 rounded-lg font-semibold hover:opacity-90 transition">
            Choisir ce pack
          </a>
        </div>

        <!-- Pack Tranquillité -->
        <div class="bg-card border-2 border-primary/20 rounded-lg p-8 hover:shadow-lg transition">
          <div class="mb-6">
            <h3 class="text-2xl font-bold text-foreground mb-2">Pack Tranquillité</h3>
            <p class="text-sm text-muted-foreground">
              Service VIP complet jusqu'à l'intégration
            </p>
          </div>
          
          <div class="mb-6">
            <div class="text-4xl font-bold text-foreground mb-1">1 500 $</div>
            <div class="text-sm text-muted-foreground">CAD</div>
          </div>

          <div class="space-y-3 mb-8">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Tous les services clés</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Recherche d'institutions</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Aide à la recherche de logement</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Accueil & intégration</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Support premium</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-muted-foreground">Assistance à l'arrivée</span>
            </div>
          </div>

          <a href="/connexion" class="block w-full text-center bg-primary text-primary-foreground py-3 rounded-lg font-semibold hover:bg-primary/90 transition">
            Choisir ce pack
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services à la carte -->
  <section class="py-20 bg-muted/30">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-foreground">Services à la carte</h2>
          <p class="text-muted-foreground">Choisissez uniquement les services dont vous avez besoin</p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <!-- Consultation & Diagnostic -->
          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Consultation d'orientation initiale</h3>
                <p class="text-sm text-muted-foreground">Analyse de profil, conseils, orientation programme</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">70 $</div>
            </div>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Diagnostic approfondi</h3>
                <p class="text-sm text-muted-foreground">Étude complète et rapport personnalisé</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">100 $</div>
            </div>
          </div>

          <!-- Préparation dossier -->
          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Préparation du dossier immigration</h3>
                <p class="text-sm text-muted-foreground">Constitution, remplissage et organisation du dossier</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">700 $</div>
            </div>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Relecture et correction du dossier</h3>
                <p class="text-sm text-muted-foreground">Vérification complète avant envoi officiel</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">100 $</div>
            </div>
          </div>

          <!-- Coaching & Préparation -->
          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Coaching / Simulation d'entretiens</h3>
                <p class="text-sm text-muted-foreground">Préparation entretiens ambassade/écoles/employeurs</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">90 $/h</div>
            </div>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Suivi du dossier & relance</h3>
                <p class="text-sm text-muted-foreground">Suivi post-dépôt, relance et assistance (3 mois)</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">300 $</div>
            </div>
          </div>

          <!-- Services spécialisés -->
          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Assistance recherche d'un garant</h3>
                <p class="text-sm text-muted-foreground">Recherche et mise en relation avec garants financiers</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">220 $</div>
            </div>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Aide à la recherche de logement</h3>
                <p class="text-sm text-muted-foreground">Conseils, contacts et accompagnement logement</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">350 $</div>
            </div>
          </div>

          <!-- Ateliers & Intégration -->
          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Atelier préparation à la vie au Canada</h3>
                <p class="text-sm text-muted-foreground">Webinaire, adaptation, conseils pratiques</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">120 $</div>
            </div>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Accueil & intégration</h3>
                <p class="text-sm text-muted-foreground">Accueil à l'arrivée, orientation, supports et démarches</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">600 $</div>
            </div>
          </div>

          <!-- Demandes spécifiques -->
          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Demandes spécifiques</h3>
                <p class="text-sm text-muted-foreground">Permis de travail/études, regroupement familial</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">500 $</div>
            </div>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 hover:shadow-lg transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-foreground mb-1">Recherche d'institutions d'accueil</h3>
                <p class="text-sm text-muted-foreground">Appui et orientation écoles/employeurs</p>
              </div>
              <div class="text-xl font-bold text-primary whitespace-nowrap ml-4">260 $</div>
            </div>
          </div>
        </div>

        <!-- Support Premium -->
        <div class="mt-8">
          <div class="bg-gradient-to-br from-primary/10 to-primary/5 border border-primary/20 rounded-lg p-8">
            <div class="flex flex-col md:flex-row items-center justify-between gap-6">
              <div>
                <h3 class="text-xl font-bold text-foreground mb-2">Messagerie premium / Support illimité</h3>
                <p class="text-muted-foreground">
                  Accès illimité au chat et support dédié pour toutes vos questions
                </p>
              </div>
              <div class="flex items-center gap-4">
                <div class="text-3xl font-bold text-primary whitespace-nowrap">70 $/mois</div>
                <a href="/connexion" class="bg-primary text-primary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition whitespace-nowrap">
                  S'abonner
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Facilités de paiement -->
  <section class="py-20 bg-background">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4 text-foreground">Facilités de paiement</h2>
          <p class="text-muted-foreground">Nous rendons nos services accessibles</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-card border border-border rounded-lg p-6 text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
            </div>
            <h3 class="font-bold text-foreground mb-2">Paiement en plusieurs fois</h3>
            <p class="text-sm text-muted-foreground">Échelonnez vos paiements sur plusieurs mois</p>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-foreground mb-2">Devis personnalisé</h3>
            <p class="text-sm text-muted-foreground">Tarif adapté selon votre situation</p>
          </div>

          <div class="bg-card border border-border rounded-lg p-6 text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-bold text-foreground mb-2">Paiement sécurisé</h3>
            <p class="text-sm text-muted-foreground">Transactions 100% sécurisées et confidentielles</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Notes importantes -->
  <section class="py-12 bg-muted/30">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-4xl mx-auto">
        <div class="bg-card border border-border rounded-lg p-8">
          <div class="flex gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div class="space-y-4">
              <div>
                <h4 class="font-bold text-foreground mb-2">Notes importantes</h4>
              </div>
              
              <div>
                <h5 class="font-semibold text-foreground mb-1">Frais gouvernementaux</h5>
                <p class="text-sm text-muted-foreground">
                  Nos tarifs ne comprennent pas les frais gouvernementaux officiels (frais de traitement, biométrie, permis, etc.) 
                  qui sont payables directement aux autorités canadiennes (IRCC). Nous vous informerons clairement de tous les frais lors de votre consultation.
                </p>
              </div>

              <div>
                <h5 class="font-semibold text-foreground mb-1">Conformité légale</h5>
                <p class="text-sm text-muted-foreground">
                  CAPITUNE offre des services de conseil et d'accompagnement. Pour toute représentation officielle devant Immigration, 
                  Réfugiés et Citoyenneté Canada (IRCC), nous travaillons avec des Consultants Réglementés en Immigration Canadienne (CRCIC) 
                  certifiés et en règle avec le CICC.
                </p>
              </div>

              <div>
                <h5 class="font-semibold text-foreground mb-1">Tarifs adaptés</h5>
                <p class="text-sm text-muted-foreground">
                  Nos tarifs sont indicatifs et peuvent être adaptés selon votre profil (étudiant, professionnel, famille) 
                  et la complexité de votre dossier. Contactez-nous pour un devis personnalisé.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary text-primary-foreground">
    <div class="container mx-auto px-4 md:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Prêt à commencer votre projet ?</h2>
      <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90">
        Réservez une consultation d'orientation initiale pour discuter de votre situation et recevoir un plan personnalisé
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/connexion" class="inline-block bg-primary-foreground text-primary px-8 py-4 rounded-lg font-semibold hover:opacity-90 transition">
          Réserver une consultation (70 $)
        </a>
        <a href="/connexion" class="inline-block border-2 border-primary-foreground text-primary-foreground px-8 py-4 rounded-lg font-semibold hover:bg-primary-foreground/10 transition">
          Demander un devis gratuit
        </a>
      </div>
    </div>
  </section>

  <FooterCustom client:only="react" />
</MainLayout>

