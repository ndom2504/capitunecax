---
import Layout from '../../layouts/main.astro';
import Jobs from '../../components/carriere/Jobs.tsx';
---

<Layout title="Marché de l'Emploi & CV - CAPITUNE">
  <!-- Styles pour forcer le dark mode sur la page si besoin -->
  <div class="carriere-page is-dark-mode min-h-screen bg-[#0a0a0a] text-white">
    <div class="back-nav p-4 max-w-7xl mx-auto">
      <a href="/dashboard" class="text-gray-400 hover:text-white flex items-center gap-2 text-sm font-bold tracking-widest uppercase mb-8 w-fit transition-colors">
        <i class="fa fa-arrow-left"></i> Retour au Dashboard
      </a>
    </div>
    
    <Jobs client:only="react" />
  </div>
</Layout>

<style>
/* CSS isolés pour intégrer proprement l'outil React Tailwind dans Astro */
.carriere-page {
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}
.carriere-page .bg-white {
    background-color: transparent !important;
}
</style>