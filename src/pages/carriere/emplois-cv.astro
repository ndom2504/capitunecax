---
import Layout from '../../layouts/main.astro';
import Jobs from '../../components/carriere/Jobs.tsx';

const isApp = Astro.url.searchParams.get('source') === 'app';
---

<Layout title="Carrière & Emploi - CAPITUNE" pageClass={isApp ? 'is-mobile-app' : ''}>

  <!-- Hero section -->
  <div class="cap-page-hero">
    <div class="cap-container">
      {!isApp && (
        <a href="/dashboard" class="cap-back-link">&#8592; Retour au Dashboard</a>
      )}
      <h1 class="cap-hero-title">&#128188; Marché de l&#39;Emploi</h1>
      <p class="cap-hero-sub">Explorez les offres d'emploi canadiennes et trouvez votre prochain poste sur le Guichet Emplois Canada.</p>
    </div>
  </div>

  <!-- Contenu interactif React -->
  <div class="cap-page-body">
    <Jobs client:only="react" isMobileApp={isApp} mode="jobs" />
  </div>

</Layout>

<style is:global>
/* ─── Variables Capitune (partagées) ─── */
:root {
  --cap-orange: #ff9408;
  --cap-dark:   #1a1a2e;
  --cap-blue:   #2980b9;
  --cap-green:  #27ae60;
  --cap-red:    #e74c3c;
}

/* ─── Layout page Carrière (commun avec etudes.astro) ─── */
.cap-page-hero {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40px 0 32px;
}
.cap-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 30px;
}
.cap-back-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  font-family: Inter, sans-serif;
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 20px;
  transition: color .2s;
}
.cap-back-link:hover { color: #fff; }
.cap-hero-title {
  font-family: 'Anton SC', sans-serif;
  font-size: 2.2rem;
  font-weight: 400;
  color: #fff;
  margin: 0 0 12px;
  letter-spacing: 0.03em;
}
.cap-hero-sub {
  font-family: Inter, sans-serif;
  font-size: 15px;
  color: rgba(255,255,255,0.68);
  margin: 0;
}
.cap-page-body {
  background: #f4f6fa;
  min-height: 60vh;
  padding: 36px 0 70px;
}

/* ═══════════════════════════════════════
   COMPOSANT JOBS — styles Capitune
═══════════════════════════════════════ */
.jobs-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 30px;
  font-family: Inter, sans-serif;
}

/* Bannière profil actif */
.jobs-profile-banner {
  background: #fff8f0;
  border: 1px solid #ffd899;
  border-radius: 12px;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}
.jobs-profile-left {
  display: flex;
  align-items: center;
  gap: 14px;
}
.jobs-profile-icon {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(255,148,8,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.jobs-profile-name { font-weight: 700; font-size: 14px; color: var(--cap-dark); margin: 0 0 3px; }
.jobs-profile-sub  { font-size: 12px; color: #333; font-size: 14px; margin: 0; }
.jobs-btn-clear {
  padding: 8px 18px;
  border-radius: 9px;
  border: 1.5px solid #ddd;
  background: #fff;
  color: #666;
  font-size: 12px;
  font-family: Inter, sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: .2s;
  white-space: nowrap;
}
.jobs-btn-clear:hover { border-color: var(--cap-orange); color: var(--cap-orange); }

/* Section CV (grille 2 colonnes) */
.jobs-cv-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
  margin-bottom: 40px;
}
@media (max-width: 760px) {
  .jobs-cv-grid { grid-template-columns: 1fr; }
}

/* Cartes blanches génériques */
.jobs-card {
  background: #fff;
  border: 1.5px solid #eee;
  border-radius: 16px;
  padding: 28px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.jobs-card-title {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}
.jobs-card-icon {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  background: rgba(255,148,8,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.jobs-card-icon.blue { background: rgba(41,128,185,0.12); }
.jobs-card-title h2 {
  font-family: Inter, sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--cap-dark);
  margin: 0;
}

/* Upload fichier */
.jobs-file-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.jobs-btn-import {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: none;
  background: none;
  color: var(--cap-orange);
  font-size: 12px;
  font-family: Inter, sans-serif;
  font-weight: 700;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: .04em;
  transition: color .2s;
  padding: 0;
}
.jobs-btn-import:hover { color: var(--cap-dark); }

.jobs-file-preview {
  width: 100%;
  min-height: 140px;
  background: #f9f9f9;
  border: 1.5px solid rgba(255,148,8,0.25);
  border-radius: 12px;
  padding: 22px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  margin-bottom: 16px;
  position: relative;
}
.jobs-file-preview-icon {
  font-size: 36px;
  margin-bottom: 10px;
}
.jobs-file-preview-name { font-weight: 700; color: var(--cap-orange); font-size: 14px; margin: 0 0 4px; }
.jobs-file-preview-sub  { font-size: 12px; color: #aaa; text-transform: uppercase; letter-spacing: .05em; }
.jobs-file-remove {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: none;
  background: #f0f0f0;
  cursor: pointer;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: .2s;
}
.jobs-file-remove:hover { background: #e74c3c; color: #fff; }

.jobs-textarea {
  width: 100%;
  min-height: 140px;
  box-sizing: border-box;
  background: #f9f9f9;
  border: 1.5px solid #e0e0e0;
  border-radius: 12px;
  padding: 14px 16px;
  font-size: 14px;
  font-family: Inter, sans-serif;
  resize: vertical;
  outline: none;
  transition: .2s;
  margin-bottom: 16px;
  color: var(--cap-dark);
}
.jobs-textarea:focus { border-color: var(--cap-orange); box-shadow: 0 0 0 3px rgba(255,148,8,0.1); background: #fff; }

/* Résultat analyse */
.jobs-analysis-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 32px 0;
  color: #bbb;
}
.jobs-analysis-empty p { margin: 8px 0 0; font-size: 14px; }

.jobs-analysis-result {
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.jobs-analysis-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.jobs-analysis-label {
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: #aaa;
  margin: 0 0 4px;
}
.jobs-analysis-name  { font-size: 22px; font-weight: 800; color: var(--cap-dark); margin: 0; }
.jobs-analysis-score { font-size: 28px; font-weight: 900; color: var(--cap-orange); }
.jobs-analysis-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.jobs-analysis-stat {
  background: #f9f9f9;
  border: 1px solid #eee;
  border-radius: 10px;
  padding: 14px;
}
.jobs-analysis-stat-val { font-size: 17px; font-weight: 700; color: var(--cap-dark); margin: 6px 0 0; }
.jobs-skills-wrap { display: flex; flex-wrap: wrap; gap: 8px; }
.jobs-skill-tag {
  padding: 5px 12px;
  background: #f4f6fa;
  border: 1px solid #e8e8e8;
  border-radius: 999px;
  font-size: 12px;
  color: #555;
}
.jobs-suggestions-box {
  background: rgba(255,148,8,0.06);
  border: 1px solid rgba(255,148,8,0.2);
  border-radius: 10px;
  padding: 14px 16px;
  font-size: 13px;
  color: #555;
  line-height: 1.65;
}
.jobs-suggestions-box strong {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--cap-orange);
  margin-bottom: 8px;
  font-weight: 800;
}

/* Boutons Capitune */
.jobs-btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #ff9408, #e67e00);
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 13px 20px;
  font-size: 14px;
  font-family: 'Anton SC', sans-serif;
  font-weight: 400;
  letter-spacing: 0.05em;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: transform .2s, box-shadow .2s;
}
.jobs-btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 18px rgba(255,148,8,0.35);
}
.jobs-btn-primary:disabled { opacity: .5; pointer-events: none; }

/* ─── Section CV Magic ─── */
.jobs-section-title {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 28px;
}
.jobs-section-icon {
  width: 54px;
  height: 54px;
  border-radius: 16px;
  background: rgba(255,148,8,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  flex-shrink: 0;
}
.jobs-section-title h2 {
  font-family: 'Anton SC', sans-serif;
  font-size: 1.8rem;
  font-weight: 400;
  color: var(--cap-dark);
  margin: 0 0 4px;
  letter-spacing: 0.03em;
}
.jobs-section-title p { font-size: 14px; color: #333; font-size: 14px; margin: 0; }

.jobs-magic-grid {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 22px;
  margin-bottom: 40px;
}
@media (max-width: 760px) {
  .jobs-magic-grid { grid-template-columns: 1fr; }
}
.jobs-step-label {
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: #aaa;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.jobs-templates-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.jobs-template-btn {
  position: relative;
  aspect-ratio: 3/4;
  border-radius: 12px;
  overflow: hidden;
  border: 2px solid #e8e8e8;
  background: none;
  cursor: pointer;
  transition: border-color .2s;
  padding: 0;
}
.jobs-template-btn.active { border-color: var(--cap-orange); }
.jobs-template-btn img { width: 100%; height: 100%; object-fit: cover; opacity: .5; display: block; }
.jobs-template-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
  padding: 10px 8px 8px;
  font-size: 11px;
  font-weight: 700;
  color: #fff;
  text-align: center;
}
.jobs-template-check {
  position: absolute;
  top: 6px; right: 6px;
  background: var(--cap-orange);
  border-radius: 50%;
  width: 20px; height: 20px;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px;
  color: #fff;
}

.jobs-magic-panel {
  background: #fff;
  border: 1.5px solid #eee;
  border-radius: 16px;
  padding: 28px;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.jobs-magic-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
  flex-wrap: wrap;
  gap: 10px;
}
.jobs-magic-actions { display: flex; align-items: center; gap: 12px; }
.jobs-model-select {
  background: #f4f6fa;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 11px;
  font-family: Inter, sans-serif;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: #666;
  outline: none;
  cursor: pointer;
}
.jobs-btn-copy {
  border: none;
  background: none;
  cursor: pointer;
  font-size: 12px;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: #333; font-size: 14px;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: color .2s;
}
.jobs-btn-copy:hover { color: var(--cap-dark); }
.jobs-btn-eye {
  width: 32px; height: 32px;
  border-radius: 8px;
  border: 1.5px solid #ddd;
  background: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  transition: .2s;
}
.jobs-btn-eye:hover { border-color: var(--cap-orange); color: var(--cap-orange); }
.jobs-btn-dl {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: var(--cap-orange);
  border: none;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  color: #fff;
  transition: .2s;
}
.jobs-btn-dl:hover { background: #e67e00; }

.jobs-magic-preview {
  flex: 1;
  background: #f0f2f7;
  border: 1px solid #e0e0e0;
  border-radius: 12px;
  padding: 20px;
  min-height: 220px;
  margin-bottom: 16px;
  overflow-y: auto;
  max-height: 600px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.jobs-magic-preview-empty {
  text-align: center;
  color: #bbb;
}
.jobs-magic-preview-empty p { font-size: 14px; margin: 10px 0 0; }
.jobs-magic-loading {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; color: #aaa; gap: 12px;
}
.jobs-magic-loading-spin {
  font-size: 28px;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.jobs-magic-loading p { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; }
.jobs-raw-pre {
  font-size: 11px; font-family: monospace;
  color: #555; white-space: pre-wrap;
  background: #f4f6fa; padding: 12px; border-radius: 8px;
  width: 100%; box-sizing: border-box;
}
.jobs-cv-scaler {
  width: 100%;
  overflow-x: auto;
}
.jobs-cv-scaler-inner {
  transform: scale(0.65);
  transform-origin: top left;
  display: inline-block;
  min-width: 800px;
}

/* ─── Section Offres d'emploi ─── */
.jobs-search-bar {
  display: flex;
  gap: 12px;
  margin-bottom: 28px;
  flex-wrap: wrap;
  align-items: center;
}
.jobs-input-wrap {
  flex: 1;
  min-width: 180px;
  position: relative;
}
.jobs-input-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #aaa;
  font-size: 14px;
  pointer-events: none;
}
.jobs-input {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid #ddd;
  border-radius: 9px;
  padding: 11px 14px 11px 36px;
  font-size: 14px;
  font-family: Inter, sans-serif;
  outline: none;
  background: #fafafa;
  transition: .2s;
  color: var(--cap-dark);
}
.jobs-input:focus {
  border-color: var(--cap-orange);
  box-shadow: 0 0 0 3px rgba(255,148,8,0.1);
  background: #fff;
}
.jobs-btn-search {
  background: linear-gradient(135deg, #ff9408, #e67e00);
  color: #fff;
  border: none;
  border-radius: 9px;
  padding: 11px 26px;
  font-size: 13px;
  font-family: 'Anton SC', sans-serif;
  font-weight: 400;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: .2s;
  white-space: nowrap;
}
.jobs-btn-search:hover { transform: translateY(-2px); box-shadow: 0 5px 18px rgba(255,148,8,0.35); }
.jobs-btn-search:disabled { opacity: .5; pointer-events: none; }

.jobs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}
@media (max-width: 640px) {
  .jobs-grid { grid-template-columns: 1fr; }
}

.jobs-job-card {
  background: #fff;
  border: 1.5px solid #eee;
  border-radius: 16px;
  padding: 22px;
  display: flex;
  flex-direction: column;
  transition: .25s;
  box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.jobs-job-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,0.09); border-color: var(--cap-orange); }
.jobs-job-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}
  .jobs-job-title  { font-family: Inter, sans-serif !important; font-size: 17px; font-weight: 700; color: #111; margin: 0 0 6px; line-height: 1.3; transition: color .2s; text-transform: none !important; letter-spacing: 0; }
  .jobs-job-card:hover .jobs-job-title { color: var(--cap-orange); }
  .jobs-job-company{ font-size: 13px; color: #444; font-weight: 500; display: flex; align-items: center; gap: 5px; }
.jobs-job-ext {
  width: 36px; height: 36px; border-radius: 9px;
  background: #f4f6fa; border: 1px solid #eee;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; color: #333; font-size: 14px; text-decoration: none; flex-shrink: 0;
  transition: .2s;
}
.jobs-job-ext:hover { background: var(--cap-orange); color: #fff; border-color: var(--cap-orange); }
.jobs-job-desc {
  font-size: 13px;
  color: #333; font-size: 14px;
  line-height: 1.55;
  margin-bottom: 18px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.jobs-job-footer {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12px;
  padding-top: 14px;
  border-top: 1px solid #f0f0f0;
  margin-top: auto;
}
.jobs-job-meta {
  font-size: 12px;
  font-weight: 700;
  color: #444; font-weight: 500;
  display: flex;
  align-items: center;
  gap: 5px;
}
.jobs-job-salary { color: var(--cap-orange); }
.jobs-job-actions { display: flex; align-items: center; gap: 14px; margin-left: auto; }
.jobs-btn-optimize {
  border: none;
  background: none;
  font-size: 12px;
  font-family: Inter, sans-serif;
  font-weight: 700;
  color: var(--cap-orange);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 0;
  transition: color .2s;
}
.jobs-btn-optimize:hover { color: var(--cap-dark); }
.jobs-btn-postuler {
  font-size: 12px;
  font-weight: 700;
  color: var(--cap-orange);
  text-decoration: none;
  transition: .2s;
}
.jobs-btn-postuler:hover { text-decoration: underline; }

/* Empty / Loading states */
.jobs-loading { text-align: center; padding: 60px 0; color: #aaa; }
.jobs-empty {
  text-align: center;
  padding: 48px;
  border: 2px dashed #e0e0e0;
  border-radius: 16px;
  color: #aaa;
  font-size: 15px;
  grid-column: 1 / -1;
}

/* Mobile */
@media (max-width: 640px) {
  .cap-hero-title { font-size: 1.6rem; }
  .cap-container  { padding: 0 18px; }
  .jobs-wrap      { padding: 0 18px; }
  .jobs-search-bar { flex-direction: column; }
  .jobs-btn-search { width: 100%; }
}
</style>
