---
import MainLayout from "../../layouts/main.astro";
import { HeaderNav } from "../../components/HeaderNav";
import { FooterCustom } from "../../components/FooterCustom";
import CvCreator from "../../components/carriere/CvCreator";

const service = Astro.url.searchParams.get("service") ?? "";

const CV_SERVICES = [
  {
    id: "cv_canada",
    icon: "🍁",
    label: "CV Canada",
    desc: "CV standard canadien, bilingue, adapté au marché national.",
    priceBase: 10, priceForfait: 2,
    color: "#e8f4ec",
    border: "#a8d5b5",
  },
  {
    id: "cv_quebec",
    icon: "⚜️",
    label: "CV Québec",
    desc: "Marché québécois, rédigé en français, normes du Québec.",
    priceBase: 10, priceForfait: 2,
    color: "#eef2fb",
    border: "#b8caf5",
  },
  {
    id: "cv_etudiant",
    icon: "🎓",
    label: "CV Étudiant",
    desc: "Premier emploi ou stage au Canada — valoriser formations et bénévolat.",
    priceBase: 8, priceForfait: 2,
    color: "#fdf5e8",
    border: "#f5d58a",
  },
  {
    id: "cv_immigration",
    icon: "✈️",
    label: "CV Immigration",
    desc: "Entrée Express, PNP — profil immigration mis en avant.",
    priceBase: 12, priceForfait: 3,
    color: "#fff0ec",
    border: "#f5b8a0",
  },
  {
    id: "cover_letter",
    icon: "✉️",
    label: "Lettre de motivation",
    desc: "Cover letter bilingue percutante pour le marché canadien.",
    priceBase: 10, priceForfait: 2,
    color: "#f5eefb",
    border: "#c9a8f5",
  },
  {
    id: "letter_ircc",
    icon: "🏛️",
    label: "Lettre IRCC",
    desc: "Lettre d'explication pour Immigration, Réfugiés et Citoyenneté Canada.",
    priceBase: 15, priceForfait: 3,
    color: "#ecf8ff",
    border: "#90cef5",
  },
];
---

<MainLayout>
  <HeaderNav client:only="react" />

  <main class="cvc-page">

    {service ? (
      /* ── Mode génération ── */
      <>
        <div class="cvc-gen-bar">
          <a href="/carriere/cv" class="cvc-back-btn">← Choisir un autre service</a>
          <span class="cvc-gen-service-label">
            {CV_SERVICES.find(s => s.id === service)?.icon}
            {CV_SERVICES.find(s => s.id === service)?.label ?? service}
          </span>
        </div>
        <CvCreator client:only="react" defaultService={service} />
      </>
    ) : (
      /* ── Mode landing services ── */
      <div class="cvc-landing">

        <!-- Hero -->
        <div class="cvc-hero">
          <span class="cvc-hero-badge">🍁 Capitune CV</span>
          <h1 class="cvc-hero-title">Créateur de CV Canadien</h1>
          <p class="cvc-hero-sub">
            Choisissez le service adapté à votre profil. L'IA adapte votre CV aux normes canadiennes,
            analyse votre compatibilité ATS et génère vos documents en quelques secondes.
          </p>
        </div>

        <!-- Grille services -->
        <div class="cvc-services-grid">
          {CV_SERVICES.map(s => (
            <a
              href={`/carriere/cv?service=${s.id}`}
              class="cvc-service-card"
              style={`--card-bg:${s.color}; --card-border:${s.border};`}
            >
              <div class="cvc-sc-top">
                <span class="cvc-sc-icon">{s.icon}</span>
                <div>
                  <p class="cvc-sc-name">{s.label}</p>
                  <p class="cvc-sc-desc">{s.desc}</p>
                </div>
              </div>
              <div class="cvc-sc-footer">
                <div class="cvc-sc-pricing">
                  <span class="cvc-sc-price-forfait">{s.priceForfait}$<small>/avec forfait</small></span>
                  <span class="cvc-sc-price-base">{s.priceBase}$ sans forfait</span>
                </div>
                <span class="cvc-sc-cta">Commencer →</span>
              </div>
            </a>
          ))}
        </div>

        <!-- Bandeau forfait -->
        <div class="cvc-forfait-banner">
          <div class="cvc-fb-left">
            <p class="cvc-fb-title">🎯 Économisez jusqu'à 80% avec un forfait Capitune</p>
            <p class="cvc-fb-sub">
              Accès illimité à tous les services CV, lettres IRCC, diagnostic IA ATS et téléchargements PDF.
            </p>
          </div>
          <a href="/tarifs" class="cvc-fb-btn">Voir les forfaits</a>
        </div>

        <!-- Comment ça marche -->
        <div class="cvc-steps">
          <h2 class="cvc-steps-title">Comment ça fonctionne ?</h2>
          <div class="cvc-steps-grid">
            {[
              { n: "1", label: "Choisissez un service", desc: "CV Canada, Québec, immigration ou lettre de motivation." },
              { n: "2", label: "Importez votre CV", desc: "Copiez-collez le texte ou importez un PDF / DOCX." },
              { n: "3", label: "Analyse IA instantanée", desc: "Score ATS, compétences clés, programmes recommandés." },
              { n: "4", label: "Générez & téléchargez", desc: "CV optimisé en format canadien + téléchargement PDF avec votre forfait." },
            ].map(step => (
              <div class="cvc-step">
                <div class="cvc-step-num">{step.n}</div>
                <p class="cvc-step-label">{step.label}</p>
                <p class="cvc-step-desc">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    )}
  </main>

  <FooterCustom client:only="react" />
</MainLayout>

<style>
  .cvc-page  { min-height: 80vh; background: #f7f9fc; }

  /* ── Landing ── */
  .cvc-landing { max-width: 960px; margin: 0 auto; padding: 56px 24px 80px; display: flex; flex-direction: column; gap: 56px; }

  .cvc-hero       { text-align: center; }
  .cvc-hero-badge { display: inline-block; background: #fff2e0; border: 1px solid #ffd080; color: #c97000; font-size: 12px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; padding: 4px 14px; border-radius: 999px; margin-bottom: 18px; }
  .cvc-hero-title { font-family: 'Anton SC', sans-serif; font-size: 2.8rem; color: #0a1628; margin: 0 0 16px; letter-spacing: 0.02em; }
  .cvc-hero-sub   { font-size: 15px; color: #666; line-height: 1.7; max-width: 620px; margin: 0 auto; }

  .cvc-services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .cvc-service-card {
    background: var(--card-bg, #fff); border: 2px solid var(--card-border, #e8e8e8);
    border-radius: 18px; padding: 22px; text-decoration: none;
    display: flex; flex-direction: column; gap: 18px;
    transition: transform .18s, box-shadow .18s;
  }
  .cvc-service-card:hover { transform: translateY(-4px); box-shadow: 0 10px 32px rgba(0,0,0,0.1); }
  .cvc-sc-top   { display: flex; align-items: flex-start; gap: 14px; }
  .cvc-sc-icon  { font-size: 28px; flex-shrink: 0; margin-top: 2px; }
  .cvc-sc-name  { font-size: 15px; font-weight: 800; color: #0a1628; margin: 0 0 4px; }
  .cvc-sc-desc  { font-size: 12px; color: #666; margin: 0; line-height: 1.6; }
  .cvc-sc-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid rgba(0,0,0,0.07); }
  .cvc-sc-pricing   { display: flex; flex-direction: column; gap: 2px; }
  .cvc-sc-price-forfait { font-size: 15px; font-weight: 800; color: #1f4b6e; }
  .cvc-sc-price-forfait small { font-size: 11px; color: #888; font-weight: 500; margin-left: 2px; }
  .cvc-sc-price-base { font-size: 11px; color: #aaa; text-decoration: line-through; }
  .cvc-sc-cta   { font-size: 13px; font-weight: 700; color: #1f4b6e; background: #fff; border: 1.5px solid #1f4b6e; border-radius: 8px; padding: 6px 14px; white-space: nowrap; }

  .cvc-forfait-banner {
    background: linear-gradient(135deg, #0a1628 0%, #1f4b6e 100%);
    border-radius: 20px; padding: 32px 40px; display: flex; align-items: center;
    justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .cvc-fb-left   { flex: 1; min-width: 240px; }
  .cvc-fb-title  { font-size: 17px; font-weight: 800; color: #fff; margin: 0 0 8px; }
  .cvc-fb-sub    { font-size: 13px; color: rgba(255,255,255,0.7); margin: 0; line-height: 1.6; }
  .cvc-fb-btn    { background: #ff9408; color: #fff; font-weight: 800; font-size: 14px; padding: 13px 28px; border-radius: 12px; text-decoration: none; white-space: nowrap; transition: background .2s; }
  .cvc-fb-btn:hover { background: #e67e00; }

  .cvc-steps       { }
  .cvc-steps-title { font-family: 'Anton SC', sans-serif; font-size: 1.5rem; color: #0a1628; text-align: center; margin: 0 0 28px; }
  .cvc-steps-grid  { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .cvc-step        { background: #fff; border-radius: 16px; padding: 22px 18px; text-align: center; border: 1px solid #eee; }
  .cvc-step-num    { width: 38px; height: 38px; border-radius: 50%; background: #1f4b6e; color: #fff; font-size: 16px; font-weight: 900; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; }
  .cvc-step-label  { font-size: 13px; font-weight: 700; color: #0a1628; margin: 0 0 6px; }
  .cvc-step-desc   { font-size: 12px; color: #888; margin: 0; line-height: 1.6; }

  /* ── Générateur ── */
  .cvc-gen-bar {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    max-width: 1100px; margin: 0 auto; padding: 20px 28px 0;
  }
  .cvc-back-btn { font-size: 13px; color: #1f4b6e; text-decoration: none; font-weight: 600; opacity: .8; }
  .cvc-back-btn:hover { opacity: 1; }
  .cvc-gen-service-label { font-size: 13px; font-weight: 800; color: #0a1628; background: #fff; border: 1.5px solid #e0e0e0; border-radius: 8px; padding: 5px 14px; }

  @media (max-width: 720px) {
    .cvc-hero-title    { font-size: 1.9rem; }
    .cvc-steps-grid    { grid-template-columns: 1fr 1fr; }
    .cvc-forfait-banner { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .cvc-steps-grid { grid-template-columns: 1fr; }
  }

  /* ── Paywall overlay ── */
  .cv-paywall-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.55); z-index: 9999;
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .cv-paywall-modal {
    background: #fff; border-radius: 20px; padding: 36px 32px 32px;
    max-width: 420px; width: 100%; text-align: center; position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,.3);
  }
  .cv-paywall-close {
    position: absolute; top: 14px; right: 18px; background: none; border: none;
    font-size: 20px; cursor: pointer; color: #aaa; line-height: 1;
  }
  .cv-paywall-icon  { font-size: 44px; margin: 0 0 12px; }
  .cv-paywall-title { font-size: 1.2rem; font-weight: 900; color: #0a1628; margin: 0 0 10px; }
  .cv-paywall-sub   { font-size: 13px; color: #666; line-height: 1.7; margin: 0 0 20px; }
  .cv-paywall-prices {
    background: #f4f8ff; border-radius: 12px; padding: 14px 20px; margin-bottom: 22px;
  }
  .cv-paywall-prices > div { font-size: 13px; color: #444; }
  .cv-paywall-prices > div strong { color: #1f4b6e; font-size: 16px; }
  .cv-paywall-vs { margin-top: 4px; color: #aaa; font-size: 12px; }
  .cv-paywall-cta {
    display: block; background: #ff9408; color: #fff; font-weight: 800; font-size: 14px;
    padding: 14px 24px; border-radius: 12px; text-decoration: none; margin-bottom: 14px;
    transition: background .2s;
  }
  .cv-paywall-cta:hover { background: #e67e00; }
  .cv-paywall-note { font-size: 12px; color: #aaa; margin: 0; }
  .cv-paywall-note a { color: #1f4b6e; }
</style>
