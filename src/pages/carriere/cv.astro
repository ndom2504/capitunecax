---
import MainLayout from "../../layouts/main.astro";
import { HeaderNav } from "../../components/HeaderNav";
import { FooterCustom } from "../../components/FooterCustom";
import CvCreator from "../../components/carriere/CvCreator";

const service = Astro.url.searchParams.get("service") ?? "";

// Affichage conditionnel selon session
const sessionCookie = Astro.cookies.get('capitune_session');
const isLoggedIn = !!sessionCookie?.value;

const CV_SERVICES = [
  {
    id: "cv_canada",
    icon: "🍁",
    label: "CV Canada",
    desc: "CV standard canadien, bilingue, adapté au marché national.",
    priceBase: 10, priceForfait: 2,
    color: "#e8f4ec",
    border: "#a8d5b5",
  },
  {
    id: "cv_quebec",
    icon: "⚜️",
    label: "CV Québec",
    desc: "Marché québécois, rédigé en français, normes du Québec.",
    priceBase: 10, priceForfait: 2,
    color: "#eef2fb",
    border: "#b8caf5",
  },
  {
    id: "cv_etudiant",
    icon: "🎓",
    label: "CV Étudiant",
    desc: "Premier emploi ou stage au Canada — valoriser formations et bénévolat.",
    priceBase: 8, priceForfait: 2,
    color: "#fdf5e8",
    border: "#f5d58a",
  },
  {
    id: "cv_immigration",
    icon: "✈️",
    label: "CV Immigration",
    desc: "Entrée Express, PNP — profil immigration mis en avant.",
    priceBase: 12, priceForfait: 3,
    color: "#fff0ec",
    border: "#f5b8a0",
  },
  {
    id: "cover_letter",
    icon: "✉️",
    label: "Lettre de motivation",
    desc: "Cover letter bilingue percutante pour le marché canadien.",
    priceBase: 10, priceForfait: 2,
    color: "#f5eefb",
    border: "#c9a8f5",
  },
  {
    id: "letter_ircc",
    icon: "🏛️",
    label: "Lettre IRCC",
    desc: "Lettre d'explication pour Immigration, Réfugiés et Citoyenneté Canada.",
    priceBase: 15, priceForfait: 3,
    color: "#ecf8ff",
    border: "#90cef5",
  },
];
---

<MainLayout>

  {isLoggedIn ? (
    <div class="cvc-dash-topbar">
      <a href="/dashboard" class="cvc-dash-back">← Tableau de bord</a>
      <span class="cvc-dash-brand">🍁 Capitune CV</span>
      <a href="/deconnexion" class="cvc-dash-logout">Déconnexion</a>
    </div>
  ) : (
    <HeaderNav client:only="react" />
  )}

  <main class="cvc-page">

    {service ? (
      /* ── Mode génération ── */
      <>
        <div class="cvc-gen-bar">
          <a href="/carriere/cv" class="cvc-back-btn">← Choisir un autre service</a>
          <span class="cvc-gen-service-label">
            {CV_SERVICES.find(s => s.id === service)?.icon}
            {CV_SERVICES.find(s => s.id === service)?.label ?? service}
          </span>
        </div>
        <CvCreator client:only="react" defaultService={service} />
      </>
    ) : (
      /* ── Mode landing services ── */
      <div class="cvc-landing">

        <!-- Hero -->
        <div class="cvc-hero">
          <span class="cvc-hero-badge">🍁 Capitune CV</span>
          <h1 class="cvc-hero-title">Créateur de CV Canadien</h1>
          <p class="cvc-hero-sub">
            Choisissez le service adapté à votre profil. L'IA adapte votre CV aux normes canadiennes,
            analyse votre compatibilité ATS et génère vos documents en quelques secondes.
          </p>
        </div>

        <!-- Grille services -->
        <div class="cvc-services-grid">
          {CV_SERVICES.map(s => (
            <a
              href={`/carriere/cv?service=${s.id}`}
              class="cvc-service-card"
              style={`--card-bg:${s.color}; --card-border:${s.border};`}
            >
              <div class="cvc-sc-top">
                <span class="cvc-sc-icon">{s.icon}</span>
                <div>
                  <p class="cvc-sc-name">{s.label}</p>
                  <p class="cvc-sc-desc">{s.desc}</p>
                </div>
              </div>
              <div class="cvc-sc-footer">
                <div class="cvc-sc-pricing">
                  <span class="cvc-sc-price-forfait">{s.priceForfait}$<small>/avec forfait</small></span>
                  <span class="cvc-sc-price-base">{s.priceBase}$ sans forfait</span>
                </div>
                <span class="cvc-sc-cta">Commencer →</span>
              </div>
            </a>
          ))}
        </div>

        <!-- Bandeau forfait -->
        <div class="cvc-forfait-banner">
          <div class="cvc-fb-left">
            <p class="cvc-fb-title">🎯 Économisez jusqu'à 80% avec un forfait Capitune</p>
            <p class="cvc-fb-sub">
              Accès illimité à tous les services CV, lettres IRCC, diagnostic IA ATS et téléchargements PDF.
            </p>
          </div>
          <a href="/tarifs" class="cvc-fb-btn">Voir les forfaits</a>
        </div>

        <!-- Comment ça marche -->
        <div class="cvc-steps">
          <h2 class="cvc-steps-title">Comment ça fonctionne ?</h2>
          <div class="cvc-steps-grid">
            {[
              { n: "1", label: "Choisissez un service", desc: "CV Canada, Québec, immigration ou lettre de motivation." },
              { n: "2", label: "Importez votre CV", desc: "Copiez-collez le texte ou importez un PDF / DOCX." },
              { n: "3", label: "Analyse IA instantanée", desc: "Score ATS, compétences clés, programmes recommandés." },
              { n: "4", label: "Générez & téléchargez", desc: "CV optimisé en format canadien + téléchargement PDF avec votre forfait." },
            ].map(step => (
              <div class="cvc-step">
                <div class="cvc-step-num">{step.n}</div>
                <p class="cvc-step-label">{step.label}</p>
                <p class="cvc-step-desc">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    )}
  </main>

  {!isLoggedIn && <FooterCustom client:only="react" />}
</MainLayout>

<style>
  /* ── Header dashboard ── */
  .cvc-dash-topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 28px; background: #fff; border-bottom: 1px solid #e8e8e8;
    position: sticky; top: 0; z-index: 50;
  }
  .cvc-dash-back { font-size: 13px; color: #1f4b6e; text-decoration: none; font-weight: 600; }
  .cvc-dash-back:hover { text-decoration: underline; }
  .cvc-dash-brand { font-size: 14px; font-weight: 800; color: #0a1628; }
  .cvc-dash-logout { font-size: 12px; color: #aaa; text-decoration: none; }
  .cvc-dash-logout:hover { color: #e74c3c; }

  .cvc-page  { min-height: 80vh; background: #f7f9fc; }

  /* ── Landing ── */
  .cvc-landing { max-width: 960px; margin: 0 auto; padding: 56px 24px 80px; display: flex; flex-direction: column; gap: 56px; }

  .cvc-hero       { text-align: center; }
  .cvc-hero-badge { display: inline-block; background: #fff2e0; border: 1px solid #ffd080; color: #c97000; font-size: 12px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; padding: 4px 14px; border-radius: 999px; margin-bottom: 18px; }
  .cvc-hero-title { font-family: 'Anton SC', sans-serif; font-size: 2.8rem; color: #0a1628; margin: 0 0 16px; letter-spacing: 0.02em; }
  .cvc-hero-sub   { font-size: 15px; color: #666; line-height: 1.7; max-width: 620px; margin: 0 auto; }

  .cvc-services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .cvc-service-card {
    background: var(--card-bg, #fff); border: 2px solid var(--card-border, #e8e8e8);
    border-radius: 18px; padding: 22px; text-decoration: none;
    display: flex; flex-direction: column; gap: 18px;
    transition: transform .18s, box-shadow .18s;
  }
  .cvc-service-card:hover { transform: translateY(-4px); box-shadow: 0 10px 32px rgba(0,0,0,0.1); }
  .cvc-sc-top   { display: flex; align-items: flex-start; gap: 14px; }
  .cvc-sc-icon  { font-size: 28px; flex-shrink: 0; margin-top: 2px; }
  .cvc-sc-name  { font-size: 15px; font-weight: 800; color: #0a1628; margin: 0 0 4px; }
  .cvc-sc-desc  { font-size: 12px; color: #666; margin: 0; line-height: 1.6; }
  .cvc-sc-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid rgba(0,0,0,0.07); }
  .cvc-sc-pricing   { display: flex; flex-direction: column; gap: 2px; }
  .cvc-sc-price-forfait { font-size: 15px; font-weight: 800; color: #1f4b6e; }
  .cvc-sc-price-forfait small { font-size: 11px; color: #888; font-weight: 500; margin-left: 2px; }
  .cvc-sc-price-base { font-size: 11px; color: #aaa; text-decoration: line-through; }
  .cvc-sc-cta   { font-size: 13px; font-weight: 700; color: #1f4b6e; background: #fff; border: 1.5px solid #1f4b6e; border-radius: 8px; padding: 6px 14px; white-space: nowrap; }

  .cvc-forfait-banner {
    background: linear-gradient(135deg, #0a1628 0%, #1f4b6e 100%);
    border-radius: 20px; padding: 32px 40px; display: flex; align-items: center;
    justify-content: space-between; gap: 24px; flex-wrap: wrap;
  }
  .cvc-fb-left   { flex: 1; min-width: 240px; }
  .cvc-fb-title  { font-size: 17px; font-weight: 800; color: #fff; margin: 0 0 8px; }
  .cvc-fb-sub    { font-size: 13px; color: rgba(255,255,255,0.7); margin: 0; line-height: 1.6; }
  .cvc-fb-btn    { background: #ff9408; color: #fff; font-weight: 800; font-size: 14px; padding: 13px 28px; border-radius: 12px; text-decoration: none; white-space: nowrap; transition: background .2s; }
  .cvc-fb-btn:hover { background: #e67e00; }

  .cvc-steps       { }
  .cvc-steps-title { font-family: 'Anton SC', sans-serif; font-size: 1.5rem; color: #0a1628; text-align: center; margin: 0 0 28px; }
  .cvc-steps-grid  { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .cvc-step        { background: #fff; border-radius: 16px; padding: 22px 18px; text-align: center; border: 1px solid #eee; }
  .cvc-step-num    { width: 38px; height: 38px; border-radius: 50%; background: #1f4b6e; color: #fff; font-size: 16px; font-weight: 900; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; }
  .cvc-step-label  { font-size: 13px; font-weight: 700; color: #0a1628; margin: 0 0 6px; }
  .cvc-step-desc   { font-size: 12px; color: #888; margin: 0; line-height: 1.6; }

  /* ── Générateur ── */
  .cvc-gen-bar {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    max-width: 1100px; margin: 0 auto; padding: 20px 28px 0;
  }
  .cvc-back-btn { font-size: 13px; color: #1f4b6e; text-decoration: none; font-weight: 600; opacity: .8; }
  .cvc-back-btn:hover { opacity: 1; }
  .cvc-gen-service-label { font-size: 13px; font-weight: 800; color: #0a1628; background: #fff; border: 1.5px solid #e0e0e0; border-radius: 8px; padding: 5px 14px; }

  @media (max-width: 720px) {
    .cvc-hero-title    { font-size: 1.9rem; }
    .cvc-steps-grid    { grid-template-columns: 1fr 1fr; }
    .cvc-forfait-banner { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .cvc-steps-grid { grid-template-columns: 1fr; }
  }

  /* ── Paywall overlay ── */
  .cv-paywall-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.55); z-index: 9999;
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .cv-paywall-modal {
    background: #fff; border-radius: 20px; padding: 36px 32px 32px;
    max-width: 420px; width: 100%; text-align: center; position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,.3);
  }
  .cv-paywall-close {
    position: absolute; top: 14px; right: 18px; background: none; border: none;
    font-size: 20px; cursor: pointer; color: #aaa; line-height: 1;
  }
  .cv-paywall-icon  { font-size: 44px; margin: 0 0 12px; }
  .cv-paywall-title { font-size: 1.2rem; font-weight: 900; color: #0a1628; margin: 0 0 10px; }
  .cv-paywall-sub   { font-size: 13px; color: #666; line-height: 1.7; margin: 0 0 20px; }
  .cv-paywall-prices {
    background: #f4f8ff; border-radius: 12px; padding: 14px 20px; margin-bottom: 22px;
  }
  .cv-paywall-prices > div { font-size: 13px; color: #444; }
  .cv-paywall-prices > div strong { color: #1f4b6e; font-size: 16px; }
  .cv-paywall-vs { margin-top: 4px; color: #aaa; font-size: 12px; }
  .cv-paywall-cta {
    display: block; background: #ff9408; color: #fff; font-weight: 800; font-size: 14px;
    padding: 14px 24px; border-radius: 12px; text-decoration: none; margin-bottom: 14px;
    transition: background .2s;
  }
  .cv-paywall-cta:hover { background: #e67e00; }
  .cv-paywall-note { font-size: 12px; color: #aaa; margin: 0; }
  .cv-paywall-note a { color: #1f4b6e; }
</style>

<style is:global>
  /* ══ CvCreator — design system Capitune ══ */
  :root { --cap-orange: #ff9408; --cap-navy: #0a1628; --cap-blue: #1f4b6e; --cap-bg: #f7f9fc; --cap-border: #e4e8f0; }

  .cv-wrap {
    max-width: 1100px; margin: 0 auto; padding: 24px 20px 60px;
    display: flex; flex-direction: column; gap: 28px; font-family: Inter, sans-serif;
  }

  /* ── Sections ── */
  .cv-services-section,
  .cv-tips-section,
  .cv-input-section,
  .cv-magic-section {
    background: #fff; border: 1px solid var(--cap-border);
    border-radius: 18px; padding: 28px 28px 32px; box-shadow: 0 2px 12px rgba(0,0,0,.04);
  }
  .cv-section-title {
    font-family: 'Anton SC', 'Anton', sans-serif; font-size: 1.1rem; letter-spacing: .05em;
    text-transform: uppercase; color: var(--cap-navy); margin: 0 0 6px;
  }
  .cv-section-sub { font-size: 13px; color: #6b7280; margin: 0 0 18px; line-height: 1.5; }
  .cv-section-header {
    display: flex; align-items: flex-start; gap: 14px; margin-bottom: 20px;
  }
  .cv-section-header > div h2 {
    font-family: 'Anton SC', 'Anton', sans-serif; font-size: 1.1rem; letter-spacing: .05em;
    text-transform: uppercase; color: var(--cap-navy); margin: 0 0 4px;
  }
  .cv-section-header > div p { font-size: 13px; color: #6b7280; margin: 0; }

  /* ── Sélecteur de service ── */
  .cv-services-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 10px;
  }
  .cv-service-card {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 16px; border: 2px solid var(--cap-border); border-radius: 14px;
    background: #fafbfc; cursor: pointer; transition: all .2s; text-align: left;
    font-family: inherit;
  }
  .cv-service-card:hover { border-color: var(--cap-blue); background: #eef4fb; }
  .cv-service-card.active { border-color: var(--cap-blue); background: #e8f0fb; }
  .cv-service-icon { font-size: 22px; flex-shrink: 0; }
  .cv-service-info { flex: 1; min-width: 0; }
  .cv-service-name { font-size: 13px; font-weight: 700; color: var(--cap-navy); margin: 0 0 2px; }
  .cv-service-desc { font-size: 11px; color: #8fa3ba; margin: 0; }
  .cv-service-pricing { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; flex-shrink: 0; }
  .cv-price-sub { font-size: 13px; font-weight: 800; color: var(--cap-blue); white-space: nowrap; }
  .cv-price-sub small { font-size: 10px; color: #aaa; font-weight: 400; }
  .cv-price-full { font-size: 11px; color: #ccc; text-decoration: line-through; }

  /* ── Conseils ── */
  .cv-tips-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 12px;
  }
  .cv-tip-card {
    display: flex; gap: 12px; background: var(--cap-bg); border-radius: 12px;
    padding: 14px 16px; border: 1px solid var(--cap-border);
  }
  .cv-tip-icon  { font-size: 22px; flex-shrink: 0; margin-top: 1px; }
  .cv-tip-title { font-size: 13px; font-weight: 700; color: var(--cap-navy); margin: 0 0 4px; }
  .cv-tip-desc  { font-size: 12px; color: #6b7280; margin: 0; line-height: 1.5; }

  /* ── Zone saisie ── */
  .cv-input-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
  }
  .cv-card {
    border: 1px solid var(--cap-border); border-radius: 14px; padding: 22px;
    background: var(--cap-bg); display: flex; flex-direction: column; gap: 14px;
  }
  .cv-card-header {
    display: flex; align-items: center; gap: 10px;
  }
  .cv-card-header h3 {
    font-family: 'Anton SC', 'Anton', sans-serif; font-size: .95rem; letter-spacing: .04em;
    text-transform: uppercase; color: var(--cap-navy); margin: 0; flex: 1;
  }
  .cv-card-icon { font-size: 20px; }
  .cv-card-icon.blue   { filter: hue-rotate(200deg); }
  .cv-card-icon.orange { filter: hue-rotate(0deg); }
  .cv-btn-clear {
    background: none; border: none; color: #aaa; cursor: pointer; font-size: 16px;
    padding: 2px 6px; border-radius: 6px; transition: color .15s, background .15s; line-height: 1;
    margin-left: auto;
  }
  .cv-btn-clear:hover { color: #e74c3c; background: #fef2f2; }

  .cv-upload-bar {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    background: #fff; border: 1.5px dashed var(--cap-border); border-radius: 10px; padding: 10px 14px;
  }
  .cv-upload-label { font-size: 12px; color: #8fa3ba; flex: 1; }
  .cv-btn-import {
    background: var(--cap-blue); color: #fff; border: none; border-radius: 8px;
    padding: 7px 14px; font-size: 12px; font-weight: 700; cursor: pointer;
    transition: opacity .2s; white-space: nowrap; font-family: inherit;
  }
  .cv-btn-import:hover { opacity: .85; }
  .cv-file-preview {
    display: flex; align-items: center; gap: 10px; background: #f0f5ff;
    border: 1px solid #c5d5f5; border-radius: 10px; padding: 12px 16px;
  }
  .cv-file-icon { font-size: 18px; }
  .cv-file-name { font-size: 13px; font-weight: 700; color: var(--cap-navy); margin: 0 0 2px; }
  .cv-file-sub  { font-size: 11px; color: #27ae60; margin: 0; }
  .cv-textarea {
    width: 100%; min-height: 160px; border: 1.5px solid var(--cap-border); border-radius: 10px;
    padding: 12px 14px; font-size: 13px; color: var(--cap-navy); background: #fff;
    resize: vertical; outline: none; transition: border .2s; font-family: inherit;
    box-sizing: border-box;
  }
  .cv-textarea:focus { border-color: var(--cap-blue); }
  .cv-error-box {
    background: #fef2f2; border: 1px solid #fca5a5; border-radius: 10px;
    padding: 10px 14px; font-size: 13px; color: #dc2626; font-weight: 600;
  }

  /* ── Boutons ── */
  .cv-btn-primary {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 12px 20px; background: linear-gradient(135deg, var(--cap-navy), var(--cap-blue));
    color: #fff; border: none; border-radius: 12px; font-size: 14px; font-weight: 700;
    cursor: pointer; transition: opacity .2s; font-family: inherit;
  }
  .cv-btn-primary:disabled { opacity: .55; cursor: not-allowed; }
  .cv-btn-primary:not(:disabled):hover { opacity: .9; }
  .cv-btn-sm {
    height: 32px; padding: 0 12px; border: 1.5px solid var(--cap-border); background: #fff;
    border-radius: 8px; font-size: 12px; font-weight: 700; color: #374151;
    cursor: pointer; transition: all .15s; font-family: inherit; white-space: nowrap;
  }
  .cv-btn-sm.orange { border-color: var(--cap-orange); color: var(--cap-orange); }
  .cv-btn-sm:hover  { background: var(--cap-bg); border-color: var(--cap-blue); }
  .cv-btn-sm.orange:hover { background: #fff5e6; }

  /* ── Spinner ── */
  .cv-spinner {
    display: inline-block; width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,.35); border-top-color: #fff;
    border-radius: 50%; animation: cv-spin .7s linear infinite;
  }
  .cv-spinner.large { width: 28px; height: 28px; border-width: 3px; border-top-color: var(--cap-blue); border-color: var(--cap-border); }
  @keyframes cv-spin { to { transform: rotate(360deg); } }

  /* ── État vide ── */
  .cv-empty-state {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 10px; padding: 32px 20px; color: #aaa; text-align: center; flex: 1;
  }
  .cv-empty-state span { font-size: 36px; }
  .cv-empty-state p { font-size: 13px; line-height: 1.6; max-width: 260px; }

  /* ── Analyse résultat ── */
  .cv-analysis-result { display: flex; flex-direction: column; gap: 14px; }
  .cv-analysis-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .cv-analysis-label  { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #8fa3ba; margin: 0 0 4px; }
  .cv-analysis-name   { font-size: 16px; font-weight: 800; color: var(--cap-navy); margin: 0; }
  .cv-score-badge     { text-align: right; }
  .cv-score-value     { font-size: 22px; font-weight: 900; color: var(--cap-blue); margin: 0; }
  .cv-analysis-row    { display: flex; gap: 16px; flex-wrap: wrap; }
  .cv-stat { flex: 1; min-width: 100px; }
  .cv-stat-val { font-size: 15px; font-weight: 700; color: var(--cap-navy); margin: 0; }
