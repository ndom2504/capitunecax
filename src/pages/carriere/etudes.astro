---
import Layout from '../../layouts/main.astro';
import EED from '../../components/carriere/EED.tsx';

const isApp = Astro.url.searchParams.get('source') === 'app';
---

<Layout title="Espace Études (EED) - CAPITUNE" pageClass={isApp ? 'is-mobile-app' : ''}>

  <!-- Hero section — même style que le dashboard -->
  <div class="cap-page-hero">
    <div class="cap-container">
      {!isApp && (
        <button onclick="history.back()" class="cap-back-link">&#8592; Retour</button>
      )}
      <h1 class="cap-hero-title">🎓 Espace Études — Établissements DLI</h1>
      <p class="cap-hero-sub">Consultez la liste officielle des établissements d'enseignement désignés (DLI) au Canada.</p>
    </div>
  </div>

  <!-- Contenu interactif React -->
  <div class="cap-page-body">
    {isApp ? (
      <EED client:only="react" isMobileApp={isApp} />
    ) : (
      <div class="cap-disabled-wrap">
        <div class="cap-disabled-card">
          <div class="cap-disabled-icon">🛠️</div>
          <h2 class="cap-disabled-title">Fonctionnalité temporairement indisponible sur le web</h2>
          <p class="cap-disabled-sub">
            Le module Carrière est momentanément désactivé sur la version web.
            Merci d’utiliser l’application mobile.
          </p>
          <div class="cap-disabled-actions">
            <a class="cap-disabled-btn" href="/dashboard">Retour au dashboard</a>
            <a class="cap-disabled-link" href="/contact">Contacter le support</a>
          </div>
        </div>
      </div>
    )}
  </div>

</Layout>

<style is:global>
/* ─── Variables Capitune ─── */
:root {
  --cap-orange: #ff9408;
  --cap-dark:   #1a1a2e;
  --cap-blue:   #2980b9;
  --cap-green:  #27ae60;
  --cap-red:    #e74c3c;
}

/* ─── Mise en page de page Carrière ─── */
.cap-page-hero {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40px 0 32px;
}
.cap-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 30px;
}
.cap-back-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  font-family: Inter, sans-serif;
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 20px;
  transition: color .2s;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}
.cap-back-link:hover { color: #fff; }
.cap-hero-title {
  font-family: 'Anton SC', sans-serif;
  font-size: 2.2rem;
  font-weight: 400;
  color: #fff;
  margin: 0 0 12px;
  letter-spacing: 0.03em;
}
.cap-hero-sub {
  font-family: Inter, sans-serif;
  font-size: 15px;
  color: rgba(255,255,255,0.68);
  margin: 0;
}
.cap-page-body {
  background: #f4f6fa;
  min-height: 60vh;
  padding: 36px 0 70px;
}

/* ── Web masking (carrière désactivée) ── */
.cap-disabled-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 30px;
}
.cap-disabled-card {
  background: #fff;
  border: 1px solid #e4e8f0;
  border-radius: 16px;
  padding: 28px 22px;
  text-align: center;
  box-shadow: 0 10px 36px rgba(0,0,0,.06);
}
.cap-disabled-icon { font-size: 40px; margin-bottom: 10px; }
.cap-disabled-title {
  font-family: 'Anton SC', sans-serif;
  font-size: 1.5rem;
  color: #0f3460;
  margin: 0 0 10px;
  letter-spacing: 0.02em;
  text-transform: none;
}
.cap-disabled-sub {
  font-family: Inter, sans-serif;
  font-size: 14px;
  color: rgba(26,26,46,0.7);
  line-height: 1.7;
  margin: 0 auto 18px;
  max-width: 640px;
  white-space: normal;
}
.cap-disabled-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}
.cap-disabled-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 42px;
  padding: 0 18px;
  border-radius: 12px;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  color: #fff;
  font-weight: 800;
  font-size: 13px;
  text-decoration: none;
}
.cap-disabled-link {
  color: rgba(15,52,96,0.95);
  font-weight: 700;
  font-size: 13px;
  text-decoration: none;
  font-family: Inter, sans-serif;
}
.cap-disabled-link:hover { text-decoration: underline; }

/* ─── Composant EED ─── */
.eed-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 30px;
  font-family: Inter, sans-serif;
}

/* Bannière profil actif */
.eed-profile-banner {
  background: #fff8f0;
  border: 1px solid #ffd899;
  border-radius: 12px;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 28px;
  font-size: 14px;
  color: #7a4e00;
}
.eed-profile-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,148,8,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.eed-profile-name {
  font-family: Inter, sans-serif;
  font-weight: 700;
  font-size: 14px;
  color: var(--cap-dark);
  margin: 0 0 3px;
}
.eed-profile-sub {
  font-size: 12px;
  color: #888;
  margin: 0;
}

/* Barre de recherche */
.eed-search-bar {
  display: flex;
  gap: 12px;
  margin-bottom: 32px;
  flex-wrap: wrap;
  align-items: center;
}
.eed-input-wrap {
  flex: 1;
  min-width: 200px;
  position: relative;
}
.eed-input-icon {
  position: absolute;
  left: 13px;
  top: 50%;
  transform: translateY(-50%);
  color: #aaa;
  font-size: 14px;
  pointer-events: none;
}
.eed-input {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid #ddd;
  border-radius: 9px;
  padding: 11px 14px 11px 38px;
  font-size: 14px;
  font-family: Inter, sans-serif;
  outline: none;
  background: #fafafa;
  transition: border-color .2s, box-shadow .2s;
  color: var(--cap-dark);
}
.eed-input:focus {
  border-color: var(--cap-orange);
  box-shadow: 0 0 0 3px rgba(255,148,8,0.12);
  background: #fff;
}
.eed-select {
  border: 1px solid #ddd;
  border-radius: 9px;
  padding: 11px 14px;
  font-size: 14px;
  font-family: Inter, sans-serif;
  outline: none;
  background: #fff;
  cursor: pointer;
  transition: border-color .2s;
  color: var(--cap-dark);
  min-width: 170px;
}
.eed-select:focus {
  border-color: var(--cap-orange);
  box-shadow: 0 0 0 3px rgba(255,148,8,0.12);
}
.eed-btn-search {
  background: linear-gradient(135deg, #ff9408, #e67e00);
  color: #fff;
  border: none;
  border-radius: 9px;
  padding: 11px 26px;
  font-size: 13px;
  font-family: 'Anton SC', sans-serif;
  font-weight: 400;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
  white-space: nowrap;
}
.eed-btn-search:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 18px rgba(255,148,8,0.35);
}
.eed-btn-search:disabled { opacity: .5; pointer-events: none; }

/* Grille de cartes DLI → STORY CAROUSEL */
.eed-story-outer {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 12px 48px rgba(0,0,0,0.22);
  margin-bottom: 20px;
}
.eed-story-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.eed-story-track::-webkit-scrollbar { display: none; }

.eed-story-card {
  flex: 0 0 100%;
  min-height: 500px;
  scroll-snap-align: start;
  position: relative;
  padding: 32px 40px 70px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.eed-story-bubble {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.eed-story-bubble.b1 { width: 300px; height: 300px; top: -80px; right: -80px; }
.eed-story-bubble.b2 { width: 180px; height: 180px; bottom: 80px; left: -50px; }

.eed-story-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28px;
}
.eed-story-counter {
  font-size: 11px; font-weight: 800;
  text-transform: uppercase; letter-spacing: .1em; opacity: .85;
}
.eed-story-ext {
  width: 36px; height: 36px; border-radius: 50%; border: 1px solid;
  background: rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 700; text-decoration: none;
  transition: background .2s;
}
.eed-story-ext:hover { background: rgba(255,255,255,0.2); }

.eed-story-logo {
  width: 90px; height: 90px;
  border-radius: 22px; border: 2px solid;
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 28px;
  flex-shrink: 0;
}
.eed-story-logo img { width: 70px; height: 70px; object-fit: contain; }

.eed-story-content { display: flex; flex-direction: column; gap: 16px; }

.eed-story-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.eed-story-tag {
  padding: 5px 13px;
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
  border-radius: 999px; font-size: 12px; font-weight: 600;
  color: rgba(255,255,255,0.85);
}
.eed-story-title {
  font-family: 'Anton SC', sans-serif;
  font-size: 2rem; font-weight: 400;
  color: #fff; margin: 0;
  letter-spacing: .02em; line-height: 1.15;
}
.eed-story-btn {
  align-self: flex-start;
  padding: 12px 28px; border-radius: 999px;
  text-decoration: none;
  font-size: 13px; font-family: 'Anton SC', sans-serif;
  letter-spacing: .04em;
  transition: opacity .2s, transform .2s;
  display: inline-flex; align-items: center; gap: 6px;
  color: #fff;
  font-weight: 400;
}
.eed-story-btn:hover { opacity: .85; transform: scale(1.03); }

/* Navigation flèches */
.eed-story-nav {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 46px; height: 46px; border-radius: 50%;
  border: none; background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  color: #fff; font-size: 26px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background .2s; z-index: 10; line-height: 1;
}
.eed-story-nav:hover { background: rgba(255,255,255,0.3); }
.eed-story-nav-prev { left: 14px; }
.eed-story-nav-next { right: 14px; }

/* Dots */
.eed-story-dots {
  position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
  display: flex; gap: 6px; z-index: 10;
  flex-wrap: wrap; justify-content: center; max-width: 80%;
}
.eed-story-dot {
  width: 8px; height: 8px; border-radius: 50%;
  border: none; background: rgba(255,255,255,0.3);
  cursor: pointer; transition: .2s; padding: 0;
}
.eed-story-dot.active { background: #fff; transform: scale(1.35); }

@media (max-width: 640px) {
  .eed-story-card { min-height: 420px; padding: 22px 22px 64px; }
  .eed-story-title { font-size: 1.5rem; }
  .eed-story-logo { width: 72px; height: 72px; }
  .eed-story-nav { width: 38px; height: 38px; font-size: 22px; }
}

/* États chargement / vide */
.eed-loading {
  text-align: center;
  padding: 60px 0;
  color: #aaa;
  font-family: Inter, sans-serif;
  font-size: 15px;
}
.eed-empty {
  text-align: center;
  padding: 48px;
  border: 2px dashed #e0e0e0;
  border-radius: 16px;
  color: #aaa;
  font-family: Inter, sans-serif;
  font-size: 15px;
}

/* Mobile */
@media (max-width: 640px) {
  .cap-hero-title { font-size: 1.6rem; }
  .cap-container { padding: 0 18px; }
  .eed-wrap { padding: 0 18px; }
  .eed-search-bar { flex-direction: column; }
  .eed-select { min-width: 100%; }
  .eed-btn-search { width: 100%; }
}
</style>