---
import Layout from '../../layouts/main.astro';
import EED from '../../components/carriere/EED.tsx';

// Détection de l'appel depuis l'application mobile via WebView
const isApp = Astro.url.searchParams.get('source') === 'app';
---

<Layout title="Espace Études (EED) - CAPITUNE" pageClass={isApp ? 'is-mobile-app' : ''}>
  <div class="carriere-page min-h-screen bg-[#f5f7fa] text-[#0a1628]">
    {!isApp && (
      <div class="back-nav p-4 max-w-7xl mx-auto">
        <a href="/dashboard" class="text-slate-600 hover:text-[#0a1628] flex items-center gap-2 text-sm font-bold tracking-widest uppercase mb-8 w-fit transition-colors">
          <i class="fa fa-arrow-left"></i> Retour au Dashboard
        </a>
      </div>
    )}

    <EED client:only="react" isMobileApp={isApp} />
  </div>
</Layout>

<style>
.carriere-page {
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}
</style>
