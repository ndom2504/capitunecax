---
import MainLayout from '../layouts/main.astro';
import { baseUrl } from '../lib/base-url';
---

<MainLayout>
<div class="vauth-root">

  <div class="vauth-card-wrap">

    <a href={`${baseUrl}/`} class="vauth-brand">CAPITUNE</a>

    <div class="vauth-card">
      <div class="vauth-icon vauth-icon--success">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="36" height="36">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <h1 class="vauth-title">Compte activé !</h1>
      <p class="vauth-sub">Votre adresse courriel a été confirmée avec succès.</p>

      <p class="vauth-desc">
        Vous pouvez maintenant vous connecter à votre espace CAPITUNE et accéder à tous nos services.
      </p>

      <a href={`${baseUrl}/connexion`} class="vauth-btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Se connecter maintenant
      </a>

      <a href={`${baseUrl}/`} class="vauth-back-link">← Retour à l'accueil</a>
    </div>

  </div>

</div>
</MainLayout>

<style>
  .vauth-root {
    min-height: 100vh;
    background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
  }
  .vauth-card-wrap {
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .vauth-brand {
    font-family: 'Anton SC', 'Anton', sans-serif;
    font-size: 28px;
    letter-spacing: .1em;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
  }
  .vauth-card {
    background: #fff;
    border-radius: 16px;
    padding: 40px 36px;
    width: 100%;
    text-align: center;
    box-shadow: 0 8px 40px rgba(0,0,0,.24);
  }
  .vauth-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1f4b6e, #2d6a96);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .vauth-icon--success {
    background: linear-gradient(135deg, #1a7a4a, #27ae60);
  }
  .vauth-title {
    font-family: 'Anton SC', 'Anton', sans-serif;
    font-size: 26px;
    letter-spacing: .05em;
    color: #0a1628;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .vauth-sub {
    color: #27ae60;
    font-size: 15px;
    font-weight: 600;
    margin: 0 0 20px;
  }
  .vauth-desc {
    color: #4a6880;
    font-size: 15px;
    line-height: 1.65;
    margin: 0 0 28px;
  }
  .vauth-btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, #0a1628, #1f4b6e);
    color: #fff;
    font-family: 'Anton SC', 'Anton', sans-serif;
    font-size: 16px;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 10px;
    padding: 14px 24px;
    width: 100%;
    transition: opacity .2s;
    margin-bottom: 20px;
  }
  .vauth-btn-primary:hover { opacity: .88; }
  .vauth-back-link {
    color: #8fa3ba;
    font-size: 13px;
    text-decoration: none;
    display: block;
    padding-top: 18px;
    border-top: 1px solid #f0f3f8;
  }
  .vauth-back-link:hover { color: #1f4b6e; }
</style>
