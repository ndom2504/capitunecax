---
const sessionId = Astro.url.searchParams.get('session_id') ?? '';
const deepLink = sessionId
  ? `capitune://capi/autonomie/payment?session_id=${encodeURIComponent(sessionId)}`
  : '';
---
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Paiement confirmé</title>
  </head>
  <body style="font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; padding: 24px;">
    <h1>Paiement confirmé ✓</h1>
    {sessionId ? (
      <>
        <p>Retour à l’application en cours…</p>
        <p>
          <a href={deepLink}>Ouvrir Capitune</a>
        </p>
        <script>
          {String.raw`
            (function(){
              try {
                var url = ${JSON.stringify(deepLink)};
                if (!url) return;
                var sessionId = ${JSON.stringify(sessionId)};
                var key = 'capitune_autonomie_redirect_' + (sessionId || '');

                // Évite une boucle : si l'utilisateur revient sur cette page (bouton retour),
                // on ne relance pas automatiquement l'ouverture de l'app.
                try {
                  if (sessionId && window.sessionStorage && window.sessionStorage.getItem(key) === '1') {
                    return;
                  }
                  if (sessionId && window.sessionStorage) {
                    window.sessionStorage.setItem(key, '1');
                  }
                } catch (e) {}

                setTimeout(function(){
                  window.location.href = url;
                }, 150);
              } catch (e) {}
            })();
          `}
        </script>
      </>
    ) : (
      <p>Session de paiement manquante.</p>
    )}
  </body>
</html>
