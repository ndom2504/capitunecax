# ============================================
# CAPITUNE - ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copier ce fichier vers .env puis compléter les valeurs.
# En production (Vercel), configurer ces variables dans le dashboard Vercel.

# ---------- AUTH ----------
# Générer avec: node -e "require('crypto').randomBytes(32).toString('base64')|Write-Output"
AUTH_SECRET=replace_with_a_strong_random_secret
AUTH_TRUST_HOST=true

# Identifiants de démo (MVP) pour tester /connexion en local.
AUTH_DEMO_EMAIL=demo@capitune.com
AUTH_DEMO_PASSWORD=demo123456

# Emails admin (séparés par virgules, espaces ou retours à la ligne).
# Exemple: ADMIN_EMAILS=info@misterdil.ca,divinegismille@gmail.com
# Si vide/non défini, l'app retombe sur la liste par défaut codée.
ADMIN_EMAILS=info@misterdil.ca,divinegismille@gmail.com

# Super-admins (facultatif) — peuvent assigner / réassigner des clients à d'autres pros.
# Si vide/non défini, tout admin est traité comme super-admin.
SUPER_ADMIN_EMAILS=

# ---------- OAUTH GOOGLE ----------
# Console Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Format: NNNNNNN.apps.googleusercontent.com (PAS le domaine Firebase)
# URI de redirection autorisée: https://votre-domaine.com/api/oauth/callback/google
AUTH_GOOGLE_ID=votre_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-votre_secret

# ---------- OAUTH MICROSOFT ----------
# Azure Portal → App registrations → votre app → Overview
# URI de redirection: https://votre-domaine.com/api/oauth/callback/microsoft-entra-id
AUTH_MICROSOFT_ID=votre-tenant-client-id
AUTH_MICROSOFT_SECRET=votre_microsoft_secret
# Alias Auth.js v5 (utilisés automatiquement par auth-astro v4)
AUTH_MICROSOFT_ENTRA_ID=votre-tenant-client-id
AUTH_MICROSOFT_ENTRA_SECRET=votre_microsoft_secret
# "common" = accepte comptes perso + orga | ou votre tenant ID spécifique
AUTH_MICROSOFT_ENTRA_TENANT_ID=common

# ---------- SITE ----------
SITE_URL=https://www.capitune.com

# ---------- FIREBASE (OPTIONNEL) ----------
# Config "Web app" Firebase (ces valeurs ne sont pas des secrets, mais restent de la config).
# À utiliser uniquement si tu intègres le SDK Firebase côté navigateur.
PUBLIC_FIREBASE_API_KEY=replace_me
PUBLIC_FIREBASE_AUTH_DOMAIN=replace_me.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=replace_me
PUBLIC_FIREBASE_STORAGE_BUCKET=replace_me.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_me
PUBLIC_FIREBASE_APP_ID=replace_me
PUBLIC_FIREBASE_MEASUREMENT_ID=replace_me

# ---------- PUBLIC (CLIENT + UI) ----------
# Variables accessibles côté client (React) et côté serveur (Astro).
# Garder le préfixe PUBLIC_ pour qu'elles soient exposées au navigateur.
PUBLIC_PAYMENT_CURRENCY=CAD
PUBLIC_CONTACT_EMAIL=contact@capitune.com
PUBLIC_CONTACT_PHONE=+1 581 443 9464
PUBLIC_CONTACT_ADDRESS=93 Rue des Castels, Lévis, QC G6V 2B8\nCAPITUNE – Export Monde Prestige Inc.\nMontréal, Québec, Canada.

# ---------- STRIPE ----------
STRIPE_SECRET_KEY=sk_live_replace_me
PUBLIC_STRIPE_PUBLIC_KEY=pk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ---------- PAYPAL ----------
PAYPAL_CLIENT_ID=replace_me
PAYPAL_SECRET=replace_me
PUBLIC_PAYPAL_CLIENT_ID=replace_me

# ---------- PAYMENT ----------
PAYMENT_CURRENCY=CAD
PAYMENT_SUCCESS_URL=https://www.capitune.com/dashboard?payment=success
PAYMENT_CANCEL_URL=https://www.capitune.com/dashboard?payment=cancelled

# ---------- AUTONOMIE (Stripe Checkout) ----------
# Prix en CENTIMES (ex: 4900 = 49,00 CAD)
# Utilisé par /api/autonomie/stripe-checkout
AUTONOMIE_PRICE_DEFAULT_CENTS=
# Optionnel: surcharger par motif
AUTONOMIE_PRICE_VISITER_CENTS=
AUTONOMIE_PRICE_TRAVAILLER_CENTS=
AUTONOMIE_PRICE_ETUDIER_CENTS=
AUTONOMIE_PRICE_RESIDENCE_PERMANENTE_CENTS=
AUTONOMIE_PRICE_FAMILLE_CENTS=
AUTONOMIE_PRICE_ENTREPRENDRE_CENTS=
AUTONOMIE_PRICE_REGULARISATION_CENTS=

# ---------- INTERAC ----------
PUBLIC_INTERAC_EMAIL=paiements@capitune.com
# Legacy / fallback (si certaines parties serveur l'utilisent encore)
INTERAC_EMAIL=paiements@capitune.com

# ---------- IA / OpenAI ----------
# Clé API OpenAI — utilisée pour les suggestions de réponses automatiques (admin panel).
# Obtenir sur : https://platform.openai.com/api-keys
# Modèle utilisé : gpt-4o-mini (rapport qualité/coût optimal)
OPENAI_API_KEY=sk-...votre_cle_openai

# ---------- BANK TRANSFER ----------
PUBLIC_BANK_ACCOUNT_NAME=Export Monde Prestige Inc.
PUBLIC_BANK_NAME=Banque TD
PUBLIC_BANK_TRANSIT=12345
PUBLIC_BANK_INSTITUTION=004
PUBLIC_BANK_ACCOUNT=1234567
# Legacy / fallback (si certaines parties serveur les utilisent encore)
BANK_ACCOUNT_NAME=Export Monde Prestige Inc.
BANK_NAME=Banque TD
BANK_TRANSIT=12345
BANK_INSTITUTION=004
BANK_ACCOUNT=1234567

